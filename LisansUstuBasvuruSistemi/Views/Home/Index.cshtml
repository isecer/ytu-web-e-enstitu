@using LisansUstuBasvuruSistemi.Models 
@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model Enstituler
@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
    bool IsMesajGonder = (bool)ViewBag.IsMesajGonder;
    var MesajGroupID = (string)ViewBag.MesajGroupID;
    var Duyurular = (List<FrDuyurularDto>)ViewBag.Duyurular;
    var AnketGiris = (string)ViewBag.AnketGiris;
}
@if (Duyurular.Count > 0)
{
    <div class="row">

        @using (Html.BeginForm())
        {
            <div class="col-md-12">

                <!-- START SIMPLE DATATABLE -->
                <div class="panel panel-danger">
                    <div class="panel-heading padding-0">
                        <h3 class="panel-title"><i class="fa fa-bullhorn"></i> Duyurular</h3>
                        <ul class="panel-controls">
                            <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                        </ul>
                    </div>
                    <div class="panel-body">


                        <table class="table">
                            <tbody>

                                @foreach (var item in Duyurular)
                                {

                                    <tr class="cls-@item.DuyuruID">
                                        <td>

                                            <div class="panel panel-success">
                                                <div class="panel-heading" style="padding:1px;">
                                                    <div class="portlet-title" style="font-size:13pt;font-weight:bold;">
                                                        <table style="width: 100%; table-layout: fixed;">
                                                            <tr>
                                                                <td style="padding-left: 1px; padding-right: 1px;">
                                                                    @item.Baslik
                                                                </td>
                                                                <td style="width: 170px; padding-left: 1px; padding-right: 1px;vertical-align:top;text-align:right;">
                                                                    @item.Tarih.ToFormatDateAndTime()
                                                                </td>
                                                            </tr>
                                                        </table>
                                                        <ul class="panel-controls">
                                                            @* <li><a href="javascript:void(0);" onclick="printContent('cls-@item.DuyuruID')"><span class="fa fa-print"></span></a></li>*@
                                                        </ul>
                                                    </div>

                                                </div>
                                                <div class="panel-body" style="padding: 1px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom:0px;">
                                                        <div class="panel-body form-group-separated">
                                                            <div class="form-group">
                                                                <div class="scrolkikko" style="max-height: 400px; width:100%; overflow:hidden;padding:2px;">
                                                                    @Html.Raw(item.AciklamaHtml)
                                                                </div>
                                                            </div>
                                                            @if (item.EkSayisi > 0)
                                                            {
                                                                <div class="form-group">
                                                                    <label class="col-md-2 col-xs-3 control-label padding-top-0 padding-bottom-0">Ekler <img src="~/Images/Attachment.png" style="height: 16px;" /></label>
                                                                    <div class="col-md-10  col-xs-9 padding-top-0 padding-bottom-0 " style="text-align: left;">
                                                                        <div class="panel panel-warning" style="margin:0px;padding:0px;">
                                                                            <div class="panel-body" style="padding-right:0px;padding-top:2px;padding-bottom:2px;">
                                                                                <div class="scrolkikko" style="max-height: 100px; width:100%; overflow:hidden;">
                                                                                    <table style="width: 100%; table-layout: fixed;">
                                                                                        @if (item.EkSayisi > 0)
                                                                                        {
                                                                                            foreach (var item2 in item.DuyuruEkleris.Select((s, inx) => new { inx, s }))
                                                                                            {
                                                                                                <tr>
                                                                                                    <td style="width: 25px;">@(item2.inx + 1))</td>
                                                                                                    <td class="name"><a href="@item2.s.DosyaYolu" target="_blank"><span class="fa fa-download" style="color: green;"></span>&nbsp;@item2.s.DosyaEkAdi</a></td>
                                                                                                </tr>
                                                                                            }
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <tr>
                                                                                                <td colspan="2">Ek Yok</td>
                                                                                            </tr>
                                                                                        }

                                                                                    </table>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                }


                            </tbody>
                        </table>
                    </div>

                </div>





            </div>
        }
    </div>
}

<div class="row">
    <div class="col-md-12">
        <!-- START SIMPLE DATATABLE -->
        <div class="panel panel-danger">
            <div class="panel-heading padding-0">
                <h3 class="panel-title"><i class="fa fa-desktop"></i> Ana Sayfa</h3>
                <ul class="panel-controls">
                    <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                </ul>
            </div>
            <div class="panel-body">
                @if (Model.EnstituKod == EnstituKodlari.FenBilimleri)
                {
                    <div class="col-md-12">

                        <div class="panel panel-default">
                            <div class="panel-body panel-body-map">
                                <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6020.048445257558!2d28.891427000000004!3d41.024726!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xab38aa352428d2ba!2zWcSxbGTEsXogVGVrbmlLIMOcbml2ZXJzaXRlc2ksIERhdnV0cGHFn2EgS2FtcMO8c8O8LCBPcnRhIEJhaMOnZQ!5e0!3m2!1str!2sus!4v1503355517050" width="100%" height="400" frameborder="0" style="border:0"></iframe>
                            </div>
                            <div class="panel-body">
                                <h3><span class="fa fa-map-marker"></span> Yıldız Teknik Üniversitesi</h3>
                                <p>Fen Bilimleri Enstitüsü</p>
                            </div>
                        </div>
                    </div>
                }
                else if (Model.EnstituKod == EnstituKodlari.SosyalBilimleri)
                {
                    <div class="col-md-12">
                        <div class="panel panel-default">
                            <div class="panel-body panel-body-map">
                                <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6020.048445257558!2d28.891427000000004!3d41.024726!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xab38aa352428d2ba!2zWcSxbGTEsXogVGVrbmlLIMOcbml2ZXJzaXRlc2ksIERhdnV0cGHFn2EgS2FtcMO8c8O8LCBPcnRhIEJhaMOnZQ!5e0!3m2!1str!2sus!4v1503355517050" width="100%" height="400" frameborder="0" style="border:0"></iframe>
                            </div>
                            <div class="panel-body">
                                <h3><span class="fa fa-map-marker"></span> Yıldız Teknik Üniversitesi</h3>
                                <p>Sosyal Bilimler Enstitüsü</p>
                            </div>
                        </div>
                    </div>
                }

            </div>
            <div class="panel-footer">

            </div>
        </div>
    </div>


</div>


@if ((MesajGroupID != null && MesajGroupID != ""))
{
    <script>

        setTimeout(function () {
            mesGonder('@MesajGroupID');
        }, 1200);
    </script>
}
else if (IsMesajGonder)
{
    <script>
        setTimeout(function () {
            mesGonder();
        }, 1200);
    </script>
}
@if (AnketGiris != null)
{

    <script src="~/Content/assets/plugins/bootbox/bootbox.min.js"></script>
    <script>

        setTimeout(getAnket(), 10);
        function getAnket() {
            var _AnketGiris = @Html.Raw(Json.Encode(AnketGiris));
            var btbxxFS = bootbox.dialog({
                message: _AnketGiris,
                buttons:
                {
                    success:
                    {
                        label: 'Anketi Tamamla',
                        className: "btn-success",
                        callback: function (event) {
                            var pnlx = $(btbxxFS).find('.modal-dialog').first();
                            _pRefresh(pnlx, false);
                            $('#FrmAnket').ajaxForm({
                                success: function (result) {
                                    if (result.IsSuccess) {
                                        var _clsBtn = $('.bootbox-close-button').first();
                                        $(_clsBtn).click();
                                        //$('#tlpFrm').submit();
                                    }
                                    else {
                                        getMsg(result);
                                        return false;
                                    }
                                    _pRefresh(pnlx, true);
                                },
                                complete: function (cmp) {
                                    _pRefresh(pnlx, true);
                                },
                                error: function (err) {
                                    _pRefresh(pnlx, true);
                                }

                            });
                            $('#FrmAnket').submit();
                            return false;
                        }
                    }
                }
            });
            $(btbxxFS).find('.modal-dialog').first().addClass('modal-lg');
        }

    </script>
}
<script>
    $(function () {
        showDuyuru(@DuyuruPopupTipleri.AnaSayfa);
    })
</script>