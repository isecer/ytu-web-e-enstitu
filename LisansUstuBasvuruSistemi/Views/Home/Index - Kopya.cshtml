                <ul class="panel-controls">
                    <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                </ul>
            </div>
            <div class="panel-body">
                @if (Model.EnstituKod == EnstituKodlari.FenBilimleri)
                {
                    <div class="col-md-12">

                        <div class="panel panel-default">
                            <div class="panel-body panel-body-map">
                                <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6020.048445257558!2d28.891427000000004!3d41.024726!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xab38aa352428d2ba!2zWcSxbGTEsXogVGVrbmlLIMOcbml2ZXJzaXRlc2ksIERhdnV0cGHFn2EgS2FtcMO8c8O8LCBPcnRhIEJhaMOnZQ!5e0!3m2!1str!2sus!4v1503355517050" width="100%" height="400" frameborder="0" style="border:0"></iframe>
                            </div>
                            <div class="panel-body">
                                <h3><span class="fa fa-map-marker"></span>&nbsp;@Localization.Get("Gnl_Ytu", culture)</h3>
                                <p>@Localization.Get("Gnl_Fbe", culture)</p>
                            </div>
                        </div>
                    </div>
                }
                else if (Model.EnstituKod == EnstituKodlari.SosyalBilimleri)
                {
                    <div class="col-md-12">
                        <div class="panel panel-default">
                            <div class="panel-body panel-body-map">
                                <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6020.048445257558!2d28.891427000000004!3d41.024726!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0xab38aa352428d2ba!2zWcSxbGTEsXogVGVrbmlLIMOcbml2ZXJzaXRlc2ksIERhdnV0cGHFn2EgS2FtcMO8c8O8LCBPcnRhIEJhaMOnZQ!5e0!3m2!1str!2sus!4v1503355517050" width="100%" height="400" frameborder="0" style="border:0"></iframe>
                            </div>
                            <div class="panel-body">
                                <h3><span class="fa fa-map-marker"></span>&nbsp;@Localization.Get("Gnl_Ytu", culture)</h3>
                                <p>@Localization.Get("Gnl_Sbe", culture)</p>
                            </div>
                        </div>
                    </div>
                }

            </div>
            <div class="panel-footer">

            </div>
        </div>
    </div>


</div>


@if ((MesajGroupID != null && MesajGroupID != ""))
{
    <script>

        setTimeout(function () {
            mesGonder('@MesajGroupID');
        }, 1200);
    </script>
}
else if (IsMesajGonder)
{
    <script>
        setTimeout(function () {
            mesGonder();
        }, 1200);
    </script>
}
@if (AnketGiris != null)
{

    <script src="~/Content/assets/plugins/bootbox/bootbox.min.js"></script>
    <script>

        setTimeout(getAnket(), 10);
        function getAnket() {
            var _AnketGiris = @Html.Raw(Json.Encode(AnketGiris));
            var btbxxFS = bootbox.dialog({
                message: _AnketGiris,
                buttons:
                {
                    success:
                    {
                        label: '@Localization.Get("AnketiTamamla", culture)',
                        className: "btn-primary",
                        callback: function (event) {
                            var pnlx = $(btbxxFS).find('.modal-dialog').first();
                            _pRefresh(pnlx, false);
                            $('#FrmAnket').ajaxForm({
                                success: function (result) {
                                    if (result.IsSuccess) {
                                        var _clsBtn = $('.bootbox-close-button').first();
                                        $(_clsBtn).click();
                                        //$('#tlpFrm').submit();
                                    }
                                    else {
                                        getMsg(result);
                                        return false;
                                    }
                                    _pRefresh(pnlx, true);
                                },
                                complete: function (cmp) {
                                    _pRefresh(pnlx, true);
                                },
                                error: function (err) {
                                    _pRefresh(pnlx, true);
                                }

                            });
                            $('#FrmAnket').submit();
                            return false;
                        }
                    }
                }
            });
            $(btbxxFS).find('.modal-dialog').first().addClass('modal-lg');
        }

    </script>
}
<script>
    $(function () {
        showDuyuru(@DuyuruPopupTipleri.AnaSayfa);
    })
</script>

