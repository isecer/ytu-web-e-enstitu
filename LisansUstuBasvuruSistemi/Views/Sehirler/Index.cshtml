@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  LisansUstuBasvuruSistemi.Utilities.Dtos.FmSehirler
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp;Şehir Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-info label-form" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Kayit")'"><i class="fa fa-plus" aria-hidden="true"></i> Yeni Şehir Ekle</span></li>
                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="sirala" field="SehirKod" width="60">Kod</th>
                                <th class="sirala" field="Ad">Şehir Adı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="30"> 
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th><input name="SehirKod" type="text" value="@Model.SehirKod" class="form-control" /></th>
                                <th>
                                    <input name="Ad" type="text" value="@Model.Ad" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                foreach (var item in Model.data)
                                {
                                    <tr>
                                        <td>@item.SehirKod</td>
                                        <td id="tdMad_@item.SehirKod">
                                            @item.Ad
                                        </td>
                                        <td id="tdIa_@item.SehirKod" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td> 
                                            <a href="@Url.Action("Kayit", "Sehirler", new { id = item.SehirKod })"><i class="fa fa-edit  tooltips" title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="SilmeOnay(this,@item.SehirKod)"><i class="fa fa-trash-o tooltips" title="Sil"></i></a>

                                        </td>
                                    </tr>


                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                   @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function SilmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Şehir Adı: " + gMesaj + " <br/> Seçilen Şehiri Silmek İstiyor Musunuz?",
            title: "Şehir Silme İşlemi",
            buttons: {
                success: {
                    label: "Şehiri Sil",
                    className: "btn-danger",
                    callback: function () {
                        Sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function Sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "Sehirler")',  
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Şehir Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    // $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
