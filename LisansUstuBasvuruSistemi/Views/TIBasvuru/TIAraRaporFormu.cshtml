<script>
    TezDiliKontrol();
    function TezDiliKontrol() {
        var IsTezDiliDegisecek = $('#IsTezDiliDegisecek').prop('checked');
        if (IsTezDiliDegisecek) {
            $('.YeniTezDiliTr').removeClass('hide');
            $('.DvDil').removeClass('hide');
            DilBilgisiKontrol('TezDanismani');
            DilBilgisiKontrol('TikUyesi1');
            DilBilgisiKontrol('TikUyesi2');


        }
        else {
            $('.YeniTezDiliTr').addClass('hide');
            $('.DvDil').addClass('hide');
            DilBilgisiKontrol('TezDanismani');
            DilBilgisiKontrol('TikUyesi1');
            DilBilgisiKontrol('TikUyesi2');
        }

    }
    function DilBilgisiKontrol(UyeTip) {
        var IsTezDiliDegisecek = $('#IsTezDiliDegisecek').prop('checked');
        var YeniTezDiliEn = $('#YeniTezDiliTr').val() == "false";

        if (IsTezDiliDegisecek && YeniTezDiliEn) {
            var IsDilSinaviOrUniversite = $('#' + UyeTip + 'IsDilSinaviOrUniversite').val();
            if (IsDilSinaviOrUniversite != '') {
                $('.' + UyeTip + 'DvDilSinavAdi').removeClass('hide');
                if (IsDilSinaviOrUniversite == 'true') {
                    $('.' + UyeTip + 'DvDilSinavTarih').removeClass('hide');
                    $('.' + UyeTip + 'DvDilSinavPuani').removeClass('hide');
                    $('.' + UyeTip + 'LblDilSinavAdi').html('Dil Sınavı Adı (*)');
                }
                else {
                    $('.' + UyeTip + 'DvDilSinavPuani').addClass('hide');
                    $('.' + UyeTip + 'DvDilSinavTarih').addClass('hide');
                    $('.' + UyeTip + 'LblDilSinavAdi').html('Üniversite Adı (*)');
                }
            }
            else {
                $('.' + UyeTip + 'DvDilSinavPuani').addClass('hide');
                $('.' + UyeTip + 'DvDilSinavAdi').addClass('hide');
                $('.' + UyeTip + 'DvDilSinavTarih').addClass('hide');
            }
        }
        else {
            $('.DvDil').addClass('hide');
        }
    }
</script>
<script>
    $('.make-switch')['bootstrapSwitch']();
    function TITabChangeSet(SelectedTabID) {

        $('#SelectedTabID').val(SelectedTabID);
        if (SelectedTabID == "4") {
            $('.btnKaydet').removeClass("btn-info").addClass("btn-primary");
            $('.btnKaydet').text('Kaydet');
            $('#SaveData').val("true");

        }
        else {

            $('.btnKaydet').addClass("btn-info").removeClass("btn-primary");
            $('.btnKaydet').text('İleri');
            $('#SaveData').val("false");
        }
    }


    $(function () {
        $('.upperCase').each(function (ix, inx) {
            $(inx).attr('autocomplete', 'off');
            $(inx).bind('keyup', function (e) {
                var vl = $(inx).val();
                $(inx).val(vl.replaceAll("i", "İ").toUpperCase());
            });
        })
        $('.egitmens').select2({
            tags: true,
            tokenSeparators: [",", " "],
            minimumInputLength: 2,
            maximumSelectionSize: 1,
            multiple: false,
            ajax: {
                url: '@Url.Action("GetYtuOgretimEleman", "Ajax")',
                dataType: "json",
                data: function (term, page) {
                    return {
                        'term': term
                    }

                },
                results: function (data, page) {
                    return {
                        results: data
                    };
                }
            },
            formatResult: function (result) {
                var cont2 =
                    "<table class='table table-striped' style='width:100%; margin:0px;'>" +
                    "<tbody>" +
                    "<tr>" +
                    "<td style='vertical-align:middle;'>" +
                    "<table class='table table-striped' style='margin:0px;border-top:none;font-size:8pt;'> " +
                    "<tbody>" +
                    "<tr><td>" + result.AdSoyad + "</td></tr>" +
                    "<tr><td>Bölüm:" + result.BolumAdi + "</td></tr>" +
                    "<tr><td>Ünvan: " + result.UnvanAdi + "</td></tr>" +
                    "</tbody> " +
                    "</table> " +
                    "</td>" +
                    "</tr> " +
                    "</tbody>" +
                    "</table>";
                return cont2;
            }
        }).on('change', function (e) {
            var Inpid = $(this).prop("id");
            var mID = Inpid.replace("AdSoyadx", "").replace("AdSoyad", "");
            $('#' + mID + 'AdSoyad').val(e.added == undefined ? "" : e.added.AdSoyad);
            $('#' + mID + 'UnvanAdi').val(e.added == undefined ? "" : e.added.UnvanAdi);
            $('#' + mID + 'EMail').val(e.added == undefined ? "" : e.added.EMail);
            $('#' + mID + 'AnabilimdaliProgramAdi').val(e.added == undefined ? "" : e.added.BolumAdi);
            $('#' + mID + 'UniversiteID').val(e.added == undefined ? "" : e.added.UniversiteID);
            $('#x' + mID + 'UniversiteID').val(e.added == undefined ? "" : e.added.UniversiteID);
            $('#x' + mID + 'UnvanAdi').val(e.added == undefined ? "" : e.added.UnvanAdi);

            //  var id = e.added.id;
            });
        //.data([{ "id": $(this).prev().val(), "text": $(this).prev().val() }]);
