                                                </label>
                                                <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                    @Html.DropDownList("UniversiteID", tikUyesi1Bilgi.SListUniversiteID, new { @class = "form-control", @style = "width:100%;color:black;", id = "TikUyesi1UniversiteID" })
                                                    @if (tikUyesi1Bilgi != null && tikUyesi1Bilgi.UniversiteID.HasValue)
                                                    {
                                                        <script>
                                                            $(function () {
                                                                $('#TikUyesi1UniversiteID').val('@tikUyesi1Bilgi.UniversiteID.Value');
                                                            })
                                                        </script>
                                                    }
                                                    @*<input type="text" class="form-control" maxlength="128" name="UniversiteAdi" value="@(TikUyesi1Bilgi != null ? TikUyesi1Bilgi.UniversiteAdi : "")" style="width: 100%;" id="TikUyesi1UniversiteAdi" />*@
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                    Anabilim Dalı (*)
                                                </label>
                                                <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                    <input type="text" class="form-control" autocomplete="off" maxlength="256" name="AnabilimdaliProgramAdi" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.AnabilimdaliProgramAdi : "")" style="width: 100%;color:black;" id="TikUyesi1AnabilimdaliProgramAdi" />
                                                </div>
