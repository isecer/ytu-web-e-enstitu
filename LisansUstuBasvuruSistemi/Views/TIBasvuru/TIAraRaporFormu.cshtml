<script src="~/Scripts/inputTextChangeUpperCase.js"></script>
@if (Model.TIBasvuruAraRaporID > 0)
{
    <script>
        setTimeout(function () {
            $('.btnKaydet').removeClass("btn-info").addClass("btn-primary");
            $('.btnKaydet').text('Kaydet');

        }, 200);
    </script>
}
<script>
    onSpecialCharacterBlockerLoaded(); 
</script>
<script>
    $('.make-switch')['bootstrapSwitch']();
    function TITabChangeSet(SelectedTabID) {

        $('#SelectedTabID').val(SelectedTabID);
        if (SelectedTabID == "4") {
            $('.btnKaydet').removeClass("btn-info").addClass("btn-primary");
            $('.btnKaydet').text('Kaydet');
            $('#SaveData').val("true");

        }
        else {

            $('.btnKaydet').addClass("btn-info").removeClass("btn-primary");
            $('.btnKaydet').text('İleri');
            $('#SaveData').val("false");
        }
    }


    $(function () {
        $('.upperCase').each(function (ix, inx) {
            $(inx).attr('autocomplete', 'off');
            $(inx).bind('keyup', function (e) {
                var vl = $(inx).val();
                $(inx).val(vl.replaceAll("i", "İ").toUpperCase());
            });
        })
        $('.egitmens').select2({
            tags: true,
            tokenSeparators: [",", " "],
            minimumInputLength: 2,
            maximumSelectionSize: 1,
            multiple: false,
            ajax: {
                url: '@Url.Action("GetYtuOgretimEleman", "Ajax")',
                dataType: "json",
                data: function (term, page) {
                    return {
                        'term': term
                    }

                },
                results: function (data, page) {
                    return {
                        results: data
                    };
                }
            },
            formatResult: function (result) {
                var cont2 =
                    "<table class='table table-striped' style='width:100%; margin:0px;'>" +
                    "<tbody>" +
                    "<tr>" +
                    "<td style='vertical-align:middle;'>" +
                    "<table class='table table-striped' style='margin:0px;border-top:none;font-size:8pt;'> " +
                    "<tbody>" +
                    "<tr><td>" + result.AdSoyad + "</td></tr>" +
