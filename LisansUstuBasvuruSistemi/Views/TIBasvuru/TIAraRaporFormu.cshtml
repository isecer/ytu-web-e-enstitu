                                            <div class="form-group">
                                                <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                    Unvanı (*)
                                                </label>
                                                <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                    <input type="text" class="form-control upperCase" maxlength="128" name="UnvanAdi" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.UnvanAdi.ToUpper() : "")" readonly="readonly" style="width: 100%;color:black;" id="TikUyesi1UnvanAdi" />
