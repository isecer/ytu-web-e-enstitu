@model  Entities.Entities.YeterlikBasvuruJuriUyeleri
@{
    Layout = null;

}


@if (Model.IsSonucOnaylandi.HasValue)
{
    if (Model.SozluNotu.HasValue)
    {
        <span style="color: green; font-size: 10pt;" aria-hidden="true"><i style="font-size: 12pt;"></i> Sözlü Notu: @Model.SozluNotu</span>
    }
    else
    {
        <span style="color: green; font-size: 10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size: 12pt;"></i> Sınav Sonucu Onaylandı</span>
    }

    <br />
    if (Model.DegerlendirmeTarihi.HasValue)
    {
        <span style="font-size: 8pt; color: green;">@Model.DegerlendirmeTarihi.Value.ToLongDateString() @Model.DegerlendirmeTarihi.Value.ToString("HH:mm") Tarihinde Değerlendirildi.</span>
    }
}
else
{


    if (Model.IsLinkGonderildi == true)
    {
        <span aria-hidden="true" style="font-size: 9pt;"><i class="fa fa-clock-o" style="font-size: 12pt;"></i> Değerlendirme Yapması Bekleniyor.</span>
        <br />
        <span style="color: green; font-size: 8pt;">@Model.LinkGonderimTarihi.Value.ToLongDateString() @Model.LinkGonderimTarihi.Value.ToString("HH:mm") Tarihinde Değerlendirme Linki Gönderildi.</span>
    }
    else
    {
        <br />
        <span style="color: maroon; font-size: 8pt;">Değerlendirme Linki Henüz Gönderilmedi.</span>
    }

}

