@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model FrYeterlikBasvuruDto
@{
    var item = Model;

    var tabAdi = "";
    var tabIconClass = "";
    var durumAdi = "";
    var durumIconClass = "";
    var durumAciklama = "";
    var durumColor = "";
    var durumDetay = "";
    var durumDetayIconClass = "";
    var aciklamaDetay = "";

    if (!item.IsEnstituOnaylandi.HasValue)
    {
        tabAdi = "Yeni Başvuru";
        tabIconClass = "fa fa-list-alt fa-lg";
        durumAdi = "Enstütü Onayı Bekleniyor";
        durumIconClass = "fa fa-clock-o";
        durumColor = "gray";
        durumDetay = "Başvuru Enstitü tarafından kabül edilmesi bekleniyor";
        durumDetayIconClass = "fa fa-comments-o";
    }
    else if (!item.IsEnstituOnaylandi.Value)
    {
        tabAdi = "Yeni Başvuru";
        tabIconClass = "fa fa-list-alt fa-lg";
        durumAdi = "Enstütü Tarafından İptal Edildi";
        durumIconClass = "fa fa-thumbs-o-down";
        durumColor = "maroon";
        durumDetay = Model.EnstituOnayAciklama.Substring(0, Model.EnstituOnayAciklama.Length > 45 ? 45 : Model.EnstituOnayAciklama.Length) + "...";
        durumDetayIconClass = "fa fa-comments-o";
        aciklamaDetay = Model.EnstituOnayAciklama;
    }
    else
    {
        if (item.IsGenelSonucBasarili.HasValue)
        {
            if (item.IsGenelSonucBasarili.Value)
            {
                tabAdi = "Yeterlik Başarı Durumu";
                tabIconClass = "fa fa-list-alt fa-lg";
                durumAdi = "Başarılı";
                durumIconClass = "fa fa-thumbs-o-up fa-lg";
                durumColor = "green";
                durumDetay = "Jüri üyeleri tarafından sınav sonucu başarılı olarak değerlendirilmiştir.";
                durumDetayIconClass = "fa fa-comments-o";
            }
            else
            {
                tabAdi = "Yeterlik Başarı Durumu";
                tabIconClass = "fa fa-list-alt fa-lg";
                durumAdi = "Başarısız";
                durumIconClass = "fa fa-thumbs-o-down fa-lg";
                durumColor = "maroon";
                durumDetay = "Jüri üyeleri tarafından sınav sonucu başarısız olarak değerlendirilmiştir.";
                durumDetayIconClass = "fa fa-comments-o";
            }

        }
        else if (item.IsSozluSinavOnline.HasValue)
        {
            if (item.IsSozluSinavinaKatildi.HasValue)
            {
                tabAdi = "Sözlü Sınav Süreci";
                tabIconClass = "fa fa-list-alt fa-lg";
                durumAdi = (item.IsSozluSinavinaKatildi.Value ? "Öğrenci Sınava Katıldı (Süreç Devam Ediyor)" : "Öğrenci Sınava Katılmadı (Başarısız)");
                durumIconClass = (item.IsSozluSinavinaKatildi.Value ? "fa fa-clock-o fa-lg" : "fa fa-thumbs-o-down fa-lg");
                durumColor = (item.IsSozluSinavinaKatildi.Value ? "green" : "maroon");
                durumDetay = "Jüri üyeleri tarafından sınav sonucu değerlendirme işlemi devam ediyor.";
                durumDetayIconClass = "fa fa-comments-o";
            }
            else
            {
                tabAdi = "Sözlü Sınavı Süreci";
                tabIconClass = "fa fa-list-alt fa-lg";
                durumAdi = "Sözlü Sınavı Sonuç Girişi Bekleniyor";
                durumIconClass = "fa fa-clock-o fa-lg";
                durumColor = "green";
                durumDetay = "Danışman tarafından sözlü sınavı sonucu girişi bekleniyor.";
                durumDetayIconClass = "fa fa-comments-o";
            }
        }
        else if (item.IsAbdKomitesiJuriyiOnayladi.HasValue && item.YaziliSinavTarihi.HasValue)
        {
            if (item.IsYaziliSinavinaKatildi.HasValue)
            {
                if (item.IsYaziliSinavBasarili == true)
                {
                    tabAdi = "Yazılı Sınav Süreci";
                    tabIconClass = "fa fa-list-alt fa-lg";
                    durumAdi = (item.IsYaziliSinavinaKatildi.Value ? "Öğrenci Sınava Katıldı (Başarılı)" : "Öğrenci Sınava Katılmadı (Başarısız)");
                    durumIconClass = (item.IsYaziliSinavinaKatildi.Value ? "fa fa-clock-o fa-lg" : "fa fa-thumbs-o-down fa-lg");
                    durumColor = "green";
                    durumDetay = "Danışman tarafından sözlü sınavı bilgi girişi yapılmalı.";
                    durumDetayIconClass = "fa fa-comments-o";
                }
                else
                {

                    tabAdi = "Yazılı Sınav Süreci";
                    tabIconClass = "fa fa-list-alt fa-lg";
                    durumAdi = (item.IsYaziliSinavinaKatildi.Value ? "Öğrenci Sınava Katıldı (Başarısız)" : "Öğrenci Sınava Katılmadı (Başarısız)");
                    durumIconClass = "fa fa-thumbs-o-down fa-lg";
                    durumColor = "maroon";
                    durumDetay = "Jüri üyeleri tarafından sınav sonucu değerlendirme işlemi devam ediyor.";
                    durumDetayIconClass = "fa fa-comments-o";

                }

            }
            else
            {
                tabAdi = "Yazılı Sınav Süreci";
                tabIconClass = "fa fa-list-alt fa-lg";
                durumAdi = "Sınav Sonucu Girişi Bekleniyor";
                durumIconClass = "fa fa-clock-o fa-lg";
                durumColor = "green";
                durumDetay = "Danışman tarafından sınav sonucu giriş işlemi yapılması bekleniyor.";
                durumDetayIconClass = "fa fa-comments-o";
            }

        }
        else if (!item.IsJuriOlusturuldu)
        {
            tabAdi = "Jüri Oluşturma Süreci";
            tabIconClass = "fa fa-group fa-lg";
            durumAdi = "Danışman Yeterlik Jüri Üyelerini Oluşturmalı";
            durumIconClass = "fa fa-clock-o fa-lg";
            durumColor = "green";
            durumDetay = "ABD Komite üyelerinin jüri üyelerini onaylayabilmesi için Danışman Jüri listesini oluşturmalı.";
            durumDetayIconClass = "fa fa-comments-o";
        }
        else
        {
            if (!item.IsAbdKomitesiJuriyiOnayladi.HasValue)
            {
                tabAdi = "ABD Komitesi Süreci";
                tabIconClass = "fa fa-group fa-lg";
                durumAdi = "Jüri Onaylama Süreci Devam Ediyor";
                durumIconClass = "fa fa-clock-o fa-lg";
                durumColor = "green";
                durumDetay = "Sınav işlemlerine geçilebilmesi için ABD Komitesinin Jüri üyelerini onaylaması gerekmektedir.";
                durumDetayIconClass = "fa fa-comments-o";
            }
            else
            {
                if (item.IsAbdKomitesiJuriyiOnayladi.Value)
                {
                    tabAdi = "ABD Komitesi Süreci";
                    tabIconClass = "fa fa-group fa-lg";
                    durumAdi = "Jüriler Onaylandı";
                    durumIconClass = "fa fa-thumbs-o-up fa-lg";
                    durumColor = "green";
                    durumDetay = "ABD Komite üyeleri Jüri üyelerini onayladı. Danışman yazılı sınavı oluşturmalı.";
                    durumDetayIconClass = "fa fa-comments-o";
                }
                else
                {
                    tabAdi = "ABD Komitesi Süreci";
                    tabIconClass = "fa fa-group fa-lg";
                    durumAdi = "Jüriler Onaylandı";
                    durumIconClass = "fa fa-thumbs-o-down fa-lg";
                    durumColor = "maroon";
                    durumDetay = "ABD Komite üyelerinin Jüri üyelerini onaylamadı.";
                    durumDetayIconClass = "fa fa-comments-o";
                }

            }

        }


    }

}


<table>
    <tbody>
        <tr style="color:@durumColor">
            <td>
                <i class="@tabIconClass" aria-hidden="true"></i> <span style="font-size:9pt;margin:0px;"> @tabAdi</span>  <span style="font-size:7pt;" title="@durumAciklama"><i style="font-size:8pt;" class="@durumIconClass"></i> @durumAdi</span>
            </td>
        </tr>
        <tr>
            <td>

                @if (durumDetay != "")
                {
                    <span style="font-size:7pt;" title="@aciklamaDetay"><i style="font-size:8pt;" class="@durumDetayIconClass"></i> @durumDetay</span>
                }
            </td>
        </tr>
    </tbody>
</table>

