@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  FmEnstitulerDto
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Enstitü Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-info label-form" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Kayit")'"><i class="fa fa-plus" aria-hidden="true"></i> Yeni Enstitü Ekle</span></li>
                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr class="info">
                                <th class="sirala" field="EnstituKod" width="50">Kod</th>
                                <th class="sirala" field="EnstituAd">Enstitü Adı</th>
                                <th class="sirala" field="IsAktif" width="150">Web Adresi</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="30">
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                             
                            @if (Model.RowCount > 0)
                            {
                                foreach (var item in Model.EnstitulerDtos)
                                {
                                    <tr>
                                        <td>@item.EnstituKod</td>

                                        <td id="tdMad_@item.EnstituKod">
                                            @item.EnstituAd
                                        </td>
                                        <td>
                                            <a href="@item.WebAdresi" target="_blank">@item.WebAdresi</a>
                                        </td>
                                        <td id="tdIa_@item.EnstituKod" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "Enstituler", new { id = item.EnstituKod })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.EnstituKod')"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Enstitü Adı: " + gMesaj + " <br/> Seçilen Enstitüyü Silmek İstiyor Musunuz?",
            title: "Enstitü Silme İşlemi",
            buttons: {
                success: {
                    label: "Enstitüyü Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "Enstituler")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Enstitü Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    // $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
