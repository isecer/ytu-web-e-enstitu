@using BiskaUtil
@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model List<kulaniciProgramYetkiModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var user = (Kullanicilar)ViewBag.Kullanici;
    var allchecked = Model.Where(s => s.YetkiVar).Count() == Model.Count;

    var kullaniciKayit = RoleNames.KullanicilarKayit.InRoleCurrent();
    var ErisimYetki = RoleNames.KullanicilarIslemYetkileri.InRoleCurrent();
    var EnstituYetki = RoleNames.KullanicilarEnstituYetkileri.InRoleCurrent();
}



<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12 col-md-12 col-md-12">
            <div class="panel panel-default">
                <div class="portlet-title">
                    <div class="panel-heading padding-0">
                        <h3 class="panel-title"><i class="fa fa-user"></i>Program Yetkileri: @user.Ad @user.Soyad [@user.KullaniciAdi] </h3>

                        <ul class="panel-controls">
                            <li>
                                Tümü:<div class="make-switch switch-small" data-on-label="Evet" data-off-label="Hayır">
                                    <input type="checkbox" value="true" id="tmunusec" onchange="tumunusec(this)" class="toggle" @allchecked.ToChecked() />
                                </div>
                            </li>
                            @if (kullaniciKayit)
                            {
                                <li><span class="label label-success label-form" onclick="window.location.href='@Url.Action("Kayit", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-edit"></i> Kullanıcı</span></li>

                            }
                            @if (ErisimYetki)
                            {
                                <li><span class="label label-success label-form" onclick="window.location.href='@Url.Action("Yetkilendirme", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-edit"></i> Erişim Yetkileri</span></li>

                            }
                            @if (EnstituYetki)
                            {
                                <li><span class="label label-success label-form" onclick="window.location.href='@Url.Action("YetkilendirmeEnstitu", new { id = user.KullaniciID })'" style="cursor:pointer;"><i class="fa fa-edit"></i> Enstitü Yetkileri</span></li>
                            }

                            <li><a href="@Url.Action("KullaniciProgramYetkileri","Kullanicilar",new {id= user.KullaniciID })" class=""><span class="fa fa-refresh panel-refresh"></span></a></li>
                        </ul>
                    </div>
                </div>
                <div class="panel-body form">
                    <input type="hidden" name="KullaniciID" value="@user.KullaniciID" />

                    <table class="table" style="width:100%;table-layout:fixed;">
                        <thead>
                            <tr>
                                <th width="600">Program Adı</th>
                                <th>Anabilim Dalı Adı</th>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <table style="width: 100%;">
                                        <tr>
                                            <td>
                                                <div style="width: 100%;" class="checkbox pull-left">
                                                    <label style="width: 100%;">
                                                        <input style="color: red; width: 100%;" type="text" name="search" id="filterBInp" placeholder="ara..." class="form-control">
                                                    </label>
                                                </div>
                                            </td>
                                            <td><a href="javascript:void(0);" onclick="Filtrele()" class="label label-warning">Ara</a></td>
                                        </tr>
                                    </table>

                                </td>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Count > 0)
                            {
                                <tr>
                                    <td colspan="2">
                                        <div style="overflow:auto;height:600px;">
                                            <table id="prgList" style="table-layout:fixed;width:100%;">
                                                @foreach (var item in Model)
                                                {
                                                    <tr class="_rows" @(item.YetkiVar ? "style=color:blue" : "")>
                                                        <td width="600">
                                                            <div class="checkbox pull-left">
                                                                <label>
                                                                    <input type="checkbox" class="icheckbox chkAll" name="ProgramKod" value="@item.ProgramKod" @item.YetkiVar.ToChecked()>
                                                                    <span class="programAdlari">@item.ProgramAdi </span>
                                                                </label>
                                                            </div>
                                                        </td>
                                                        <td class="bolumAdlari">@item.AnabilimDaliAdi</td>
                                                    </tr>
                                                }
                                            </table>
                                        </div>
                                    </td>
                                </tr>

                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td id="filtreKelime" colspan="2"></td>
                            </tr>

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply">&nbsp</i>Geri Dön</a>
                    <button class="btn btn-primary pull-right"><i class="fa fa-save">&nbsp</i>Kaydet</button>
                </div>
            </div>
        </div>


    }
</div>
<script type="text/javascript">

    function tumunusec(sndr) {
        var chkD = $(sndr).prop("checked");
        $('.chkAll').each(function (inx, itmx) {
            if ($(itmx).parents('._rows').first().css('display') != "none") {
                if (chkD) { $(itmx).parent().addClass("checked"); }
                else { $(itmx).parent().removeClass("checked"); }
                $(itmx).prop("checked", chkD);
            }
        });
    }
    function Filtrele() {
        var filtreval = $('#filterBInp').val().replace('İ', 'i').toLowerCase();
        var $fltrRow = $('._rows');

        if (filtreval != null && filtreval != "") {
            var toplam = $('._rows').length;
            $('#prgList').find('tr').each(function (inx, trx) {
                var _bolumadi = $(trx).find(".bolumAdlari").first().text();
                var _programadi = $(trx).find(".programAdlari").first().text();
                var clmValBol = _bolumadi.replace('İ', 'i').toLowerCase();
                var clmValprog = _programadi.replace('İ', 'i').toLowerCase();
                //var ipS = $(trx).find('.ipS').first().text().toLowerCase();
                var AShow = clmValBol.indexOf(filtreval) > -1 || clmValprog.indexOf(filtreval) > -1;
                // var IShow = ipS.indexOf(filtreval) > -1;
                if (AShow) {
                    $(trx).removeClass("hide");
                }
                else {
                    $(trx).addClass("hide");
                }

            })
            var Gizli = $('._rows.hide').length;
            var gosterilen = toplam - Gizli;
            $('#filtreKelime').html("[Ara:  %<span style='color:red;'>" + filtreval + "</span>%] [Bulunan: <span style='color:red;'>" + gosterilen + "</span>]");

        }
        else {
            $fltrRow.removeClass("hide");
            $('#filtreKelime').html("");

        }
    }
    $('#filterBInp').bind("keydown", function (event) {
        if (event.keyCode == 13) {
            Filtrele();
            event.preventDefault();
        }
    });
</script>


