                                    </div>
                                </div>
                                <div class="form-group">
                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                        Üniversitesi (*)
                                    </label>
                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                        @Html.DropDownList("UniversiteID", tezDanismaniBilgi.SListUniversiteID, new { @class = "form-control", @style = "width:100%;color:black;", id = "TezDanismaniUniversiteID" })
                                        @if (tezDanismaniBilgi.UniversiteID.HasValue)
                                        {
                                            <script>
                                                $(function () {
                                                    $('#TezDanismaniUniversiteID').val('67');
                                                })
                                            </script>
                                        }
                                        @*<input type="text" class="form-control" maxlength="128" name="UniversiteAdi" value="@(TezDanismaniBilgi != null ? TezDanismaniBilgi.UniversiteAdi : "")" style="width: 100%;" id="TezDanismaniUniversiteAdi" />*@
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                        Anabilimdalı (*)
                                    </label>
