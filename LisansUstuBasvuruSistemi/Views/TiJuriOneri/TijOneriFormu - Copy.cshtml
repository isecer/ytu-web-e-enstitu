                                        <input type="hidden" name="AnaTabAdi" value="tab-TezDanismani" />
                                        <input type="hidden" name="DetayTabAdi" value="tab-TezDanismani" />
                                        <input type="text" class="form-control upperCase" name="AdSoyad" maxlength="128" value="@(tezDanismaniBilgi != null ? tezDanismaniBilgi.AdSoyad : "")" style="width: 100%;color:black;" id="TezDanismaniAdSoyad" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                        Unvanı (*)
                                    </label>
                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                        <input type="text" class="form-control upperCase hide" name="xUnvanAdi" maxlength="128" value="@(tezDanismaniBilgi != null ? tezDanismaniBilgi.UnvanAdi : "")" style="width: 100%;color:black;" />

                                        @Html.DropDownList("UnvanAdi", tezDanismaniBilgi.SlistUnvanAdi, new { @class = "form-control", @style = "width:100%;color:black;", id = "TezDanismaniUnvanAdi" })

                                        @if (!string.IsNullOrEmpty(tezDanismaniBilgi.UnvanAdi))
                                        {
                                            <script>
                                                            $(function () {
                                                                $('#TezDanismaniUnvanAdi').val('@Html.Raw(tezDanismaniBilgi.UnvanAdi)');
                                                            })
                                            </script>
                                        }

                                    </div>
                                </div>
                                <div class="form-group">
