                                                                        {
                                                                            <script>
                                                                                setTimeout( function () {
                                                                                   var secilen = @Html.Raw(Json.Encode(new { id = rowData.AdSoyad, text = rowData.AdSoyad }));
                                                                                   $("#YtuIciJuri@(i)AdSoyad").select2('data', secilen);

                                                                               },1200)
                                                                            </script>
                                                                        }
