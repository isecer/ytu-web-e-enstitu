@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model TijOneriFormuKayitDto
@{
    Layout = null;
    var tezDanismaniBilgi = Model.JoFormJuriList.FirstOrDefault(p => p.JuriTipAdi == "TezDanismani");

}
<div class="widget widget-default" style="margin:0px;padding:4px;">
    <div class="panel panel-default form-horizontal" style="margin:0px;margin-top:5px;">
        <div class="panel-heading padding-0">
            <h3 class="panel-title"><i class="fa fa-book myCaptionTd"></i><span class="myCaptionTd"> Tez İzleme Jüri Öneri Formu</span> </h3>
        </div>
        <div class="panel-body" style="padding:0px;padding-left:2px;padding-right:2px;">


            @using (Ajax.BeginForm("TijOneriFormuPost", "TiJuriOnerileriGb", null, new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "FrmTijOneriFormu" }))
            {
                @Html.HiddenFor(p => p.TijBasvuruID);
                @Html.HiddenFor(p => p.KullaniciId);
                @Html.HiddenFor(p => p.TijBasvuruOneriID);
                @Html.HiddenFor(p => p.IsTezDiliTr);
                @Html.Hidden("PostDetayTabAdi", "tab-TezDanismani");
                @Html.Hidden("SaveData", (Model.TijBasvuruOneriID > 0 ? "true" : "false"));
              
                <div class="panel-body form-group-separated">
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Adı ve Soyadı - Numarası</label>
                        <div class="col-md-9 col-xs-10">
                            @Model.OgrenciAdSoyad
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Tez Dili</label>
                        <div class="col-md-9 col-xs-10">
                            @(Model.IsTezDiliTr ? "Türkçe" : "İngilizce")
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Tez Başlığı Türkçe</label>
                        <div class="col-md-9 col-xs-10">
                            @Model.TezBaslikTr
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Tez Başlığı İngilizce</label>
                        <div class="col-md-9 col-xs-10">
                            @Model.TezBaslikEn
                        </div>
                    </div>
                    @if (!Model.IsTezDiliTr && Model.TezDanismanID == UserIdentity.Current.Id)
                    {
                        <div class="form-group">
                            <label class="col-md-3 col-xs-2 control-label" style="color:maroon">Tahhüt</label>
                            <div class="col-md-9 col-xs-10" style="color:maroon">
                                Seçilen jüri üyeleri için ‘Yükseköğretim kurumlarında yabancı dil öğretimi ve yabancı dille öğretim yapılmasında uyulacak esaslara ilişkin yönetmeliğe göre dil şartını sağlamaktadır’ tahhütünü kabul ediyorum.
                            </div>
                        </div>
                    }
                </div>
                <div class="col-md-4">
                    <div class="panel-body list-group">
                        <a href="#" class="list-group-item active"><span class="fa fa-user"></span> Profile</a>
                        <a href="#" class="list-group-item"><span class="fa fa-cog"></span> Settings</a>
                        <a href="#" class="list-group-item"><span class="fa fa-bar-chart-o"></span> Activity</a>
