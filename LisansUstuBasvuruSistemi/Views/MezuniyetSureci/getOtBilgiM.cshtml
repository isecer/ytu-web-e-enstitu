@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.Helpers
@model KmMezuniyetSureciOgrenimTipModel
@{
    Layout = null;
}

<div class="panel panel-default" style="padding: 0px; margin: 0px;">
    <div class="panel-heading padding-0">
        <h4 class="panel-title"><i class="fa fa-pencil"></i> Mezuniyet Başvurusu ve  Süreci için gerekli kriterler</h4>
    </div>
    <div class="panel-body padding-0">

        <table class="table" style="width:100%;table-layout:fixed;">
            <thead>
                <tr >
                    <th>Öğrenim Tipleri</th>
                    <th style="font-size:7pt;" width="70" title="Öğrencinin mezuniyet başvurusu yapabilmesi için en fazla kaçıncı dönemde olması gerekir.">Dönem K.</th>
                    <th style="font-size:7pt;" width="80" title="Son dönem kayıt yaptırması gereken ders kodları">K.Y.D.K</th>
                    <th style="font-size:7pt;" width="40" title="Etik dersi notu belirlenen nottan düşük ise başvuru yapamayacak. (Not kriteri belirlenmezse öğrenci bu kontrole tabi tutulmaz)">Etik <br/> Not</th>
                    <th style="font-size:7pt;" width="40" title="Seminer dersi notu belirlenen nottan düşük ise başvuru yapamayacak. (Not kriteri belirlenmezse öğrenci bu kontrole tabi tutulmaz)">Smnr <br /> Not</th>
                    <th style="font-size:7pt;" width="40" title="Tüm dönem toplam kredi kriteri">Min <br /> Kredi</th>
                    <th style="font-size:7pt;" width="40" title="Genel AGNO kriteri">Min <br /> AGNO</th>
                    <th style="font-size:7pt;" width="40" title="Genel AKTS kriteri">Min <br /> AKTS</th>
                    <th style="font-size:7pt;" width="50" title="Mezuniyet başvurusu kabulü için en fazla tek kaynak benzerlik oranı kontrol kriteri (boş bırakılırsa bu veri istenmez).">Tek Kay.<br />Bnz.Orn.</th>
                    <th style="font-size:7pt;" width="50" title="Mezuniyet Başvuru kabulü için toplam benzerlik oranı kontrol kriteri (boş bırakılırsa bu veri istenmez).">Toplam<br />Bnz.Orn.</th>
                    <th style="font-size:7pt;" width="50" title="EYK tarihinden sonra sınav talebi en erken kaç gün sonra yapılabilir (Gün)">Snv.Talep<br/>Suresi</th>
                    <th style="font-size:7pt;" width="50" title="EYK tarihinden sonra sınav talebi en geç kaç gün sonra yapılabilir (Gün)">Snv.Talep<br/>Suresi</th>
                    <th style="font-size:7pt;" width="50" title="Tez sınavı uzatma sonrası en geç kaç gün içinde öğrenci tez teslimi yapmalı (Gün)">U.Sonrasi<br/>Tez Teslim</th>
                    <th style="font-size:7pt;" width="50" title="Tez sınavı uzatma sonrası en geç kaç gün içinde sınav alınmalı (Gün)">U.Sonrasi<br />Snv.Talep</th>
                    <th style="font-size:7pt;" width="50" title="Tez sınavdan başarılı olunduktan sonra tez teslimi en geç kaç gün içinde yapılmalı (Gün)">Tez Teslim<br/>Süresi</th>
                </tr>
            </thead>
            <tbody id="Rw_tbody">
                @foreach (var item in Model.OgrenimTipKriterList.OrderBy(t => t.OgrenimTipAdi))
                {

                    <tr class="rw_bst">
                        <td>
                            <div class="form-group">
                                <input type="text" name="MezuniyetSureciOgrenimTipKriterID" value="@item.MezuniyetSureciOgrenimTipKriterID" class="hide">
                                <input type="text" name="OgrenimTipID" value="@item.OgrenimTipID" class="hide" />
                                <input type="text" name="OgrenimTipKod" value="@item.OgrenimTipKod" class="hide" />
                                @item.OgrenimTipAdi
                            </div>
                        <td>
                            <div class="form-group">
                                <select class="form-control" name="AktifDonemMaxKriteri">
                                    @for (int i = 1; i <= 20; i++)
                                    {
                                        <option value="@i" @((i == item.AktifDonemMaxKriteri).ToSelected())>@(i+". Dönem")</option>

                                    }
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="form-group"> 
                                <input type="text" class="form-control" name="AktifDonemDersKodKriteri" value="@item.AktifDonemDersKodKriteri" />
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <select class="form-control" name="AktifDonemEtikNotKriteri">
                                    <option value=""></option>
                                    @foreach (var itemNot in HarfNotuHelper.NotDegerleri)
                                    {
                                        <option @((itemNot == item.AktifDonemEtikNotKriteri).ToSelected())>@itemNot</option>

                                    }
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <select class="form-control" name="AktifDonemSeminerNotKriteri">
                                    <option value=""></option>
                                    @foreach (var itemNot in HarfNotuHelper.NotDegerleri)
                                    {
                                        <option @((itemNot == item.AktifDonemSeminerNotKriteri).ToSelected())>@itemNot</option>

                                    }
                                </select>
                            </div>
                        </td> 
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="AktifDonemToplamKrediKriteri" value="@item.AktifDonemToplamKrediKriteri">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="AktifDonemAgnoKriteri" value="@item.AktifDonemAgnoKriteri">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="AktifDonemAktsKriteri" value="@item.AktifDonemAktsKriteri">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="TekKaynakOraniKriteri" value="@item.TekKaynakOrani">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="ToplamKaynakOraniKriteri" value="@item.ToplamKaynakOrani">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="SinavKacGunSonraAlabilir" value="@item.SinavKacGunSonraAlabilir">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="SinavEnGecKacGunSonraAlabilir" value="@item.SinavEnGecKacGunSonraAlabilir">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="SinavUzatmaOgrenciTaahhutMaxGun" value="@item.SinavUzatmaOgrenciTaahhutMaxGun">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="SinavUzatmaSinavAlmaSuresiMaxGun" value="@item.SinavUzatmaSinavAlmaSuresiMaxGun">
                            </div>
                        </td>
                        <td>
                            <div class="form-group">
                                <input type="text" class="form-control" name="TezTeslimSuresiGun" value="@item.TezTeslimSuresiGun">
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



