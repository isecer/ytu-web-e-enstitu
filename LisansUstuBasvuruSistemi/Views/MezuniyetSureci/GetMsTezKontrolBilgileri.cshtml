@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  LisansUstuBasvuruSistemi.Utilities.Dtos.MezuniyetSureciTezKontrolDto
@{
    Layout = null;
    var tableUniqueId = Guid.NewGuid();
}


<div class="panel panel-info" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-list-alt"></i>Mezuniyet Süreci Tez Şablon Kontrol Verileri
        </h3>
        <ul class="panel-controls">
            <li><span class="label label-primary label-form"><a style="width:54px;color:white;" href="javascript:void(0)" onclick="ExportToExcel('@tableUniqueId', '@Model.DonemAdi Mezuniyet Süreci Tez Şablon Kontrol Verileri')"><i class="fa fa-download fa-lg"></i> Excel olarak indir</a></span></li>
        </ul>
    </div>
    <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
        <div class="panel-body" style="margin: 0px; padding: 0px;">
            <div class="col-md-12" style="text-align: left; height: 345px; overflow: auto;">
                <table class="table table-hover" id="@tableUniqueId">
                    @if (Model.AktifMezuniyetSureciTezKontrolBilgiDtos.Any())
                    {
                        <tr class="success">
                            <td colspan="9" style="text-align:center;">
                                Aktif Tez Şablon Kontrol Yetkilileri Tez Şablon Kontrol Bilgileri
                            </td>
                        </tr>
                        <tr>
                            <th width="30"></th>
                            <th width="30"></th>
                            <th></th>
                            <th class="info" colspan="3" style="text-align:center;">@Model.DonemAdi Döneminde Yapılan</th>
                            <th class="warning" colspan="3" style="text-align:center;">Tüm Süreçlerde Yapılan</th>
                        </tr>
                        <tr style="font-size:7pt;">
                            <th></th>
                            <th></th>
                            <th>Kontrol<br />Sorumlusu</th>
                            <th class="info" style="text-align:center;">Sorumluya Atanan<br />Toplam Tez</th>
                            <th class="info" style="text-align:center;">Sorumluya Atanan<br />Tez Kontrolü</th>
                            <th class="info" style="text-align:center;">Sorumlu Tüm Tez <br />Kontrolleri</th>
                            <th class="warning" style="text-align:center;">Sorumluya Atanan<br />Toplam Tez</th>
                            <th class="warning" style="text-align:center;">Sorumluya Atanan<br />Tez Kontrolü</th>
                            <th class="warning" style="text-align:center;">Sorumlu Tüm Tez <br />Kontrolleri</th>
                        </tr>

                        int rowIndex = 0;
                        foreach (var item in Model.AktifMezuniyetSureciTezKontrolBilgiDtos)
                        {
                            rowIndex++;
                            <tr>

                                <td>@rowIndex</td>
                                <td><img src="@item.ResimAdi.ToKullaniciResim()" style="width:30px;height:30px;cursor:pointer;padding:1px;" onclick="DetayGor('@item.UserKey')" class="img-thumbnail"></td>
                                <td>@item.AdSoyad</td>
                                <td style="text-align:center;">@item.SurecToplamAtanan</td>
                                <td style="text-align:center;">@item.SurecToplamKendiOnayi</td>
                                <td style="text-align:center;">@item.SurecToplamOnay</td>
                                <td class="warning" style="text-align:center;">@item.GenelToplamAtanan</td>
                                <td class="warning" style="text-align:center;">@item.GenelToplamKendiOnayi</td>
                                <td class="warning" style="text-align:center;">@item.GenelToplamOnay</td>
                            </tr>

                        }
                    }
                    @if (Model.PasifMezuniyetSureciTezKontrolBilgiDtos.Any())
                    {
                        <tr class="success">
                            <td colspan="9" style="text-align:center;">
                                Aktif Tez Şablon Kontrol Yetkilileri Haricindeki Tez Şablon Kontrol Bilgileri
                            </td>
                        </tr>
                        <tr>
                            <th width="30"></th>
                            <th width="30"></th>
                            <th></th>
                            <th class="info" colspan="3" style="text-align:center;">@Model.DonemAdi Döneminde Yapılan</th>
                            <th class="warning" colspan="3" style="text-align:center;">Tüm Süreçlerde Yapılan</th>
                        </tr>
                        <tr style="font-size:7pt;">
                            <th></th>
                            <th></th>
                            <th>Kontrol<br />Sorumlusu</th>
                            <th class="info" style="text-align:center;">Sorumluya Atanan<br />Toplam Tez</th>
                            <th class="info" style="text-align:center;">Sorumluya Atanan<br />Tez Kontrolü</th>
                            <th class="info" style="text-align:center;">Sorumlu Tüm Tez <br />Kontrolleri</th>
                            <th class="warning" style="text-align:center;">Sorumluya Atanan<br />Toplam Tez</th>
                            <th class="warning" style="text-align:center;">Sorumluya Atanan<br />Tez Kontrolü</th>
                            <th class="warning" style="text-align:center;">Sorumlu Tüm Tez <br />Kontrolleri</th>
                        </tr>
                        var rowIndex = 0;
                        foreach (var item in Model.PasifMezuniyetSureciTezKontrolBilgiDtos)
                        {
                            rowIndex++;
                            <tr>

                                <td>@rowIndex</td>
                                <td><img src="@item.ResimAdi.ToKullaniciResim()" style="width:30px;height:30px;cursor:pointer;padding:1px;" onclick="DetayGor('@item.UserKey')" class="img-thumbnail"></td>
                                <td>@item.AdSoyad</td>
                                <td style="text-align:center;">@item.SurecToplamAtanan</td>
                                <td style="text-align:center;">@item.SurecToplamKendiOnayi</td>
                                <td style="text-align:center;">@item.SurecToplamOnay</td>
                                <td class="warning" style="text-align:center;">@item.GenelToplamAtanan</td>
                                <td class="warning" style="text-align:center;">@item.GenelToplamKendiOnayi</td>
                                <td class="warning" style="text-align:center;">@item.GenelToplamOnay</td>
                            </tr>

                        }
                    }
                    @if (!Model.PasifMezuniyetSureciTezKontrolBilgiDtos.Any() && !Model.AktifMezuniyetSureciTezKontrolBilgiDtos.Any())
                    {
                        <tr>
                            <td style="text-align:center;height:250px;">
                                <div class="tasks">
                                    <div class="task-item task-danger" style="margin-bottom: 0px; cursor: auto;">
                                        <div class="task-text" style="padding-bottom: 0px; font-size: 8pt;">
                                            Gösterilecek Tez Şablon Kontrol Verileri Bulunamadı.
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </table>

            </div>
        </div>
    </div>
</div>