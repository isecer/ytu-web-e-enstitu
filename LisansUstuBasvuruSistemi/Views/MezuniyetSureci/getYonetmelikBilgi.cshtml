@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums 
@model IEnumerable<FrMezuniyetYonetmelikler>
@{
    Layout = null;
}

<div class="panel panel-info" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-list-alt"></i>Mezuniyet Süreci Yönetmelik Bilgisi
        </h3>
    </div>
    <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
        <div class="panel-body" style="margin: 0px; padding: 0px;">
            <div class="col-md-12" style="text-align: left; height: 345px; overflow: auto;">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th width="75"></th>          
                            <th>Tarih Kriteri</th>
                            <th>Öğretim Yılı</th>
                            <th>Öğretim Yılı B</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 0;
                            foreach (var item in Model)
                            {
                                rowIndex++;
                                <tr class="delrw_@item.MezuniyetYonetmelikID">
                                    <td>
                                        <table>
                                            <tr>
                                                <td style="width: 30px;">@rowIndex</td>
                                                <td>
                                                    <ul class="panel-controls">
                                                        <li id="iShow-Yontm-@item.MezuniyetYonetmelikID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail(@item.MezuniyetYonetmelikID,'Yontm-')">
                                                            <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                        </li>
                                                    </ul>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>                       
                                    <td>@item.TarihKriterAdi</td>
                                    <td>@item.BaslangicYil / @item.BitisYil @item.DonemAdi</td>
                                    <td>@(item.TarihKriterID == TarihKriterSecimEnum.SecilenTarihAraligi ? (item.BaslangicYilB + " / " + item.BitisYilB + " " + item.DonemAdiB) : "")</td>



                                </tr>
                                <tr class="cls-Yontm-@item.MezuniyetYonetmelikID delrw_@item.MezuniyetYonetmelikID" style="display:none;">
                                    <td id="cls-Yontm-@item.MezuniyetYonetmelikID" colspan="4">
                                        <div class="panel panel-info" style="margin:0px;">
                                            
                                            <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                    <div class="col-md-12" style="text-align: left; ">
                                                        <table class="table" style="font-size:9pt;margin:0px;">
                                                          
                                                            <tr>
                                                                <td style="text-align:right;" width="230">Tarih Kriteri</td>
                                                                <td width="10">:</td>
                                                                <td>
                                                                    @item.TarihKriterAdi
                                                                </td>
                                                            </tr>
                                                            <tr>
                                                                <td style="text-align:right;">Öğretim Yılı</td>
                                                                <td>:</td>
                                                                <td style="font-weight:bold;"><span>@item.BaslangicYil / @item.BitisYil @item.DonemAdi</span></td>
                                                            </tr>
                                                            @if (item.TarihKriterID == TarihKriterSecimEnum.SecilenTarihAraligi)
                                                            {
                                                                <tr>
                                                                    <td style="text-align:right;">Öğretim Yılı Bitiş</td>
                                                                    <td>:</td>
                                                                    <td style="font-weight:bold;"><span>@item.BaslangicYilB / @item.BitisYilB @item.DonemAdiB</span></td>
                                                                </tr>
                                                            }

                                                            <tr>
                                                                <td colspan="3">
                                                                    @{
                                                                        var ots = item.MezuniyetYonetmelikData.Select(s => new { s.OgrenimTipKod, s.OgrenimTipAdi }).Distinct();
                                                                        foreach (var Otip in ots)
                                                                        {
                                                                            var modelOt = item.MezuniyetYonetmelikData.Where(p => p.OgrenimTipKod == Otip.OgrenimTipKod).ToList();
                                                                            <div class="form-group">
                                                                                <div class="col-md-12 col-xs-12" id="_otBilgi">
                                                                                    <div class="panel panel-default" style="padding: 0px; margin: 0px;">
                                                                                        <div class="panel-heading padding-0">
                                                                                            <h4 class="panel-title"><i class="fa fa-pencil"></i> @Otip.OgrenimTipAdi Öğrenim tipi için belirlenen kriterler</h4>
                                                                                        </div>
                                                                                        <div class="panel-body padding-0">

                                                                                            <table class="table table-hover" style="width:100%;table-layout:fixed;">
                                                                                                <thead>
                                                                                                    <tr>
                                                                                                        <th>Yayın Türü</th>
                                                                                                        <th width="105">Geçerli</th>
                                                                                                        <th width="105">Zorunlu</th>
                                                                                                        <th width="105">Grp.Kodu</th>
                                                                                                        <th width="105">Ve/Veya</th>
                                                                                                    </tr>
                                                                                                </thead>
                                                                                                <tbody id="Rw_tbody">
                                                                                                    @foreach (var item2 in modelOt)
                                                                                                    {

                                                                                                        <tr class="rw_bst">
                                                                                                            <td>
                                                                                                                @item2.MezuniyetYayinTurAdi
                                                                                                            <td>
                                                                                                                @(item2.IsGecerli ? "Geçerli" : "Geçerli Değil")
                                                                                                            </td>
                                                                                                            <td>
                                                                                                                @(item2.IsZorunlu ? "Zorunlu" : "Zorunlu Değil")
                                                                                                            </td>
                                                                                                            <td>
                                                                                                                @item2.GrupKodu
                                                                                                            </td>
                                                                                                            <td>
                                                                                                                @(item2.IsVeOrVeya.HasValue ? (item2.IsVeOrVeya.Value ? "Ve" : "Veya") : "")
                                                                                                            </td>
                                                                                                        </tr>
                                                                                                    }
                                                                                                </tbody>
                                                                                            </table>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        }
                                                                    }
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                            }
                        }

                    </tbody>
                </table>

            </div>
        </div>
    </div>
</div>