@model Exception
@using LisansUstuBasvuruSistemi.Models
@using BiskaUtil;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    using (var db = new LisansustuBasvuruSistemiEntities())
    {
        var ExceltionMessage = Model.ToExceptionMessage();
        bool SaveError = true;
        if (ExceltionMessage.Contains("1- The controller for path"))
        {
            var SplitMesssages = ExceltionMessage.Split('\'');
            if (SplitMesssages.Count() >= 3)
            {
                var Path = SplitMesssages[1];
                if (Path.Contains("/tr"))
                {
                    Path = Path.Replace("/tr", "");
                    SaveError = false;
                    <script>
                        window.location.href = '@Path';
                    </script>
                }
            }
        }
        if (SaveError)
        {
            db.SistemBilgilendirmes.Add(new SistemBilgilendirme
            {
                BilgiTipi = BilgiTipi.Hata,
                Message = Model.ToExceptionMessage(),
                IslemYapanID = (UserIdentity.Current.IsAuthenticated ? UserIdentity.Current.Id : (int?)null),
                IslemYapanIP = UserIdentity.Ip,
                IslemTarihi = DateTime.Now,
                StackTrace = Model.ToExceptionStackTrace()
            });
            db.SaveChanges();
        }
    }
}

<div class="error-container">
    <div class="error-code">Hata! <div class="icon-preview"><i class="fa fa-frown-o"></i></div></div>
    <div class="error-text">İşlem Yapılırken Bir Hata Oluştu.</div>
    <div class="error-subtext">
        Hata: @Model.ToExceptionMessage()
    </div>
    <div class="error-subtext">Bu hata sistem tarafından loglandı.</div>
    @*<div class="error-code">500</div>
        <div class="error-text">Internal server error</div>
        <div class="error-subtext">The server encountered an internal error or misconfiguration and was unable to complete your request.</div>*@
</div>
