@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model  FmTalepler
@{
    ViewBag.Title = "Index";
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var kYetki = RoleNames.SrTalepDuzelt.InRoleCurrent();
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Salon Rezervasyonu Gelen Talepler</h3>
                    <ul class="panel-controls">
                        @foreach (var item in indexModel.ListB)
                        {
                            <li style="color:@item.Color"> <i class="@item.ClassName" style="font-size:11pt;"></i>@item.Key:<b>@item.Toplam</b></li>
                        }
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75">
                                </th>
                                <th class="sirala" width="230" field="TalepYapan">Ad Soyad</th>
                                <th class="sirala" width="230" field="TalepTipAdi">Talep Tipi</th>
                                <th class="sirala" field="SalonAdi">Salon Bilgisi</th>
                                <th class="sirala" field="DurumListeAdi" width="130">Durum</th>
                            </tr>

                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th>

                                </th>
                                <th>
                                    <input name="Aciklama" type="text" value="@Model.Aciklama" class="form-control" />
                                </th>
                                <th>@Html.DropDownList("SRTalepTipID", null, new { @class = "form-control" })</th>
                                <th>@Html.DropDownList("SRSalonID", null, new { @class = "form-control" })</th>
                                @*<th></th>*@
                                <th>@Html.DropDownList("SRDurumID", null, new { @class = "form-control" })</th>

                            </tr>
                            @if (Model.RowCount > 0)
                            {

                                int rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.data)
                                {
                                    var starih = Convert.ToDateTime(item.Tarih.ToShortDateString() + " " + item.BasSaat.ToString());
                                    var fWeight = starih > DateTime.Now ? "font-weight:bold;" : "";
                                    rowIndex++;
                                    <tr class="mColor_@item.SRTalepID" style="@fWeight color:@item.Color">
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.SRTalepID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.SRTalepID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            <table class="table" style="padding:0px;margin:0px;border:none;table-layout:fixed;">
                                                <tr>
                                                    <td style="margin:0px;border:none;" width="40"> <img src="@item.ResimAdi.ToKullaniciResim()" style="width:40px;height:40px;cursor:pointer;" onclick="DetayGor('@item.UserKey')" class="img-circle img-thumbnail"></td>
                                                    <td style="margin:0px;border:none;">
                                                        @item.TalepYapan
                                                        <br />@item.OgrenciNo
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            @item.TalepTipAdi <br />
                                            @item.Tarih.ToFormatDate() @item.HaftaGunAdi @item.BasSaat.ToFormatTime() - @item.BitSaat.ToFormatTime()

                                        </td>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td>@(item.IsOnline ? "Online" : item.SalonAdi)</td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            <table style="width:100%;table-layout:fixed;">
                                                <tr>
                                                    <td style="width:30px;">
                                                        @if (!item.ClassName.IsNullOrWhiteSpace())
                                                        {
                                                            <span class="tooltips mColor_@item.SRTalepID" data-style="blue" data-original-title="@item.SRDurumAciklamasi">
                                                                <i id="bticon_@item.SRTalepID" class="@item.ClassName" style="font-size:17pt;@fWeight"></i>
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <i class="@item.ClassName mColor_@item.SRTalepID" style="font-size:17pt;@fWeight color:@item.Color"></i>
                                                        }
                                                    </td>
                                                    <td>
                                                        <span id="btCapt_@item.SRTalepID">@Html.Raw(item.DurumListeAdi)</span>
                                                    </td>
                                                </tr>

                                            </table>

                                        </td>
                                    </tr>
                                    <tr class="cls-@item.SRTalepID" style="display:none">
                                        <td id="cls-@item.SRTalepID" colspan="5" style="padding: 1px 1px 2px 75px;"></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
@if (kYetki)
{
    <script>
        function RezervasyonDurumKayit(id) {
            var ibtID = $('#SRDurumID_' + id).val();
            var ibTipAciklama = $('#SRDurumAciklamasi_' + id).val();
            var _panel = $('#SRDetay_' + id);
            PanelRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("RezervasyonDurumKayit", "SrGelenTalepler")',
                data: {
                    'id': id,
                    'SRDurumID': ibtID,
                    'SRDurumAciklamasi': ibTipAciklama
                },
                success: function (result) { 
                    $(".mColor_" + id).each(function (inx, itmx) {
                        $(itmx).attr("style", "color:" + result.Color + (result.IsFontWeightBold?";font-weight:bold;":""));
                    });
                    $("#btCapt_" + id).html(result.IslemTipListeAdi);
                    $("#bticon_" + id).attr("Class", "");
                    $("#bticon_" + id).addClass(result.ClassName);
                    if (result.IsSuccess)
                        GetDetail(id, false, null);
                    if (result.messageView)
                        swal.fire({
                            html: result.messageView,
                            icon: (result.IsSuccess ? "success" : "error"),
                            type: (result.IsSuccess ? "success" : "error"),
                            confirmButtonText: 'tamam',
                            padding: '2em'
                        });
                    PanelRefresh(_panel, true);
                },
                error: function (err) {
                    alert(err.responseText);
                    PanelRefresh(_panel, true);

                }
            });
        }
    </script>
}
<script type="text/javascript">

    function ShowDetail(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
        if (unTogled) GetDetail(id);
    }
    function GetDetail(id) {

        var _panel = $('#SRDetay_' + id);
        PanelRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("GetDetail", "SrGelenTalepler")',
            data: { id: id  },
            success: function (result) {
                $('#cls-' + id).html(result);
                PanelRefresh(_panel, true);
            },
            error: function (err) {
                alert(err.responseText);
                PanelRefresh(_panel, true);
            }
        });
    }
</script>
