@using BiskaUtil
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  FmUnvanlar
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Ünvan Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="70">Sıra No</th>
                                <th class="sirala" field="UnvanAdi">Ünvan Adı</th>
                                <th class="sirala" width="240" field="YetkiGrupID">Yetki Grubu</th>
                                <th width="70" class="sirala" field="IsAkademik">U.Türü</th>
                                <th width="70" class="sirala" field="IsAktif">Durum</th>
                                <th width="50">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    <input name="UnvanAdi" type="text" value="@Model.UnvanAdi" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("YetkiGrupID", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    @Html.DropDownList("IsAkademik", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>

                                </th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                foreach (var item in Model.data.Select((s, inx) => new { data = s, Index = inx }))
                                {
                                    <tr>
                                        <td>@(item.Index + 1)</td>
                                        <td id="tdMad_@item.data.UnvanID">
                                            @item.data.UnvanAdi
                                        </td>
                                        <td id="tddu_@item.data.UnvanID">
                                            @if (item.data.YetkiGrupID.HasValue)
                                            {
                                                <table style="width:100%;">
                                                    <tr>
                                                        <td>@item.data.YetkiGrupAdi </td>
                                                        @if (UserIdentity.Current.IsAdmin)
                                                        {
                                                            <td width="30">
                                                                <a href="javascript:void(0);" onclick="UpdateUnvanYetkiGrubu('@item.data.UnvanID','@item.data.UnvanAdi','@item.data.YetkiGrupID','@item.data.YetkiGrupAdi','@item.data.UnvanUserCount')"><i class="fa fa-users" style="font-size:12pt;" title="@item.data.UnvanAdi ünvanı olan tüm kullanıcıların yetkisini @item.data.YetkiGrupAdi yetki grubunu olarak güncelle"></i></a>
                                                            </td>
                                                        }
                                                    </tr>
                                                </table>
                                            }
                                        </td>
                                        <td>
                                            @(item.data.IsAkademik?"Akademik":"İdari")
                                        </td>
                                        <td id="tdIa_@item.data.UnvanID" style="text-align:center;">
                                            <span class="label label-@(item.data.IsAktif ? "success" : "danger")">@item.data.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit")"><i class="fa fa-plus tooltips" title="Yeni"></i></a>
                                            <a href="@Url.Action("Kayit", "Unvanlar", new { id = item.data.UnvanID })"><i class="fa fa-edit  tooltips" title="Düzelt"></i></a>
                                            <a href="javascript:void(0);" onclick="SilmeOnay(this,@item.data.UnvanID)"><i class="fa fa-trash-o tooltips" title="Sil"></i></a>
                                        </td>
                                    </tr>


                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function SilmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Ünvan Adı: " + gMesaj + " <br/> Seçilen Ünvanı Silmek İstiyor Musunuz?",
            title: "Ünvan Silme İşlemi",
            buttons: {
                success: {
                    label: "Ünvan Sil",
                    className: "btn-danger",
                    callback: function () {
                        Sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
     function Sil(sndr, id) {
     $.ajax({
         url: '@Url.Action("Sil", "Unvanlar")',
         data: { id: id },
         success: function (result) {
             toastr[result.success ? "success" : "error"](result.message, "Ünvan Silme İşlemi")
             if (result.success) {
                 $(sndr).closest("tr").remove();
                 // $(".cls-" + id).remove();
             }

         },
         error: function (err) {
             alert(err.responseText);
         }
     });
 }

    function UpdateUnvanYetkiGrubu(unvanId,unvanAdi,yetkiGrupId,YetkiGrupAdi,yetkiliUserCount) {

        Swal.fire({
            html: "<table style='table-layout:fixed;width:100%;'><tr><td style='font-size:11pt;text-align:center;color:maroon;'>" + unvanAdi + " ünvanı olan " + yetkiliUserCount + " kullanıcı hesabı yetkisi '" + YetkiGrupAdi +"' yetki grubunu olarak güncellemek istiyor musunuz?</td></tr></table>",
            type: 'warning',
            icon: "question",
            showCancelButton: true,
            confirmButtonText: 'Yetki Gruplarını Güncelle',
            confirmButtonColor: "maroon",
            cancelButtonText: 'Vazgeç',
            showLoaderOnConfirm: true,
            backdrop: true,
            padding: '2em',
            backdrop: true,
            allowOutsideClick: false,
            preConfirm: function () {
                $('.swal2-cancel').first().text("Güncelleniyor...");
                return new Promise(function (resolve) {
                    $.ajax({
                        url: '@Url.Action("UpdateUnvanYetkiGrubu", "Unvanlar")',
                        data: { unvanId, yetkiGrupId },
                        success: function (result) {
                            swal.fire({
                                html: result.message,
                                icon: (result.IsSuccess ? "success" : "error"),
                                type: (result.IsSuccess ? "success" : "error"),
                                confirmButtonText: 'tamam',
                                padding: '2em'
                            });
                        },
                        error: function (err) {
                            alert(err.responseText);
                        }
                    });
                });
            }
        });

    }
</script>
