@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums 
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  FmOzelTanimlar
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <table style="table-layout:fixed;width:100%;">
                        <tr>
                            <td><h3 class="panel-title"><i class="fa fa-list-alt"></i> Resmi Tatil Listesi</h3></td> 
                            <td width="40px;">
                                <ul class="panel-controls">
                                    <li>
                                        <span class="label label-info label-form" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Kayit")'"><i class="fa fa-plus" aria-hidden="true"></i> Yeni Resmi Tatil Bilgisi Ekle</span>
                                     </li>
                                </ul>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th> 
                                <th class="sirala" field="SROzelTanimTipAdi" width="120">Tip</th>
                                <th class="sirala" field="TTarih" width="220">Tarih</th>
                                <th class="sirala" field="IslemTarihi">Açıklama</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="40"></th>
                            </tr>

                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th>
                                   
                                </th> 
                                <th>
                                    @Html.DropDownList("SROzelTanimTipID", null, new { @class = "form-control" })
                                </th>
                                <th></th>
                                <th>
                                    <input name="Aciklama" type="text" value="@Model.Aciklama" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {

                                int rowIndex = Model.StartRowIndex; 
                                foreach (var item in Model.FrOzelTanimlars)
                                {
                                    rowIndex++; 
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.SROzelTanimID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.SROzelTanimID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td> 
                                        <td>
                                            @item.SROzelTanimTipAdi
                                        </td>
                                        <td>
                                            @if (item.SROzelTanimTipID == SrOzelTanimTipiEnum.ResmiTatilSabit)
                                            {
                                                @(item.Gun + " " + item.AyAdi)
                                            }
                                            else if (item.SROzelTanimTipID == SrOzelTanimTipiEnum.ResmiTatilDegisen)
                                            {
                                                <span>@item.BasTarih.ToFormatDate() - @item.BitTarih.ToFormatDate() </span>
                                            }
                                            
                                        </td>
                                        <td>
                                            @if (item.TalepTipAdi.IsNullOrWhiteSpace() == false)
                                            {
                                                <span style="color:brown;">@item.TalepTipAdi :</span>
                                                <br />
                                            }
                                            @item.Aciklama
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "SrOzelTanimlar" , new { id=item.SROzelTanimID })"><i style="font-size:11pt;" class="fa fa-edit tooltips" title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="GetDetail('@item.SROzelTanimID',true,this)"><i style="font-size:11pt;" class="glyphicon glyphicon-trash tooltips" title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.SROzelTanimID" style="display:none">
                                        <td id="cls-@item.SROzelTanimID" colspan="6" style="padding: 1px 1px 2px 75px;"></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Html.Raw(Model.ToPagerString().ToString())
                </div>
            </div>
        </div>
    }
</div>

<script type="text/javascript">

    function ShowDetail(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
        if (unTogled) GetDetail(id, false);
    }
    function GetDetail(id, Isdelete, sndr) {
        var _panel = $('#dvDetay_' + id);
        PanelRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("GetDetail", "SrOzelTanimlar")',
            data: { id: id },
            success: function (result) {
                if (Isdelete != true) {
                    $('#cls-' + id).html(result);
                    PanelRefresh(_panel, true);
                }
                else {
                    PanelRefresh(_panel, true);
                    var btbx = bootbox.dialog({
                        message: result + " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Seçili Özel tanımını silmek istiyor musunuz?</td></tr></table>",
                        title: "Özel Tanım silme işlemi",
                        buttons: {
                            success: {
                                label: 'Özel Tanımı Sil',
                                className: "btn-danger",
                                callback: function () {
                                    Sil(sndr, id);
                                }
                            },
                            danger: {
                                label: 'Vazgeç',
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });
                    $(btbx).find('.modal-dialog').addClass('modal-lg');

                }
                onload();
            },
            error: function (err) {
                alert(err.responseText);
                PanelRefresh(_panel, true);
            }
        });
    }
    function Sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "SrOzelTanimlar")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Özel Tanım Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }
            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script> 
