@using LisansUstuBasvuruSistemi.Models @using LisansUstuBasvuruSistemi.Models.FilterModel
@using BiskaUtil
@model  fmOzelTanimlar
@{
    ViewBag.Title = "Index";
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    var haftaGunleri = (List<HaftaGunleri>)ViewBag.HaftaGunleri;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <table style="table-layout:fixed;width:100%;">
                        <tr>
                            <td><h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp; Özel Tanımlar Listesi</h3></td>
                            <td width="220px;">
                                @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;", onchange = "$(this).parents('form').first().submit();" })
                            </td>
                            <td width="40px;">
                                <ul class="panel-controls">    
                                    <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>          
                                </ul>
                            </td>
                        </tr>
                    </table>    
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                @*<th class="sirala" field="EnstituAdi" width="180">Enstitü Adı</th>*@
                                <th class="sirala" field="SROzelTanimTipAdi" width="120">Tip</th>
                                <th class="sirala" field="TTarih" width="220">Tarih</th>
                                <th class="sirala" field="IslemTarihi">Açıklama</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="40"></th>
                            </tr>

                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th>
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                                @*<th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control" })
                                </th>*@
                                <th>
                                    @Html.DropDownList("SROzelTanimTipID", null, new { @class = "form-control" })
                                </th>
                                <th></th>
                                <th>
                                    <input name="Aciklama" type="text" value="@Model.Aciklama" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {

                                int RowIndex = Model.StartRowIndex; string trCls = "odd";
                                foreach (var item in Model.data)
                                {
                                    RowIndex++;
                                    trCls = RowIndex % 2 == 1 ? "" : "even";
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.SROzelTanimID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="showDetail('@item.SROzelTanimID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        @*<td>
                                            @item.EnstituAdi
                                        </td>*@
                                        <td>
                                            @item.SROzelTanimTipAdi
                                        </td>
                                        <td>
                                            @if (item.SROzelTanimTipID == SROzelTanimTip.ResmiTatilSabit)
                                            {
                                                @(item.Gun + " " + item.AyAdi)
                                            }
                                            else if (item.SROzelTanimTipID == SROzelTanimTip.ResmiTatilDegisen)
                                            {
                                                <span>@item.BasTarih.Value.ToString("dd.MM.yyyy") - @item.BitTarih.Value.ToString("dd.MM.yyyy") </span>
                                            }
                                            else if (item.SROzelTanimTipID == SROzelTanimTip.Rezervasyon)
                                            {
                                                var dofW = item.Tarih.Value.DayOfWeek.ToString("d").ToInt().Value;
                                                var haftaGunu = haftaGunleri.Where(p => p.HaftaGunID == dofW).First();

                                                <span>
                                                    @item.SalonAdi   <br />
                                                    @item.Tarih.ToString("dd.MM.yyyy") @haftaGunu.HaftaGunAdi
                                                    <br />
                                                    <span>@string.Join(", ", item.SROzelTanimSaatlers.Select(s => string.Format("{0:hh\\:mm}", s.BasSaat) + "-" + string.Format("{0:hh\\:mm}", s.BitSaat)).ToList())</span>
                                                </span>
                                            }
                                            else if (item.SROzelTanimTipID == SROzelTanimTip.Rezerve)
                                            {
                                                @item.SalonAdi <br />
                                                <span>@item.BasTarih.Value.ToString("dd.MM.yyyy") - @item.BitTarih.Value.ToString("dd.MM.yyyy") Tarih Arası</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.TalepTipAdi.IsNullOrWhiteSpace() == false)
                                            {
                                                <span style="color:brown;">@item.TalepTipAdi :</span>
                                                <br />
                                            }
                                            @item.Aciklama
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "SROzelTanimlar" , new { id=item.SROzelTanimID })"><i style="font-size:11pt;" class="fa fa-edit tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="getDetail('@item.SROzelTanimID',true,this)"><i style="font-size:11pt;" class="glyphicon glyphicon-trash tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.SROzelTanimID" style="display:none">
                                        <td id="cls-@item.SROzelTanimID" colspan="8" style="padding: 1px 1px 2px 75px;"></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Html.Raw(Model.ToPagerString().ToString())
                </div>
            </div>
        </div>
    }
</div>

<script type="text/javascript">

    function showDetail(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
        if (unTogled) getDetail(id, false);
    }
    function getDetail(id, Isdelete, sndr) {
        var _panel = $('#dvDetay_' + id);
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("getDetail", "SROzelTanimlar")',
            data: { id: id },
            success: function (result) {
                if (Isdelete != true) {
                    $('#cls-' + id).html(result);
                    _pRefresh(_panel, true);
                }
                else {
                    _pRefresh(_panel, true);
                    var btbx = bootbox.dialog({
                        message: result + " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Seçili Özel tanımını silmek istiyor musunuz?</td></tr></table>",
                        title: "Özel Tanım silme işlemi",
                        buttons: {
                            success: {
                                label: 'Özel Tanımı Sil',
                                className: "btn-danger",
                                callback: function () {
                                    sil(sndr, id);
                                }
                            },
                            danger: {
                                label: 'Vazgeç',
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });
                    $(btbx).find('.modal-dialog').addClass('modal-lg');

                }
                onload();
            },
            error: function (err) {
                alert(err.responseText);
                _pRefresh(_panel, true);
            }
        });     
    }     
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "SROzelTanimlar")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Özel Tanım Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }
            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>

<script type="text/javascript">
    $(function () {
        jQuery('.popovers').popover();
    });
</script>
