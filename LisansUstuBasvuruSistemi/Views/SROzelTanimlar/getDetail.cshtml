@using LisansUstuBasvuruSistemi.Models 
@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums 
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model FrOzelTanimlar
@{ 
    Layout = null;
}

<div class="panel panel-success" id="dvDetay_@Model.SROzelTanimID">
    <div class="panel-heading  padding-0">
        <div class="portlet-title">
            <h3 class="panel-title"><i class="fa fa-file-text"></i>&nbsp;Detay</h3>
        </div>
    </div>
    <div class="panel-body" style="padding: 0px;">
        <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">
            <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                <div class="panel-body" style="margin: 0px; padding: 0px;">
                    <div class="panel-body form-group-separated">
                        
                        <div class="form-group">
                            <label class="col-md-3 control-label">Özel Tanım Tipi</label>
                            <div class="col-md-9">@Model.SROzelTanimTipAdi</div>
                        </div>
                        @if (Model.TalepTipAdi.IsNullOrWhiteSpace() == false)
                        {
                            <div class="form-group">
                                <label class="col-md-3 control-label">Talep Tipi</label>
                                <div class="col-md-9">@Model.TalepTipAdi</div>
                            </div>
                        }
                        <div class="form-group">
                            <label class="col-md-3 control-label">Rezervasyon Bilgi</label>
                            <div class="col-md-9">
                                @if (Model.SROzelTanimTipID == SrOzelTanimTipiEnum.ResmiTatilSabit)
                                {
                                    @(Model.Gun + " " + Model.AyAdi)
                                }
                                else if (Model.SROzelTanimTipID == SrOzelTanimTipiEnum.ResmiTatilDegisen)
                                {
                                    <span>@Model.BasTarih.Value.ToFormatDate() - @Model.BitTarih.Value.ToFormatDate() </span>
                                } 
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-md-3 control-label">Açıklama</label>
                            <div class="col-md-9">
                                @Model.Aciklama
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-md-3 control-label">Durum</label>
                            <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">
                                <span class="label label-@(Model.IsAktif ? "success" : "danger")">@(Model.IsAktif ? "Aktif" : "Pasif")</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-md-3 control-label">İşlem Yapan</label>
                            <div class="col-md-9">@Model.IslemYapan [@Model.IslemTarihi.ToFormatDateAndTime()]</div>
                        </div> 
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

