@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using BiskaUtil
@model  FmOgrenimTipleri
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp;Öğrenim Tip Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-info label-form" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Kayit")'"><i class="fa fa-plus" aria-hidden="true"></i> Yeni Öğrenim Tipi Ekle</span></li>

                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                     </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="EnstituAd" width="140">Enstitü Adı</th>
                                <th class="sirala" field="OgrenimTipKod" width="60">Ö.T.Kod</th>
                                <th class="sirala" field="OgrenimTipAd">Öğrenim Tip Adı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="50">
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    <input name="OgrenimTipKod" type="text" value="@Model.OgrenimTipKod" class="form-control" />
                                </th>
                                <th>
                                    <input name="OgrenimTipAd" type="text" value="@Model.OgrenimTipAd" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.data)
                                {
                                    rowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.OgrenimTipID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.OgrenimTipID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>@item.EnstituAd</td>
                                        <td>@item.OgrenimTipKod</td>
                                        <td>@item.OgrenimTipAdi</td>

                                        <td id="tdIa_@item.OgrenimTipID" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit")"><i class="fa fa-plus tooltips" data-style="blue" data-original-title="Yeni"></i></a>
                                            <a href="@Url.Action("Kayit", "OgrenimTipleri", new { id = item.OgrenimTipID })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.OgrenimTipID')"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>

                                        </td>
                                    </tr>
                                    <tr class="cls-@item.OgrenimTipID" style="display:none">
                                        <td id="cls-@item.OgrenimTipID" colspan="7" style="padding: 1px 1px 2px 75px;">

                                            <div class="panel panel-default">

                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">

                                                        <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                <div class="panel-body form-group-separated">
                                                                    <div class="form-group">
                                                                        <label class="col-md-5 control-label">Enstitü Adı</label>
                                                                        <div class="col-md-7">@item.EnstituAd</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-5 control-label">Öğrenim Tip Kod</label>
                                                                        <div class="col-md-7">@item.OgrenimTipKod</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-5 control-label">Öğrenim Tipi</label>
                                                                        <div class="col-md-7">@item.OgrenimTipAdi</div>
                                                                    </div>

                                                                    <div class="panel" style="margin:0px; margin-top:4px;">
                                                                        <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
                                                                            <h3 class="panel-title">
                                                                                <i class="fa fa-gears"></i>Mezuniyet Başvurusu Ayarları
                                                                            </h3>
                                                                        </div>
                                                                        <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                            <div class="panel" style="margin:0px;">
                                                                                <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
                                                                                    <h3 class="panel-title" style="float:right;">
                                                                                        <i class="fa fa-gears"></i> Başvuru Kriterleri
                                                                                    </h3>

                                                                                </div>
                                                                                <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                                    <div class="form-group">
                                                                                        <label class="col-md-5 control-label">Mezuniyet Başvurusu Yapılabilir Mi</label>
                                                                                        <div class="col-md-7">
                                                                                            <span class="label label-@(item.IsMezuniyetBasvurusuYapabilir ? "success" : "danger")">@(item.IsMezuniyetBasvurusuYapabilir ? "Evet" : "Hayır")</span>
                                                                                        </div>
                                                                                    </div>
                                                                                    @if (item.IsMezuniyetBasvurusuYapabilir)
                                                                                    {
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Son Dönem Kayıt Yaptırması Gereken Ders Kodları</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBasvuruSonDonemKaydiKontrolEdilecekDersKodlari
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Etik Ders Notu Kriteri</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBasvuruEtikNotKriteri
                                                                                            </div>
                                                                                        </div> <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Tüm Dönem Toplam Kredi Kriteri</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBasvuruToplamKrediKriteri
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Genel AGNO Kriteri</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBasvuruAGNOKriteri
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Genel AKTS Kriteri</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBasvuruAKTSKriteri
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">SR Talebini Kaç Gün Sonra Alabilir</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBSRTalebiKacGunSonraAlabilir
                                                                                            </div>
                                                                                        </div>
                                                                                    }
                                                                                </div>
                                                                            </div>
                                                                            @if (item.IsMezuniyetBasvurusuYapabilir)
                                                                            {
                                                                                <div class="panel" style="margin:0px;">
                                                                                    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
                                                                                        <h3 class="panel-title" style="float:right;">
                                                                                            <i class="fa fa-gears"></i> Tez Sınavı ve Tez Teslimi Kriterleri
                                                                                        </h3>

                                                                                    </div>
                                                                                    <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Tez Sınavı Uzatma Süresi (Gün)</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBSinavUzatmaSuresiGun
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="form-group">
                                                                                            <label class="col-md-5 control-label">Tez Teslim Süresi (Gün)</label>
                                                                                            <div class="col-md-7">
                                                                                                @item.MBTezTeslimSuresiGun
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            }
                                                                        </div>



                                                                    </div>


                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>


                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function ShowDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Öğrenim Tip Adı: " + gMesaj + " <br/> Seçilen Öğrenim Tipini Silmek İstiyor Musunuz?",
            title: "Öğrenim Tip Silme İşlemi",
            buttons: {
                success: {
                    label: "Öğrenim Tipi Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "OgrenimTipleri")',
            data: { id: id  },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Öğrenim Tip Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                     $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
