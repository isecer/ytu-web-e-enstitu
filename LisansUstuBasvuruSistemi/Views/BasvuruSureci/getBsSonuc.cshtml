                                                            <span style="color:@_colorAna;">Kyt</span>
                                                        </td>
                                                        <td style="border-right:1px solid;">
                                                            <span style="color:@_colorMul;">Asl</span>
                                                        </td>
                                                        <td style="border-right:1px solid;">
