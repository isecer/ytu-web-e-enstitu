@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model BasvuruSurecDetayDto
@{
    Layout = null;
    var IsDelete = Model.IsDelete;
    var nowDate = DateTime.Now;
    bool MulakatBilgiGirisAcik = Model.BaslangicTarihi <= nowDate && Model.BitisTarihi >= nowDate;
    bool KayitYetki = RoleNames.BasvuruSureciKayit.InRoleCurrent();
    bool MailGondermeYetkisi = RoleNames.MailGonder.InRoleCurrent();

    string _colorAna = "#268a8b";
    string _colorMul = "green";
    string _colorYedk = "#917729";
    string _colorKaznm = "maroon";
    string _colorUyari = "red";

    bool kayitOlanVar = Model.MulakatSonucu.MulakatSonucDetay.Any(a => a.ADKayitCount > 0 || a.AIKayitCount > 0);
    var Otips = Json.Encode(Model.CmbOgrenimTipBilgi);
}

<div class="panel panel-info" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-sort-amount-desc"></i> Başvuru Sonuç Genel Bilgi
        </h3>
        <ul class="panel-controls">
            <li>
                @if (!MulakatBilgiGirisAcik && IsDelete == false && KayitYetki)
                {
                    if (true || (Model.SonucGirisBaslangicTarihi.HasValue == false && Model.SonucGirisBitisTarihi.HasValue == false) || (Model.SonucGirisBitisTarihi.HasValue && Model.SonucGirisBitisTarihi.Value < nowDate))
                    {
                        if (Model.MulakatSonucu.HesaplamaYapildi == false)
                        {
                            <span style="cursor:pointer;" onclick="getBSonucHesap(@Model.BasvuruSurecID)" class="label label-info label-form"><i class="fa fa-sort-amount-desc"></i> Hesapla</span>
                        }
                        else
                        {
                            if (Model.MulakatSonucu.TumProgramlarHesaplandi)
                            {
                                if (kayitOlanVar)
                                {
                                    <span style="cursor:pointer;" onclick="getBSonucHesap(@Model.BasvuruSurecID)" class="label label-info label-form"><i class="fa fa-sort-amount-desc"></i> Tekrar Hesapla (Kayıt alan programlar hariç)</span>
                                }
                                else
                                {
                                    <span style="cursor:pointer;" onclick="getBSonucHesap(@Model.BasvuruSurecID)" class="label label-info label-form"><i class="fa fa-sort-amount-desc"></i> Tekrar Hesapla</span>
                                }

                            }
                            else
                            {
                                <span style="cursor:pointer;" onclick="getBSonucHesap(@Model.BasvuruSurecID)" class="label label-info label-form"><i class="fa fa-sort-amount-desc"></i> Tekrar Hesapla (Kayıt alan programlar hariç)</span>
                            }

                        }
                    }
                    else
                    {
                        <span>Mülakat not giriş süreci sona erdikten sonra hesaplama işlemi aktif olacaktır!</span>
                    }
                }
            </li>
        </ul>

    </div>
    <div class="portlet-body">
        <div class="col-md-12 col-xs-12" style="text-align: left;font-size:9pt;font-weight:bold;">
            <table style="width:100%;table-layout:fixed;text-align:center;font-weight:bold;background-color:gainsboro;border:1px solid;">

                <tbody>
                    <tr>
                        <td colspan="3" style="border-bottom:1px solid;background-color:antiquewhite;">Hesaplama Sayısal Bilgi</td>
                    </tr>
                    <tr>
                        <td width="200" style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                            <span style="color:#268a8b;">Toplam Hesaplanan</span>
                        </td>
                        <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                            <span style="color:#268a8b;">Alan İçi</span>
                        </td>
                        <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                            <span style="color:green;">Alan Dışı</span>
                        </td>

                    </tr>
                    <tr>
                        <td width="200" style="font-size:14pt;border-right:1px solid;">
                            <table style="width:100%;table-layout:fixed">
                                <tr>

                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:#268a8b;">Program</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:green;">Tercih</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td>
                            <table style="width:100%;table-layout:fixed">
                                <tr>

                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:#268a8b;">Kayıt</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:green;">Asil</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:#917729;">Yedek</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:maroon;">Kazanamadı</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tr>

                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:#268a8b;">Kayıt</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:green;">Asil</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:#917729;">Yedek</span>
                                    </td>
                                    <td style="font-size:8.2pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:maroon;">Kazanamadı</span>
                                    </td>
                                </tr>
                            </table>
                        </td>

                    </tr>
                    <tr>
                        <td width="200" style="font-size:14pt;border-right:1px solid;">
                            <table style="width:100%;table-layout:fixed">
                                <tr>

                                    <td style="font-size:14pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:#268a8b;">@Model.MulakatSonucu.HesaplananProgramCount / @Model.MulakatSonucu.ToplamProgramCount</span>
                                    </td>
                                    <td style="font-size:14pt;border-right:1px solid;border-bottom:1px solid;width:25%;">
                                        <span style="color:green;">@Model.MulakatSonucu.HesaplananTercihCount / @Model.MulakatSonucu.ToplamTercihCount</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td>
                            <table style="width:100%;table-layout:fixed">
                                <tr>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:#268a8b;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.AIKayitCount)</span>
                                    </td>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:green;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.AIAsilCount)</span>
                                    </td>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:#917729;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.AIYedekCount)</span>
                                    </td>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:maroon;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.AIKazanamayanCount)</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tr>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:#268a8b;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.ADKayitCount)</span>
                                    </td>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:green;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.ADAsilCount)</span>
                                    </td>
                                    <td style="font-size:14pt;border-right:1px solid;width:25%;">
                                        <span style="color:#917729;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.ADYedekCount)</span>
                                    </td>
                                    <td style="font-size:14pt;width:25%;">
                                        <span style="color:maroon;">@Model.MulakatSonucu.MulakatSonucDetay.Sum(s => s.ADKazanamayanCount)</span>
                                    </td>
                                </tr>
                            </table>
                        </td>

                    </tr>
                </tbody>
            </table>
        </div>




    </div>
</div>
<div class="panel panel-info" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-list-alt"></i> Başvuru Sonuçları
            @if (Model.MulakatSonucu.HesaplamaYapildi && KayitYetki)
            {
                <a href="javascript:void(0);" style="color:#296cc8;" onclick="getReportType(@Model.BasvuruSurecID,'','','','@Otips')">
                    <span style="font-size:14pt;color:#296cc8;" title="Yazdır" class="fa fa-print"></span> Tüm Liste
                </a>

            }
            @if (MailGondermeYetkisi)
            {
                <a href="javascript:void(0);" title="Öğrencilere Toplu Mail Gönder" onclick="mGonder('', '', '', '', @Model.BasvuruSurecID, 'false', '','','true')"><img src="~/Images/mail_send_O.png" style="width:30px;height:25px;" /></a>

            }
        </h3>
        <ul class="panel-controls">
            <li>

                @if (!MulakatBilgiGirisAcik && KayitYetki && Model.KayitOlmayanlarAnketID.HasValue)
                {
                    var bilgi = "";
                    if (Model.KayitOlmayanOgrencilereAnketLinkiGonderildi)
                    {
                        bilgi = "Lisansüstü başvuruyu kazanıp kayıt olmayan öğrencilere anket doldurma bilgisi " + Model.KayitOlmayanOgrencilereAnketLinkiGonderimTarihi.Value.ToFormatDateAndTime() + " tarihinde mail olarak gönderildi";
                    }
                    if (IsDelete == false && Model.MulakatSonucu.HesaplamaYapildi)
                    {
                        <span style="cursor:pointer;" onclick="getBSSendMailBB(@Model.BasvuruSurecID,'@bilgi',false,'@Otips')" class="label label-success label-form"><i class="fa fa-envelope"></i>@(Model.KayitOlmayanOgrencilereAnketLinkiGonderildi ? " Anket bilgisini tekrar gönder" : " Anket bilgisini gönder")</span>
                    }
                }
                @if (!MulakatBilgiGirisAcik && KayitYetki)
                {
                    var bilgi = "";
                    if (Model.SinavSonucBilgisiOgrenciMailiGonderildi)
                    {
                        bilgi = "Sınav sonuç bilgileri " + Model.SinavSonucBilgisiOgrenciMailiGonderimTarihi.Value.ToFormatDateAndTime() + " tarihinde Öğrencilere mail olarak gönderildi";
                    }
                    if (IsDelete == false && Model.MulakatSonucu.HesaplamaYapildi)
                    {
                        <span style="cursor:pointer;" onclick="getBSSendMailBB(@Model.BasvuruSurecID,'@bilgi',true,'@Otips')" class="label label-success label-form"><i class="fa fa-envelope"></i>@(Model.SinavSonucBilgisiOgrenciMailiGonderildi ? " Sonuçları tekrar gönder" : " Sonuçları gönder")</span>
                    }
                }
            </li>
        </ul>
    </div>
    <div class="portlet-body">
        <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">
            <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                <div class="panel-body" style="margin: 0px; padding: 0px;">
                    <table class="table" style="margin:0px;">
                        <thead>
                            <tr>
                                <th style="background-color:gainsboro;" width="35"></th>
                                <th style="background-color:gainsboro;" width="110" colspan="2">
                                    <table>
                                        <tr>
                                            <td width="120">Öğr.Sev / ABD-Program</td>
                                            <td>
                                                <table style="width:100%; table-layout:fixed;width:100%;">
                                                    <tr>

                                                        <td class="text-center" id="filtreKelimeS_@Model.BasvuruSurecID"></td>
                                                        <td style="width:150px;">
                                                            <input style="color:red;width:150px;" type="text" name="search" id="filterInpS_@Model.BasvuruSurecID" onchange="" placeholder="ara...">
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </th>
                                <th width="40" style="border-left:1px solid;border-bottom:1px solid;padding:0px;text-align:center;background-color:gainsboro;">G.Topl</th>
                                <th width="270" style="border-left:1px solid;border-right:1px solid;border-bottom:1px solid;padding:0px;">
                                    <table style="width:100%;table-layout:fixed;text-align:center;font-weight:bold;background-color:gainsboro;">
                                        <tr>
                                            <td style="border-right:1px solid;border-bottom:1px solid;">Alan İçi</td>
                                            <td style="border-bottom:1px solid;">Alan Dışı</td>
                                        </tr>
