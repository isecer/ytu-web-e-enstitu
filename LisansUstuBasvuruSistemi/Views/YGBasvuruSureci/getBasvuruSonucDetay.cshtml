@if (IsBootBox)
{
    <script>
        function tHesapla(IsKayitVar){
            var contt=  $('#tblKotaBilgi').html();
            var id='@Model.BasvuruSurecID';
            var _panel = $('#pndMDcPnl_' + id);
            var btbxX = bootbox.dialog({
                message: contt,
                title: "Başvuru Sonuç Tekrar Hesaplama İşlemi",
                buttons: {
                    success: {
                        label: "Belirtilen Kotalara Göre Hesapla",
                        className: "btn btn-info",
                        callback: function () {
                            var prk='@Model.ProgramKod';
                            var otKod = '@Model.OgrenimTipKod';
                            var ort = "";
                            var aiK = "";
                            var adK = "";
                            var aiEK = "";
                            var adEK = "";
                            if (IsKayitVar) {
                                var aiEK = $(btbxX).find('#AlanIciEkKota').val();
                                var adEK = $(btbxX).find('#AlanDisiEkKota').val();
                            }
                            else {
                                ort = $(btbxX).find('#OrtakKotaSayisi').val();
                                aiK = $(btbxX).find('#AlanIciKota').val();
                                adK = $(btbxX).find('#AlanDisiKota').val();
                            }

                            _pRefresh(_panel, false);
                            $.ajax({
                                url: '@Url.Action("BasvuruSonucHesap", "YGBasvuruSureci")',
                                data: { 'id': id, 'ProgramKod': prk, 'OgrenimTipKod': otKod, 'OrtakKotaSayisi': ort, 'AlanIciKota': aiK, 'AlanDisiKota': adK, 'AlanIciEkKota': aiEK, 'AlanDisiEkKota':adEK},
                                success: function (result) {
                                    if (result.IsSuccess) {
                                        getMDDetail();
                                    }
                                    showMmMessage(result.Messages, 'Tamam');

                                    return true;
                                },
                                error: function (err) {
                                    alert(err.responseText);
                                    return false;
                                }
                            });
                        }
                    },
                    danger: {
                        label: "Vazgeç",
                        className: "btn-primary",
                        callback: function () {
                        }
                    }
                }

            });
        }
    </script>
    <script>
        function GetAtip() {
            var retval = "";
            $('.TabLiContetn li').each(function (inx, lix) {
                if ($(lix).hasClass('active'))
                    retval= $(lix).attr("atipval");

            });
            return retval;
        }
        var ATip =@Model.SelectedTabIndex== 1 ? "AI" : "AD";
        function kKayitTops(AlanTipID) {
            var btbx = bootbox.dialog({
                message: "<table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>İşlem görmeyen Asil öğrenci kayıtları Kayıt olmadı şeklinde güncellenecek! İşlemi Onaylıyor Musunuz?</td></tr></table>",
                title: "Toplu Kayıt Kapatma İşlemi",
                buttons: {
                    success: {
                        label: 'Evet',
                        className: "btn-danger",
                        callback: function () {
                            KaydetTops(AlanTipID);
                        }
                    },
                    danger: {
                        label: 'Hayır',
                        className: "btn-primary",
                        callback: function () {
                        }
                    }
                }
            });
        }
        function KaydetTops(AlanTipID){
            var id='@Model.BasvuruSurecID';
            var _panel = $('#pndMDcPnl_' + id);
            _pRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("TopluKayit", "YGBasvuruSureci")',
                data: { BasvuruSurecID: '@Model.BasvuruSurecID', ProgramKod: '@Model.ProgramKod',OgrenimTipKod:'@Model.OgrenimTipKod',AlanTipID:AlanTipID },
                success: function (result) {

                    if(result.Messages.length>0)
                        showMmMessage(result.Messages, 'Tamam');
                    getMDDetail();
                    _pRefresh(_panel, true);
                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        function kKayitTopsY(AlanTipID) {
            var btbx = bootbox.dialog({
                message: "<table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>İşlem görmeyen Yedek öğrenci kayıtları Kayıt olmadı şeklinde güncellenecek! İşlemi Onaylıyor Musunuz?</td></tr></table>",
                title: "Toplu Kayıt Kapatma İşlemi",
                buttons: {
                    success: {
                        label: 'Evet',
                        className: "btn-danger",
                        callback: function () {
                            KaydetTopsY(AlanTipID);
                        }
                    },
                    danger: {
                        label: 'Hayır',
                        className: "btn-primary",
                        callback: function () {
                        }
                    }
                }
            });
        }
        function KaydetTopsY(AlanTipID){
            var id='@Model.BasvuruSurecID';

            var _panel = $('#pndMDcPnl_' + id);
            _pRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("TopluKayitY", "YGBasvuruSureci")',
                data: { BasvuruSurecID: '@Model.BasvuruSurecID', ProgramKod: '@Model.ProgramKod',OgrenimTipKod:'@Model.OgrenimTipKod',AlanTipID:AlanTipID },
                success: function (result) {

                    if(result.Messages.length>0)
                        showMmMessage(result.Messages, 'Tamam');
                    getMDDetail();
                    _pRefresh(_panel, true);
                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        function kKayit(msID,UniqueID,AdSoyad,BasvuruID) {

            var drm = $("#KayitDurumID_"+msID).val();
            var strDrm = $("#KayitDurumID_" + msID).val() != "" ? $("#KayitDurumID_" + msID + " option:selected").text() : "Kayıt Olmadı";;
            var bRow = "";
            if (drm == "@KayitDurumu.KayitOldu" || drm=="@KayitDurumu.OnKayit") {
                 bRow+="<tr><td style='font-size:14pt;text-align:center;color:maroon;'><input style='width:18px;height:18px;cursor:pointer;' type='checkbox' checked='checked' id='YokOgrenimDurumKotrol'/> Yök Web Servisinden Öğrenim Durumu Kontrolü Yapılsın</td></tr>";
            }
            bRow+="<tr><td style='font-size:12pt;text-align:center;color:green;'>'"+AdSoyad+"' Öğrencisine ait başvurunun kayıt durumunu '"+strDrm+"' şeklinde değiştirmek istiyorsunuz. İşleme devam edilsin mi?</td></tr>";
            if(drm!=null){
                var btbx = bootbox.dialog({
                    message: "<table style='table-layout:fixed;width:100%;'>"+bRow+"</table>",
                    title: "Başvuru Kayıt İşlemi",
                    buttons: {
                        success: {
                            label: 'Kaydet',
                            className: "btn-danger",
                            callback: function () {
                                var YokODKontrolYap = $('#YokOgrenimDurumKotrol').prop('checked');
                                Kaydet(msID, UniqueID, YokODKontrolYap, BasvuruID);
                            }
                        },
                        danger: {
                            label: 'Vazgeç',
                            className: "btn-primary",
                            callback: function () {
                            }
                        }
                    }
                });
                //$(btbx).find('.modal-dialog').addClass('modal-lg');
            }
        }
        var btbxBelgeler = "";
        function Kaydet(msID, UniqueID, YokODKontrolYap, BasvuruID, IsSave) {
            var id = '@Model.BasvuruSurecID';
            var _panel = $('#pndMDcPnl_' + id);
            var tID = getSelectedTabID('@tbName');
            var KayitDurumID = $('#KayitDurumID_' + msID).val();
            _pRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("KazananKayit", "YGBasvuruSureci")',
                data: { 'MulakatSonucID': msID, 'KayitDurumID': KayitDurumID, 'YokODKontrolYap': YokODKontrolYap, 'IsSave': IsSave },
                success: function (result) {
                    _pRefresh(_panel, true);
                    if (result.DekontIste) {
                        dekontKontrol(UniqueID);
                    }
                    else if (result.IsBelgeDialogYuklemeShow) {
                        getDetailOgr(BasvuruID, "4", true, msID, UniqueID,  YokODKontrolYap);
                    }
                    else if (result.IsBelgeDialogYuklemeClose) {
                        $(btbxBelgeler).find(".closeBtn").first().click();
                        btbxBelgeler = "";
                    }
                    if (result.IsReloadPage) {
                        getMDDetail();
                    }
                    if (result.Messages.length > 0)
                        showMmMessage(result.Messages, 'Tamam');

                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        $("#AI_fltr_@Model.MulakatID tr").click(function () {
            var UniqueID = $(this).attr("UniqueID");
            $('#UniqueID_@Model.MulakatID').val(UniqueID);
            $("#AI_fltr_@Model.MulakatID tr").removeClass("@RwSelectedCls");
            $(this).addClass("@RwSelectedCls");
        });
        $("#AD_fltr_@Model.MulakatID tr").click(function () {
            var UniqueID = $(this).attr("UniqueID");
            $('#UniqueID_@Model.MulakatID').val(UniqueID);
            $("#AD_fltr_@Model.MulakatID tr").removeClass("@RwSelectedCls");
            $(this).addClass("@RwSelectedCls");
        });
        @*function RowSelectedClear(atips) {
            $('#' + atips + '_fltr_@Model.MulakatID').find('.Mainrow.info').each(function (inx, trx) {
                $(trx).removeClass('info');
            });
        }*@
        function RowAddSelectedClass(UniqueID) {
            $('#UniqueID_@Model.MulakatID').val(UniqueID);
            $('#Rw_' + UniqueID).addClass('@RwSelectedCls');
        }
        function getDetailOgr(id, tbID, IsSave, msID, UniqueID,  YokODKontrolYap) {
            var _panel = $('#pndMDcPnl_' + id);

            var tID = "1";
            if (tbID == undefined) {
                tID = getSelectedTabID('@tbName');
            }
            else tID = tbID;
            IsSave = IsSave == true || IsSave == 'true';
            _pRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("GetBasvuruDetay", "Ajax")',
                data: { id: id, tbInx: tID, 'IsSave': IsSave },
                success: function (result) {
                    _pRefresh(_panel, true);
                    var bbButtons = "";
                    if (IsSave) {
                        bbButtons = {
                            success: {
                                label: 'Kayıt İşlemini Tamamla',
                                className: "btn-danger",
                                callback: function () {
                                    Kaydet(msID, UniqueID, YokODKontrolYap, id, true);
                                    return false;
                                }
                            },
                            danger: {
                                label: "Kapat",
                                className: "btn-primary closeBtn",
                                callback: function () {
                                    //getMDDetail();
                                }
                            }
                        };
                    }
                    else {
                        bbButtons = {
                            danger: {
                                label: "Kapat",
                                className: "btn-primary closeBtn",
                                callback: function () {
                                    //getMDDetail();
                                }
                            }
                        };
                    }
                    btbxBelgeler = bootbox.dialog({
                        message: result.page,
                        title: "Başvuru Detayı",
                        onEscape: function () {

                            //getMDDetail();
                        },
                        buttons: bbButtons
                    });
                    SubData(id);
                    $(btbxBelgeler).find('.modal-dialog').addClass('modal-lg');
                    var bbBody = $(btbxBelgeler).find('.bootbox-body').first();
                    $(bbBody).attr("id", "cls-" + id);

                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        function SubData(id) {
            var _panel = $('#bsvrDet_' + id);
            var tbName = "@TabAdlari.BasvuruDetayTN-" + id;
            var tID = getSelectedTabID(tbName);
            _pRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("GetBasvuruSubData", "Ajax")',
                data: { 'id': id, 'tbInx': tID},
                success: function (result) {
                    var _nme = tbName + "-" + tID;
                    $('#' + _nme).html(result.page);
                    _pRefresh(_panel, true);
                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        function dekontKontrol(UniqueID) {
            var url = '@Url.Action("Index","DekontBilgi")';
            url = url + "?BTID=" + UniqueID + "&IsPopup=true";
            yeniDialogBB(null, 'Dekont Bilgisi', url, '430', '@ModalSizeClass.Basic');
        }
        function getMDDetail() {

            var id = '@Model.BasvuruSurecID';
            var prKod = '@Model.ProgramKod';
            var otID = '@Model.OgrenimTipKod';
            var _panel = $('#pndMDcPnl_' + id);
            var tID = getSelectedTabID('@tbName');

            var filterVal = null;
            var filterInp = null;
            var scrlName = null;
            var scrlT = 0;
            var atips = GetAtip();
            if (atips != null && atips != undefined && atips!="") {
                filterVal = $('#' + atips + '_filterInp_@Model.MulakatID').val();
                filterInp = ('#' + atips + '_filterInp_@Model.MulakatID');
                scrlName = "#scrl_@(Model.MulakatID)_" + atips;
                scrlT = $(scrlName).scrollTop();
            }
            _pRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("getBasvuruSonucDetay", "YGBasvuruSureci")',
                data: { id: id, ProgramKod: prKod, OgrenimTipKod: otID, tbInx: tID, IsDelete: false, IsBootBox: '@IsBootBox' },
                success: function (result) {
                    dt1 = new Date();
                    $('#pndMDc_' + id, result)
                    dt2 = new Date();
                    console.log("innerHTML " + (dt2 - dt1));

                    if (filterInp != null) {
                        $(filterInp).val(filterVal);
                        flter($(filterInp), (filterInp == '#AI_filterInp_@(Model.MulakatID)' ? '@AlanTipi.AlanIci' : '@AlanTipi.AlanDisi'),@(Model.MulakatID));
                    }
                    if (scrlName != null) {
                        $(scrlName).animate({ scrollTop: parseInt(scrlT) }, 600);
                    }
                    var UniqueID = $('#UniqueID_@Model.MulakatID').val();
                    if (UniqueID != undefined && UniqueID != null && UniqueID != null) {
                        RowAddSelectedClass(UniqueID);
                    }
                    _pRefresh(_panel, true);
                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        $('#AI_filterInp_@(Model.MulakatID)').bind('keypress', function (e) {
            var code = (e.keyCode ? e.keyCode : e.which);
            if (code == 13) {
                flter(this,'@AlanTipi.AlanIci',@(Model.MulakatID));
            }
        });
        $('#AD_filterInp_@(Model.MulakatID)').bind('keypress', function (e) {
            var code = (e.keyCode ? e.keyCode : e.which);
            if (code == 13) {
                flter(this,'@AlanTipi.AlanDisi',@(Model.MulakatID));
            }
        });
        function flter(sndr, type, mulID) {
            var _val = $(sndr).val();
            var tableName = "_fltr_" + mulID;
            var fltrdCol = "_fltrAdS_" + mulID;
            var filtrDurum = "_filtreKelime_" + mulID;
            if (type == '@AlanTipi.AlanIci') {
                tableName = "AI" + tableName;
                fltrdCol = "AI" + fltrdCol;
                filtrDurum = "AI" + filtrDurum;
            }
            else {
                tableName = "AD" + tableName;
                fltrdCol = "AD" + fltrdCol;
                filtrDurum = "AD" + filtrDurum;
            }

            if (_val == null || _val.trim() == "")
            {
                $('#' + tableName).find('tr').removeClass("hide");
                $('#' + filtrDurum).html("");
            }
            else {
                _val = _val.trim().replaceAll('İ', 'i').toLowerCase();
                var toplam = $('#' + tableName).find('tr.mainRow').length;
                $('#' + tableName).find('.' + fltrdCol).each(function (inx, filtrx) {
                    var gVal = $(filtrx).text().trim().replaceAll('İ','i').toLowerCase();
                    var AShow = gVal.indexOf(_val) > -1;
                    if (AShow) {
                        $(filtrx).parents('tr').first().removeClass('hide');
                    }
                    else {
                        $(filtrx).parents('tr').first().addClass('hide');
                    }
                });
                var Gizli = $('#'+tableName).find('tr.mainRow.hide').length;
                var gosterilen = toplam - Gizli;
                $('#' + filtrDurum).html("[Ara:  %<span style='color:red;'>" + _val + "</span>%] [Bulunan: <span style='color:red;'>" + gosterilen + "</span>]");
            }

        }

        function setchkRtEkBilgi(sndr) {
            if ($(sndr).attr('id') == '_rprsncTip') {
                if ($(sndr).prop('checked')) {
                    $('#_rprsncIletisim').prop('checked', false);
                }
            }
            else {
                if ($(sndr).prop('checked')) {
                    $('#_rprsncTip').prop('checked', false);
                }
            }
        }

    </script>
