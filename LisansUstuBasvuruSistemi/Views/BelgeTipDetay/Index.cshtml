@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using BiskaUtil
@model  FmBelgeTipDetayDto
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp;Belge Tip Detayı</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-success label-form">T:@IndexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@IndexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@IndexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="Ad">Belge Adı</th>
                                <th class="sirala" field="Ad">Öğrenim Durum Adı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="50">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    <input name="BelgeTipAdi" type="text" value="@Model.BelgeTipAdi" class="form-control" />
                                </th>
                                <th>
                                    <input name="OgrenimDurumAdi" type="text" value="@Model.OgrenimDurumAdi" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex;
                                foreach (var item in Model.BelgeTipDetayDtos)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.BelgeTipDetayID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.BelgeTipDetayID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td id="tdMad_@item.BelgeTipDetayID">
                                          @string.Join(", ",item.BelgeTipAdi)
                                        </td>
                                        <td id="tdOd_@item.BelgeTipDetayID">
                                            @item.OgrenimDurumAdi
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit")"><i class="fa fa-plus tooltips" data-style="blue" data-original-title="Yeni"></i></a>
                                            <a href="@Url.Action("Kayit", "BelgeTipDetay", new { id = item.BelgeTipDetayID })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.BelgeTipDetayID')"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.BelgeTipDetayID" style="display:none">
                                        <td id="cls-@item.BelgeTipDetayID" colspan="5" style="padding: 1px 1px 2px 2px;">

                                            <div class="panel panel-success">
                                                <div class="panel-heading  padding-0">
                                                    <div class="portlet-title">
                                                        <h3 class="panel-title"><i class="fa fa-file-text"></i>&nbsp;Detay</h3>
                                                    </div>
                                                </div>
                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">
                                                        <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                <div class="panel-body form-group-separated">

                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Belge Tipi</label>
                                                                        <div class="col-md-9 col-xs-9">@string.Join(", ", item.BelgeTipAdi)</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Öğrenim Durum Adı</label>
                                                                        <div class="col-md-9 col-xs-9">@item.OgrenimDurumAdi</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Ücret alım var mı?</label>
                                                                        <div class="col-md-9 col-xs-9">
                                                                            <span class="label label-@(item.UcretAlimiVar ? "success" : "info")">@(item.UcretAlimiVar ? "Evet" : "Hayır")</span>
                                                                        </div>
                                                                    </div>
                                                                    @if (item.UcretAlimiVar)
                                                                    {
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 col-xs-3 control-label">Belge Fiyatı</label>
                                                                            <div class="col-md-9 col-xs-9" style="font-size:11pt;font-weight:bold;">
                                                                                @item.BelgeFiyati.Value TL
                                                                            </div>
                                                                        </div>
                                                                        if (item.UcretsizMiktar.HasValue)
                                                                        {
                                                                            <div class="form-group">
                                                                                <label class="col-md-3 col-xs-3 control-label">Ücretsiz alınabilecek miktar?</label>
                                                                                <div class="col-md-9 col-xs-9" style="font-size:11pt;font-weight:bold;">
                                                                                    @item.UcretsizMiktar.Value Adet
                                                                                </div>
                                                                            </div>
                                                                        }
                                                                    }
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Dönemlik Kota</label>
                                                                        <div class="col-md-9 col-xs-9" style="font-size:11pt;font-weight:bold;">
                                                                            @(item.DonemlikKota.HasValue ? (item.DonemlikKota.Value + " Adet") : "Kota Yok")
                                                                        </div>
                                                                    </div>
                                                                    @if (item.UcretAciklamasiLink.IsNullOrWhiteSpace()==false)
                                                                    {
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Ücret Bilgi Linki</label>
                                                                        <div class="col-md-9 col-xs-9" style="font-size:9pt;font-weight:bold;">
                                                                          <a href="@item.UcretAciklamasiLink" target="_blank">@item.UcretAciklamasiLink</a> 
                                                                        </div>
                                                                    </div>
                                                                    }
                                                                    <div class="form-group">                                                                                                
                                                                        <div class="col-md-12 col-xs-12">
                                                                            <table class="table" style="width:100%;table-layout:fixed;">
                                                                                <thead>
                                                                                    <tr>
                                                                                        <th>Hafta Günleri</th>
                                                                                        <th width="120">Talep Saat Aralığı</th>
                                                                                        <th width="120">Verilecek Gün</th>
                                                                                        <th width="120">Teslim Saat Aralığı</th>     
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    @foreach (var itemS in item.Saatler)
                                                                                    {
                                                                                        <tr>
                                                                                            <td>                                                                                                              
                                                                                                @string.Join(", ", itemS.GunNos.Select(s => s.Caption))
                                                                                            </td>
                                                                                            <td>                                                                               
                                                                                                @(itemS.TalepBaslangicSaat)-@(itemS.TalepBitisSaat)
                                                                                            </td>
                                                                                            <td>
                                                                                                @(itemS.EklenecekGun == 0 ? "Aynı gün verilsin" : itemS.EklenecekGun + " gün sonra verilsin")  
                                                                                            </td>
                                                                                            <td>
                                                                                                @(itemS.TeslimBaslangicSaat)-@(itemS.TeslimBitisSaat)               
                                                                                            </td>  
                                                                                        </tr>
                                                                                    }
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Durum</label>
                                                                        <div class="col-md-9 col-xs-9">
                                                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@(item.IsAktif ? "Aktif" : "Pasif")</span>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">İşlem Yapan</label>
                                                                        <div class="col-md-9 col-xs-9">@item.IslemYapan [@item.IslemTarihi]</div>
                                                                    </div>    
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function ShowDetail(id) {    
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        var gMesajOd = $("#tdOd_" + id).html();
        bootbox.dialog({
            message: "Belge Tip Adı: " + gMesaj + " <br/>Öğrenim Durumu Adı" + gMesajOd + "<br/>Seçilen Belge Tipi Detayını Silmek İstiyor Musunuz?",
            title: "Belge Tip Detayı Silme İşlemi",
            buttons: {
                success: {
                    label: "Belge Tip Detayını Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "BelgeTipDetay")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Belge Tip Detayı Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
