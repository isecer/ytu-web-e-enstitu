        function FilterInputKeyPress(sndr, e, gID) {
            var code = (e.keyCode ? e.keyCode : e.which);
            if (code == 13) {
                FilterTableRow(sndr, gID);
                return false;
            }


        }
        function FilterTableRow(sndr, gID) {
            var _val = $(sndr).val().trim().replace(/İ/g, 'i').replace(/I/g, 'ı').toLowerCase();
            var TableID = "#Filter_Table_" + gID;
            var TableColumn = ".Filter_Col_" + gID;
            var FilterInfo = "#FilterInfo_" + gID;

            if (_val == null || _val.trim() == "") {
                $(TableID).find('.MainRow').each(function (inx, filtrx) {
                    $(filtrx).removeClass('hide');
                    if ($(filtrx).next().hasClass('MainRow2')) {
                        if ($(filtrx).find('span').first().hasClass('fa-angle-down')) {
                            $(filtrx).next().removeClass('hide');
                        }
                        else {
                            $(filtrx).next().addClass('hide');
                        }
                    }
                });
                $(FilterInfo).html("");
            }
            else {
                var toplam = $(TableID).find('.MainRow').length;
                $(TableID).find('.MainRow').each(function (inx, filtrx) {
                    var show = false;
                    $(filtrx).find(TableColumn).each(function (inx2, filtrx2) {
                        var gVal = $(filtrx2).text().trim().replace(/İ/g, 'i').replace(/I/g, 'ı').toLowerCase();
                        var AShow = gVal.indexOf(_val) > -1;
                        if (AShow) show = true;
                    });
                    if (show) {
                        $(filtrx).removeClass('hide');
                        if ($(filtrx).next().hasClass('MainRow2')) {
                            if ($(filtrx).find('span').first().hasClass('fa-angle-down')) {
                                $(filtrx).next().removeClass('hide');
                            }
                            else {
                                $(filtrx).next().addClass('hide');
                            }
                        }
                    }
                    else {
                        $(filtrx).addClass('hide');
                        if ($(filtrx).next().hasClass('MainRow2')) {
                            $(filtrx).next().addClass('hide');
                        }
                    }
                });
                var Gizli = $(TableID).find('.MainRow.hide').length;
                var gosterilen = toplam - Gizli;
                $(FilterInfo).html("<span class='label label-info label-form'>[Aranan:  %<span style='color:maroon;'>" + _val + "</span>%] [Bulunan: <span style='color:maroon;'>" + gosterilen + "</span>]</span>");
            }
        }
        function setTumu(sndr, gID, InpName) {
            var TableID = "#Filter_Table_" + gID;
            var checked = $(sndr).prop('checked');
            $(TableID).find('.MainRow').each(function (inx, trx) {
                if ($(trx).hasClass('hide') == false) {
                    var chk = $(trx).find('input[name=' + InpName + ']');
                    var rwID = $(chk).val();
                    RwClick(gID, rwID, checked ? false : true, false);
                }
            });
            checkedInfo(TableID);
        }
        function RwClick(gID, rwID, checked, chkInfo) {
            chkInfo = chkInfo == undefined ? true : chkInfo;
            var TableID = "#Filter_Table_" + gID;
            var _checked = $(TableID).find('.tr_' + rwID).hasClass("success");
            if (checked != undefined) _checked = checked;
            if (_checked) {
                $(TableID).find('.tr_' + rwID).removeClass("success");
                $(TableID).find('#chk_' + rwID).prop("checked", false);
            }
            else {
                $(TableID).find('.tr_' + rwID).addClass("success");
                $(TableID).find('#chk_' + rwID).prop("checked", true);
            }
            if (chkInfo) checkedInfo(TableID);
        }
        function checkedInfo(TableID) {
            var Rows = $(TableID).find('tr.MainRow').length;
            var CheckedR = $(TableID).find('tr.MainRow.success').length;
            if (CheckedR > 0)
                $(TableID).parents('.MainTable').find('.footerInfo').html('Toplam: ' + Rows + ',  Seçilen: ' + CheckedR);
            else
                $(TableID).parents('.MainTable').find('.footerInfo').html('Toplam: ' + Rows);
        }
    </script>
    <script>
        function ShowMessageAjaxRequest(status, textStatus) {
            if (status == 401) {
                showMessage("info", "Oturumunuz sonlanmıştır.", "<strong>5 sn</strong> içinde giriş sayfasına yönlendirileceksiniz.");
                setTimeout(function () { window.location.href = "@Url.Action("LogIn","Account")?returnurl=" + window.location.href }, 5000);
            }
            else if (status == 403) {
                showMessage("danger", "Yetki Hatası", "Bu işlem için yetkiniz bulunmamaktadır.");
            }
            else if (status == 404) {
                showMessage("warning", "Sayfa Hatası", "Aranılan sayfa bulunamadı.");
            }
            else if (status != 0 && status != 200) {
                showMessage("danger", "İşlem Hatası", "İşlem yapılırken bir hata oluştu.");
            }
        }
    </script>
