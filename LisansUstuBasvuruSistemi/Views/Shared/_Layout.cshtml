            function ExportToExcel(tableID, filename = '') {
                var downloadLink;
                var dataType = 'application/vnd.ms-excel';
                var tableSelect = document.getElementById(tableID);

                // Clone the table to avoid modifying the original table
                var clonedTable = tableSelect.cloneNode(true);

                // Remove images from the cloned table
                var imgElements = clonedTable.querySelectorAll('img');
                imgElements.forEach(function (img) {
                    var td = img.closest('td');
                    if (td) {
                        td.innerHTML = ''; // Clear the content of the cell if it contains an image
                    }
                });

                var tableHTML = clonedTable.outerHTML;

                // Specify file name
                filename = filename ? filename + '.xls' : 'excel_data.xls';

                // Create download link element
                downloadLink = document.createElement("a");

                document.body.appendChild(downloadLink);

                if (navigator.msSaveOrOpenBlob) {
                    // Internet Explorer
                    var blob = new Blob(['\ufeff', tableHTML], { type: dataType });
                    navigator.msSaveOrOpenBlob(blob, filename);
                } else {
                    // Other browsers
                    // Create a link to the file
                    downloadLink.href = 'data:' + dataType + ';charset=utf-8, ' + encodeURIComponent('\ufeff' + tableHTML);

                    // Setting the file name
                    downloadLink.download = filename;

                    // Triggering the function
                    downloadLink.click();
                }
            }
