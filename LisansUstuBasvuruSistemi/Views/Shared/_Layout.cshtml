    <script>
        function HesapKayit(id) {
            if (id == undefined) id = "";
            var IsAuthenticated = '@UserIdentity.Current.IsAuthenticated' == 'True';
            if (IsAuthenticated && id == "") return;
            else if (!IsAuthenticated && id != "") return;
            $.ajax({
                url: '@Url.Action("HesapKayit", "Account")',
                data: { 'id': id },
                success: function (result) {
                    var btbxxFS = bootbox.dialog({
                        message: result,
                        title: "<i class='fa fa-user-o fa-lg'></i> " + (id == "" ? 'Yeni Kullanıcı Hesabı Oluşturma İşlemi' : 'Kullanıcı Hesabı Güncelleme İşlemi'),
                        buttons: {
                            success: {
                                label: 'Kaydet',
                                className: "btn-success",
                                callback: function (event) {
                                    var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                    PanelRefresh(pnlx, false);
                                    $('#frmHesapKayit').ajaxForm({
                                        success: function (result) {
                                            if (result.IsSuccess) {
                                                if (id == "") {
                                                    getMsg(result);
                                                }
                                                else {
                                                    toastr["success"](result.Messages[0], result.Title);
                                                }
                                            }
                                            else {
                                                getMsg(result);
                                                return false;
                                            }
                                            if (result.IsCloseDialog) {
                                                var _clsBtn = $('.modal-header').find('button').first();
                                                $(_clsBtn).click();
                                            }
                                            PanelRefresh(pnlx, true);

                                        },
                                        complete: function (cmp) {
                                            PanelRefresh(pnlx, true);
                                        },
                                        error: function (err) {
                                            PanelRefresh(pnlx, true);
                                        }

                                    }).submit();

