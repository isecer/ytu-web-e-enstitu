<body class="@(boxedOrFullWidth?("page-container-boxed "+backgroundImage):"") ">
    <div class="js">
        <div id="preloader"></div>
        <!-- START PAGE CONTAINER -->
        <div class="page-container @(fixedHeader?" page-navigation-top-fixed":"") @(rightSidebar?"page-mode-rtl":"") @(toggledNavigation?"page-navigation-toggled page-container-wide":"")">

            <!-- START PAGE SIDEBAR -->
            <div class="page-sidebar @(boxedOrFullWidth ? "" : "page-sidebar-fixed") @(fixedSidebar ? "page-sidebar-fixed" : "") @(fixedSidebar && !boxedOrFullWidth ? "scroll mCustomScrollbar _mCS_1 mCS-autoHide" : "")">
                <!-- START X-NAVIGATION -->
                <ul class="x-navigation  @(customNavigation ? "x-navigation-custom" : "") @(toggledNavigation ? "x-navigation-minimized" : "")">
                    <li class="xn-logo">
                        <a href="javascript:void(0);">YTÜ</a>
                        <a href="javascript:void(0);" class="x-navigation-control"></a>
                    </li>

                    <li class="xn-profile">
                        <a href="javascript:void(0);" class="profile-mini">
                            <img src="~/Content/assets/images/ytu_logo_tr.png" />
                        </a>
                        <div class="profile">
                            <div class="profile-image">
                                <div class="tile tile-primary" style="margin: 0px; padding: 0px;">
                                    <div class="mn profile-image">
                                        <img src="~/Content/assets/images/ytu_logo_tr.png" />
                                        <script>
                                        setTimeout(function () {
                                            $('.mn.profile-image').find("img").attr("src", "@lImage");
                                        }, 200)
                                        </script>
                                    </div>
                                    <ul>
                                        <li style="cursor: pointer;" class="active">
                                            <a href="javasscript:void(0); " style="text-align: center; font-size: 11pt; color: #ffd559; padding: 0px;">
                                                @{

                                                    <span>@selectedEnstitu.EnstituAd</span>
                                                }
                                            </a>
                                            <ul class="xn-drop-left xn-drop-white animated zoomIn">
                                                <li style="padding: 0px; margin: 0px;">
                                                    @foreach (var itm in enstituler.Where(p => p.EnstituKisaAd.ToLower().Contains(urlInfo.EnstituKisaAd) == false))
                                                    {
                                                        <a href="@(urlInfo.Root + itm.EnstituKisaAd.ToLower() +  "/" + urlInfo.LastPath+urlInfo.Query)" style="text-align:center;padding:0px;margin:0px;">
                                                            @itm.EnstituAd'ne geç
                                                        </a>
                                                    }
                                                </li>
                                            </ul>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="profile-data">
                                <div class="profile-data-title">
                                    ONLINE BAŞVURU SİSTEMİ<br />
                                    <span style="font-size:7.5pt;">© 2015 - @(DateTime.Now.Year) Bilgi İşlem Daire Başkanlığı</span>
                                </div>

                            </div>
                            <div class="profile-controls">
                                <a href="javascript:void(0);" class="profile-control-left"><span class="fa fa-info"></span></a>
                                <a href="javascript:void(0);" onclick="mesGonder('')" class="profile-control-right"><span class="fa fa-envelope"></span></a>
                            </div>
                        </div>
                    </li>

                    @*<li class="xn-title">Navigation</li>*@
                    <li>
                        <a href="@(urlInfo.FakeRoot)Home/Index" menuurl="@(urlInfo.FakeRoot.ToLower() + "home/index")">
                            <span class="fa fa-desktop"></span>
                            <span class="xn-text">Ana Sayfa</span>
                        </a>
                    </li>
                    <li>
                        <a href="@(urlInfo.FakeRoot)Kduyurular/Index" menuurl="@(urlInfo.FakeRoot.ToLower() + "kduyurular/index")">
                            <span class="fa fa-bullhorn"></span>
                            <span class="xn-text">Duyurular</span>
                        </a>
                    </li>
                    <li>
                        <a href="@(urlInfo.FakeRoot)SikcaSorulanSorular/Index" menuurl="@(urlInfo.FakeRoot.ToLower() + "sikcasorulansorular/index")">
                            <span class="glyphicon glyphicon-question-sign"></span>
                            <span class="xn-text" style="font-size:9.2pt">Sıkça Sorulan Sorular</span>
                        </a>
                    </li>

                    @{Html.RenderPartial("_MenuPartial");}

                </ul>
                <!-- END X-NAVIGATION -->
            </div>
            <!-- END PAGE SIDEBAR -->
            <!-- PAGE CONTENT -->
            <div class="page-content" style="height:auto;">

                <!-- START X-NAVIGATION VERTICAL -->
                <ul class="x-navigation x-navigation-horizontal x-navigation-panel">
                    <!-- TOGGLE NAVIGATION -->
                    <li class="xn-icon-button">
                        <a href="javascript:void(0);" class="x-navigation-minimize"><span class="fa fa-dedent"></span></a>

                    </li>
                    <li style="height: 50px; display: flex; flex-direction: column; justify-content: center;">
                        <span style="font-size: 11pt; color: #ffd559; line-height: 1;">
                            <i class="fa fa-home"></i> @selectedEnstitu.EnstituAd.ToUpper()
                        </span>
                        @if (UserIdentity.Current.IsAuthenticated && !isEnstituYetkisiVar)
                        {
                            <div style="color: #B64645; font-size: 7.5pt;">Bu Enstitü İçin Yetkiniz Yok!!!</div>
                        }
                    </li>
                    <!-- END TOGGLE NAVIGATION -->

                    @if (UserIdentity.Current.IsAuthenticated)
                    {
                        var prevUserKey = UserIdentity.Current.Informations.FirstOrDefault(p => p.Key == "PrevUserKey");
                        <!-- PROFILE -->
                        <li class="dropdown user pull-right" style="padding-top: 0px; padding-bottom: 0px;">
                            <a style="padding-bottom: 0px;" href="javascript:void(0)" class="dropdown-toggle" data-close-others="true">

                                <img id="userMainImage" style="margin-top: -12px; width: 45px; height: 45px; object-fit: cover;" src="@UserIdentity.Current.ImagePath">
                                <span class="xn-text elementToHide" style="margin-top: 10px;">@UserIdentity.Current.NameSurname</span>
                                <i class="fa fa-angle-down"></i>
                            </a>
                            <ul class="xn-drop-left animated zoomIn" style="z-index:997;">
                                <li><a href="javascript:void(0)" onclick="DetayGor('@UserIdentity.Current.UserKey')"><i class="fa fa-user"></i> Hesap Bilgileri</a></li>
                                <li><a href="javascript:void(0);" onclick="HesapKayit(@UserIdentity.Current.Id)"><span class="fa fa-id-card-o fa-lg"></span>Hesap Bilgilerini Düzenle</a></li>
                              
                                @if (RoleNames.Kullanicilar.InRoleCurrent())
                                {
                                    <li>
                                        <a href="javascript:void(0);" onclick="OgrenciSorgula();"><span class="fa fa-search"></span> OBS'de öğrenci sorgula</a>
                                        <script type="text/javascript">
                                            function OgrenciSorgulaView(tc) {
                                                var view = "";
                                                $.ajax({
                                                    url: '@Url.Action("ObsOgrenciSorgula", "Ajax")',
                                                    async: false,
                                                    data: { tc: tc },
                                                    success: function (result) {
                                                        view = result;
                                                    },
                                                    error: function (err) {
                                                        alert(err.responseText);
                                                    }
                                                });
                                                return view;
                                            }
                                            function OgrenciSorgula(tc) {
                                                var view = OgrenciSorgulaView(tc);
                                                var btbxxFS = bootbox.dialog({
                                                    message: '<div id="obsOgrenciPanel" style="max-height:700px;overflow-x:scroll;">' + view + '</div>',
                                                    title: "Obs Öğrenci Sorgulama",
                                                    buttons: {
                                                        danger: {
                                                            label: 'Kapat',
                                                            className: "btn-primary",
                                                            callback: function () {
                                                            }
                                                        }
                                                    }
                                                });
                                            }

                                        </script>
                                    </li>
                                }
                                <li><a href="javascript:void(0);" onclick="yetkiYenile();"><span class="fa fa-refresh"></span>Yetkilerimi Yenile</a></li>

                                @if (prevUserKey.Key != null)
                                {
                                    <li><a href="@Url.Action("SetLogin","Kullanicilar",new { UserIdentity.Current.UserKey,key=prevUserKey.Value })"><i class="fa fa-user"></i> Önceki Hesaba Geç</a></li>
                                }

                                @if (UserIdentity.Current.IsActiveDirectoryUser == false)
                                {
                                    <li><a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Şifre Değiştir', '@(Url.Action("ParolaSifirla", "Account", new { KullaniciID = UserIdentity.Current.Id }))', 600, '@ModalSizeClassEnum.Basic')"><span class="fa fa-lock"></span>Şifreyi değiştir</a></li>
                                }

                                <li><a href="javascript:void(0);" class="mb-control" data-box="#mb-signout"><span class="fa fa-sign-out"></span>Çıkış Yap</a></li>
                            </ul>
                            <div class="message-box animated fadeIn" data-sound="alert" id="mb-signout">
                                <div class="mb-container">
                                    <div class="mb-middle">
                                        <div class="mb-title"><span class="fa fa-sign-out"></span><strong>Sistemden Çıkış Yapılacak</strong> ?</div>
                                        <div class="mb-content">
                                            <p>Çıkış yapmak istediğinizden emin misiniz?</p>
                                        </div>
                                        <div class="mb-footer">
                                            <div class="pull-right">
                                                <a href="javascript:void(0)" class="btn btn-success btn-lg" onclick="SignOut()">Evet</a>
                                                <button class="btn btn-default btn-lg mb-control-close">Hayır</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <script type="text/javascript">
                                function yetkiYenile() {
                                    $.ajax({
                                        url: '@Url.Action("YetkiYenile", "Ajax")',
                                        data: { 'ReturnUrl': '@urlInfo.AbsolutePath' },
                                        success: function (result) {
                                            if (result.IsSuccess) {
                                                if (result.ReturnUrl != null && result.ReturnUrl != "")
                                                    window.location.href = result.ReturnUrl;
                                            }
                                        },
                                        error: function (err) {
                                            alert(err.responseText);
                                        }
                                    });
                                }
                                function SignOut() {
                                    $.ajax({
                                        url: '@Url.Action("SignOut", "Ajax")',
                                        data: {},
                                        success: function (result) {
                                            if (result.IsSuccess) {
                                                if (result.ReturnUrl != null && result.ReturnUrl != "")
                                                    window.location.href = result.ReturnUrl;
                                            }
                                        },
                                        error: function (err) {
                                            alert(err.responseText);
                                        }
                                    });
                                } 
                            </script>

                        </li>
                        <!--END PROFILE -->

                    }

                    @if (UserIdentity.Current.IsAuthenticated && RoleNames.Mesajlar.InRoleCurrent())
                    {
                        var enstituKod = EnstituBus.GetSelectedEnstitu(urlInfo.EnstituKisaAd);
                        var msjModel = MesajlarBus.GetCevaplanmamisMesajCount(enstituKod);
                        <li class="xn-icon-button pull-right" id="_msgCountLi">
                            <a href="javascript:void(0);"><span class="fa fa fa-envelope fa-lg"></span></a>
                            <div id="_msjCount" class="informer informer-@(msjModel.Value>0?"warning":"success")">@msjModel.Value</div>
                            <div id="_msgContent" class="panel panel-primary animated zoomIn xn-drop-left xn-panel-dragging ui-draggable" style="z-index: 999;">
                                <div class="panel-heading ui-draggable-handle padding-0">
                                    <h3 class="panel-title"><span class="fa fa fa-envelope fa-lg"></span> Gelen Mesajlar @(msjModel.Value > 20 ? "(Son 20)" : "")</h3>
                                    <div class="pull-right">
                                        <span id="_msjCount2" class="label label-@(msjModel.Value>0?"warning":"success")">@msjModel.Value Açık Msj</span>
                                    </div>
                                </div>
                                <div class="panel-body list-group list-group-contacts _mCS_2" style="max-height: 200px;">
                                    <div id="mCSB_2" class="scrolkikkoxMsj" tabindex="0">
                                        <div id="mCSB_2_container" style="position: relative; top: 0px; left: 0px;" dir="ltr">
                                            @Html.Raw(msjModel.Caption)
                                        </div>
                                    </div>
                                </div>
                                <div class="panel-footer text-center padding-0">
                                    <a href="@Url.Action("Index","Mesajlar")" target="_blank">Tüm Mesajları Gör</a>
                                </div>
                            </div>
                            <script>
                            $(function () {
                                if (@msjModel.Value>0) {
                                    MessageCntPulsate();
                                    $('.scrolkikkoxMsj').slimScroll({
                                        color: 'red',
                                        height: '200px'
                                    });
                                }
                            })
                            function MessageCntPulsate() {
                                $('#_msgCountLi').pulsate({ color: "#fdbe41", reach: 60, repeat: 14, speed: 300, glow: true });
                                $('#_msgContent').pulsate({ color: "#fdbe41", reach: 60, repeat: 14, speed: 300, glow: true });
                            }
                            var tmrMsg = null;
                            $(function () {
                                tmrMsgFnc(1, 30000);
                            });

                            function tmrMsgFnc(eventType, time) {
                                if (eventType == 0) clearInterval(tmrMsg);
                                else if (eventType == 1) {
                                    tmrMsg = setInterval(function () { GetAcikMsjCount() }, time);
                                }
                                else if (eventType == 2) {
                                    clearInterval(tmrLogn);
                                    tmrMsg = setInterval(function () { GetAcikMsjCount() }, time);
                                }
                            }
                            function GetAcikMsjCount() {
                                var panel = $('#_msgContent');
                                PanelRefresh(panel, false);
                                $.ajax({
                                    url: '@Url.Action("GetAcikMsjCount", "Mesajlar")',
                                    data: {EnstituKod:'@enstituKod'},
                                    success: function (result) {

                                        var oldCount = parseInt($('#_msjCount').text());
                                        $('#_msjCount').removeClass('informer-warning').removeClass('informer-success');
                                        $('#_msjCount2').removeClass('label-warning').removeClass('label-success');
                                        if (result.mCount > 0) {
                                            $('#_msjCount').addClass('informer-warning');
                                            $('#_msjCount2').addClass('label-warning');
                                        }
                                        else {
                                            $('#_msjCount').addClass('informer-success');
                                            $('#_msjCount2').addClass('label-success');
                                        }
                                        $('#_msjCount').html(result.mCount);
                                        $('#_msjCount2').html(result.mCount + " Açık Mesaj");
                                        $('#mCSB_2_container').html(result.HtmlContent);
                                        if (result.mCount > oldCount) {
                                            $('#_msgCountLi').addClass('active');
                                            MessageCntPulsate();
                                        }

                                        PanelRefresh(panel, true);
                                        trmlognFnc(2, 30000);
                                    },
                                    error: function (err) {
                                        PanelRefresh(panel, true);
                                        trmlognFnc(0);
                                    }
                                });

                            }
                            </script>
                        </li>
                    }

                    @if (UserIdentity.Current.IsAuthenticated && RoleNames.KullanicilarOnlineKullanicilar.InRoleCurrent())
                    {

                        <li class="xn-icon-button pull-right" style="cursor:pointer;" onclick="getOnlineUsers()">
                            <a href="javascript:void(0)" onclick="getOnlineUsers()"><span class="fa fa-group"></span></a>
                            <div id="userCnt" class="informer informer-success">@OnlineUsersHelper.OnlineUserCount</div>
