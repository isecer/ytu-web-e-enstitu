@using BiskaUtil
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model  FmDonemProjesiBasvuruDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var filteredOgrenciIds = (List<int>)ViewBag.filteredOgrenciIds;
    var filteredDanismanIds = (List<int>)ViewBag.filteredDanismanIds;
    var onayYapmayanJuriEmails = (List<string>)ViewBag.onayYapmayanJuriEmails;
    var eykDaOnaylanacakBasvuruIds = (List<int>)ViewBag.EykDaOnaylanacakBasvuruIds;

}
<div class="row">
    @using (Html.BeginForm("Index", "DpGelenBasvurular", FormMethod.Post, new { id = "frmDpBasvurular" }))
    {

        <div class="col-md-12">
            @Html.Hidden("export", false)
            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-info" id="pnlFltr">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title">
                        <i class="glyphicon glyphicon-filter"></i> Filtre İşlemi
                    </h3>
                    <ul class="panel-controls">
                        @if (Model.RowCount > 0 && UserIdentity.Current.IsAdmin && eykDaOnaylanacakBasvuruIds.Any())
                        {
                            <li>
                                <a href="javascript:void(0);" onclick="EykYaHazirlaTopluOnay()" title="EYK'da onay işlemi bekleyen başvuruları onayla"><i class="fa fa-thumbs-o-up fa-lg"></i></a>
                                <script>
                                     function EykYaHazirlaTopluOnay() {
                                        var kontrolEdilmeyenTalepIds = @Json.Encode(eykDaOnaylanacakBasvuruIds);

                                        // Bugünün tarihini varsayılan olarak ayarla
                                        var bugun = new Date();
                                        var varsayilanTarih = bugun.getFullYear() + '-' +
                                            String(bugun.getMonth() + 1).padStart(2, '0') + '-' +
                                            String(bugun.getDate()).padStart(2, '0');

                                        Swal.fire({
                                            title: 'Dönem Projesi Başvurusu Toplu Onay İşlemi',
                                            html: `
                                                <p style="margin-bottom: 15px;">EYK'da onay işlemi bekleyen '@eykDaOnaylanacakBasvuruIds.Count' adet başvuruyu onaylamak istiyor musunuz?</p>
                                                <div style="margin-bottom: 10px;">
                                                    <label for="eykTarihi" style="display: block; text-align: left; font-weight: bold; margin-bottom: 5px;">
                                                        EYK Tarihi: <span style="color: red;">*</span>
                                                    </label>
                                                    <input type="date"
                                                           id="eykTarihi"
                                                           class="swal2-input"
                                                           value="${varsayilanTarih}"
                                                           style="width: 100%; margin: 0;"
                                                           required>
                                                </div>
                                                <small style="color: #666;">* EYK tarihi zorunludur</small>
                                            `,
                                            icon: "question",
                                            showCancelButton: true,
                                            confirmButtonText: 'Onayla',
                                            confirmButtonColor: "#28a745",
                                            cancelButtonText: 'Vazgeç',
                                            showLoaderOnConfirm: true,
                                            backdrop: true,
                                            padding: '2em',
                                            allowOutsideClick: false,
                                            focusConfirm: false,
                                            preConfirm: function () {
                                                const eykTarihi = document.getElementById('eykTarihi').value;

                                                // Tarih kontrolü
                                                if (!eykTarihi) {
                                                    Swal.showValidationMessage('EYK tarihi girişi zorunludur!');
                                                    return false;
                                                }

                                                // Tarih formatı kontrolü
                                                const tarihRegex = /^\d{4}-\d{2}-\d{2}$/;
                                                if (!tarihRegex.test(eykTarihi)) {
                                                    Swal.showValidationMessage('Geçerli bir tarih formatı giriniz! (YYYY-MM-DD)');
                                                    return false;
                                                }

                                                // Geçmiş tarih kontrolü (isteğe bağlı)
                                                //const girilenTarih = new Date(eykTarihi);
                                                //const bugun = new Date();
                                                //bugun.setHours(0,0,0,0); // Saati sıfırla, sadece tarihi karşılaştır

                                                //if (girilenTarih > bugun) {
                                                //    Swal.showValidationMessage('EYK tarihi bugünden ileri bir tarih olamaz!');
                                                //    return false;
                                                //}

                                                $('.swal2-cancel').first().text("Onaylanıyor...");

                                                return new Promise(function (resolve) {
                                                    $.ajax({
                                                        url: '@Url.Action("EykDaTopluOnay", "DpGelenBasvurular")',
                                                        type: 'POST',
                                                        cache: false,
                                                        data: {
                                                            'basvuruIds': kontrolEdilmeyenTalepIds,
                                                            'eykTarihi': eykTarihi
                                                        },
                                                        success: function (result) {
                                                            $('.swal2-cancel').first().text("Vazgeç");
                                                            Swal.fire({
                                                                html: result.message,
                                                                icon: (result.success ? "success" : "error"),
                                                                type: (result.success ? "success" : "error"),
                                                                confirmButtonText: 'Tamam',
                                                                padding: '2em'
                                                            }).then(function() {
                                                                if (result.success) {
                                                                    // Başarılı olursa sayfayı yenile
                                                                    location.reload();
                                                                }
                                                            });
                                                            resolve();
                                                        },
                                                        error: function() {
                                                            $('.swal2-cancel').first().text("Vazgeç");
                                                            Swal.fire({
                                                                title: 'Hata!',
                                                                text: 'İşlem sırasında bir hata oluştu!',
                                                                icon: 'error',
                                                                confirmButtonText: 'Tamam'
                                                            });
                                                            resolve();
                                                        }
                                                    });
                                                });
                                            }
                                        });
                                    }
                                </script>
                            </li>
                        }
                        @if (Model.IsFiltered && Model.RowCount > 0)
                        {
                            <li>
                                <a href="javascript:void(0);" onclick="$('#export').val('true'); $('#frmDpBasvurular').submit(); $('#export').val('false');" title="Listelenen kaydı excel e aktar"><i class="fa fa-download"></i></a>
                            </li>

                        }

                        @if (RoleNames.DonemProjesiEykYaGonder.InRole())
                        {
                            <li>
                                <a href="javascript:void(0);" onclick="ShowDialogTutanakRpr()" title="Tutanak Raporu Oluştur"><i class="fa fa-file-text-o"></i></a>
                                <script>
                                    function ShowDialogTutanakRpr() {
                                        var _panel = $('#pnlFltr');

                                        PanelRefresh(_panel, false);
                                        $.ajax({
                                            url: '@Url.Action("GetTutanakRaporu", "DpGelenBasvurular")',
                                            data: {},
                                            success: function (result) {

                                                PanelRefresh(_panel, true);
                                                var btbxxFS = bootbox.dialog({
                                                    message: result,
                                                    title: "<i class='fa fa-bar-chart-o'></i> Tutanak Çıktısı Oluşturma İşlemi",
                                                    buttons: {
                                                        success: {
                                                            label: 'Çıktı Al',
                                                            className: "btn btn-info",
                                                            callback: function (event) {
                                                                toastr["success"]('Tutanak oluşturuluyor lütfen bekleyiniz...', 'Tutanak Oluşturma İşlemi');
                                                                var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                                                PanelRefresh(pnlx, false);
                                                                $('#TutanakRprForm').ajaxForm({
                                                                    success: function (result) {

                                                                        PanelRefresh(pnlx, true);
                                                                        if (result.IsSuccess) {

                                                                            var _Bastar = $('#BasTar').val();
                                                                            var _Bittar = $('#BitTar').val();
                                                                            var _ExportWordOrExcel = $('#exportWordOrExcel').val();
                                                                            var _EnstituOnayDurumId = $('#EnstituOnayDurumId').val();

                                                                            window.location = '@Url.Action("GetTutanakRaporuExport", "DpGelenBasvurular")?&BasTar=' + _Bastar + '&BitTar=' + _Bittar + '&ExportWordOrExcel=' + _ExportWordOrExcel + "&enstituOnayDurumId=" + _EnstituOnayDurumId;

                                                                        }
                                                                        else {
                                                                            GetMsg(result);
                                                                        }


                                                                    },
                                                                    complete: function (cmp) {
                                                                        PanelRefresh(pnlx, true);
                                                                    },
                                                                    error: function (err) {
                                                                        PanelRefresh(pnlx, true);
                                                                    }

                                                                });
                                                                $('#TutanakRprForm').submit();
                                                                return false;
                                                            }
                                                        },
                                                        danger: {
                                                            label: 'Kapat',
                                                            className: "btn-primary",
                                                            callback: function () {
                                                            }
                                                        }
                                                    }
                                                });
                                            },
                                            error: function (err) {
                                                alert(err.responseText);
                                                PanelRefresh(_panel, true);
                                            }
                                        });

                                    }
                                </script>
                            </li>

                            if (filteredOgrenciIds.Any())
                            {
                                <li>
                                    <a href="javascript:void(0)" onclick="mGonderGB('@string.Join(",", filteredOgrenciIds)',true,false)" title="Listelenen Başvurular için @filteredOgrenciIds.Count Öğrenciye Mail Gönder"><i class="fa fa-envelope" aria-hidden="true"> Ö</i></a>
                                </li>
                            }

                            if (filteredDanismanIds.Any())
                            {
                                <li>
                                    <a href="javascript:void(0)" onclick="mGonderGB('@string.Join(",", filteredDanismanIds)',true,false)" title="Listelenen Başvurular için @filteredDanismanIds.Count Danışmana Mail Gönder"><i class="fa fa-envelope" aria-hidden="true"> D</i></a>
                                </li>
                            }

                            if (onayYapmayanJuriEmails.Any())
                            {
                                <li>
                                    <a href="javascript:void(0)" onclick="mGonderGB('@string.Join(",", onayYapmayanJuriEmails)',true,false)" title="Listelenen Başvurular için Değerlendirme Yapmayan @onayYapmayanJuriEmails.Count Jüri Üyesine Mail Gönder"><i class="fa fa-envelope" aria-hidden="true"> J</i></a>
                                </li>
                            }


                        }
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover" style="width:100%;table-layout:fixed;">
                        <tr>
                            <td style="padding-left:10px;">
                                <table style="width:100%;table-layout:fixed;">
                                    <tbody>
                                        <tr>
                                            <td width="160">Başvuru Dönemi</td>
                                            <td>
                                                @Html.DropDownList("AkademikDonemID", null, new { @class = "form-control" })
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                            <td style="padding-left: 10px;">
                                <table style="width:100%;table-layout:fixed;">
                                    <tbody>
                                        <tr>
                                            <td width="160">Anabilim Dalı</td>
                                            <td>
                                                @Html.DropDownList("AnabilimDaliID", null, new { @class = "form-control" })
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>

                            </td>
                        </tr>
                        <tr>

                            <td style="padding-left:10px;">
                                <table style="width:100%;table-layout:fixed;">
                                    <tbody>
                                        <tr>
                                            <td width="160">Başvuru Durumu</td>
                                            <td>
                                                @Html.DropDownList("DonemProjesiDurumID", null, new { @class = "form-control" })
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                            <td style="padding-left: 10px; vertical-align: top;">
                                <table style="width: 100%; table-layout: fixed;">
                                    <tbody>
                                        <tr>
                                            <td width="160">Aranacak Kelime</td>
                                            <td>

                                                <table style="width: 100%; table-layout: fixed;">
                                                    <tbody>
                                                        <tr>
                                                            <td> <input name="AdSoyad" id="AdSoyad" type="text" value="@Model.AdSoyad" onkeypress="if (event.which == 13) { $('#frmDpBasvurular').submit(); }" class="form-control" /></td>
                                                            <td width="110">
                                                                <a href="javascript:void(0);" onclick="$('#frmDpBasvurular').submit();" class="btn btn-info" style="width: 110px;"><i class="glyphicon glyphicon-filter"> Filtrele</i></a>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-12">

            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Gelen Başvurular</h3>
                </div>
                <div class="panel-body">
                    <table class="table table-hover" style="width: 100%;">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th width="40"></th>
                                <th class="sirala" field="AdSoyad">Ad Soyad</th>
                                <th width="150" class="sirala" field="BasvuruTarihi" width="80">Son Başvuru Tarihi</th>
                                <th>Son Başvuru Durumu</th>
                                <th width="45"></th>
                            </tr>
                        </thead>
                        <tbody>

                            @if (Model.RowCount > 0)
                            {

                                var rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.Data)
                                {
                                    rowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.UniqueID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.UniqueID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            <img src="@item.ResimAdi.ToKullaniciResim()" style="width: 40px; height: 40px; cursor: pointer;" onclick="DetayGor('@item.UserKey')" class="img-circle img-thumbnail">
                                        </td>
                                        <td>
                                            @item.AdSoyad <br /> @item.OgrenciNo
                                        </td>
                                        <td id="DpBasvuruDonem_@item.UniqueID">
                                            @item.SonBasvuruDurum.ToDpBasvuruDonemView()
                                        </td>
                                        <td id="DpBasvuruDurum_@item.UniqueID">
                                            @item.SonBasvuruDurum.ToDpBasvuruDurumView()
                                        </td>
                                        <td>
                                            @if (item.SonBasvuruDurum == null)
                                            {
                                                <a href="@Url.Action("BasvuruYap","DpBasvuru", new { id = item.UniqueID })"><i style="font-size: 11pt;" class="fa fa-edit tooltips" title="Düzelt"></i></a>
                                                <a href="javascript:void(0)" onclick="BasvuruSil(this,'@item.UniqueID','@item.BasvuruTarihi.ToFormatDateAndTime()')"><i style="font-size: 11pt;" class="glyphicon glyphicon-trash tooltips" title="Sil"></i></a>
                                            }
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.UniqueID" style="display: none">
                                        <td colspan="6" style="padding: 1px 1px 2px 75px;">
                                            <div class="panel" style="padding:0px;margin:0px;" id="cls-@item.UniqueID"></div>
                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center;">
                                        Listelenen Kayıt Yok
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>

        </div>
    }
</div>


<script>

    function YeniBasvuruDuyuruKontrol()
    {
        var popupSetting = {
            title:'||',
            popupTipId:@DuyuruPopupTipiEnum.DonemProjesiBasvuru,
            btnAdi: 'Başvuru Yap',
            redirectUrl: '@Url.Action("BasvuruYap","DpBasvuru")',
            callbackFnc: ''
        }
        ShowDuyuru(popupSetting);
    }
    function BasvuruSil(sndr, uniqueId, tarih) {
        Swal.fire({
            text: tarih + " tarihli dönem projesi başvurusunu silmek istiyor musunuz?",
            type: 'warning',
            icon: "question",
            showCancelButton: true,
            confirmButtonText: 'Dönem Projesi Başvurusunu Sil',
            confirmButtonColor: "maroon",
            cancelButtonText: 'Vazgeç',
            showLoaderOnConfirm: true,
            backdrop: true,
            padding: '2em',
            backdrop: true,
            allowOutsideClick: false,
            preConfirm: function () {
                $('.swal2-cancel').first().text("Siliniyor...");
                return new Promise(function (resolve) {
                    $.ajax({
                        url: '@Url.Action("Sil", "DpBasvuru")',
                        data: { uniqueId },
                        success: function (result) {
                            if (result.IsSuccess) {
                                $(sndr).parents('tr').first().remove();
                                $(".cls-" + uniqueId).remove();
                            }
                            swal.fire({
                                html: result.messageView,
                                icon: (result.IsSuccess ? "success" : "error"),
                                type: (result.IsSuccess ? "success" : "error"),
                                confirmButtonText: 'tamam',
                                padding: '2em'
                            });
                        }
                    });

                });
            }
        });
    }
    function ShowDetail(uniqueId) {
        var rwID = $('#iShow_' + uniqueId);
        var cls = 'cls-' + uniqueId;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
        if (unTogled) GetDetail(uniqueId);

    }
</script>

<script>

    function GetDetail(donemProjesiUniqueId) {
        var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        $.ajax({
            url: '@Url.Action("GetDetailDpBasvuru", "Ajax")',
            data: { donemProjesiUniqueId },
            success: function (result) {
                $('#cls-' + donemProjesiUniqueId).html(result);
                PanelRefresh(panel, true);
            },
            error: function (err) {
                alert(err.responseText);
                PanelRefresh(panel, true);
            },
            complete: function (cmp) {
                PanelRefresh(panel, true);
            },
        });
    }
    function YeniBasvuruDuyuruKontrol2(donemProjesiUniqueId, donemProjesiBasvuruUniqueId) {
        var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        var popupSetting = {
            title: '||',
            popupTipId:@DuyuruPopupTipiEnum.DonemProjesiBasvuru,
            btnAdi: 'Yeni Dönem Projesi Başvurusu Oluştur',
            redirectUrl: '',
            fncparameter: { donemProjesiUniqueId, donemProjesiBasvuruUniqueId },
            callbackFnc: GetDonemProjesiBasvuruFormu
        }
        ShowDuyuru(popupSetting);
        PanelRefresh(panel, true);
    }
    function GetDonemProjesiBasvuruFormu(donemProjesiUniqueId, donemProjesiBasvuruUniqueId) {
        if (donemProjesiUniqueId.donemProjesiUniqueId) donemProjesiUniqueId = donemProjesiUniqueId.donemProjesiUniqueId;
        if (donemProjesiUniqueId.donemProjesiBasvuruUniqueId) donemProjesiBasvuruUniqueId = donemProjesiUniqueId.donemProjesiBasvuruUniqueId;
        var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        $.ajax({
            url: '@Url.Action("GetDonemProjesiBasvuruFormu", "DpBasvuru")',
            data: {
                donemProjesiUniqueId,
                donemProjesiBasvuruUniqueId
            },
            success: function (resultG) {
                PanelRefresh(panel, true);
                if (resultG.IsSuccess) {
                    var btbxxFS = bootbox.dialog({
                        message: resultG.Content,
                        title: "<i class='fa fa-pencil'></i> " + (donemProjesiBasvuruUniqueId ? "Dönem Projesi Başvuru Formu Düzelt" : "Yeni Dönem Projesi Başvuru Formu"),
                        buttons: {
                            success: {
                                label: 'Kaydet',
                                className: "btn-info btnKaydet",
                                callback: function (event) {
                                    var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                    PanelRefresh(pnlx, false);
                                    $('#FrmDonemProjesiBasvuruFormu').ajaxForm({
                                        success: function (result) {
                                            if (result.IsSuccess) {
                                                if (result.Messages.length > 0) toastr["success"](result.Messages.join('<br/>'), result.Title, { timeOut: 8000 });
                                                var _clsBtn = $('.bootbox-close-button').first();
                                                $(_clsBtn).click();
                                                GetDetail(donemProjesiUniqueId);

                                            }
                                            else {
                                                if (result.Messages.length > 0) GetMsg(result);
                                                return false;
                                            }
                                            PanelRefresh(pnlx, true);
                                        },
                                        complete: function (cmp) {
                                            PanelRefresh(pnlx, true);
                                        },
                                        error: function (err) {
                                            PanelRefresh(pnlx, true);
                                        }

                                    });
                                    $('#FrmDonemProjesiBasvuruFormu').submit();
                                    return false;
                                }
                            }
                            ,danger: {
                                label: "Kapat",
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });
                    //$(btbxxFS).find('.modal-dialog').first().addClass('modal-lg');
                    if (resultG.Messages.trim() != "") ShowMmMessage(resultG.Messages, 'Tamam');

                }
                else {
                    ShowMmMessage(resultG.Messages, 'Tamam');
                }

            },
            error: function (err) {
                PanelRefresh(panel, true);
                alert(err.responseText);

            }
        })
    }
    function BasvuruFormuSil(donemProjesiUniqueId, donemProjesiBasvuruUniqueId, tarih) {
        Swal.fire({
            text: tarih + " tarihli dönem projesi başvuru formunu silmek istiyor musunuz?",
            type: 'warning',
            icon: "question",
            showCancelButton: true,
            confirmButtonText: 'Dönem Projesi Başvuru Formunu Sil',
            confirmButtonColor: "maroon",
            cancelButtonText: 'Vazgeç',
            showLoaderOnConfirm: true,
            backdrop: true,
            padding: '2em',
            backdrop: true,
            allowOutsideClick: false,
            preConfirm: function () {
                $('.swal2-cancel').first().text("Siliniyor...");
                return new Promise(function (resolve) {
                    $.ajax({
                        url: '@Url.Action("BasvuruFormuSil", "DpBasvuru")',
                        data: { 'uniqueId': donemProjesiBasvuruUniqueId },
                        success: function (result) {
                            if (result.IsSuccess) {
                                GetDetail(donemProjesiUniqueId);
                            }
                            swal.fire({
                                html: result.messageView,
                                icon: (result.IsSuccess ? "success" : "error"),
                                type: (result.IsSuccess ? "success" : "error"),
                                confirmButtonText: 'tamam',
                                padding: '2em'
                            });
                        }
                    });

                });
            }
        });
    }
    function ShowDetailY(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
    }
    function GetDonemProjesiJuriForm(donemProjesiUniqueId, donemProjesiBasvuruUniqueId) {
         var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        $.ajax({
            url: '@Url.Action("GetDonemProjesiJuriFormu", "DpBasvuru")',
            data: {
                'donemProjesiUniqueId': donemProjesiUniqueId,
                'donemProjesiBasvuruUniqueId': donemProjesiBasvuruUniqueId
            },
            success: function (resultG) {
                PanelRefresh(panel, true);
                if (resultG.IsSuccess) {
                    var btbxxFS = bootbox.dialog({
                        message: resultG.Content,
                        title: '|| Dönem Projesi Jüri Formu',
                        buttons: {

                            success: {
                                label: 'Kaydet',
                                className: "btn-info btnKaydet",
                                callback: function (event) {
                                    var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                    PanelRefresh(pnlx, false);
                                    $('#FrmDonemProjesiJuriFormu').ajaxForm({
                                        success: function (result) {
                                            PanelRefresh(pnlx, true);
                                            if (result.mMessage.IsSuccess) {
                                                var _clsBtn = $('.bootbox-close-button').first();
                                                $(_clsBtn).click();
                                                GetDetail(donemProjesiUniqueId);
                                                if (result.showSinavKayitForm) {
                                                    ShowSrDialog(donemProjesiUniqueId, donemProjesiBasvuruUniqueId, false)
                                                }
                                            }
                                            else {
                                                if (result.selectedJuriNum > 0) {
                                                    ShowContent(result.selectedJuriNum);
                                                }
                                                if (result.mMessage.Messages.length > 0) GetMsg(result.mMessage);
                                                return false;
                                            }
                                        },
                                        complete: function (cmp) {
                                            PanelRefresh(pnlx, true);
                                        },
                                        error: function (err) {
                                            PanelRefresh(pnlx, true);
                                        }

                                    });
                                    $('#FrmDonemProjesiJuriFormu').submit();
                                    return false;
                                }
                            },
                            danger: {
                                label: 'Vazgeç',
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });
                    if (resultG.Messages.trim() != "") ShowMmMessage(resultG.Messages, 'Tamam');

                }
                else {
                    ShowMmMessage(resultG.Messages, 'Tamam');
                }

            },
            error: function (err) {
                PanelRefresh(panel, true);
                alert(err.responseText);

            }
        });
    }
    function ShowDLinkGonder(donemProjesiUniqueId, donemProjesiBasvuruUniqueId, uniqueId) {
        var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        $.ajax({
            url: '@Url.Action("DegerlendirmeLinkView", "DpBasvuru")',
            data: {
                uniqueId,
            },
            success: function (result) {
                PanelRefresh(panel, true);
                var btbxxFS = bootbox.dialog({
                    message: result,
                    title: "<i class='fa fa-envelope fa-lg'></i> Yeni Değerlendirme Linki Gönderme İşlemi",
                    buttons: {
                        success: {
                            label: "Gönder",
                            className: "btn-info",
                            callback: function (event) {
                                var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                PanelRefresh(pnlx, false);
                                var email = $('#EMail_' + uniqueId).val();
                                $.ajax({
                                    url: '@Url.Action("DegerlendirmeLinkiGonder", "DpBasvuru")',
                                    data: {
                                        donemProjesiUniqueId,
                                        donemProjesiBasvuruUniqueId,
                                        uniqueId,
                                        email
                                    },
                                    success: function (result) {
                                        PanelRefresh(pnlx, true);
                                        GetDetail(donemProjesiUniqueId);
                                        swal.fire({
                                            html: result.messageView,
                                            icon: (result.IsSuccess ? "success" : "error"),
                                            type: (result.IsSuccess ? "success" : "error"),
                                            confirmButtonText: 'tamam',
                                            padding: '2em'
                                        });
                                        if (result.IsSuccess) {
                                            var _clsBtn = $(pnlx).find('.bootbox-close-button').first();
                                            $(_clsBtn).click();
                                        }
                                    },
                                    error: function (err) {
                                        PanelRefresh(pnlx, true);
                                        alert(err.responseText);

                                    }
                                });
                                return false;
                            }
                        },
                        danger: {
                            label: "Kapat",
                            className: "btn-primary",
                            callback: function () {
                                PanelRefresh(panel, true);
                            }
                        }
                    }
                });

            },
            error: function (err) {
                PanelRefresh(panel, true);
                alert(err.responseText);

            }
        });



    }
    function DonemProjesiDegerlendir(donemProjesiUniqueId, uniqueId) {
        var donemProjesiJuriOnayDurumId = $('#DonemProjesiJuriOnayDurumID_' + uniqueId).val();
        var fileInput = document.getElementById('intihalDosya_' + uniqueId);
        var intihalDosya = fileInput != null ? fileInput.files[0] : null;
        var TekKaynakOrani = $('#TekKaynakOrani_' + uniqueId).val();
        var ToplamKaynakOrani = $('#ToplamKaynakOrani_' + uniqueId).val();
        var Aciklama = $('#Aciklama_' + uniqueId).val();
        var panel = $('#cls-' + donemProjesiUniqueId);
        bootbox.dialog({
            message: "Dönem projesi değerlendirmenizi kaydetmek istediğinize emin misiniz?",
            title: "<i class='glyphicon glyphicon-info-sign'></i> Dönem Projesi Değerlendirmesi",
            buttons: {
                success: {
                    label: "Evet",
                    className: "btn-success",
                    callback: function (event) {
                        PanelRefresh(panel, false);
                        var formData = new FormData();
                        formData.append('uniqueId', uniqueId);
                        formData.append('donemProjesiJuriOnayDurumId', donemProjesiJuriOnayDurumId);
                        formData.append('TekKaynakOrani', TekKaynakOrani);
                        formData.append('ToplamKaynakOrani', ToplamKaynakOrani);
                        formData.append('intihalDosya', intihalDosya);
                        formData.append('Aciklama', Aciklama);

                        $.ajax({
                            url: '@Url.Action("DonemProjesiDegerlendir", "DpBasvuru")',
                            type: 'POST',
                            data: formData,
                            contentType: false, // İçerik tipini false olarak ayarlayın
                            processData: false, // jQuery'nin data'yı işlemesini engelleyin
                            success: function (result) {
                                PanelRefresh(panel, true);
                                if (result.IsSuccess || result.IsRefresh) {
                                    GetDetail(donemProjesiUniqueId);
                                }
                                ShowMmMessage(result.Messages, 'Tamam');
                            },
                            error: function (err) {
                                PanelRefresh(panel, true);
                                alert(err.responseText);
                            }
                        });
                    }
                },
                danger: {
                    label: "Hayır",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
</script>