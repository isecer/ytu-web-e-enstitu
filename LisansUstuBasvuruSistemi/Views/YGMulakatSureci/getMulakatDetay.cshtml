}
<script>

    $(function () {
        $('.icheckbox').iCheck({ checkboxClass: 'icheckbox_minimal-grey', radioClass: 'iradio_minimal-grey' });

        $(function () {
            $('.make-switch')['bootstrapSwitch']();
        });
    })
    function kDownEvent(event,sndr){
        myMask(event, sndr,  false, 5, 3, 2);
    }
    function SnvcheckedChange(sndr) {
        var IsChecked = $(sndr).prop('checked');
        var cls = $(sndr).attr("gsid");
        var $InpGS = $('.' + cls).first();
        if (IsChecked) {
            $InpGS.attr("disabled", "disabled");
            $InpGS.val("");
        }
        else {
            $InpGS.removeAttr("disabled");
            $InpGS.val("");
        }
    }

    $('#AI_filterInp_@(Model.MulakatID)').bind('keypress', function (e) {
        var code = (e.keyCode ? e.keyCode : e.which);
        if (code == 13) {
            flter(this,'@AlanTipi.AlanIci',@(Model.MulakatID));
        }
    });
    $('#AD_filterInp_@(Model.MulakatID)').bind('keypress', function (e) {
        var code = (e.keyCode ? e.keyCode : e.which);
        if (code == 13) {
            flter(this,'@AlanTipi.AlanDisi',@(Model.MulakatID));
        }
    });
    function flter(sndr, type, mulID) {
        var _val = $(sndr).val();
        var tableName = "_fltr_" + mulID;
        var fltrdCol = "_fltrAdS_" + mulID;
        var filtrDurum = "_filtreKelime_" + mulID;
        if (type == '@AlanTipi.AlanIci') {
            tableName = "AI" + tableName;
            fltrdCol = "AI" + fltrdCol;
            filtrDurum = "AI" + filtrDurum;
        }
        else {
            tableName = "AD" + tableName;
            fltrdCol = "AD" + fltrdCol;
            filtrDurum = "AD" + filtrDurum;
        }

        if (_val == null || _val.trim() == "")
        {
            $('#' + tableName).find('.mainRow').removeClass("hide");
            $('#' + filtrDurum).html("");
        }
        else { 
            _val = _val.trim().replaceAll('İ', 'i').toLowerCase();
            var toplam = $('#' + tableName).find('.mainRow').length;
            $('#' + tableName).find('.' + fltrdCol).each(function (inx, filtrx) {
                var gVal = $(filtrx).text().trim().replaceAll('İ','i').toLowerCase();
                var AShow = gVal.indexOf(_val) > -1;
                if (AShow) {
                    $(filtrx).parents('tr.mainRow').first().removeClass('hide');
                }
                else {
                    $(filtrx).parents('tr.mainRow').first().addClass('hide');
                }
            });
            var Gizli = $('#'+tableName).find('.mainRow.hide').length;
            var gosterilen = toplam - Gizli;
            $('#' + filtrDurum).html("[Ara:  %<span style='color:red;'>" + _val + "</span>%] [Bulunan: <span style='color:red;'>" + gosterilen + "</span>]");
        }

    }
