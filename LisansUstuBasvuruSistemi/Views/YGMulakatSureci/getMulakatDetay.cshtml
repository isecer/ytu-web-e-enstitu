@using LisansUstuBasvuruSistemi.Models @using LisansUstuBasvuruSistemi.Models.FilterModel
@using BiskaUtil;
@model bsMulakatDetay
@{
    Layout = null;
    var IsBootBox = (bool)ViewBag.IsBootBox;
    var IsDelete = (bool)ViewBag.IsDelete;
    var nID = !IsBootBox ? Model.MulakatID.ToString() : (Model.BasvuruSurecID + "_" + Model.OgrenimTipKod + "_" + Model.ProgramKod);
    var Id = Model.MulakatID;
    string Color = "color=blue;"; 

    var nowDate = DateTime.Now;
    bool MulakatBilgiGirisAcik = Model.BaslangicTarihi <= nowDate && Model.BitisTarihi >= nowDate;
    bool MulakatNotGirisAcik = Model.SonucGirisBaslangicTarihi.HasValue && Model.SonucGirisBaslangicTarihi <= nowDate && Model.SonucGirisBitisTarihi >= nowDate;
    bool AgnoNotGirisAcik = Model.AGNOGirisBaslangicTarihi.HasValue && Model.AGNOGirisBaslangicTarihi <= nowDate && Model.AGNOGirisBitisTarihi >= nowDate;
    var mAlanIciData = Model.MulakatSonuc.Where(p => p.AlanTipID == AlanTipi.AlanIci).ToList();
    var mAlanDisiData = Model.MulakatSonuc.Where(p => p.AlanTipID == AlanTipi.AlanDisi).ToList();
    var mulakatSGirisyetki = RoleNames.MulakatKayıt.InRoleCurrent();
    var bSurecKayit = RoleNames.BasvuruSureciKayit.InRoleCurrent();
    string _colorAna = "#268a8b";
    string _colorMul = "green";
    string _colorSG = "gray";
    string _colorUyari = "red";

    var NotGirisiAcik = Model.MulakatSurecineGirecek ? (Model.MulakatSurecineGirecek && Model.MulakatID > 0 && mulakatSGirisyetki && (Model.MulakatSinavNotGirisiAktif || UserIdentity.Current.IsAdmin) && Model.SonucHesaplandi == false) : (mulakatSGirisyetki && Model.IsAlesYerineDosyaNotuIstensin && Model.SonucHesaplandi == false);

    var tbName = TabAdlari.MulakatDetayTN + "-" + nID;
}
<div id="bb_MD_@nID">
    <div class="panel panel-success" id="pndMD_@nID">
        <div class="panel-body" style="margin: 0px; padding: 0px;">
            <div class="panel panel-default tabs" style="margin-bottom:0px; padding:0px;">
                <ul class="nav nav-tabs" role="tablist">
                    @if (Model.MulakatSurecineGirecek)
                    {
                        <li class="@(Model.SelectedTabIndex == 1 ? "active" : "") bnt-@tbName-1"><a onclick="tabchangeSet('@tbName',1)" style="cursor:pointer;" role="tab" data-toggle="tab"> <i class="fa fa-book" style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color"></i>&nbsp; <span style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color">Süreç Bilgisi</span></a></li>
                        <li class="@(Model.SelectedTabIndex == 2 ? "active" : "") bnt-@tbName-2"><a onclick="tabchangeSet('@tbName',2)" style="cursor:pointer;" role="tab" data-toggle="tab"> <i class="fa fa-book" style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color"></i>&nbsp; <span style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color">Sınav Notu Girişi (Alan İçi)</span></a></li>
                        <li class="@(Model.SelectedTabIndex == 3 ? "active" : "") bnt-@tbName-3"><a onclick="tabchangeSet('@tbName',3)" style="cursor:pointer;" role="tab" data-toggle="tab"> <i class="fa fa-book" style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color"></i>&nbsp; <span style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color">Sınav Notu Girişi (Alan Dışı)</span></a></li>

                    }
                    else
                    {
                        <li class="@(Model.SelectedTabIndex == 1 ? "active" : "") bnt-@tbName-1"><a onclick="tabchangeSet('@tbName',1)" style="cursor:pointer;" role="tab" data-toggle="tab"> <i class="fa fa-book" style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color"></i>&nbsp; <span style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color">Başvuranlar (Alan İçi)</span></a></li>
                        <li class="@(Model.SelectedTabIndex == 2 ? "active" : "") bnt-@tbName-2"><a onclick="tabchangeSet('@tbName',2)" style="cursor:pointer;" role="tab" data-toggle="tab"> <i class="fa fa-book" style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color"></i>&nbsp; <span style="text-align: right;font-weight: bold;font-size: 11pt;margin: 0px;@Color">Başvuranlar (Alan Dışı)</span></a></li>

                    }
                    @if (!IsDelete)
                    {
                        <li><a href="javascript:void(0);" onclick="getMDDetail('@Id','@Model.BasvuruSurecID','@Model.OgrenimTipKod','@Model.ProgramKod')" class="panel-refresh" title="Yenile"><span class="fa fa-refresh myValueTd" style="@Color"></span></a></li>
                    }
                </ul>
                <div class="panel-body tab-content" style="padding:0px;">
                    <input type="text" id="SelectedTb-@tbName" style="display:none;" value="@Model.SelectedTabIndex" />
                    <table class="table" style="margin:0px;">
                        <tr>
                            <td style="text-align:right;" width="230">Eğitim Öğretim Yılı</td>
                            <td style="width:4px;">:</td>
                            <td style="font-weight:bold;"><span style="color:@(MulakatBilgiGirisAcik || MulakatNotGirisAcik ? _colorMul : _colorSG);">@Model.BaslangicYil / @Model.BitisYil @Model.DonemAdi</span></td>
                        </tr>
                        <tr>
                            <td style="text-align:right;">Başvuru, Mülakat Jüri&Yer Bilgisi Süreci</td>
                            <td>:</td>
                            <td style="font-weight:bold;">
                                @if (MulakatBilgiGirisAcik)
                                {
                                    <span style="color:@_colorMul;">@Model.BaslangicTarihi.ToFormatDateAndTime() / @Model.BitisTarihi.ToFormatDateAndTime() (Aktif)</span>
                                }
                                else
                                {
                                    if (Model.BitisTarihi < nowDate)
                                    {
                                        <span style="color:@_colorSG;">@Model.BaslangicTarihi.ToFormatDateAndTime() / @Model.BitisTarihi.ToFormatDateAndTime() (Pasif)</span>
                                    }
                                    else if (Model.BaslangicTarihi > nowDate)
                                    {
                                        <span style="color:@_colorSG;">@Model.BaslangicTarihi.ToFormatDateAndTime() / @Model.BitisTarihi.ToFormatDateAndTime() (Pasif)</span>
                                    }

                                }
                            </td>
                        </tr>
                        @if (Model.OgrenimTipKod == OgrenimTipi.TezliYuksekLisans)
                        {
                            <tr>
                                <td style="text-align:right;">AGNO Not Giriş Süreci</td>
                                <td>:</td>
                                <td style="font-weight:bold;">
                                    @if (AgnoNotGirisAcik)
                                    {
                                        <span style="color:@_colorMul;">@Model.AGNOGirisBaslangicTarihi.Value.ToFormatDateAndTime() / @Model.AGNOGirisBitisTarihi.Value.ToFormatDateAndTime() (Aktif)</span>
                                    }
                                    else
                                    {
                                        if (Model.AGNOGirisBitisTarihi.HasValue && Model.AGNOGirisBitisTarihi.Value < nowDate)
                                        {
                                            <span style="color:@_colorSG;">@Model.AGNOGirisBaslangicTarihi.Value.ToFormatDateAndTime() / @Model.AGNOGirisBitisTarihi.Value.ToFormatDateAndTime() (Pasif)</span>
                                        }
                                        else if (Model.AGNOGirisBaslangicTarihi.HasValue && Model.AGNOGirisBaslangicTarihi.Value > nowDate)
                                        {
                                            <span style="color:@_colorSG;">@Model.AGNOGirisBaslangicTarihi.Value.ToFormatDateAndTime() / @Model.AGNOGirisBitisTarihi.Value.ToFormatDateAndTime() (Pasif)</span>
                                        }
                                        else
                                        {
                                            <span style="color:@_colorUyari;">Süreç Tarihleri Belirlenmedi</span>
                                        }
                                    }
                                </td>
                            </tr>
                            if (Model.MulakatSonuc.Any(a => a.LOgrenimDurumID == OgrenimDurum.HalenOğrenci))
                            {
                                <tr>
                                    <td style="text-align:right;">Dikkat!</td>
                                    <td>:</td>
                                    <td style="font-weight:bold;color:maroon;">
                                        Henüz mezun olmadığını belirten ve AGNO bilgisi güncel olmayan @Model.MulakatSonuc.Count(a => a.LOgrenimDurumID == OgrenimDurum.HalenOğrenci) adet öğrenci bulunmaktadır.
                                    </td>
                                </tr>
                            }
                        }
                        <tr>
                            <td style="text-align:right;">Mülakat Not Giriş Süreci</td>
                            <td>:</td>
                            <td style="font-weight:bold;">
                                @if (Model.MulakatSurecineGirecek)
                                {
                                    if (MulakatNotGirisAcik)
                                    {
                                        <span style="color:@_colorMul;">@Model.SonucGirisBaslangicTarihi.Value.ToFormatDateAndTime() / @Model.SonucGirisBitisTarihi.Value.ToFormatDateAndTime() (Aktif)</span>
                                    }
                                    else
                                    {
                                        if (Model.SonucGirisBitisTarihi.HasValue && Model.SonucGirisBitisTarihi.Value < nowDate)
                                        {
                                            <span style="color:@_colorSG;">@Model.SonucGirisBaslangicTarihi.Value.ToFormatDateAndTime() / @Model.SonucGirisBitisTarihi.Value.ToFormatDateAndTime() (Pasif)</span>
                                        }
                                        else if (Model.SonucGirisBaslangicTarihi.HasValue && Model.SonucGirisBaslangicTarihi.Value > nowDate)
                                        {
                                            <span style="color:@_colorSG;">@Model.SonucGirisBaslangicTarihi.Value.ToFormatDateAndTime() / @Model.SonucGirisBitisTarihi.Value.ToFormatDateAndTime() (Pasif)</span>
                                        }
                                        else
                                        {
                                            <span style="color:@_colorUyari;">Süreç Tarihleri Belirlenmedi</span>
                                        }
                                    }
                                }
                                else
                                {
                                    <span>Mülakat Sürecine Girmeyecek</span>
                                }
                            </td>
                        </tr>

                        <tr>
                            <td style="text-align:right;">Anabilim Dalı / Program Adı</td>
                            <td>:</td>
                            <td>
                                @Model.AnabilimDaliAdi / @Model.ProgramAdi
                            </td>
                        </tr>
                        <tr>
                            <td style="text-align:right;">Öğrenim Seviyesi</td>
                            <td>:</td>
                            <td>@Model.OgrenimTipAdi</td>
                        </tr>
                        <tr>
                            <td style="text-align:right;">Kota Bilgisi</td>
                            <td>:</td>
                            <td>
                                @if (Model.OrtakKota)
                                {

                                    <div>Ortak Kota: <span style="font-weight:bold">@Model.OrtakKotaSayisi.Value</span></div>
                                }
                                else
                                {
                                    <div>Alan İçi Kota: <span style="font-weight:bold">@Model.AlanIciKota</span>   Alan Dışı Kota: <span style="font-weight:bold">@Model.AlanDisiKota</span></div>
                                }

                            </td>
                        </tr>
                        @*<tr>
                                <td style="text-align:right;">Bilimsel Hazırlık</td>
                                <td style="width:4px;">:</td>
                                <td>@(Model.AlanIciBilimselHazirlik ? "Alan İçi Bilimsel Hazırlık Var" : "Alan İçi Bilimsel Hazırlık Yok"), @(Model.AlanDisiBilimselHazirlik ? "Alan Dışı Bilimsel Hazırlık Var" : "Alan Dışı Bilimsel Hazırlık Yok")</td>
                            </tr>*@
                    </table>

                    @if (Model.MulakatSurecineGirecek)
                    {
                        <div class="tab-pane @(Model.SelectedTabIndex == 1 ? "active" : "") " style="height:350px;overflow-x:auto;" id="@tbName-1">
                            <div class="widget widget-default" style="margin:0px;padding:0px;">
                                <div class="panel-heading padding-0">
                                    <h3 class="panel-title"><i class="fa fa-pencil"></i>&nbsp;Mülakat Sınavı Yer Bilgisi</h3>
                                </div>
                                <div class="panel panel-default form-horizontal" style="margin:0px;">
                                    <table class="table table-hover" style="width:100%;table-layout:fixed;@Color">
                                        <thead>
                                            <tr>
                                                <th width="80">Sınav Türü</th>
                                                <th width="60">% Oranı</th>
                                                <th width="110">S Tarihi</th>
                                                <th width="140">Kampüs</th>
                                                <th>Sınav Yer Adı</th>
                                            </tr>
                                        </thead>
                                        <tbody id="Rw_tbodyD">
                                            @if (Model.MulakatDetay.Count > 0)
                                            {
                                                foreach (var item in Model.MulakatDetay)
                                                {
                                                    <tr>
                                                        <td>
                                                            @item.MulakatSinavTurAdi
                                                        </td>
                                                        <td>
                                                            <span>%@item.YuzdeOran</span>
                                                        </td>
                                                        <td>
                                                            @item.SinavTarihi.ToString("dd-MM-yyyy HH:mm")
                                                        </td>
                                                        <td>
                                                            @item.KampusAdi
                                                        </td>
                                                        <td>
                                                            @item.YerAdi
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="5" style="color:red;font-size:14pt;text-align:center;">
                                                        Sınav yer/saat bilgi girişi yapılmadı
                                                    </td>

                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="panel-heading padding-0" style="margin-top:10px;">
                                    <h3 class="panel-title"><i class="fa fa-group"></i>&nbsp;Mülakat Jüri Bilgisi</h3>
                                </div>
                                <div class="panel panel-default form-horizontal" style="margin:0px;">
                                    <table class="table table-hover" style="width:100%;table-layout:fixed;@Color">
                                        <thead>
                                            <tr>
                                                <th width="60">Sıra No</th>
                                                <th>Jüri Adı</th>
                                                <th width="140">Asil/Yedek</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model.MulakatJuris.Count > 0)
                                            {
                                                foreach (var item in Model.MulakatJuris)
                                                {
                                                    <tr>
                                                        <td>
                                                            @item.SiraNo
                                                        </td>
                                                        <td>
                                                            @item.JuriAdi
                                                        </td>
                                                        <td>
                                                            @(item.IsAsil ? "Asil" : "Yedek")
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="3" style="color:red;font-size:14pt;text-align:center;">
                                                        Jüri bilgi girişi yapılmadı
                                                    </td>

                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    }

                    <div class="tab-pane @(Model.SelectedTabIndex == (Model.MulakatSurecineGirecek ? 2 : 1) ? "active" : "") " id="@tbName-@(Model.MulakatSurecineGirecek ? 2 : 1)">

                        @if ((Model.BitisTarihi < nowDate || true) && mAlanIciData.Count > 0)
                        {
                            <table class="table" style="width:100%;margin:0px;">

                                <tr>
                                    <td style="text-align:right;" width="230">Çıktı Al</td>
                                    <td style="width:4px;">:</td>
                                    <td>
                                        @if (Model.MulakatSonuc.Count > 0)
                                        {
                                            if (Model.MulakatSurecineGirecek && Model.MulakatID > 0)
                                            {
                                                <a href="javascript:void(0);" onclick="yeniDialogBB('','Mülakata Girecek Öğrenci Listesi','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.BasvuruSonucListesiBolum&MulakatID=@Model.MulakatID&AlanTipID=@AlanTipi.AlanIci&PuanlarGozuksun=false','auto','modal-dialog modal-lg')">

                                                    <span style="font-size:14pt;" title="Yazdır" class="fa fa-print"></span> Mülakata Girecek Öğrenci Listesi
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="javascript:void(0);" onclick="yeniDialogBB('','Başvuru Yapan Öğrenci Listesi','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.BasvuruOgrenciListesi&BasvuruSurecID=@Model.BasvuruSurecID&AlanTipID=@AlanTipi.AlanIci&OgrenimTipKod=@Model.OgrenimTipKod&ProgramKod=@Model.ProgramKod&PuanlarGozuksun=false','auto','modal-dialog modal-lg')">
                                                    <span style="font-size:14pt;" title="Yazdır" class="fa fa-print"></span> Başvuru Yapan Öğrenci Listesi
                                                </a>
                                            }
                                        }
                                        <span id="_AISonucRapor">
                                            @if (Model.MulakatSonuc.Any(p => p.MulakatSonucTipID != MulakatSonucTipi.Hesaplanmadı) && Model.MulakatID > 0)
                                            {

                                                <a href="javascript:void(0);" onclick="getReportTypeBB(@Model.BasvuruSurecID,@AlanTipi.AlanIci,'@Model.AnabilimDaliKod','@Model.ProgramKod')">
                                                    <span style="font-size:14pt;" title="Yazdır" class="fa fa-print"></span> Başvuru Sonuç Listesi
                                                </a>

                                            }
                                            else if (Model.MulakatSurecineGirecek && Model.MulakatSonuc.Count(c => c.AlanTipID == AlanTipi.AlanIci) > 0 && Model.MulakatSonuc.Count(p => p.AlanTipID == AlanTipi.AlanIci && p.SuccessRow) == Model.MulakatSonuc.Count(c => c.AlanTipID == AlanTipi.AlanIci))
                                            {
                                                <a href="javascript:void(0);" onclick="yeniDialogBB('','Mülakat Sonuç Öğrenci Listesi','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.BasvuruSonucListesiBolum&MulakatID=@Model.MulakatID&AlanTipID=@AlanTipi.AlanIci&PuanlarGozuksun=true&SadecePuanliListe=true','auto','modal-dialog modal-lg')">

                                                    <span style="font-size:14pt;" title="Yazdır" class="fa fa-print"></span> Mülakat Sonuç Öğrenci Listesi
                                                </a>
                                            }
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        }
                        <div class="widget widget-default" style="margin:0px;padding:0px;">
                            <div class="panel-heading padding-0">
                                <h3 class="panel-title"><i class="fa fa-group"></i>&nbsp; Alan İçi @(mAlanIciData.Count > 0 ? " Başvuran (" + mAlanIciData.Count + " Kişi)" : " başvuran yok")</h3>
                                <table style="float:right;">
                                    <tbody>
                                        <tr>
                                            <td style="padding-right: 2px; padding-left: 2px; " class="text-center" id="AI_filtreKelime_@Model.MulakatID"></td>
                                            <td><input style="color:red;" type="text" name="search" id="AI_filterInp_@Model.MulakatID" placeholder="ara..."></td>

                                            <td><a href="javascript:void(0);" onclick="flter($('#AI_filterInp_@Model.MulakatID'),'@AlanTipi.AlanIci',@Model.MulakatID)" class="label label-warning panel-refresh"> Ara</a></td>
                                            @if (NotGirisiAcik)
                                            {
                                                <td style="width:120px;text-align:right;">
                                                    @if (mAlanIciData.Count > 0)
                                                    {
                                                        <a onclick="Kaydet(@Model.MulakatID,@AlanTipi.AlanIci,@mAlanIciData.Count)" href="javascript:void(0);" class="btn btn-success"><i class="fa fa-save">&nbsp;</i>Kaydet</a>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    </tbody>
                                </table>

                            </div>
                            <div class="panel panel-default form-horizontal" style="margin:0px;">
                                <table class="table " style="@Color">
                                    <thead>
                                        <tr>
                                            <th width="40">S.No</th>
                                            <th>Ad Soyad</th>
                                            @if (!Model.SonucHesaplandi && bSurecKayit && Model.AlanDisiKota > 0)
                                            {
                                                <th width="75">

                                                </th>
                                            }
                                            <th width="80">@(Model.IsAlesYerineDosyaNotuIstensin ? "Dosya Notu" : "Ales Notu")</th>
                                            <th width="70">AGNO</th>
                                            @if (Model.MulakatSurecineGirecek)
                                            {
                                                <th width="110">Yzl.Notu</th>
                                                <th width="110">Szl.Notu</th>
                                                <th width="35" title="Bilimsel Hazırlık">B.Haz</th>
                                            }
                                            <th width="19"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td colspan="9">
                                                <div style="height:276px;overflow-y:scroll;">
                                                    <table id="AI_fltr_@Model.MulakatID" class="table table-hover alantip_@(Model.MulakatID + "_" + AlanTipi.AlanIci)" style="width:100%;table-layout:fixed;margin:0px;">
                                                        @{
                                                            int inx = 1;
                                                            foreach (var item in mAlanIciData)
                                                            {
                                                                <tr class="mainRow bstR_@item.BasvuruTercihID" style="color:@((item.SuccessRow || (!item.MulakatSurecineGirecek && !Model.IsAlesYerineDosyaNotuIstensin)) ? "green;" : "red;") @(item.LOgrenimDurumID.HasValue && item.LOgrenimDurumID == OgrenimDurum.HalenOğrenci ? "font-weight:bold;" : "")">
                                                                    <td width="40" style="font-size:11pt;font-weight:bold;">
                                                                        @(inx++)
                                                                        <input type="text" style="display:none;" name="BasvuruTercihID" value="@item.BasvuruTercihID" />
                                                                    </td>
                                                                    <td>
                                                                        <table>
                                                                            <tr>
                                                                                <td style="width:22px;" title="öğrenciyi gör">
                                                                                    <i class="fa fa-eye bstR_@item.BasvuruTercihID" style="color:@((item.SuccessRow || (!item.MulakatSurecineGirecek && !Model.IsAlesYerineDosyaNotuIstensin)) ? "green" : "red");cursor:pointer;" onclick="getDetailOgr('@item.BasvuruID')"></i>
                                                                                </td>
                                                                                <td title="öğrenciyi gör">
                                                                                    <span class="AI_fltrAdS_@Model.MulakatID" style="cursor:pointer;" onclick="getDetailOgr('@item.BasvuruID')">
                                                                                        @item.AdSoyad
                                                                                    </span>
                                                                                </td>
                                                                            </tr>
                                                                        </table>
                                                                    </td>
                                                                    @if (!Model.SonucHesaplandi && bSurecKayit && Model.AlanDisiKota > 0)
                                                                    {
                                                                        <td width="75">
                                                                            <span title="Alan dışına aktar" style="cursor:pointer;font-size:8pt;" onclick="AlanTipDegistir('@item.UniqueID','@item.AdSoyad',false)">A.D Aktar  <i class="fa fa-fast-forward fa-lg"></i></span>

                                                                        </td>
                                                                    }
                                                                    <td width="80">
                                                                        @if (NotGirisiAcik && Model.IsAlesYerineDosyaNotuIstensin)
                                                                        {
                                                                            <input type="text" name="AlesNotuOrDosyaNotu" class="DosyNot_@item.BasvuruTercihID" onkeydown="kDownEvent(window.event,this)" style="width:65px;height:20px;" value="@item.AlesNotuOrDosyaNotu" />
                                                                        }
                                                                        else
                                                                        {
