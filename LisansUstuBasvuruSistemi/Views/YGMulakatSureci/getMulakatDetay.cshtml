    function Kaydet(mlktID, aTip, cnt) {
        var _panel = $('#pndMD_' + '@nID');
        var _tAtip=aTip=='@AlanTipi.AlanIci'?"AI":"AD";
        var _BilimselHazirlik = "[";
        var _BasvuruTercihID = "[";
        var _GirisSinavNotuY = "[";
        var _GirisSinavNotuS = "[";
        var _SinavaGirmediY = "[";
        var _SinavaGirmediS = "[";
        var _AlesNotuOrDosyaNotu = "[";
        $('.alantip_' + mlktID + "_" + aTip).find('.mainRow').each(function (inx, trx) {
            var BTercihID = $(trx).find('input[name=BasvuruTercihID]').first().val();
            var bilhaz = $(trx).find('input[name=BilimselHazirlikVar]').first().prop("checked");

            bilhaz = bilhaz == true;
            _BasvuruTercihID += (inx > 0 ? "," : "") + "'" + BTercihID + "'";
            _BilimselHazirlik += (inx > 0 ? "," : "") + "'" + bilhaz + "'";

            if ('@Model.YaziliNotuIstensin.ToString().ToLower()' == 'true') {
                var YaziliNotu = $(trx).find('input[name=YaziliNotu]').first().val();
                var SGirmediY = $(trx).find('input[name=SinavaGirmediY]').first().prop("checked");
                _GirisSinavNotuY += (inx > 0 ? "," : "") + "'" + YaziliNotu + "'";
                _SinavaGirmediY += (inx > 0 ? "," : "") + "'" + SGirmediY + "'";
            }
            else {
                _GirisSinavNotuY += (inx > 0 ? "," : "") + "''";
                _SinavaGirmediY += (inx > 0 ? "," : "") + "''";
            }
            if ('@Model.SozluNotuIstensin.ToString().ToLower()' == 'true') {
                var SozluNotu = $(trx).find('input[name=SozluNotu]').first().val();
                var SGirmediS = $(trx).find('input[name=SinavaGirmediS]').first().prop("checked");
                _GirisSinavNotuS += (inx > 0 ? "," : "") + "'" + SozluNotu + "'";
                _SinavaGirmediS += (inx > 0 ? "," : "") + "'" + SGirmediS + "'";
            }
            else {

                _GirisSinavNotuS += (inx > 0 ? "," : "") + "''";
                _SinavaGirmediS += (inx > 0 ? "," : "") + "''";
            }
            if ('@Model.IsAlesYerineDosyaNotuIstensin.ToString().ToLower()' == 'true') {
                var DNot = $(trx).find('input[name=AlesNotuOrDosyaNotu]').first().val();
                _AlesNotuOrDosyaNotu += (inx > 0 ? "," : "") + "'" + DNot + "'";
            }
            else {

                _AlesNotuOrDosyaNotu += (inx > 0 ? "," : "") + "''";
            }
        });
        _BasvuruTercihID += "]";
        _GirisSinavNotuY += "]";
        _GirisSinavNotuS += "]";
        _SinavaGirmediY += "]";
        _SinavaGirmediS += "]";
        _BilimselHazirlik += "]";
        _AlesNotuOrDosyaNotu += "]";
        var frmD = {
            "MulakatID": mlktID,
            "BasvuruSurecID": '@Model.BasvuruSurecID',
            "IsAlesYerineDosyaNotuIstensin": '@Model.IsAlesYerineDosyaNotuIstensin.ToString().ToLower()',
            "MulakatSurecineGirecek": '@Model.MulakatSurecineGirecek.ToString().ToLower()',
            "ProgramKod": '@Model.ProgramKod',
            "OgrenimTipKod": '@Model.OgrenimTipKod',
            "AlanTipID": aTip,
            "BasvuruTercihID": eval(_BasvuruTercihID),
            "SinavaGirmediY": eval(_SinavaGirmediY),
            "YaziliNotu": eval(_GirisSinavNotuY),
            "SinavaGirmediS": eval(_SinavaGirmediS),
            "SozluNotu": eval(_GirisSinavNotuS),
            "BilimselHazirlikVar": eval(_BilimselHazirlik),
            "AlesNotuOrDosyaNotu": eval(_AlesNotuOrDosyaNotu)
        };
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("GirisSinavNotuKaydet", "YGMulakatSureci")',
            type: 'POST',
            enctype: "multipart/form-data",
            cache: false,
            dataType: "json",
            data: frmD,
            success: function (result) {
                var tamamOlan=0;
                for (var i = 0; i < result.ColorSet.Data.length; i++) {
                    var xRw= result.ColorSet.Data[i];
                    if(xRw.Value=="green")tamamOlan+=1;
                    $('.bstR_'+xRw.Key).css("color",xRw.Value);
                }
                $('#nGirisEksikC_' + mlktID + "_" + _tAtip).html("Eksik Olan: "+(result.ColorSet.Data.length-tamamOlan));
                $('#nGirisTamamC_' + mlktID + "_" + _tAtip).html("Tamamlanan: "+tamamOlan);
                if(result.ColorSet.Data.length-tamamOlan==0){
                    var _lnkUrl = "<a href='javascript:void(0);' onclick=yeniDialogBB('','Mülakat Sonuç Öğrenci Listesi','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.BasvuruSonucListesiBolum&MulakatID=@Model.MulakatID&AlanTipID='"+aTip+"'&PuanlarGozuksun=true&SadecePuanliListe=true','auto','modal-dialog modal-lg')><span style='font-size:14pt;' title='Yazdır')' class='fa fa-print'></span> Mülakat Sonuç Öğrenci Listesi</a>"  ;
                    $('#_'+_tAtip+'SonucRapor').html(_lnkUrl);
                }
                else {
                    $('#_'+_tAtip+'SonucRapor').html("");
                }
                showMmMessage(result.Messages, 'Tamam');
                _pRefresh(_panel, true);
            },
            error: function (err) {
                alert(err.responseText);
                _pRefresh(_panel, true);

            }
        });
    }
