            title: "Alan değiştirme işlemi",
            buttons: {
                success: {
                    label: 'Evet',
                    className: "btn-danger",
                    callback: function () {
                        var id = '@Model.BasvuruSurecID';
                        var _panel = $('#pndMD_' + '@nID');
                        _pRefresh(_panel, false);
                        $.ajax({
                            url: '@Url.Action("AlanDegistirmeIslemi", "MulakatSureci")',
                            data: { UniqueID: UniqueID, IsAlanIciOrDisi: IsAlanIciOrDisi },
                            success: function (result) {
                                _pRefresh(_panel, true);
                                if (result.Messages.length > 0)
                                    showMmMessage(result.Messages, 'Tamam');

                                getMDDetail('@Id', '@Model.BasvuruSurecID', '@Model.OgrenimTipKod', '@Model.ProgramKod');

                            },
                            error: function (err) {
                                alert(err.responseText);
                                _pRefresh(_panel, true);
                            }
                        });
                    }
                },
                danger: {
                    label: 'Hayır',
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
