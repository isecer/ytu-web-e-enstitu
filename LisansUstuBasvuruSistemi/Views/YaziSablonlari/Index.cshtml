@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.Helpers
@model  FmYaziSablonlariDto
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Şablon Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-info label-form" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Kayit")'"><i class="fa fa-plus" aria-hidden="true"></i> Yeni Yazı Şablonu Ekle</span></li>

                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="EnstituAdi" width="150">Enstitü Adı</th>
                                <th class="sirala" field="Konu">Yazı Konusu</th>
                                <th class="sirala" field="IsAktif" width="65">Durum</th>
                                <th width="80"> </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    <input name="Konu" type="text" value="@Model.Konu" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.YaziSablonlariDtos)
                                {
                                    rowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.YaziSablonlariID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.YaziSablonlariID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>@item.EnstituAdi</td>
                                        <td id="tdMad_@item.YaziSablonlariID">@item.SablonTipAdi <br />Konu: @item.Konu</td>
                                        <td id="tdIa_@item.YaziSablonlariID" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "YaziSablonlari", new { id = item.YaziSablonlariID })"><i class="fa fa-edit fa-lg  tooltips" title="Düzelt"></i></a>
                                            <a href="javascript:void(0);" onclick="YeniDialogBB('@item.Konu','@Url.Action("ShowYazi", "YaziSablonlari")?id=@item.YaziSablonlariID' , 'auto', 'modal-dialog modal-lg' )">
                                                <i class="fa fa-eye fa-lg tooltips" title="Önizleme"></i>
                                            </a>
                                            <a href="@Url.Action("Kayit", "YaziSablonlari", new { id = item.YaziSablonlariID,isKopya=true })"><i class="fa fa-copy  fa-lg  tooltips" title="Kopya Aç"></i></a>
                                            <a href="javascript:void(0)" onclick="SilmeOnay(this,'@item.YaziSablonlariID')"><i class="fa fa-trash-o  fa-lg tooltips" title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.YaziSablonlariID" style="display:none">
                                        <td id="cls-@item.YaziSablonlariID" colspan="7" style="padding: 1px 1px 2px 75px;">
                                            <div  class="panel panel-success">

                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-primary form-horizontal" style="margin-bottom: 0px;">
                                                        <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body form-group-separated">
                                                                @if (item.Parametreler.IsNullOrWhiteSpace() == false)
                                                                {
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Parametreler</label>
                                                                        <div class="col-md-9">@item.Parametreler</div>
                                                                    </div>

                                                                }
                                                                <div class="form-group">
                                                                    <label class="col-md-3 control-label">Yazı Konusu</label>
                                                                    <div class="col-md-9">@item.Konu</div>
                                                                </div>

                                                                <div class="form-group">
                                                                    <div class="col-md-12 col-xs-12" style="text-align: left;">
                                                                        <div class="panel panel-primary" style="margin:0px;padding:0px;">
                                                                            <div class="panel-body" style="padding-right:0px;padding-top:2px;padding-bottom:2px;">
                                                                                @Html.Raw(item.SablonHtml)
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label class="col-md-3 control-label">İşlem Yapan</label>
                                                                    <div class="col-md-9">@item.IslemYapan [@item.IslemTarihi.ToFormatDateAndTime()]</div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function ShowDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function SilmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message:   gMesaj + " <br/> Seçilen Yazı Şablonunu Silmek İstiyor Musunuz?",
            title: "Yazı Şablonu Silme İşlemi",
            buttons: {
                success: {
                    label: "Yazı Şablonunu Sil",
                    className: "btn-danger",
                    callback: function () {
                        Sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function Sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "YaziSablonlari")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Sistem Şablonu Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
