                                                    </div>
                                                    <script>
                                                        function getDSinavTip(SinavTipID, sinavTipGrupID) {

                                                            var _OgrenimTipKods = "[";
                                                            var _ProgramKods = "[";
                                                            var _Ingilizces = "[";
                                                            $('#Rw_tbody').find('.blgTD').each(function (inx, tdx) {
                                                                var _otipID = $(tdx).find('input[name=_OgrenimTipKod]').val();
                                                                var _ing = $(tdx).find('input[name=_Ingilizce]').val();
                                                                var _ProgramKod = $(tdx).find('input[name=_ProgramKod]').val();
                                                                _OgrenimTipKods += (inx > 0 ? "," : "") + "'" + _otipID + "'";
                                                                _Ingilizces += (inx > 0 ? "," : "") + "'" + _ing + "'";
                                                                _ProgramKods += (inx > 0 ? "," : "") + "'" + _ProgramKod + "'";
                                                            })
                                                            _OgrenimTipKods += "]";
                                                            _Ingilizces += "]";
                                                            _ProgramKods += "]";
                                                            var _selectedT = "";
                                                            var frmD = {
                                                                "SinavTipGrupID": sinavTipGrupID,
                                                                "BasvuruSurecID":@Model.BasvuruSurecID,
                                                            "OgrenimTipKods": eval(_OgrenimTipKods),
                                                                "Ingilizces": eval(_Ingilizces),
                                                                    "ProgramKods": eval(_ProgramKods)
                                                        };
                                                        var $dst = $('#DSinavTipID');
                                                        var $dstV = $('#DWsSinavDonem');
                                                        var $dstVs = $('#DWsIsWebService');
                                                        if (sinavTipGrupID == '@SinavTipGrup.Ales_Gree') {
                                                            $dst = $('#ASinavTipID');
                                                            $dstV = $('#AWsSinavDonem');
                                                            $dstVs = $('#AWsIsWebService');
                                                        }
                                                        else if (sinavTipGrupID == '@SinavTipGrup.DilSinavlari') {
                                                            $dst = $('#DSinavTipID');
                                                            $dstV = $('#DWsSinavDonem');
                                                            $dstVs = $('#DWsIsWebService');
                                                        }
                                                        else {
                                                            $dst = $('#TSinavTipID');
                                                            $dstV = $('#TWsSinavDonem');
                                                            $dstVs = $('#TWsIsWebService');
                                                        }

                                                        $dst.empty();
                                                        $.ajax({
                                                            url: '@Url.Action("dAktifSinavlar", "Ajax")',
                                                            type: 'POST',
                                                            enctype: "multipart/form-data",
                                                            cache: false,
                                                            dataType: "json",
                                                            // async: false,
                                                            data: frmD,
                                                            success: function (result) {
                                                                var opt = "";
                                                                for (var i = 0; i < result.length; i++) {
                                                                    opt += "<option " + (SinavTipID == result[i].Value ? "selected=selected" : "") + " value=" + result[i].Value + ">" + result[i].Caption + "</option>"
                                                                }
                                                                $dst.append(opt);
                                                                if (sinavTipGrupID == '@SinavTipGrup.Ales_Gree') {
                                                                    if (result.length == 0) {
                                                                        $('#AlesIstensinmi').val("false");
                                                                        $('._Alessinavi').addClass("hide");
                                                                    }
                                                                    else {
                                                                        $('#AlesIstensinmi').val("true");
                                                                        $('._Alessinavi').removeClass("hide");
                                                                    }
                                                                }
                                                                if (sinavTipGrupID == '@SinavTipGrup.DilSinavlari') {
                                                                    if (result.length == 0) {
                                                                        $('#DilIstensinmi').val("false");
                                                                        $('._dilsinavi').addClass("hide");
                                                                    }
                                                                    else {
                                                                        $('#DilIstensinmi').val("true");
                                                                        $('._dilsinavi').removeClass("hide");
                                                                        //getSinavTip($dst,sinavTipGrupID,_selectedT);
                                                                    }
                                                                }

                                                                _selectedT = $dstV.val();
                                                                getSinavTip($dst,sinavTipGrupID,_selectedT);
                                                                // if($dstVs.val()=="true")
                                                              //  getSinavTip($dst, sinavTipGrupID, _selectedT);


                                                            },
                                                            error: function (err) {
                                                                alert(err.responseText);

                                                            }
                                                        });
                                                   }
                                                    </script>
                                                </div>
