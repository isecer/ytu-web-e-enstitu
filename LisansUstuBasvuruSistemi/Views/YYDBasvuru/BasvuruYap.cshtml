    function postD(frmData, step) {
        $.ajax({
            url: '@Url.Action("ValidationControlSteps", "Ajax")',
            type: 'POST',
            enctype: "multipart/form-data",
            cache: false,
            dataType: "json",
            data: frmData,
            success: function (result) {
                if (result.sbmtForm) {
                    if (result.EkAciklamalar != "") {
                        bootbox.dialog({
                            message: result.EkAciklamalar,
                            buttons: {
                                danger: {
                                    label: 'Başvuruyu Tamamla',
                                    className: "btn-primary",
                                    callback: function () {
                                        $('#bsvrSbmtFrm').submit();
                                    }
                                }
                            }
                        });
                    }
                    else if (result.AnketGiris != "") {
                        var btbxxFS = bootbox.dialog({
                            message: result.AnketGiris,
                            //title: "<i class='fa fa-pencil'></i> Anket Sorusu Ekleme İşlemi",
                            buttons: {
                                success: {
                                    label: 'Başvuruyu Tamamla',
                                    className: "btn-primary",
                                    callback: function (event) {
                                        var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                        _pRefresh(pnlx, false);
                                        $('#FrmAnket').ajaxForm({
                                            success: function (result) {
                                                if (result.IsSuccess) {
                                                    var _clsBtn = $('.modal-header').find('button').first();
                                                    $(_clsBtn).click();
                                                    $('#bsvrSbmtFrm').submit();
                                                }
                                                else {
                                                    getMsg(result);
                                                    return false;
                                                }
                                                _pRefresh(pnlx, true);
                                            },
                                            complete: function (cmp) {
                                                _pRefresh(pnlx, true);
                                            },
                                            error: function (err) {
                                                _pRefresh(pnlx, true);
                                            }

                                        });
                                        $('#FrmAnket').submit();
                                        return false;
                                    }
                                }
                            }
                        });
                        $(btbxxFS).find('.modal-dialog').first().addClass('modal-lg');
                    }
                    else {

                        $('#bsvrSbmtFrm').submit();
                    }
                }
                else if (result._MmMessage.IsSuccess) {
                    setActSelectedStep(parseInt(step) + 1);
                }
                if (step == 2) {
                    getalanlariKontrolEt();
                    if (result.ShowEgitimDili) {
                        $('#dvLEgitimDiliTurkce').removeClass('hide');
                        if (result.YLDurum) $('#dvYLEgitimDiliTurkce').removeClass('hide');
                        else $('#dvYLEgitimDiliTurkce').addClass('hide');

                            $('#pnlSnv_T').removeClass('hide');

                    }
                    else {
                        $('#dvLEgitimDiliTurkce').addClass('hide');
                        $('#dvYLEgitimDiliTurkce').addClass('hide');
                        $('#pnlSnv_T').addClass('hide');
                    }
                }
                getMsgb(result._MmMessage, step);

            },
            error: function (err) {
                alert(err.responseText);

            }
        });
    }


    function getMsgb(result, step) {
        if (result.IsSuccess == false) {
            var cls = result.MessageType == 1 ?
                'success' : (result.MessageType == 3 ? 'warning' : (result.MessageType == 2 ? 'danger' : 'info'));
            var pnlStrt = "<div class=panel panel-" + cls + "  style='margin-bottom:3px;'> <div class='panel-body panel-body-pricing'>";
            if (result.Title != "") {
                pnlStrt += "<h3 style='font-size:10pt;' class=text-" + cls + ">" + result.Title + "</h3>";
            }
            var _msgs = "";
            for (var i = 0; i < result.Messages.length; i++) {

                _msgs += "<p style='margin: 0px; padding: 0px;'><span style='color:red;' class='fa fa-caret-right'></span>&nbsp " + result.Messages[i] + "</p>";
            }
            var pnlEnd = "</div></div>";
            $('#msgsB').html(pnlStrt + _msgs + pnlEnd);
            bootbox.dialog({
                message: $('#msgsB').html(),
                buttons: {
                    danger: {
                        label: 'Tamam',
                        className: "btn-success",
                        callback: function () {
                        }
                    }
                }
            });

        }
        validateControl(null, result);
    }




    var model = '@Html.Raw(Json.Encode(_MmMessage))';
    validateControl(model);

</script>


