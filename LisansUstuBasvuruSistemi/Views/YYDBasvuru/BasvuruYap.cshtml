            $('#rwSubOT').addClass('hide');
            rowID = "otBilgi";
            $('#otBilgi').removeClass('hide');
            $('#SotBilgi').addClass('hide');

        }
        else {
            rowID = "SotBilgi";
            $('#otBilgi').addClass('hide');
