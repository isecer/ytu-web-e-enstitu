            else $('.lOdurumBilgi').addClass('hide');
        }
        if (sndrVal != null && sndrVal != "") {
            $.ajax({
                url: '@Url.Action("getBolumler", "Ajax")',
                data: { 'BasvuruSurecID': _BasvuruSurecID, 'otKod': sndrVal, 'KTipID': kTipID },
                success: function (result) {
                    $('#AnabilimdaliKod').empty();
                    var opt = "";
                    for (var i = 0; i < result.data.length; i++) {
                        var valR = result.data[i].Value;
                        var _value = "";
                        if (valR != null) {
                            _value = valR;
                        }
                        opt += "<option value=" + _value + ">" + result.data[i].Caption + "</option>"
                    }
                    _pRefresh(_panel, true);
                    if (result.IsSubOT) {
                        $('#otBilgi').addClass('hide');
                        $('#SotBilgi').removeClass('hide');
                        $('#SubOgrenimTipKod').empty();
                        $('#rwSubOT').removeClass("hide");
                        $('#SubOgrenimTipKod').append(opt);
                    }
                    else {
                        $('#AnabilimdaliKod').append(opt);
                        getOgrenimSBilgi(sndrVal, rowID, result.YLShow);
                    }
                },
                error: function (err) {
                    $('#otBilgi').addClass('hide');
                    alert(err.responseText);
                    _pRefresh(_panel, true);

                }
            });
        }
        else {
            $('#otBilgi').addClass('hide');
            if ($(sndr).attr("id") != "SubOgrenimTipKod") {
                $('#SotBilgi').addClass('hide');
                $('#rwSubOT').addClass('hide');
            }
            if ($(sndr).attr("id") != "AnabilimdaliKod") $('#AnabilimdaliKod').empty();
            $('#ProgramKod').empty();
            _pRefresh(_panel, true);
            yLBilgisiIstendimi();
        }
    }

