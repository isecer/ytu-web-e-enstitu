    function tercihBDOTkontrol(_OtKod) {
        var trchKalankota = $('.TercihKalanKota').text();
        var trchkota = $('.TercihKota').text();
        var topkota = $('.ToplamKalanTercihKota').text();
        var TipfkOtEklenemez = $('.BasvuruSurecKontrolTipID').text();
        var fkOtEklenemez = $('.FarkliOgrenimTipiEklenemez').text();
        var fkOtEklenemezAB = $('.FarkliOgrenimTipiEklenemezAyniBasvuruda').text();
        var fkOtEklenemezAds = $('.FarkliOgrenimTipiEklenemezAds').text();
        var bbOtKod = $('.BasvurulabilecekDigerOgrenimTipleriKods').text();
        var bbOtIsSuccess = false;
        var ayniCount = 0;
        var toplRow = 0;
        $('#Rw_tbody').find('li').each(function (inx, trx) {
            var _rwClss = $(trx).attr("class").split(" ")[2];
            var _gOtKod = $(trx).find('input[name=_OgrenimTipKod]').first().val();
            if (_gOtKod == _OtKod) ayniCount++;
            toplRow++;
            if (bbOtKod != "" && bbOtKod != null) {
                var bbotKods = bbOtKod.split(',');
                for (var i = 0; i < bbotKods.length; i++) {
                    var _gbbotKods = bbotKods[i];
                    if (_gOtKod == _gbbotKods) bbOtIsSuccess = true;
                }
            }
            else {
                if (_gOtKod == _OtKod) bbOtIsSuccess = true;
            }
        });

        if (bbOtIsSuccess == false && $('#Rw_tbody').find('li').length > 0) {
            showMessage("warning", 'Dikkat', 'Eğer bu öğrenim tipinde bir başvuru tercihi yapacaksanız başka bir öğrenim tipinde tercih eklememiş olmanız gerekmektedir!');
            return false;
        }
        if (fkOtEklenemez == "true") {
            var msgVal = "";
            if (TipfkOtEklenemez == '@KotaHesapTipleri.SeciliBasvuruSureci') {
                msgVal = 'Bu öğrenim tipi tercih olarak seçilecekse bu başvuru sürecinde (xXx) öğrenim tipi ile başvurunuzun olmaması gerekmektedir!';
            }
            else {
                msgVal = 'Bu öğrenim tipi tercih olarak seçilecekse bu başvuru sürecinde (xXx) öğrenim tipi ile başvurunuzun olmaması gerekmektedir!';

            }
            showMessage("warning", 'Dikkat', msgVal.replace("xXx", fkOtEklenemezAds));
            return false;
        }
        if (toplRow > parseInt(topkota)) {
            var msgVal = "";
            if (TipfkOtEklenemez == '@KotaHesapTipleri.SeciliBasvuruSureci') {
                msgVal = 'Ekleyebileceğiniz toplam tercih sayısını doldurdunuz! Yeni tercih ekleyemezsiniz.';
            }
            else {
                msgVal = 'Ekleyebileceğiniz toplam tercih sayısını doldurdunuz! Yeni tercih ekleyemezsiniz.';
            }
            showMessage("warning", 'Dikkat', msgVal);
            return false;
        }
        if ((ayniCount > parseInt(trchkota) || parseInt(trchKalankota) <= 0)) {
            var msgVal = "";
            if (TipfkOtEklenemez == '@KotaHesapTipleri.SeciliBasvuruSureci') {
                msgVal = 'Seçtiğiniz öğrenim tipi için toplam tercih sayısını doldurdunuz! Yeni tercih ekleyemezsiniz.';
            }
            else {
                msgVal = 'Seçtiğiniz öğrenim tipi için toplam tercih sayısını doldurdunuz! Yeni tercih ekleyemezsiniz.';
            }
            showMessage("warning", 'Dikkat', msgVal);
            return false;
        }
        if (fkOtEklenemezAB == "true") {
            var msgVal = 'Eğer bu öğrenim tipinde bir başvuru tercihi yapacaksanız bu başvuru için başka bir öğrenim tipinde tercih eklememiş olmanız gerekmektedir. Yeni bir başvuruda tercihinizi ekleyebilirsiniz.';
            showMessage("warning", 'Dikkat', msgVal);
            return false;
        }
        return true;
    }
