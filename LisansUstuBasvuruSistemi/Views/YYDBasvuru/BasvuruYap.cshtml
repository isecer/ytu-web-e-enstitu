    function NotConvert(IdN, BasvuruSurecSinavTipID) {
        var tip = $('#' + IdN + 'SubSinavAralikID').val();
        var Stip = BasvuruSurecSinavTipID;
        var Puan = $('#' + IdN + 'BasvuruSurecSubNot').val();
        if (Puan.trim() == "" || tip == "") {
            $('#alsKarsiligi').text("");
            $('#' + IdN + 'SinavNotu').val("");
            $('.dvAlesK').addClass('hide');
        }
        else {
            $.ajax({
                url: '@Url.Action("getFormul", "YYDBasvuru")',
                data: { 'BasvuruSurecSinavTipID': Stip, 'SubSinavAralikID': tip, 'Puan': Puan },
                success: function (result) {
                    $('.dvAlesK').removeClass('hide');
                    $('#alsKarsiligi').text(result.Sonuc);
                    $('#' + IdN + 'SinavNotu').val(result.Sonuc);
                },
                error: function (err) {
                    alert(err.responseText);
                }
            });
        }
    }
    function MezuniyetNotConvert(IdN, propID) {

        var nsID = $('#' + IdN + 'NotSistemID').val();
        if (nsID == "100" || nsID == "") return;
        var Puan = $('#' + IdN + 'MezuniyetNotu').val();
        if (Puan.trim() == "" || Puan.trim() == "0") {
            $(propID).html("");
        }
        else {
            $.ajax({
                url: '@Url.Action("NotKontrol", "YYDBasvuru")',
                data: { 'NotSistemID': nsID, 'Puan': Puan.replace(",", ".") },
                success: function (result) {
                    $(propID).html("100'Lük Karşılığı" + result.Deger);
                },
                error: function (err) {
                    alert(err.responseText);
                }
            });
        }
    }
