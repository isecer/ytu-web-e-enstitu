<script type="text/javascript">

    var nextTxt = 'İleri';
    var prvText = 'Geri';
    var kydet = 'Kaydet';

    $('#myWizard').easyWizard({
        'stepClassName': 'content',
        'showSteps': false,
        'stepsText': '{n}. {t}',
        'showButtons': true,
        'buttonIleriClass': 'btn btn-default pull-right',
        'buttonGeriClass': 'btn btn-default pull-left',
        'prevButton': prvText,
        'nextButton': nextTxt,
        'debug': false,
        'submitButton': true,
        'submitButtonText': kydet,
        'submitButtonClass': 'btn btn-primary pull-right',
    });



    $(function () {
        btnkKontrol();
        $('#myWizard').find(".content").css("display", "");
        $('._popover').popover({ trigger: 'hover' });
        //$('#TcKimlikNo').simpleMask({ 'mask': '###########' });
        $('#CiltNo').simpleMask({ 'mask': '####' });
        $('#AileNo').simpleMask({ 'mask': '#######' });
        $('#SiraNo').simpleMask({ 'mask': '####' });



    })
    $('#bsvrSbmtFrm').find('input').each(function (ix, inx) {
        $(inx).attr('autocomplete', 'off');
        $(inx).bind('keyup', function (e) {
            if (e.which >= 97 && e.which <= 122) {
                var newKey = e.which - 32;
                // I have tried setting those
                e.keyCode = newKey;
                e.charCode = newKey;

            }
            if (e.which != 91 && e.which != 32 && e.which != 8 && e.which != 46 && e.which != 39 && e.which != 37 && e.which != 38 && e.which != 40 && e.which != 16 && e.which != 17 && e.which != 18) {
                if (inx.id != "EMail" && inx.id != "IsTel" && inx.id != "EvTel" && inx.id != "CepTel") {

                    var vl = $(inx).val();
                    $(inx).val(vl.replace("i", "İ").toUpperCase());
                }
            }
        });
    })
    $("#CepTel").mask("(9999) 999-9999");
    $("#EvTel").mask("(9999) 999-9999");
    $("#IsTel").mask("(9999) 999-9999");
    function getNotTipKontrol(sndr, propID) {
        var not = $(sndr).val();
        if (not == "100") {
            $(propID).html("");
            bootbox.dialog({
                message: 'Bu seçim transkriptinde yalnızca 100 lük not ortalaması yer alan adaylar tarafından gerçekleştirilmelidir. Transkriptinde 100 lük not ortalaması ile birlikte 4 lük not ortalaması da yer aldığı halde 100 lük not girişi yapan adaylar kayıt haklarını kaybederler. Değerlendirmelerde Yükseköğretim Kurulu nun belirlediği karşılıklar esas alınmaktadır.',
                title: 'Uyarı',
                buttons: {
                    danger: {
                        label: 'Tamam',
                        className: "btn-warning"
                    }
                }
            });
        }
