    function getSinavTip(sndr, tp, selectedV) {
        var _BasvuruSurecID = @Model.BasvuruSurecID;
        var _panel = '';
        if (tp == '@SinavTipGrup.Ales_Gree') {
            _panel = $('#pnlSnv_A');
        }
        else if (tp == '@SinavTipGrup.DilSinavlari') {
            _panel = $('#pnlSnv_D');
        }
        else if (tp == '@SinavTipGrup.Tomer') {
            _panel = $('#pnlSnv_T');
        }
        _pRefresh(_panel, false);
        var _SinavTipID = $(sndr).val();
        if (_SinavTipID != "" && _SinavTipID != "null" && _SinavTipID != null) {
            var _OtIDs = "[";
            $('input[name=_OgrenimTipKod]').each(function (inx, otX) {
                if (inx == 0)
                    _OtIDs += "'" + $(otX).val().trim() + "'";
                else _OtIDs += ",'" + $(otX).val().trim() + "'";
            })
            _OtIDs += "]";
            var nOtIDs = eval(_OtIDs);
            var _Ings = "[";
            $('input[name=_Ingilizce]').each(function (inx, IngX) {
                if (inx == 0)
                    _Ings += "'" + $(IngX).val().trim() + "'";
                else _Ings += ",'" + $(IngX).val().trim() + "'";
            })
            _Ings += "]";
            var nIngs = eval(_Ings);

            var _PRKods = "[";
            $('input[name=_ProgramKod]').each(function (inx, prkX) {
                if (inx == 0)
                    _PRKods += "'" + $(prkX).val().trim() + "'";
                else _PRKods += ",'" + $(prkX).val().trim() + "'";
            })
            _PRKods += "]";
            var nPrkds = eval(_PRKods);

            var YLDurum = ($('#ylBilgi').hasClass('hide') == false);
            var EgitimDiliTurkce = $('#LEgitimDiliTurkce').val() == "true";
            if (YLDurum && !EgitimDiliTurkce) {
