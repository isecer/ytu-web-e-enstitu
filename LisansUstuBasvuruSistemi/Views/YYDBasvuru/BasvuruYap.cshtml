                                                        var sb = Management.getSinavBilgisi( Model.BasvuruSurecID, Model.BasvurularSinavBilgi_D.SinavTipID, otsIds, prks, IngsIds);
                                                        sb.BasvuruSinavData = Model.BasvurularSinavBilgi_D;
                                                        Html.RenderPartial("getSinavTip", sb);
