                                                                @Html.DropDownList("LOgrenciBolumID", null, new { @class = "form-control", onchange = "getalanlariKontrolEt()" })
                                                            </div>
                                                        </div>
                                                        <div class="form-group lOdurumBilgi @(Model.LUniversiteID==Management.UniversiteYtuKod && Model.BasvuruTercihleri.Any(a=>a.OgrenimTipKod==OgrenimTipi.TezliYuksekLisans && Model.ODurumIstensin)?" ":" hide")">
                                                            <label class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">Öğrenim Durumu</label>
                                                            <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                                @Html.DropDownList("LOgrenimDurumID", null, new { @class = "form-control", onchange = "getODKontrolEt(this)" })
                                                                <script>
                                                                    function getODKontrolEt(sndr) {
                                                                        var sVal = $(sndr).val();
                                                                        if (sVal != null && sVal != "") {
                                                                            $.ajax({
                                                                                url: '@Url.Action("LoDKontrol", "YYDBasvuru")',
                                                                                type: 'POST',
                                                                                enctype: "multipart/form-data",
                                                                                cache: false,
                                                                                dataType: "json",
                                                                                data: { LOgrenimDurumID: sVal, BasvuruSurecID: '@Model.BasvuruSurecID' },
                                                                                success: function (result) {
                                                                                    if (result.ShowMsg == true) {
                                                                                        var btbx = bootbox.dialog({
                                                                                            message: result.Msg,
                                                                                            title: ("<span class='fa fa-warning'></span> " + result.Capt),
                                                                                            buttons: {
                                                                                                success: {
                                                                                                    label: 'Tamam',
                                                                                                    className: "btn-success",
                                                                                                    callback: function () {
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                        });
                                                                                        $(btbx).find(".modal-title").attr("style", "color:red;");
                                                                                    }
                                                                                    getProgramBilgi($('#ProgramKod'));
                                                                                },
                                                                                error: function (err) {
                                                                                    alert(err.responseText);

                                                                                }
                                                                            });
                                                                        }
                                                                    }
                                                                </script>
                                                            </div>
                                                        </div>
