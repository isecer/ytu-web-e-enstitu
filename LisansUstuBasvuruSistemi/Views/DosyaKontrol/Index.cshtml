@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var kod = (string)ViewBag.Kod;
}
<div class="row">

    <div class="col-md-12">

        <!-- START SIMPLE DATATABLE -->
        <div class="panel panel-danger">
            <div class="panel-heading padding-0">
                <h3 class="panel-title"><i class="fa fa-file-pdf-o fa-lg"></i>&nbsp; Döküman Doğrulama İşlemi</h3>
            </div>
            <div class="panel-body">
                <iframe class="modalFrame" allowtransparency="true" src="@Url.Action("Reports", new { Kod = kod })" border="0" frameborder="0"  style="width:100%;height:800px;margin:0px;overflow:hidden;" scrolling="yes"></iframe>
            </div>
        </div>

    </div>
</div>