@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model FmMesajlarDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    var mSilYetki = RoleNames.MesajlarSil.InRoleCurrent();
}

<div class="row">
    @using (Html.BeginForm("Index", "Mesajlar", FormMethod.Post, new { id = "frmMesajlar" }))
    {
        <div class="col-md-12">
            @Html.Hidden("export", false)
            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-info @(Model.Expand?"":"panel-toggled")" id="pnlFltr">
                <input class="hide" name="Expand" value="@Model.Expand.ToString().ToLower()" id="Expand" />
                <div class="panel-heading padding-0">
                    <table style="width:100%;table-layout:fixed;">
                        <tr>
                            <td><h3 class="panel-title"><i class="fa fa-list-alt"></i> Filtre İşlemi</h3></td>
                            <td style="width:90px;">
                                <table>
                                    <tr>
                                        <td width="120px;text-align:right;">
                                            @if (Model.RowCount > 0)
                                            {
                                                <a href="javascript:void(0);" class="btn btn-info btn-sm" onclick="$('#export').val('true'); $('#frmMesajlar').submit(); $('#export').val('false');" title="Listelenen kaydı excel e aktar"><i class="fa fa-download"></i> Excel Olarak İndir</a>

                                            }
                                        </td>
                                    </tr>
                                </table>


                            </td>
                            <td style="width:90px;">
                                <ul class="panel-controls">
                                    <li><a href="javasctipr:void(0)" onclick="$('#Expand').val(($('#pnlFltr').hasClass('panel-toggled') ? 'true' :'false' )); " class="panel-collapse"><span class="fa fa-angle-down"></span></a></li>
                                </ul>
                            </td>
                        </tr>
                    </table>

                </div>
                <div class="panel-body">
                    <table class="table table-hover" style="table-layout:fixed;">
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td width="120">Enstitü</td>
                                        <td>
                                            @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;", onchange = "$('#frmMesajlar').submit();" })
                                        </td>
                                    </tr>
                                </table>

                            </td>
                            <td style="padding-left:10px;">
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td width="120">Mesaj Yılı</td>
                                        <td>
                                            @Html.DropDownList("MesajYili", null, new { @class = "form-control", style = "padding:0px;", onchange = "$('#frmMesajlar').submit();" })
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td width="120">Mesaj Kategorisi</td>
                                        <td>@Html.DropDownList("MesajKategoriID", null, new { @class = "form-control", onchange = "$('#frmMesajlar').submit();" })</td>
                                    </tr>
                                </table>

                            </td>
                            <td style="padding-left:10px;">
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td width="120">Durum</td>
                                        <td>@Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;", onchange = "$('#frmMesajlar').submit();" })</td>
                                    </tr>
                                </table>

                            </td>

                        </tr>
                        <tr>
                            <td>
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td width="120">Dosya Ek Durumu</td>
                                        <td>@Html.DropDownList("IsDosyaEkDurum", null, new { @class = "form-control", onchange = "$('#frmMesajlar').submit();" })</td>
                                    </tr>
                                </table>
                            </td>
                            <td style="padding-left:10px;">
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td width="120">Aranacak Kelime</td>
                                        <td>
                                            <table style="width:100%;table-layout:fixed;">
                                                <tr>
                                                    <td><input name="AdSoyad" id="AdSoyad" type="text" onkeypress="if (event.which == 13) { $('#frmMesajlar').submit(); }" value="@Model.AdSoyad" class="form-control" /></td>
                                                    <td width="110px;"><a href="javascript:void(0);" onclick="$('#frmMesajlar').submit();" class="btn btn-info"><i class="glyphicon glyphicon-filter"> Filtrele</i></a></td>
                                                </tr>
                                            </table>
                                            @if (Model.AdSoyad.IsNullOrEmpty() == false)
                                            {
                                                <script>
                                                    $(function () {
                                                        SetCaretAtEnd(document.getElementById('AdSoyad'));
                                                    });

                                                </script>
                                            }
                                        </td>
                                    </tr>
                                </table>
                            </td>

                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <table style="table-layout:fixed;width:100%;">
                        <tr>
                            <td><h3 class="panel-title"><i class="fa fa-envelope"></i> Gelen Mesaj Listesi</h3></td>
                            <td width="460px;">
                                <ul class="panel-controls">
                                    <li><span class="label label-info label-form">Toplam Konu: <b>@indexModel.Toplam</b></span></li>
                                    <li><span class="label label-success label-form">Kapalı Konu: <b>@indexModel.Aktif</b></span></li>
                                    <li><span class="label label-warning label-form">Açık Konu: <b>@indexModel.Pasif</b></span></li>
                                    <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                                </ul>
                            </td>
                        </tr>
                    </table>


                </div>
                <div class="panel-body" style="padding-bottom:0px;">
                    <table class="table table-hover" style="margin-bottom:0px;">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala sorting" width="280" field="AdSoyad"> Mesaj Gönderen</th>
                                <th class="sirala sorting" field="KategoriAdi">Kategori/Konu</th>
                                <th width="35" class="sirala sorting" field="EkSayisi"></th>
                                <th width="110" class="sirala sorting" field="Tarih">Tarih</th>
                                <th width="60" class="sirala sorting" field="IsAktif">Durum</th>
                                <th width="20" style="padding-left: 0px; padding-right: 0px;"></th>

                            </tr>

                        </thead>
                        <tbody>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex;
                                foreach (var item in Model.MesajlarDtos)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width:30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.MesajID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail(@item.MesajID)">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span> </a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            @if (item.KullaniciID > 0)
                                            {
                                                <table>
                                                    <tr>
                                                        <td title="Kullanıcı Detayını Gör">
                                                            <span class="user" style="width: 50px; height: 50px; margin-right: 5px;">
                                                                <img style="width: 50px; height: 50px; cursor: pointer; margin: 0px;" onclick="DetayGor('@item.UserKey','#kulPnl')" src="@item.ResimAdi.ToKullaniciResim()">
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <a href="javascript:void(0)" title="Cevapla" onclick="senMx('@item.KullaniciID',@item.MesajID,@item.MesajID)"><i class="fa fa-mail-reply fa-2x"></i></a>
                                                            <span>
                                                                @item.AdSoyad<br>
                                                                <span style="font-size: 8pt; color: gray;">Mail: @item.Email</span>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </table>
                                            }
                                            else
                                            {
                                                <table>
                                                    <tr>
                                                        <td>
                                                            <span class="user" style="width: 55px; height: 55px; margin-right: 5px;">
                                                                <img style="width: 55px; height: 55px;margin:0px;" src="@("".ToKullaniciResim())">
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <a href="javascript:void(0)" title="Cevapla" onclick="senMx('@(item.Email)',@item.MesajID,@item.MesajID)"><i class="fa fa-mail-reply fa-2x"></i></a>
                                                            <span>
                                                                @item.AdSoyad<br>
                                                                <span style="font-size: 8pt; color: gray;"><b>Mail:</b> @item.Email</span><br>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </table>
                                            }
                                            <input type="text" id="konu_@item.MesajID" value="@item.Konu" style="display:none;" />

                                        </td>

                                        <td>

                                            <b>Kategori:</b> @(item.EnstituKod == EnstituKodlariEnum.FenBilimleri ? "FBE" : "SBE") - @item.KategoriAdi <br />
                                            <b>Konu:</b> @(item.Konu.Length > 70 ? item.Konu.Substring(0, 69) + "..." : item.Konu)
                                        </td>
                                        <td style="text-align:right;">
                                            @if (item.EkSayisi > 0)
                                            {
                                                <b>@item.EkSayisi</b> <img title="@item.EkSayisi Adet Ek Mevcut" src="@Url.Content("/Images/Attachment.png")" style="height:16px;">
                                            }
                                        </td>
                                        <td>
                                            <b>@item.Tarih.ToFormatDateAndTime()</b>
                                        </td>
                                        <td style="text-align:center;">
                                            <input style="width:18px;height:18px;cursor:pointer;" type="checkbox" @item.IsAktif.ToChecked() onchange="dKayit(this,@item.MesajID)" id="msjCvpDurum_@item.MesajID" />
                                        </td>
                                        <td style="vertical-align: middle; padding-left: 0px; padding-right: 0px;">
                                            @if (mSilYetki)
                                            {
                                                <a href="javascript:void(0)" onclick="SilmeOnay(this,@item.MesajID)"><i class="fa fa-trash-o fa-lg tooltips" title="Sil"></i></a>
                                            }
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.MesajID hide">
                                        <td colspan="8" style="padding: 1px 1px 2px 75px;">
                                            <div style="max-height:550px;overflow:auto;">
                                                <div id="cls-@item.MesajID" class="panel panel-default">
                                                    <div class="panel-body" style="padding: 0px;">
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align: center">
                                        [ Listelenen Kayıt Yok ]

                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function senMx(id, mID) {
        var _konu = $('#konu_' + mID).val(); 
        mGonder(id, _konu, '', mID);

    }
    function getMDetay(id, _Konu) {
        $('#msjCvpDurum_' + id).prop('checked', true);
        toastr["success"]("'" + _Konu + "' Konulu Mesaj durumu Kapalı olarak İşaretlendi", "Mesaj Durum Güncelleme İşlemi");
        GetMails(id);
    }
    function ShowDetail(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass3(rwID, cls, unTogled);
        if (unTogled) GetMails(id);

    }
    function showDetail2(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).hasClass("hide"));
        toggleByClass3(rwID, cls, unTogled);
        //if (unTogled) setTimeout(function () { GetDetail(dbdID, klID); }, 200);
    }
    function silmeOnay(sndr, id) {
        var htmlCont = $("#cls-" + id).html();
        var eks = $("#tdEk_" + id).html();
        bootbox.dialog({
            message: htmlCont + "</br></br>Seçtiğiniz mesaj ile birlikte bu mesaja cevap yazılan tüm mail bilgileri silinecek! <br/>Seçilen Mesajı Silmek İstiyor Musunuz? ",
            title: "Mesaj Silme İşlemi",
            buttons: {
                success: {
                    label: "Mesaj Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
 function dKayit(sndr, id) {
        var sndrVal = $(sndr).is(':checked');

        $.ajax({
            url: '@Url.Action("DurumKayit", "Mesajlar")',
            data: { id: id, IsAktif: sndrVal },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Mesaj Durum Güncelleme İşlemi");
            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
    function GetMails(id) {
        var pnlx = $("#cls-" + id);
        PanelRefresh(pnlx, false);
        $.ajax({
            url: '@Url.Action("GetMesajDetay", "Mesajlar")',
            data: { 'MesajID': id},
            success: function (result) {
                var _nme = 'cls-' + id;
                $('#' + _nme).html(result);
                PanelRefresh(pnlx, true);

            },
            error: function (err) {
                alert(err.responseText);
                PanelRefresh(pnlx, true);
            }
        });
    }
    function SilmeOnay(sndr, id) {
        var htmlCont = $("#cls-" + id).html();
        var SoruHtml = "<table style='color:maroon;table-layout:fixed;width:100%;'><tr><td width='30' style='padding-left:10px;'><i class='fa fa-info fa-2x'></i></td><td style='padding-right:10px;'>Seçtiğiniz mesaj ile birlikte bu mesaja cevap yazılan tüm mail bilgileri silinecek! <br/>Seçilen Mesajı Silmek İstiyor Musunuz?</td></tr></table>";
        bootbox.dialog({
            message: htmlCont + SoruHtml,
            title: "Mesaj Silme İşlemi",
            buttons: {
                success: {
                    label: "Mesaj Sil",
                    className: "btn-danger",
                    callback: function () {
                        Sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function Sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "Mesajlar")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Mesaj Silme İşlemi");
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }
            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>