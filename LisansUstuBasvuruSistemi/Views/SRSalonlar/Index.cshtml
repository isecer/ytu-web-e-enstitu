@using Entities.Entities 
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  FmSalonlar
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    var stt = (List<SRTalepTipleri>)ViewBag.TT;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Salonlar</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="EnstituAdi" width="220">Enstitü</th> 
                                <th class="sirala" field="Ad">Salon Adı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="50">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th> 
                                <th>
                                    <input name="SalonAdi" type="text" value="@Model.SalonAdi" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex;
                                foreach (var item in Model.FrSalonlars)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.SRSalonID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.SRSalonID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            @item.EnstituAdi
                                        </td>
                                        
                                        <td id="tdMad_@item.SRSalonID">
                                            @item.SalonAdi <br />
                                            <span style="color:maroon;" title="Salon Talep Tipleri">STT: @string.Join(",", stt.Where(p => item.SrSalonTalepTipleris.Any(a => a.SRTalepTipID == p.SRTalepTipID)).Select(s => s.TalepTipAdi))</span>
                                        </td>
                                        <td id="tdIa_@item.SRSalonID" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit")"><i class="fa fa-plus tooltips" title="Yeni"></i></a>
                                            <a href="@Url.Action("Kayit", new { id = item.SRSalonID })"><i class="fa fa-edit  tooltips" title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="SilmeOnay(this,'@item.SRSalonID')"><i class="fa fa-trash-o tooltips" title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.SRSalonID" style="display:none">
                                        <td id="cls-@item.SRSalonID" colspan="6" style="padding: 1px 1px 2px 75px;">

                                            <div class="panel panel-success">
                                                <div class="panel-heading  padding-0">
                                                    <div class="portlet-title">
                                                        <h3 class="panel-title"><i class="fa fa-file-text"></i> Detay</h3>
                                                    </div>
                                                </div>
                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">
                                                        <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                <div class="panel-body form-group-separated">
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-2 control-label">Enstitü</label>
                                                                        <div class="col-md-9 col-xs-10">@item.EnstituAdi</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-2 control-label">Talep Tipleri</label>
                                                                        <div class="col-md-9 col-xs-10">@string.Join(",", stt.Where(p => item.SrSalonTalepTipleris.Any(a => a.SRTalepTipID == p.SRTalepTipID)).Select(s => s.TalepTipAdi))</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-2 control-label">Salon Adı</label>
                                                                        <div class="col-md-9 col-xs-10">@item.SalonAdi</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-2 control-label">Saat Kriterleri</label>
                                                                        <div class="col-md-9 col-xs-10">
                                                                            <table class="table" style="width:100%;table-layout:fixed;">
                                                                                <thead>
                                                                                    <tr>
                                                                                        <th>Hafta Günleri</th>
                                                                                        <th width="130">Saat Aralığı</th>
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    @foreach (var itemS in item.Saatler)
                                                                                    {
                                                                                        <tr>
                                                                                            <td>
                                                                                                @string.Join(", ", itemS.GunNos.Select(s => s.Caption))
                                                                                            </td>
                                                                                            <td>
                                                                                                @(itemS.BasSaat)-@(itemS.BitSaat)
                                                                                            </td>
                                                                                        </tr>
                                                                                    }
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-2 control-label">Durum</label>
                                                                        <div class="col-md-9 col-xs-10" style="text-align: left; max-height: 200px; overflow: auto;">
                                                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@(item.IsAktif ? "Aktif" : "Pasif")</span>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-2 control-label">İşlem Yapan</label>
                                                                        <div class="col-md-9 col-xs-10">@item.IslemYapan [@item.IslemTarihi.ToFormatDateAndTime()]</div>
                                                                    </div>
                                                                  
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function ShowDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function SilmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Salon Adı: " + gMesaj + " <br/> Seçilen Salonu Silmek İstiyor Musunuz?",
            title: "Salon Silme İşlemi",
            buttons: {
                success: {
                    label: "Salon Sil",
                    className: "btn-danger",
                    callback: function () {
                        Sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function Sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "SrSalonlar")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Salon Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    // $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
