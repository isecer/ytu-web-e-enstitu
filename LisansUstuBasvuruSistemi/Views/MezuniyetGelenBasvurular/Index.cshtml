    function EykOnayChange(id) {
        var val = $('#EYKDaOnaylandi_' + id).val();
        if (val == 'false') {
            $('#EYKOnayAciklamaRow_' + id).removeClass('hide');
            $('#EYKOnayEykTarihTd_' + id).addClass('hide');
        }
        else if (val == 'true') {
            $('#EYKOnayAciklamaRow_' + id).addClass('hide');
            var eykTarih = $('#EYKDaOnaylandiOnayTarihi_' + id).val();
            if (eykTarih == "") {
                var today = new Date(), year = today.getFullYear(), month = today.getMonth() + 1, day = today.getDate();
                if (month < 10) month = "0" + month;
                if (day < 10) day = "0" + day;
                var formattedDate = year + "-" + month + "-" + day;
                $('#EYKDaOnaylandiOnayTarihi_' + id).val(formattedDate);
            }
            $('#EYKOnayEykTarihTd_' + id).removeClass('hide');
        }
        else if (val == '') {
            $('#EYKOnayAciklamaRow_' + id).addClass('hide');
            $('#EYKOnayEykTarihTd_' + id).addClass('hide');
        }

    }
