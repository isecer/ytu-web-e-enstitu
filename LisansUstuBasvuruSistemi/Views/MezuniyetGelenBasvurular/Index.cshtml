@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model  FmMezuniyetBasvurulari
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var kYetki = RoleNames.MezuniyetGelenBasvurularKayit.InRole();
    var eykYetki = RoleNames.MezuniyetGelenBasvurularKayit.InRoleCurrent() || RoleNames.MezuniyetGelenBasvurularJuriOneriFormuOnay.InRoleCurrent();
    var eykOnayYetki = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuEykOnay.InRoleCurrent();
    var filteredOgrenciIds = (List<int>)ViewBag.filteredOgrenciIds;
    var filteredDanismanIds = (List<int>)ViewBag.filteredDanismanIds;
    var hideFilterRow = !kYetki && Model.Data.Select(s => s.TezDanismanID).FirstOrDefault() == UserIdentity.Current.Id ? "hide" : "";
}

<div class="row">
@using (Html.BeginForm("Index", "MezuniyetGelenBasvurular", FormMethod.Post, new { id = "frmGBasvurular" }))
{

    <div class="col-md-12">
        @Html.Hidden("export", false)
        <!-- START SIMPLE DATATABLE -->
        <div class="panel panel-info" id="pnlFltr">
            <div class="panel-heading padding-0">
                <h3 class="panel-title">
                    <i class="glyphicon glyphicon-filter"></i> Filtre İşlemi
                </h3>
                <ul class="panel-controls">
                    @if (eykOnayYetki && Model.JuriOneriFormuDurumuID == MezuniyetJofDurumuEnum.EykYaHazirlandi && Model.SelectedMezuniyetBasvurulariIds.Any())
                    {
                        <li>
                            <a href="javascript:void(0);" class="topluOnay" onclick="TopluEYKDaOnay()" title="EYK'ya hazırlanmış olan başvuruları Eyk'da onaylandı olarak güncelle"><i class="fa fa-thumbs-o-up fa-lg" aria-hidden="true"></i></a>
                            <script>

                                    function TopluEYKDaOnay() {
                                        var btbx = bootbox.dialog({
                                            message: "Listelenen @Model.SelectedMezuniyetBasvurulariIds.Count() adet EYK'ya hazırlanmış ve EYK'da onay işlemi bekleyen</b> Tez Jüri Öneri formlarını <b>EYK'da onaylandı</b> olarak güncellemek istiyor musunuz?<br>Not: bu işlem onaylanan başvuru sayısına göre uzun sürebilir.",
                                            title: "Toplu EYK'da onaylama işlemi",
                                            buttons: {
                                                success: {
                                                    label: "Onayla",
                                                    className: "btn-info btnBbOnaylama",
                                                    callback: function () {
                                                        $('.btnBbOnaylama').html('Onaylanıyor...');
                                                        var _panel = $(btbx).find('.modal-content');
                                                        PanelRefresh(_panel, false);
                                                        toastr["info"]("Lütfen işlem tamamlanana kadar bekleyiniz.", "Toplu EYK'da Onaylama İşlemi Başlatıldı");
                                                        var mezuniyetBasvurulariIds = eval('@Html.Raw(Json.Encode(Model.SelectedMezuniyetBasvurulariIds))');
                                                        $.ajax({
                                                            url: '@Url.Action("EYKDaOnay", "MezuniyetGelenBasvurular")',
                                                            cache: false,
                                                            type: 'POST',
                                                            data: { mezuniyetBasvurulariIds },
                                                            success: function (result) {
                                                                PanelRefresh(_panel, true);
                                                                toastr["info"](result.Count + " adet başvuru eyk'da onaylandı olarak güncellendi.", "Toplu Onaylama İşlemi Tamamlandı");
                                                                $(btbx).find('.close').first().click();
                                                            },
                                                            error: function (err) {
                                                                PanelRefresh(_panel, true);
                                                                alert(err.responseText);
                                                            }
                                                        });
                                                        return false;
                                                    }
                                                },
                                                danger: {
                                                    label: "Vazgeç",
                                                    className: "btn-primary",
                                                    callback: function () {
                                                    }
                                                }
                                            }
                                        });
                                    }

                                </script>
                        </li>

                    }
                    @if (eykYetki)
                    {
                        <li>
                            <a href="javascript:void(0);" onclick="ShowDialogTutanakRpr()" title="Tutanak Raporu Oluştur"><i class="fa fa-file-text-o"></i></a>
                            <script>
                                    function ShowDialogTutanakRpr() {
                                        var _panel = $('#pnlFltr');

                                        PanelRefresh(_panel, false);
                                        $.ajax({
                                            url: '@Url.Action("GetTutanakRaporu", "MezuniyetGelenbasvurular")',
                                            data: {},
                                            success: function (result) {
                                                PanelRefresh(_panel, true);
                                                var btbxxFS = bootbox.dialog({
                                                    message: result,
                                                    title: "<i class='fa fa-bar-chart-o'></i> Tutanak Çıktısı Oluşturma İşlemi",
                                                    buttons: {
                                                        success: {
                                                            label: 'Çıktı Al',
                                                            className: "btn btn-info",
                                                            callback: function (event) {
                                                                toastr["success"]('Tutanak oluşturuluyor lütfen bekleyiniz...', 'Tutanak Oluşturma İşlemi');
                                                                var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                                                PanelRefresh(pnlx, false);
                                                                $('#TutanakRprForm').ajaxForm({
                                                                    success: function (result) {

                                                                        PanelRefresh(pnlx, true);
                                                                            if (result.IsSuccess) {

                                                                                var _RtipID = $('#RaporTipID').val();
                                                                                var _OtipKods = $('#OgrenimTipKods').val();
                                                                                var otips = "";
                                                                                for (var i = 0; i < _OtipKods.length; i++) {
                                                                                    otips +=(i==0?"":",")+ _OtipKods[i];
                                                                                }
                                                                                var _Bastar = $('#BasTar').val();
                                                                                var _Bittar = $('#BitTar').val();
                                                                                var _RaporTarihi = $('#BitTar').val();
                                                                                var _ExportWordOrExcel = $('#ExportWordOrExcel').val().toLowerCase();
                                                                                var enstituOnayDurumId = $('#EnstituOnayDurumId').val();
                                                                                window.location = '@Url.Action("GetTutanakRaporuExport", "MezuniyetGelenbasvurular")?RaporTipID=' + _RtipID + '&OgrenimTipKods=' + otips + '&enstituOnayDurumId=' + enstituOnayDurumId + '&BasTar=' + _Bastar + '&BitTar=' + _Bittar + '&RaporTarihi=' + _RaporTarihi + '&ExportWordOrExcel=' + _ExportWordOrExcel;

                                                                            }
                                                                            else {
                                                                                GetMsg(result);
                                                                            }


                                                                    },
                                                                    complete: function (cmp) {
                                                                        PanelRefresh(pnlx, true);
                                                                    },
                                                                    error: function (err) {
                                                                        PanelRefresh(pnlx, true);
                                                                    }

                                                                });
                                                                $('#TutanakRprForm').submit();
                                                                return false;
                                                            }
                                                        },
                                                        danger: {
                                                            label: 'Kapat',
                                                            className: "btn-primary",
                                                            callback: function () {
                                                            }
                                                        }
                                                    }
                                                });
                                            },
                                            error: function (err) {
                                                alert(err.responseText);
                                                PanelRefresh(_panel, true);
                                            }
                                        });

                                    }
                                </script>
                        </li>
                    }
                    @if (kYetki && Model.RowCount > 0)
                    {
                        <li>
                            <a href="javascript:void(0);" onclick="$('#export').val('true'); $('#frmGBasvurular').submit(); $('#export').val('false');" title="Listelenen kaydı excel e aktar"><i class="fa fa-download"></i></a>
                        </li>

                    }
                    @if (kYetki)
                    {
                        if (filteredOgrenciIds.Any())
                        {
                            <li>
                                <a href="javascript:void(0)" onclick="mGonderGB('@string.Join(",", filteredOgrenciIds)',true,false)" title="Listelenen Başvurular için @filteredOgrenciIds.Count Öğrenciye Mail Gönder"><i class="fa fa-envelope" aria-hidden="true"> Ö</i></a>
                            </li>
                        }

                        if (filteredDanismanIds.Any())
                        {
                            <li>
                                <a href="javascript:void(0)" onclick="mGonderGB('@string.Join(",", filteredDanismanIds)',true,false)" title="Listelenen Başvurular için @filteredDanismanIds.Count Danışmana Mail Gönder"><i class="fa fa-envelope" aria-hidden="true"> D</i></a>
                            </li>
                        }


                    }
                </ul>
            </div>
            <div class="panel-body">
                <table class="table table-hover" style="width:100%;table-layout:fixed;">
                    <tr>
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Akademik Dönem</td>
                                    <td>@Html.DropDownList("MezuniyetSureci", null, new { @class = "form-control" })</td>
                                    <td>
                                        @Html.DropDownList("MezuniyetSurecID", null, new { @class = "form-control" })
                                    </td>
                                </tr>
                                </tbody>
                            </table>

                        </td>
                        <td style="padding-left:10px;">
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Öğrenim S. / Tez Dili</td>
                                    <td>
                                        @Html.DropDownList("OgrenimTipKod", null, new { @class = "form-control" })
                                    </td>
                                    <td>@Html.DropDownList("IsTezDiliTr", null, new { @class = "form-control" })</td>
                                </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <tr class="@hideFilterRow">
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Kayıt Dönemi</td>
                                    <td>
                                        @Html.DropDownList("KayitDonemi", null, new { @class = "form-control" })
                                    </td>
                                </tr>
                                </tbody>
                            </table>

                        </td>
                        <td style="padding-left:10px;">
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Jüri Öneri Form Durumu</td>
                                    <td>
                                        @Html.DropDownList("JuriOneriFormuDurumuID", null, new { @class = "form-control" })
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <tr class="@hideFilterRow">
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Başvuru Durumu</td>
                                    <td>
                                        @Html.DropDownList("MezuniyetYayinKontrolDurumID", null, new { @class = "form-control" })
                                    </td>
                                </tr>
                                </tbody>
                            </table>

                        </td>
                        <td style="padding-left:10px;">
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Salon Rez / Sınav</td>
                                    <td>
                                        @Html.DropDownList("SRDurumID", null, new { @class = "form-control" })
                                    </td>
                                    <td>
                                        @Html.DropDownList("MezuniyetSinavDurumID", null, new { @class = "form-control" })
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <tr class="@hideFilterRow">
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Tez Kontrol / Yetkili</td>
                                    <td> @Html.DropDownList("TDDurumID", null, new { @class = "form-control" })</td>
                                    <td> @Html.DropDownList("TezKontrolKullaniciId", null, new { @class = "form-control" })</td>
                                </tr>
                                </tbody>
                            </table>

                        </td>
                        <td style="padding-left:10px;">
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Tez Teslim Formu Durumu</td>
                                    <td>
                                        @Html.DropDownList("TeslimFormDurumu", null, new { @class = "form-control" })
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Mezuniyet Durumu</td>
                                    <td>
                                        @Html.DropDownList("MezuniyetDurumID", null, new { @class = "form-control", onchange = "$(this).val()==1?$('.mDurumTarih').removeClass('hide'):$('.mDurumTarih').addClass('hide')" })
                                    </td>
                                </tr>
                                <tr class="mDurumTarih @(Model.MezuniyetDurumID==1?"":"hide")">
                                    <td width="150">Mezuniyet Tarih Aralığı</td>
                                    <td>
                                        <table style="width:100%;table-layout:fixed;">
                                            <tr>
                                                <td><input class="form-control form-control-inline input-medium date-pickerx" autocomplete="off" size="16" type="text" placeholder="Baş:@DateTime.Now.AddMonths(-3).ToFormatDateInput()" value="@Model.MBaslangicTarihi.ToFormatDateInput()" name="MBaslangicTarihi" id="MBaslangicTarihi"></td>
                                                <td width="5">/</td>
                                                <td><input class="form-control form-control-inline input-medium date-pickerx" autocomplete="off" size="16" type="text" placeholder="Bit:@DateTime.Now.ToFormatDateInput()" value="@Model.MBitisTarihi.ToFormatDateInput()" name="MBitisTarihi" id="MBitisTarihi"></td>
                                            </tr>
                                        </table>
                                        <script>
                                                    $('.date-pickerx').datetimepicker({
                                                        timepicker: false,
                                                        format: 'Y-m-d'
                                                    });
                                                </script>

                                    </td>
                                </tr>
                                </tbody>
                            </table>

                        </td>
                        <td style="padding-left:10px; vertical-align:top;">
                            <table style="width:100%;table-layout:fixed;">
                                <tbody>
                                <tr>
                                    <td width="150">Aranacak Kelime</td>
                                    <td>

                                        <table style="width:100%;table-layout:fixed;">
                                            <tbody>
                                            <tr>
                                                <td> <input name="AdSoyad" id="AdSoyad" type="text" value="@Model.AdSoyad" onkeypress="if (event.which == 13) { $('#frmGBasvurular').submit(); }" class="form-control" /></td>
                                                <td width="110">
                                                    <a href="javascript:void(0);" onclick="$('#frmGBasvurular').submit();" class="btn btn-info" style="width:110px;"><i class="glyphicon glyphicon-filter"> Filtrele</i></a>
                                                </td>
                                            </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-12">
        <div class="panel panel-danger">
            <div class="panel-heading padding-0">
                <h3 class="panel-title"><i class="fa fa-list-alt"></i> Gelen Mezuniyet Başvuruları</h3>

            </div>
            <div class="panel-body">
                <table class="table table-hover" style="width:100%;">
                    <thead>
                    <tr>
                        <th width="75">
                        </th>
                        <th width="40"></th>
                        <th class="sirala" field="AdSoyad">Ad Soyad</th>
                        <th class="sirala" field="BasvuruTarihi" width="80">B. Tarihi</th>
                        <th>Mezuniyet Durumu</th>
                        <th width="40"></th>
                    </tr>

                    </thead>
                    <tbody>

                    @if (Model.RowCount > 0)
                    {

                        int rowIndex = Model.StartRowIndex;
                        foreach (var item in Model.Data)
                        {
                            rowIndex++;
                            <tr>
                                <td>
                                    <table>
                                        <tr>
                                            <td style="width: 30px;">@rowIndex</td>
                                            <td>
                                                <ul class="panel-controls">
                                                    <li id="iShow_@item.MezuniyetBasvurulariID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.MezuniyetBasvurulariID')">
                                                        <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                    </li>
                                                </ul>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td>
                                    <img src="@item.ResimAdi.ToKullaniciResim()" style="width:40px;height:40px;cursor:pointer;" onclick="DetayGor('@item.UserKey')" class="img-circle img-thumbnail">
                                </td>
                                <td width="240">
                                    @item.AdSoyad <br /> @item.OgrenciNo
                                </td>
                                <td>
                                    @item.BasvuruTarihi.ToFormatDateAndTime()
                                </td>

                                <td id="MDurum_@item.MezuniyetBasvurulariID">
                                    @item.ToMezuniyetDurum()
                                </td>
                                <td>
                                    @if (kYetki)
                                    {
                                        <a href="@Url.Action("BasvuruYap", "Mezuniyet", new { item.MezuniyetBasvurulariID })"><i style="font-size:11pt;" class="fa fa-edit" title="Düzelt"></i></a>
                                        <a href="javascript:void(0)" onclick="GetDetailx('@item.MezuniyetBasvurulariID',true,null,this)"><i style="font-size:11pt;" class="glyphicon glyphicon-trash" title="Sil"></i></a>
                                    }
                                </td>
                            </tr>
                            <tr class="cls-@item.MezuniyetBasvurulariID" style="display:none">
                                <td id="cls-@item.MezuniyetBasvurulariID" colspan="6" style="padding: 1px 1px 2px 75px;"></td>
                            </tr>

                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" style="text-align: center;">
                                [ Listelenen Kayıt Yok ]
                            </td>
                        </tr>
                    }

                    </tbody>
                </table>
            </div>
            <div class="panel-footer">
                @Model.ToPagerString()
            </div>
        </div>
    </div>
}
</div> 
<div id="msgsB" style="display: none;">
</div>
@if (Model.RowCount > 0 && (Model.Data.First().TezDanismanID == UserIdentity.Current.Id || Model.SMezuniyetBID.HasValue))
{
    <script>
        $(function () {
            ShowDetail('@Model.Data.First().MezuniyetBasvurulariID');
        },200)
    </script>
}
<script type="text/javascript">
    function ShowDetailY(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
    }


    function ShowDetail(id) {
        var rwID = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
        if (unTogled) GetDetailx(id);

    }
    function GetDetailx(id, Isdelete, mbyID, sndr) {
        var _panel = $('#bsvrDet_' + id);
        var tbName = "@TabAdiEnum.MezuniyetBasvurulariTn-" + id;
        var STabID = "@Model.STabID";

        var tID = GetSelectedTabID(tbName);
        if (STabID != "") tID = STabID; 
        PanelRefresh(_panel, false); 
        $.ajax({
            url: '@Url.Action("GetDetailMezuniyet", "Ajax")',
            data: { id: id, ShowDetayYayinID: mbyID, tbInx: tID, IsDelete: (Isdelete == true), 'GelenBasvuru': true },
            success: function (result) {
                if (Isdelete != true) {
                    $('#cls-' + id).html(result);
                    PanelRefresh(_panel, true);
                }
                else {
                    PanelRefresh(_panel, true);
                    var btbx = bootbox.dialog({
                        message: result + " <br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:11pt;text-align:center;color:maroon;'>Seçilen Mezuniyet Başvurusunu Silmek İstiyor Musunuz?</td></tr></table>",
                        title: "Mezuniyet Başvurusu Silme İşlemi",
                        buttons: {
                            success: {
                                label: 'Başvuruyu Sil',
                                className: "btn-danger",
                                callback: function () {
                                    Sil(sndr, id);
                                }
                            },
                            danger: {
                                label: 'Vazgeç',
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });

                }
            },
            error: function (err) {
                alert(err.responseText);
                PanelRefresh(_panel, true);
            }
        });

    }

    function BDurumChange(sndr, id) {
        if ($(sndr).val() == "@MezuniyetYayinKontrolDurumuEnum.IptalEdildi" || $(sndr).val() == "@MezuniyetYayinKontrolDurumuEnum.KaydiSilindi" ) {
            $('#bdurumRowID_'+id).removeClass("hide");
        } else {
            $('#bdurumRowID_' + id).addClass("hide");
        }
        if ($(sndr).val() == "@MezuniyetYayinKontrolDurumuEnum.KabulEdildi") {
            $('.intihalRwBasvuru_' + id).removeClass("hide");
        } else {
            $('.intihalRwBasvuru_' + id).addClass("hide");
        }
    }
    function BDurumKayit(id) {
        var message = "";
        var successSave = true;
        var $durumInput = $('#MezuniyetYayinKontrolDurumID_' + id).first();
        var mezuniyetYayinKontrolDurumID = $durumInput.val();
        var selectedBasvuruDurumAdi = $durumInput.children("option").filter(":selected").text();
        var mezuniyetYayinKontrolDurumAciklamasi = $('#MezuniyetYayinKontrolDurumAciklamasi_' + id).val();

        var tekKaynakOrani = $('#TekKaynakOrani_' + id).val();
        var toplamKaynakOrani = $('#ToplamKaynakOrani_' + id).val();
        if (mezuniyetYayinKontrolDurumID == "" || mezuniyetYayinKontrolDurumID == null) {
            message = "kayıt işlemini yapabilmek için başvuru durumunu seçiniz";
            successSave = false;
        }
        else if ((mezuniyetYayinKontrolDurumID == "@MezuniyetYayinKontrolDurumuEnum.IptalEdildi" || mezuniyetYayinKontrolDurumID == "@MezuniyetYayinKontrolDurumuEnum.KaydiSilindi") && mezuniyetYayinKontrolDurumAciklamasi.trim() == "") {
            successSave = false;
            message ="Açıklaması giriniz";
        }
        else if (mezuniyetYayinKontrolDurumID == "@MezuniyetYayinKontrolDurumuEnum.Taslak") {
            message = "Başvuru taslağa çekilecek fakat varsa eğer danışman onayı, yayın onayı işlemleri geri alınacak.";
        }
        else {
            message = "Başvuru durumunu " + selectedBasvuruDurumAdi + " olarak değiştirmek istiyor musunuz?";
            }
        if (!successSave) {
            swal.fire({
                text: message,
                icon: "error",
                type: "error",
                confirmButtonText: 'tamam',
                padding: '2em'
            });
            return;
        }
        Swal.fire({
            text: message,
            type: 'warning',
            icon: "question",
            showCancelButton: true,
            confirmButtonText: 'Evet',
            confirmButtonColor: "gren",
            cancelButtonText: 'Hayır',
            showLoaderOnConfirm: true,
            backdrop: true,
            padding: '2em',
            backdrop: true,
            allowOutsideClick: false,
            preConfirm: function () {
