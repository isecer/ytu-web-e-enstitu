                                                        E-Posta Adresi (*)
                                                    </label>
                                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                        <input type="text" class="form-control" maxlength="128" name="EMail" value="@(tikUyesi2Bilgi != null ? tikUyesi2Bilgi.EMail : "")" style="width: 100%;" id="TikUyesi2EMail" />
