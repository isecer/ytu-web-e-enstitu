                                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                        <input type="text" class="form-control" maxlength="128" name="UzmanlikAlani" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.UzmanlikAlani : "")" style="width: 100%;" id="TikUyesi1UzmanlikAlani" />
                                                    </div>
                                                </div>
                                            </div>
