<script>
    onSpecialCharacterBlockerLoaded();

    $(function () {
        $('.upperCase').each(function (ix, inx) {
            $(inx).attr('autocomplete', 'off');
            $(inx).bind('keyup', function (e) {
                var vl = $(inx).val();
                $(inx).val(vl.replace("i", "İ").toUpperCase());
            });
        })
        $('.egitmens').select2({
            tags: true,
            tokenSeparators: [",", " "],
            minimumInputLength: 2,
            maximumSelectionSize: 1,
            multiple: false,
            ajax: {
                url: '@Url.Action("GetYtuOgretimEleman", "Ajax")',
                dataType: "json",
                data: function (term, page) {
                    return {
                        'term': term
                    }

                },
                results: function (data, page) {
                    return {
                        results: data
                    };
                }
            },
            formatResult: function (result) {
                var cont2 =
                    "<table class='table table-striped' style='width:100%; margin:0px;'>" +
                    "<tbody>" +
                    "<tr>" +
                    "<td style='vertical-align:middle;'>" +
                    "<table class='table table-striped' style='margin:0px;border-top:none;font-size:8pt;'> " +
                    "<tbody>" +
                    "<tr><td>" + result.UnvanAdi + " " + result.AdSoyad + "</td></tr>" +
                    "<tr><td>Bölüm:" + result.BolumAdi + "</td></tr>" +
                    "</tbody> " +
                    "</table> " +
                    "</td>" +
                    "</tr> " +
                    "</tbody>" +
                    "</table>";
                return cont2;
            }
        }).on('change', function (e) {
            var Inpid = $(this).prop("id");
            var mID = Inpid.replace("AdSoyad", "");
            $('#' + mID + 'AdSoyadVal').val(e.added == undefined ? "" : e.added.AdSoyad);
            $('#' + mID + 'UnvanAdi').val(e.added == undefined ? "" : e.added.UnvanAdi);
            $('#' + mID + 'EMail').val(e.added == undefined ? "" : e.added.EMail);
            $('#' + mID + 'AnabilimdaliProgramAdi').val(e.added == undefined ? "" : e.added.BolumAdi);
            $('#' + mID + 'UniversiteAdi').val(e.added == undefined ? "" : 'Yıldız Teknik Üniversitesi');
            if (e.added == undefined) $('#' + mID + 'UzmanlikAlani').val("");

        });
        $('.yUniversites').select2({
            tags: false,
            tokenSeparators: [",", " "],
            minimumInputLength: 2,
            maximumSelectionSize: 1,
            multiple: false,
            ajax: {
                url: '@Url.Action("GetUniversitelerYtuDahil", "Ajax")',
                dataType: "json",
                data: function (term, page) {
                    return {
                        'term': term
                    }
                },
                results: function (data, page) {
                    return {
                        results: data
                    };
                }
            },
            formatResult: function (result) {
                var cont2 = result.text;
                return cont2;
            }
        }).on('change', function (e) {
            var inpInd = $(this).prop("id");
            $('#' + inpInd).val(e.added == undefined ? "" : e.added.text);
            //var mID = Inpid.replace("AdSoyad", "");
            //$('#' + mID + 'AdSoyadVal').val(e.added == undefined ? "" : e.added.AdSoyad);
            //$('#' + mID + 'UnvanAdi').val(e.added == undefined ? "" : e.added.UnvanAdi);
            //$('#' + mID + 'EMail').val(e.added == undefined ? "" : e.added.EMail);
            //$('#' + mID + 'AnabilimdaliProgramAdi').val(e.added == undefined ? "" : e.added.BolumAdi);
            //$('#' + mID + 'UniversiteAdi').val(e.added == undefined ? "" : 'Yıldız Teknik Üniversitesi');

        });
        $('.universites').select2({
            tags: false,
            tokenSeparators: [",", " "],
            minimumInputLength: 2,
            maximumSelectionSize: 1,
            multiple: false,
            ajax: {
                url: '@Url.Action("GetUniversiteler", "Ajax")',
                dataType: "json",
                data: function (term, page) {
                    return {
                        'term': term
                    }
                },
                results: function (data, page) {
                    return {
                        results: data
                    };
                }
            },
            formatResult: function (result) {
                var cont2 = result.text;
                return cont2;
            }
        }).on('change', function (e) {
            var inpInd = $(this).prop("id");
            $('#' + inpInd).val(e.added == undefined ? "" : e.added.text);
            //var mID = Inpid.replace("AdSoyad", "");
            //$('#' + mID + 'AdSoyadVal').val(e.added == undefined ? "" : e.added.AdSoyad);
            //$('#' + mID + 'UnvanAdi').val(e.added == undefined ? "" : e.added.UnvanAdi);
            //$('#' + mID + 'EMail').val(e.added == undefined ? "" : e.added.EMail);
            //$('#' + mID + 'AnabilimdaliProgramAdi').val(e.added == undefined ? "" : e.added.BolumAdi);
            //$('#' + mID + 'UniversiteAdi').val(e.added == undefined ? "" : 'Yıldız Teknik Üniversitesi');

        });
