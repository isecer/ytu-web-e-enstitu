                                                        <input type="hidden" name="DetayTabAdi" value="tab-TikUyesi1" />
                                                        <input type="text" class="form-control upperCase" maxlength="128" readonly="readonly" name="AdSoyad" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.AdSoyad.ToUpper() : "")" style="width: 100%;color:black;" id="TikUyesi1AdSoyad" />
                                                    </div>
