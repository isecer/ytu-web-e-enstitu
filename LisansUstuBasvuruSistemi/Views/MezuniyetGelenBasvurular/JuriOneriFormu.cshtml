@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model MezuniyetJuriOneriFormuKayitDto
@{
    Layout = null;
    var tezDanismaniBilgi = Model.JoFormJuriList.FirstOrDefault(p => p.JuriTipAdi == "TezDanismani");
    var tikUyesi1Bilgi = Model.JoFormJuriList.FirstOrDefault(p => p.JuriTipAdi == "TikUyesi1");
    var tikUyesi2Bilgi = Model.JoFormJuriList.FirstOrDefault(p => p.JuriTipAdi == "TikUyesi2");

}
<div class="widget widget-default" style="margin:0px;padding:4px;">
    <div class="panel panel-default form-horizontal" style="margin:0px;margin-top:5px;">
        <div class="panel-heading padding-0">
            <h3 class="panel-title"><i class="fa fa-book myCaptionTd"></i> <span class="myCaptionTd"> @(Model.IsDoktoraOrYL ? "Doktora Tez Jüri Öneri Formu" : "Yüksek Lisans Tez Jüri Öneri Formu")</span> </h3>
            <ul class="panel-controls">

                <li><a href="javascript:void(0);" onclick="ShowNote();"><span class="fa fa-info-circle"></span></a></li>
            </ul>
        </div>
        <div class="panel-body" style="padding:0px;padding-left:2px;padding-right:2px;">


            @using (Ajax.BeginForm("JuriOneriFormuPost", "MezuniyetGelenBasvurular", null, new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "FrmJuriOneriFormu" }))
            {
                @Html.HiddenFor(p => p.MezuniyetBasvurulariID);
                @Html.HiddenFor(p => p.MezuniyetJuriOneriFormID);
                @Html.HiddenFor(p => p.IsTezDiliTr);
                @Html.Hidden("PostDetayTabAdi", "tab-TezDanismani");
                @Html.Hidden("SaveData", (Model.MezuniyetJuriOneriFormID > 0 ? "true" : "false"));
                <div class="panel-body form-group-separated">
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Ad Soyad</label>
                        <div class="col-md-9 col-xs-10">
                            @Model.OgrenciAdSoyad
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Tez Dili</label>
                        <div class="col-md-9 col-xs-10">
                            @(Model.IsTezDiliTr ? "Türkçe" : "İngilizce")
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Tez Başlığı Türkçe</label>
                        <div class="col-md-9 col-xs-10" style="font-size: 7.5pt;">
                            @Model.TezBaslikTr
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Tez Başlığı İngilizce</label>
                        <div class="col-md-9 col-xs-10" style="font-size:7.5pt;">
                            @Model.TezBaslikEn
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-3 col-xs-2 control-label">Başlık Değişecek mi?</label>
                        <div class="col-md-9 col-xs-10">
                            <select class="form-control" style="width:100%;" name="IsTezBasligiDegisti" onchange="if($(this).val()=='true'){ $('.RwtezBasliklari').removeClass('hide'); }else{$('.RwtezBasliklari').addClass('hide');}">
                                <option @((Model.IsTezBasligiDegisti == null).ToSelected()) value=""></option>
                                <option @((Model.IsTezBasligiDegisti == true).ToSelected()) value="true">Sınavda tez başlığı değişecek</option>
                                <option @((Model.IsTezBasligiDegisti == false).ToSelected()) value="false">Sınavda tez başlığı değişmeyecek</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group RwtezBasliklari @(Model.IsTezBasligiDegisti == true ? "" : "hide")">
                        <label class="col-md-3 col-xs-2 control-label">Yeni Tez Başlığı Türkçe</label>
                        <div class="col-md-9 col-xs-10">
                            <input type="text" name="YeniTezBaslikTr" id="YeniTezBaslikTr" maxlength="512" value="@Model.YeniTezBaslikTr" class="form-control UpperTextTr tCharacterBlock" />
                        </div>
                    </div>
                    <div class="form-group RwtezBasliklari @(Model.IsTezBasligiDegisti == true ? "" : "hide")">
                        <label class="col-md-3 col-xs-2 control-label">Yeni Tez Başlığı İngilizce</label>
                        <div class="col-md-9 col-xs-10">
                            <input type="text" name="YeniTezBaslikEn" id="YeniTezBaslikEn" maxlength="512" value="@Model.YeniTezBaslikEn" class="form-control UpperTextEn tCharacterBlock" />
                        </div>
                    </div>


                </div>
                <div class="panel panel-primary" style="margin:0px;margin-top:0px;">
                    <div class="panel panel-default tabs" style="margin-bottom:0px; padding:0px;">
