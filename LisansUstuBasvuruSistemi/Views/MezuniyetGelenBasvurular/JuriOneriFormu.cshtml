                                                <div class="form-group">
                                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                        Unvanı (*)
                                                    </label>
                                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                        <input type="text" class="form-control upperCase" name="UnvanAdi" id="UnvanAdi" maxlength="128" readonly="readonly" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.UnvanAdi : "")" style="width: 100%;color:black;" />
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                        E-Posta Adresi (*)
                                                    </label>
                                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                        <input type="text" class="form-control" maxlength="128" name="EMail" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.EMail : "")" style="width: 100%;" id="TikUyesi1EMail" />
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                        Üniversitesi (*)
                                                    </label>
                                                    <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                        <input type="text" class="form-control yUniversites" maxlength="128" name="UniversiteAdi" id="TikUyesi1UniversiteAdi"value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.UniversiteAdi : "")" style="width: 100%;" />
                                                        @if (tikUyesi1Bilgi != null && !tikUyesi1Bilgi.UniversiteAdi.IsNullOrWhiteSpace())
                                                        {
                                                            <script>
                                                                setTimeout(function () {
                                                                    var secilen = @Html.Raw(Json.Encode(new { id = tikUyesi1Bilgi.UniversiteAdi, text = tikUyesi1Bilgi.UniversiteAdi }));
                                                                    $("#TikUyesi1UniversiteAdi").select2('data', secilen);
