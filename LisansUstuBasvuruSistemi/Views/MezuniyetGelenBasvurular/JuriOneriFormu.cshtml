                            <li class="active">
                                <a href="#tab-TezDanismani" data-toggle="tab" aria-expanded="false">
                                    <i class="fa fa-user myCaptionTd"></i>&nbsp; <span style="font-size:8pt;">Tez Danışmanı</span>
                                </a>
                            </li>
                            @if (Model.IsDoktoraOrYL)
