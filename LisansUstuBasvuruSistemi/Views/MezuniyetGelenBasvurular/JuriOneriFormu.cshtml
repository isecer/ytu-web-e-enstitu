                                        <i class="fa fa-user myCaptionTd"></i>&nbsp; <span style="font-size:8pt;">1. Tik Üyesi</span>
                                    </a>
                                </li>
                                <li>
                                    <a href="#tab-TikUyesi2" data-toggle="tab" aria-expanded="false">
                                        <i class="fa fa-user myCaptionTd"></i>&nbsp; <span style="font-size:8pt;">2. Tik Üyesi</span>
                                    </a>
                                </li>
                            }
                            <li>
                                <a href="#tab-YtuIciJuri" data-toggle="tab" aria-expanded="false">
                                    <i class="fa fa-user myCaptionTd"></i>&nbsp; <span style="font-size:8pt;">YTÜ İçinden Jüri Adayı Önerisi</span>
                                </a>
                            </li>
                            <li>
