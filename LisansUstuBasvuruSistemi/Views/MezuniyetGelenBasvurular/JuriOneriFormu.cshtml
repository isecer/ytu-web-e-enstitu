                                                        <input type="text" class="form-control" maxlength="256" name="AnabilimdaliProgramAdi" value="@(tikUyesi1Bilgi != null ? tikUyesi1Bilgi.AnabilimdaliProgramAdi : "")" style="width: 100%;" id="TikUyesi1AnabilimdaliProgramAdi" />
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                        Uzmanlık Alanı (*)
