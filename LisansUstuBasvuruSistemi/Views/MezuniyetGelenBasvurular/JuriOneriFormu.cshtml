                                                    <input type="hidden" name="JuriTipAdi" value="TezDanismani" />
                                                    <input type="hidden" name="AnaTabAdi" value="tab-TezDanismani" />
                                                    <input type="hidden" name="DetayTabAdi" value="tab-TezDanismani" />
                                                    <input type="text" class="form-control upperCase" name="AdSoyad" maxlength="128" readonly="readonly" value="@(tezDanismaniBilgi != null ? tezDanismaniBilgi.AdSoyad : "")" style="width: 100%;color:black;" id="TezDanismaniAdSoyad" />
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                    Unvanı (*)
                                                </label>
                                                <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                    <input type="text" class="form-control upperCase" name="UnvanAdi" maxlength="128" readonly="readonly" value="@(tezDanismaniBilgi != null ? tezDanismaniBilgi.UnvanAdi : "")" style="width: 100%;color:black;" />
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                    E-Posta Adresi (*)
                                                </label>
                                                <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                    <input type="text" class="form-control" maxlength="128" name="EMail" value="@Model.Danisman.EMail.Trim()" style="width: 100%;" id="TezDanismaniEMail" />
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                    Üniversitesi (*)
                                                </label>
