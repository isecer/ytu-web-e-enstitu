                                </a>
                            </li>
                            <li>
                                <a href="#tab-YtuDisiJuri" data-toggle="tab" aria-expanded="false" style="padding:4px;">
                                    <i class="fa fa-user"></i> <span style="font-size:8pt;">YTÜ Dışı Jüri Önerisi</span>
                                </a>
                            </li>
                        </ul>
                        <div class="panel-body tab-content" style="padding:0px;">
