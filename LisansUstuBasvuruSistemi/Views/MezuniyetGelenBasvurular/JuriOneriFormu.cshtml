                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label style="text-align:left;" class="col-md-3 col-xs-4 control-label padding-top-0 padding-bottom-0">
                                                    Uzmanlık Alanı (*)
                                                </label>
                                                <div class="col-md-9 col-xs-8 line-height-30 padding-top-0 padding-bottom-0">
                                                    <input type="text" class="form-control" maxlength="128" name="UzmanlikAlani" value="@(tezDanismaniBilgi != null ? tezDanismaniBilgi.UzmanlikAlani : "")" style="width: 100%;" id="TezDanismaniUzmanlikAlani" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            @if (Model.IsDoktoraOrYL)
