@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@model KmMailGonder
@{
    var mmMessage = ViewBag.MmMessage as MmMessage;
    Layout = null;
}

<div class="row">
    @using (Ajax.BeginForm("MailGonderPost", "Ajax", new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "mailForm" }))
    {
        <input type="text" name="MesajID" id="MesajID" value="@Model.MesajID" style="display:none;" />
        <div class="panel panel-danger" style="padding-bottom: 0px;" id="pnlMailGonder">
            <div class="panel-body" style="padding: 0px;">
                <div class="panel panel-default form-horizontal" style="margin: 0px;">
                    <div class="panel-body form-group-separated">
                        <input type="hidden" name="BasvuruRowID" value="@Model.BasvuruRowID" />
                        <input type="hidden" name="toOrBcc" value="@Model.IsToOrBCC.ToString().ToLower()" />
                        @if (Model.BasvuruSurecID.HasValue)
                        {
                            <input type="hidden" name="BasvuruSurecID" id="BasvuruSurecID" value="@Model.BasvuruSurecID" />

                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Öğrenim Tipi</label>
                                <div class="col-md-10 col-xs-10">
                                    @Html.DropDownList("OgrenimTipKods", null, new { @class = "form-control selectpicker", id = "OgrenimTipKods", multiple = "multiple", data_actions_box = "false", onchange = "getProgramlar();" })
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Gönderilecek Grup</label>
                                <div class="col-md-10 col-xs-10">
                                    @Html.DropDownList("IsBolumOrOgrenci", null, new { @class = "form-control", id = "IsBolumOrOgrenci", onchange = "SetBolumOrOgrenci(this);" })
                                </div>
                            </div>
                            @*<div class="form-group bDurum @(Model.IsBolumOrOgrenci || !Model.IsBasvuruSonuc ?"hide":"")">
                                    <label class="col-md-2 col-xs-2 control-label">Başvuru Durumu</label>
                                    <div class="col-md-10 col-xs-10">
                                        @Html.DropDownList("BasvuruDurumID", null, new { @class = "form-control selectpicker", id = "BasvuruDurumID", multiple = "multiple", data_live_search_placeholder = "Search", data_actions_box = "true", onchange = "getProgramlar();" })
                                    </div>
                                </div>*@
                            <div class="form-group kDurum @(Model.IsBolumOrOgrenci || !Model.IsBasvuruSonuc ?"hide":"")">
                                <label class="col-md-2 col-xs-2 control-label">Kazanma Durumu</label>
                                <div class="col-md-10 col-xs-10">
                                    @Html.DropDownList("MulakatSonucTipIDs", null, new { @class = "form-control selectpicker", id = "MulakatSonucTipIDs", multiple = "multiple", data_live_search_placeholder = "Search", data_actions_box = "false", onchange = "getProgramlar();" })
                                </div>
                            </div>
                            <div class="form-group kDurum @(Model.IsBolumOrOgrenci || !Model.IsBasvuruSonuc ?"hide":"")">
                                <label class="col-md-2 col-xs-2 control-label">Kayıt Durumu</label>
                                <div class="col-md-10 col-xs-10">
                                    @Html.DropDownList("KayitDurumIDs", null, new { @class = "form-control selectpicker", id = "KayitDurumIDs", multiple = "multiple", data_live_search_placeholder = "Search", data_actions_box = "false" })
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Programlar</label>
                                <div class="col-md-10 col-xs-10">
                                    @Html.DropDownList("ProgramKods", null, new { @class = "form-control selectpicker", id = "ProgramKods", multiple = "multiple", data_live_search = "true", data_live_search_placeholder = "Search", data_actions_box = "true" })
                                </div>
                            </div>
                            <script>

                                $(function () {
                                    $('.selectpicker').selectpicker();

                                    setTimeout(setValues(), 600);
                                });
                                function setValues() {
                                    var selectedOgrenimTipKods = '@Html.Raw(Json.Encode(Model.OgrenimTipKods))';
                                    var selectedOgrenimTipKodsJson = JSON.parse(selectedOgrenimTipKods);
                                    if (selectedOgrenimTipKodsJson.length > 0) $('#OgrenimTipKods').selectpicker('val', selectedOgrenimTipKodsJson);
                                    else { $('#OgrenimTipKods').selectpicker('selectAll'); getProgramlar();}
                                    $('#OgrenimTipKods').selectpicker("refresh");
                                }
                                function SetBolumOrOgrenci(sndr){
                                    var vals=$(sndr).val().toLowerCase();
                                    var bSonuc='@(Model.IsBasvuruSonuc.ToString().ToLower())'
                                    if ((vals=="false" || vals==null || vals=="") && bSonuc=="false") {
                                        $('.bDurum').removeClass("hide");
                                    }
                                    else {
                                        $('.bDurum').addClass("hide");
                                    }
                                    if ((vals=="false" || vals==null || vals=="") && bSonuc=="true") {
                                        $('.kDurum').removeClass("hide");
                                    }
                                    else {
                                        $('.kDurum').addClass("hide");
                                    }
                                    getProgramlar();
                                }
                                function getProgramlar() {
                                    var _OgrenimTipKods = $('#OgrenimTipKods').val();
                                    var _IsBolumOrOgrenci=$('#IsBolumOrOgrenci').val();
                                    var _panel = $('#pnlMailGonder');
                                    var _IsSonucOrMulakat='@Model.IsBasvuruSonuc.ToString().ToLower()'
                                    PanelRefresh(_panel, false);
                                    $.ajax({
                                        url: '@Url.Action("GetProgramlarBs", "Ajax")',
                                        data: { 'BasvuruSurecID': '@Model.BasvuruSurecID', 'OgrenimTipKods': _OgrenimTipKods, 'IsBolumOrOgrenci': _IsBolumOrOgrenci, 'IsSonucOrMulakat': _IsSonucOrMulakat},
                                        type: 'POST',
                                        dataType: "json",
                                        enctype: "multipart/form-data",
                                        success: function (result) {
                                            var prgVal = $('#ProgramKods').val();
                                            $('#ProgramKods').empty();
                                            var opt = "";
                                            for (var i = 0; i < result.length; i++) {
                                                var valR = result[i].Value;
                                                var _value = "";
                                                if (valR != null) {
                                                    _value = valR;
                                                }
                                                opt += "<option value=" + _value + ">" + result[i].Caption + "</option>"
                                            }
                                            $('#ProgramKods').append(opt);
                                            var nVal = prgVal;
                                            if (nVal == "" || nVal == null) {
                                                var selectedProgramKods = '@Html.Raw(Json.Encode(Model.ProgramKods))';
                                                var selectedProgramKodsJson = JSON.parse(selectedProgramKods);
                                                if (selectedProgramKodsJson.length > 0) $('#ProgramKods').selectpicker('val', selectedProgramKodsJson);
                                                else $('#ProgramKods').selectpicker('selectAll');
                                                $('#ProgramKods').selectpicker("refresh");
                                            }
                                            else {

                                                $('#ProgramKods').selectpicker('val', nVal);
                                                $('#ProgramKods').selectpicker("refresh");
                                            }
                                            PanelRefresh(_panel, true);
                                        },
                                        error: function (err) {
                                            alert(err.responseText);
                                            PanelRefresh(_panel, true);
                                        }
                                    });
                                }
                            </script>
                        }
                        else
                        {
                            if (Model.IsTopluMail)
                            {

                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Hazır Seçilmiş Liste</label>
                                    <div class="col-md-10 col-xs-10" style="color:maroon;">
                                        <b>@Model.SecilenAlicilars.Count</b> Kişi hazır listeden seçildi
                                        <input type="hidden" name="SecilenTopluAlicilar" value="@string.Join(",", Model.SecilenAlicilars)" />
                                        <input type="hidden" name="IsTopluMail" value="true" />
                                    </div>
                                </div>
                            }
                            <div class="form-group">
                                <label class="col-md-2 col-xs-2 control-label">Alıcı</label>
                                <div class="col-md-10 col-xs-10">
                                    <input type="text" name="Alici" id="Alici" value="" style="width: 100%;" />
                                </div>
                            </div>
                        }
                        <div class="form-group">
                            <label class="col-md-2 col-xs-2 control-label">Şablonlar</label>
                            <div class="col-md-10 col-xs-10">
                                @Html.DropDownList("MailSablonlariID", null, new { @class = "form-control", id = "MailSablonlariID", onchange = "getSablon(this);" })
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-md-2 col-xs-2 control-label">Konu</label>
                            <div class="col-md-10 col-xs-10">
                                <input type="text" name="Konu" id="Konu" value="@Model.Konu" class="form-control removerEnter">
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-md-12 col-xs-12" style="padding: 0px;">
                                <div>
                                    <textarea style="height:100%;" id="AciklamaHtml" name="AciklamaHtml" class="form-control Ckeditor">@Model.AciklamaHtml</textarea>
                                    <textarea style="display: none;" id="Aciklama" name="Aciklama">@Model.Aciklama</textarea>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="col-md-12 col-xs-12">
                                <div>
                                    <img src="~/Images/Attachment.png" style="height: 16px;" /><span> Duyuru Ekleri:</span>
                                    <table id="tableEk" class="table table-striped table-hover table-bordered" style="width: 100%; table-layout: fixed; margin: 0px; font-size: 8pt;">

                                        <tr class="AnaRow">
                                            <th style="width: 30px; padding: 0px;">S.No</th>
                                            <th style="padding: 0px;">Ek Adı</th>
                                            <th style="padding: 0px;">Ek </th>
                                            <th style="padding: 0px; width: 35px;"></th>
                                        </tr>
                                        @foreach (var item in Model.GonderilenMailEkleris.Select((s, inx) => new { s, inx }))
                                        {
                                            <tr class="Detay">
                                                <td style="padding: 0px; vertical-align: middle;" class="Sno">
                                                    @(item.inx + 1))
                                                </td>
                                                <td style='padding: 0px;'>
                                                    <input type="text" name="GonderilenMailEkiID" style="display: none;" value="@item.s.GonderilenMailEkiID" />
                                                    <input type="text" name="EkAdi" style="padding: 0px; height: 22px; " value="@item.s.EkAdi" maxlength="250" placeholder="Ek Adı Giriniz" class="form-control" />
                                                </td>
                                                <td style='padding: 0px; vertical-align: middle;'>
                                                    <a href="@item.s.EkDosyaYolu" target="_blank"><span class="fa fa-download" style="color: green;"></span>&nbsp;@item.s.EkAdi</a>
                                                </td>
                                                <td style='padding-top: 0px; padding-bottom: 0px; vertical-align: middle; text-align: center;'>
                                                    <span style="cursor: pointer;" onclick="EkSil(this)" class="fa fa-trash-o" data-original-title="Eki Sil"></span>
                                                </td>
                                            </tr>
                                        }

                                        <tr class="foterRow">
                                            <td colspan="4" style="text-align: center;">
                                                <a href="javascript:void(0)" onclick="yeniEkEkle()" class="btn btn-xs btn-success"><i class="fa fa-plus tooltips" data-style="blue" data-original-title="">Yeni Ek Ekle</i></a>
                                            </td>
                                        </tr>
                                    </table>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<script src="~/Content/ckeditor/ckeditor.js"></script>
<script src="~/Content/ckeditor/showCk.js"></script>
@if (mmMessage.IsCloseDialog)
{
    <script>
        setTimeout(function () { window.top.dialogKapat('@mmMessage.DialogID'); }, 2000);

    </script>
}

<script>

    $(function () {
        $("#Alici").select2({
            tags: true,
            tokenSeparators: [",", " "],
            minimumInputLength: 2,
            multiple: true,
            ajax: {
                url: '@Url.Action("getTumMailListesi", "Ajax")',
                dataType: "json",
                data: function (term, page) {
                    return {
                        term: term
                    };
                },
                results: function (data, page) {
                    return {
                        results: data
                    };
                }
            },
            formatResult: function (result) {
                var src =   result.Images.toString();
                var cont2="<table class='table table-striped' style='width:100%; margin:0px;'>"+
                            "<tbody>"+
                                "<tr>"+
                                    "<td style='vertical-align:middle;' width='40'>"+
                                        "<span class='user' style='width: 40px;height:40px;margin-right:5px;'> "+
                                            "<img style='width:40px;height:40px;' src='" + src + "' class='pull-left' alt='" + result.AdSoyad + "'>"+
                                        "</span> "+
                                    "</td>"+
                                    "<td style='vertical-align:middle;'>"+
                                        "<table class='table table-striped' style='margin:0px;border-top:none;font-size:8pt;'> "+
                                            "<tbody>"+
                                                "<tr> "+
                                                    "<td>" + result.AdSoyad + "</td> "+
                                                "</tr>  "+
                                                "<tr> "+
                                                    "<td>" + result.text + "</td> "+
                                                "</tr>"+
                                            "</tbody> "+
                                        "</table> "+
                                    "</td>"+
                                "</tr> "+
                            "</tbody>"+
                        "</table>";
                return cont2;
            }
        });
        var emList = @Html.Raw(Json.Encode(Model.EMails.Select(s => new { id = s.Value, text = s.Caption })));
        $("#Alici").select2('data', emList);

    });

    function yeniEkEkle() {
        var row = "<tr class='Detay'>" +
                       "<td class='Sno' style='padding:0px;padding-top:2px;'></td>" +
                        "<td style='padding:0px;' ><input type='text' name='DuyuruDosyaEkID' style='display: none;'/><input type='text'name='DosyaEkiAdi' maxlength='250' style='height:24px;' placeholder='Ek Adı Giriniz' class='form-control removerEnter' /></td>" +
                        "<td style='padding-top:0px;padding-bottom:0px;'><input type='file' name='DosyaEki'    style='height:24px;'/><input type='text' class='hide' name='EkYolu' style='height:24px;'/></td>" +
                        "<td style='width:40px;padding-top:0px;padding-bottom:0px;'>" +
                             "<a href='javascript:void(0)' onclick='EkSil(this)' class='btn btn-xs btn-danger'><i class='fa fa-trash-o tooltips' data-style='blue' data-original-title='Eki Sil'></i></a>" +
                        "</td>" +
                   "</tr>";

        $(row).insertBefore('.foterRow');
        SnoVer();
    }
    function yeniEkEkleG(EkAdi,EkYolu) {
        var row = "<tr class='Detay'>" +
                       "<td class='Sno' style='padding:0px;padding-top:2px;'></td>" +
                        "<td style='padding:0px;' ><input type='text' name='DuyuruDosyaEkID' style='display: none;'/><input type='text'name='DosyaEkiAdi' maxlength='250' style='height:24px;' value='"+EkAdi+"' placeholder='Ek Adı Giriniz' class='form-control removerEnter' /></td>" +
                        "<td style='padding-top:0px;padding-bottom:0px;'>"+EkYolu+"<input class='hide' type='file' name='DosyaEki' style='height:24px;'/><input class='hide' type='text' name='EkYolu' value='"+EkYolu+"'   style='height:24px;'/></td>" +
                        "<td style='width:40px;padding-top:0px;padding-bottom:0px;'>" +
                             "<a href='javascript:void(0)' onclick='EkSil(this)' class='btn btn-xs btn-danger'><i class='fa fa-trash-o tooltips' data-style='blue' data-original-title='Eki Sil'></i></a>" +
                        "</td>" +
                   "</tr>";

        $(row).insertBefore('.foterRow');
        SnoVer();
    }
    function EkSil(sndr) {
        $(sndr).parents('tr').first().remove();
        SnoVer();
    }
    function SnoVer() {
        setTimeout(function () {
            $('#tableEk').find('.Detay').each(function (inx, itmx) {
                var sNoTd = $(itmx).find('td').first().text((inx + 1) + ")");
            })
        }, 200);
    }
    function sbmtDosyaKontrol() {
        var saveOk = true;
        $('#tableEk').find('.Detay').each(function (inx, itmx) {
            var duyuruDosyaAdi = $(itmx).find('td').eq(1).find("input[name='DosyaEkiAdi']").first().val();
            var duyuruDosyaEki = "";
            var duyuruDosyaYolu = "";
            if ($(itmx).find('td').eq(1).find("input").first() != null && $(itmx).find('td').eq(1).find("input").first() != "") {
                duyuruDosyaEki = $(itmx).find('td').eq(2).find("input[name='DosyaEki']").first().val();
                duyuruDosyaYolu = $(itmx).find('td').eq(2).find("input[name='EkYolu']").first().val();

            }
            if (duyuruDosyaAdi == "") {
                saveOk = false;
                $(itmx).find('td').eq(1).first().pulsate({
                    color: "#fdbe41",
                    reach: 60,
                    repeat: 14,
                    speed: 300,
                    glow: true
                });
            }
            if (duyuruDosyaEki == "" && duyuruDosyaYolu=="") {
                saveOk = false;
                $(itmx).find('td').eq(2).first().pulsate({
                    color: "#fdbe41",
                    reach: 60,
                    repeat: 14,
                    speed: 300,
                    glow: true
                });
            }
        });

        if ($('#Konu').val() == "") {
            saveOk = false;
            $('#Konu').parents('div').first().pulsate({
                color: "#fdbe41",
                reach: 60,
                repeat: 14,
                speed: 300,
                glow: true
            });
        }
        var txt = CKEDITOR.instances.AciklamaHtml.document.getBody().getText().trim();
        if (txt == "") {
            saveOk = false;
            $('#AciklamaHtml').parents('div').first().pulsate({
                color: "#fdbe41",
                reach: 60,
                repeat: 14,
                speed: 300,
                glow: true
            });
        }
        var AliciSecildimi = $('#Alici').val();


        if (AliciSecildimi == "" && '@Model.IsTopluMail.ToString().ToLower()'=='false') {
            saveOk = false;
            $('#Alici').parents('div').first().pulsate({
                color: "#fdbe41",
                reach: 60,
                repeat: 14,
                speed: 300,
                glow: true
            });
        }

        var TopluDrm='@(Model.BasvuruSurecID.HasValue?"true":"false")'
        if(TopluDrm=="true"){
            var prKods = $('#ProgramKods').val();
            if (prKods == "" || prKods==null || prKods.length==0) {
                saveOk = false;
                $('#ProgramKods').parents('div').first().pulsate({
                    color: "#fdbe41",
                    reach: 60,
                    repeat: 14,
                    speed: 300,
                    glow: true
                });
            }


        }



        return saveOk;
    }
    function ekleriSil(){
        $('#tableEk').find('.Detay').each(function (inx, itmx) {
            $(itmx).remove();
        })
    }
    function getSablon(sndr) {
        var sndrVal=$(sndr).val();
        var stAck = "@Html.Raw((Model.Aciklama??"").Replace('"','\''))";
        var _panel = $('#pnlMailGonder');
        PanelRefresh(_panel, false);
        if(sndrVal!=""){
            $.ajax({
                url: '@Url.Action("GetSablonlar", "Ajax")',
                data: { 'MailSablonlariID': sndrVal},
                type: 'POST',
                dataType: "json",
                enctype: "multipart/form-data",
                success: function (result) {
                    //$('#Konu').val(result.SablonAdi);
                    CKEDITOR.instances['AciklamaHtml'].setData(result.SablonHtml+stAck);
                    //CKEDITOR.instances["AciklamaHtml"].setData(appndVal);
                    ekleriSil();
                    for (i=0;i<result.MailSablonlariEkleri.length;i++){
                        var ekb_=  result.MailSablonlariEkleri[i];
                        yeniEkEkleG(ekb_.EkAdi,ekb_.EkDosyaYolu);
                    }
                    PanelRefresh(_panel, true);

                },
                error: function (err) {
                    alert(err.responseText);
                    PanelRefresh(_panel, true);
                }
            });
        }
        else {
            ekleriSil();
            CKEDITOR.instances['AciklamaHtml'].setData(stAck);
            PanelRefresh(_panel, true);
        }
    }
</script>



