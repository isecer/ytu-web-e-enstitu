@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model MezuniyetBasvuruDetayDto
@{
    Layout = null;
    var juriOneriFormuKyetki = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuKayit.InRoleCurrent();
    var jofEykyaGonderimYetkisi = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuOnay.InRoleCurrent() && Model.MezuniyetSrModel.SalonRezervasyonlari.All(a => a.SRDurumID != SrTalepDurumEnum.Onaylandı);
    var jofEykYaHazirlandiYetkisi = RoleNames.MezuniyetGelenBasvurularEykyaHazirlandiYetkisi.InRoleCurrent();
    var jofEykdaOnayYetkisi = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuEykOnay.InRoleCurrent() && Model.MezuniyetSrModel.SalonRezervasyonlari.All(a => a.SRDurumID != SrTalepDurumEnum.Onaylandı);
    var juriOneriFormu = Model.MezuniyetJuriOneriFormlaris.FirstOrDefault();
    var tbName = TabAdiEnum.MezuniyetBasvurulariTn + "-" + (Model.IsDelete ? Model.MezuniyetBasvurulariID.ToString() + "_cp" : Model.MezuniyetBasvurulariID.ToString());

    var isDoktora = Model.OgrenimTipKod.IsDoktora();
}

<div class="tab-pane @(Model.SelectedTabIndex == 2 ? "active" : "") " id="@tbName-2">
    <div class="col-md-12">
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg"></i> @(isDoktora ? "Doktora Tez Jüri Öneri Formu" : "Yüksek Lisans Tez Jüri Öneri Formu")</td>
                        <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
                            @if (juriOneriFormuKyetki)
                            {
                                <span class="label label-@(juriOneriFormu==null?"primary":"info")" style="cursor:pointer;" onclick="GetJuriOneriFormu(@Model.MezuniyetBasvurulariID)"><i class="fa fa-@(juriOneriFormu!=null?"edit":"plus") fa-lg"></i> @(juriOneriFormu == null ? "Yeni Jüri öneri Formu Oluştur" : "Jüri Öneri Formunu Düzenle")</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding-left:10px;text-align:left;">
                            @if (juriOneriFormu == null)
                            {

                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td style="text-align:center;height:250px;">
                                            <div class="tasks">
                                                <div class="task-item task-danger" style="margin-bottom: 0px; cursor: auto;">
                                                    <div class="task-text" style="padding-bottom: 0px; font-size: 8pt;">
                                                        Süreç Devamı için Jüri Öneri Formu oluşturulmalı!
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            }
                            else
                            {
                                <table style="width:100%;">
                                    <tr>
                                        <td class="CaptionTd" width="160">Form Kodu</td>
                                        <td class="CaptionTd" width="10">:</td>
                                        <td class="ValueTd">@juriOneriFormu.UniqueID</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd">Tez Dili</td>
                                        <td class="CaptionTd">:</td>
                                        <td class="ValueTd">@(Model.IsTezDiliTr.HasValue ? (Model.IsTezDiliTr == true ? "Türkçe" : "İngilizce") : "")</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Tez Başlığı Türkçe</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">@Model.TezBaslikTr</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Tez Başlığı İngilizce</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">@Model.TezBaslikEn</td>
                                    </tr>
                                    @if (juriOneriFormu.IsTezBasligiDegisti == true)
                                    {
                                        <tr>
                                            <td class="CaptionTd" style="font-weight:bold;">Yeni Tez Başlığı Türkçe</td>
                                            <td class="CaptionTd" style="font-weight:bold;">:</td>
                                            <td class="ValueTd">@juriOneriFormu.YeniTezBaslikTr</td>
                                        </tr>
                                        <tr>
                                            <td class="CaptionTd" style="font-weight:bold;">Yeni Tez Başlığı İngilizce</td>
                                            <td class="CaptionTd" style="font-weight:bold;">:</td>
                                            <td class="ValueTd">@juriOneriFormu.YeniTezBaslikEn</td>
                                        </tr>
                                    }
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Form Çıktısı</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">
                                            <div class="btn-group">
                                                <a href="javascript:void(0);" data-toggle="dropdown" class="btn dropdown-toggle" aria-expanded="false">Form Çıktılarını İndir <span class="caret"></span></a>
                                                <ul class="dropdown-menu" role="menu">

                                                    <li>
                                                        <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Mezuniyet Jüri Öneri Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipiEnum.MezuniyetJuriOneriFormuRaporu&ID=@Model.MezuniyetBasvurulariID' , 'auto', 'modal-dialog modal-lg' )">
                                                            <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> @(isDoktora? "FR-0300 Doktora" : "FR-0339 Yüksek Lisans") Tez Jüri Öneri Formunu İndir
                                                        </a>
                                                    </li>
                                                    @if (juriOneriFormu.EYKDaOnaylandi == true)
                                                    {
                                                        if (!Model.DanismanImzaliFormDosyaAdi.IsNullOrWhiteSpace())
                                                        {

                                                            <li>
                                                                <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Tez Teslim Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipiEnum.MezuniyetJuriUyelerineTezTeslimFormu&MezuniyetJuriOneriFormID=@juriOneriFormu.MezuniyetJuriOneriFormID' , 'auto', 'modal-dialog modal-lg' )">
                                                                    <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> @(isDoktora? "FR-0302 Doktora" : "FR-0341 Yüksek Lisans") Jüri Üyelerine Tez Teslim Formunu İndir
                                                                </a>
                                                            </li>

                                                        }
                                                        <li>
                                                            <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Yayınları Değerlendirme Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipiEnum.MezuniyetTezdenUretilenYayinlariDegerlendirmeFormu&MezuniyetJuriOneriFormID=@juriOneriFormu.MezuniyetJuriOneriFormID' , 'auto', 'modal-dialog modal-lg' )">
                                                                <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0304 Tezden Üretilen Yayınları Değerlendirme Formunu İndir
                                                            </a>
                                                        </li>
                                                    }

                                                </ul>
                                            </div>

                                        </td>
                                    </tr>
                                </table>
                                <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                    <table style="width:100%;">
                                        <tbody>
                                            <tr>
                                                <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg"></i> Önerilen Jüriler</td>
