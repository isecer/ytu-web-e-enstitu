                                                    else
                                                    {
                                                        <tr>
                                                            <td class="CaptionTd" width="200">EYK'da Onay Durumu</td>
                                                            <td class="CaptionTd" width="10">:</td>
                                                            <td class="ValueTd">
                                                                @if (!juriOneriFormu.EYKDaOnaylandi.HasValue)
                                                                {

                                                                    <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> EYK'da onay işlemi Bekleniyor.</span>
                                                                }
                                                                else if (juriOneriFormu.EYKDaOnaylandi == true)
                                                                {

                                                                    <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> EYK'da Onaylandı. (@juriOneriFormu.EYKDaOnaylandiOnayTarihi.ToFormatDate())</span>

                                                                }
                                                                else
                                                                {
                                                                    <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> EYK'da Onaylanmadı. (@juriOneriFormu.EYKDaOnaylandiOnayTarihi.ToFormatDate())</span>

                                                                }
                                                            </td>
                                                        </tr>
                                                        if (juriOneriFormu.EYKDaOnaylandi == false)
                                                        {
                                                            <tr>
                                                                <td class="CaptionTd">Onaylanmama Açıklaması</td>
                                                                <td class="CaptionTd">:</td>
                                                                <td class="ValueTd">
                                                                    @juriOneriFormu.EYKDaOnaylanmadiDurumAciklamasi
                                                                </td>
                                                            </tr>
                                                        }

                                                    }
                                                }
                                            }


                                        </table>
                                    </div>*@
                            }

                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

    </div>
</div>
