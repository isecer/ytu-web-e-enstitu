                                                            </td>
                                                            <td>
                                                                @if (!itemJr.DilSinavAdi.IsNullOrWhiteSpace() && !itemJr.DilPuani.IsNullOrWhiteSpace())
                                                                {
                                                                    <span style="font-size: 8pt;"> @itemJr.DilSinavAdi<br />@itemJr.DilPuani</span>
                                                                }
                                                            </td>
                                                            <td width="120" style="text-align:center;">
                                                                @if (juriOneriFormuOnayYetkiEykDa && juriOneriFormu.EYKYaGonderildi == true && juriOneriFormu.EYKDaOnaylandi != true)
                                                                {
                                                                    @Html.DropDownList("IsAsilOryedek", Model.SIsAsilOryedek, new { id = "IsAsilOryedek_" + itemJr.JuriTipAdi + "_" + juriOneriFormu.MezuniyetJuriOneriFormID, onchange = "JoFormAsilYedekDurumKayit(this," + Model.MezuniyetBasvurulariID + "," + juriOneriFormu.MezuniyetJuriOneriFormID + ",'" + itemJr.JuriTipAdi + "')", @class = "form-control", @style = "text-align-last: center" })
                                                                    if (itemJr.IsAsilOrYedek.HasValue)
                                                                    {
                                                                        <script>
                                                                                                setTimeout(function () {
                                                                                                    $('#IsAsilOryedek_@(itemJr.JuriTipAdi)_@(juriOneriFormu.MezuniyetJuriOneriFormID)').val('@(itemJr.IsAsilOrYedek.ToString())');
                                                                                                }, 50);
                                                                        </script>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    @(juriOneriFormu.EYKDaOnaylandi == true ? itemJr.IsAsilOrYedek.ToAsilYedek() : "Belirlenmedi")
                                                                }
                                                            </td>
                                                        </tr>
                                                        <tr class="MainRow2 cls-Jo_@itemJr.MezuniyetJuriOneriFormuJuriID" style="display:none;">
                                                            <td id="cls-Jo_@itemJr.MezuniyetJuriOneriFormuJuriID" colspan="5" style="padding: 1px 1px 2px 50px;">
                                                                <div class="panel panel-primary">
                                                                    <div class="panel-body">
                                                                        <table class="table" style="table-layout:fixed; font-size:9pt;margin:0px;">
                                                                            <tbody>
                                                                                <tr>
                                                                                    <td width="160" style="font-weight:bold;">Ad Soyad</td>
                                                                                    <td width="10" style="font-weight:bold;">:</td>
                                                                                    <td>@itemJr.AdSoyad</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td style="font-weight:bold;">Unvan</td>
                                                                                    <td style="font-weight:bold;">:</td>
                                                                                    <td>@itemJr.UnvanAdi</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td style="font-weight:bold;">E-Posta Adresi</td>
                                                                                    <td style="font-weight:bold;">:</td>
                                                                                    <td>@itemJr.EMail</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td style="font-weight:bold;">Üniversitesi</td>
                                                                                    <td style="font-weight:bold;">:</td>
                                                                                    <td>@itemJr.UniversiteAdi</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td style="font-weight:bold;">Anabilim Dalı / Program</td>
                                                                                    <td style="font-weight:bold;">:</td>
