                                                                                    <td style="font-weight:bold;">:</td>
                                                                                    <td>@itemJr.UzmanlikAlani</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td style="font-weight:bold;">Bilimsel Çalışmalara Ait Anahtar Sözcükler (3 adet)</td>
                                                                                    <td style="font-weight:bold;">:</td>
                                                                                    <td>@itemJr.BilimselCalismalarAnahtarSozcukler</td>
                                                                                </tr>
                                                                                @if (!itemJr.DilSinavAdi.IsNullOrWhiteSpace() && !itemJr.DilPuani.IsNullOrWhiteSpace())
                                                                                {

                                                                                    <tr>
                                                                                        <td style="font-weight:bold;">Sınav Adı</td>
                                                                                        <td width="10" style="font-weight:bold;text-align:center;">:</td>
                                                                                        <td>@itemJr.DilSinavAdi</td>
                                                                                    </tr>
