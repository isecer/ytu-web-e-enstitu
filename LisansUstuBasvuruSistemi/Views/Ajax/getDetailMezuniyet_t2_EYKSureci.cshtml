@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model MezuniyetBasvuruDetayDto
@{
    Layout = null;
    bool juriOneriFormuKyetki = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuKayit.InRoleCurrent();
    bool juriOneriFormuOnayYetki = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuOnay.InRoleCurrent() && Model.MezuniyetSRModel.SalonRezervasyonlari.All(a => a.SRDurumID != SRTalepDurum.Onaylandı);
    bool juriOneriFormuOnayYetkiEykDa = RoleNames.MezuniyetGelenBasvurularJuriOneriFormuEykOnay.InRoleCurrent() && Model.MezuniyetSRModel.SalonRezervasyonlari.All(a => a.SRDurumID != SRTalepDurum.Onaylandı);
    var juriOneriFormu = Model.MezuniyetJuriOneriFormlaris.FirstOrDefault();
    var tbName = TabAdlari.MezuniyetBasvurulariTN + "-" + (Model.IsDelete ? Model.MezuniyetBasvurulariID.ToString() + "_cp" : Model.MezuniyetBasvurulariID.ToString());
}

<div class="tab-pane @(Model.SelectedTabIndex == 2 ? "active" : "") " id="@tbName-2">
    <div class="col-md-12">
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg"></i> @(Model.OgrenimTipKod.IsDoktora() ? "Doktora Tez Jüri Öneri Formu" : "Yüksek Lisans Tez Jüri Öneri Formu")</td>
                        <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
                            @if (juriOneriFormuKyetki)
                            {
                                <span class="label label-@(juriOneriFormu==null?"primary":"info")" style="cursor:pointer;" onclick="GetJuriOneriFormu(@Model.MezuniyetBasvurulariID)"><i class="fa fa-@(juriOneriFormu!=null?"edit":"plus") fa-lg"></i> @(juriOneriFormu == null ? "Yeni Jüri öneri Formu Oluştur" : "Jüri Öneri Formunu Düzenle")</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding-left:10px;text-align:left;">
                            @if (juriOneriFormu == null)
                            {
                                <table style="width:100%;table-layout:fixed;">
                                    <tr>
                                        <td style="color:maroon;font-size:13pt; text-align:center;height:250px;">Mezuniyet Başvurusuna Ait Jüri Öneri Formu Oluşturulmadı!</td>
                                    </tr>
                                </table>
                            }
                            else
                            {
                                <table style="width:100%;">
                                    <tr>
                                        <td class="CaptionTd" width="160">Form Kodu</td>
                                        <td class="CaptionTd" width="10">:</td>
                                        <td class="ValueTd">@juriOneriFormu.UniqueID</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd">Tez Dili</td>
                                        <td class="CaptionTd">:</td>
                                        <td class="ValueTd">@(Model.IsTezDiliTr.HasValue ? (Model.IsTezDiliTr == true ? "Türkçe" : "İngilizce") : "")</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Tez Başlığı Türkçe</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">@Model.TezBaslikTr</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Tez Başlığı İngilizce</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">@Model.TezBaslikEn</td>
                                    </tr>
                                    @if (juriOneriFormu.IsTezBasligiDegisti == true)
                                    {
                                        <tr>
                                            <td class="CaptionTd" style="font-weight:bold;">Yeni Tez Başlığı Türkçe</td>
                                            <td class="CaptionTd" style="font-weight:bold;">:</td>
                                            <td class="ValueTd">@juriOneriFormu.YeniTezBaslikTr</td>
                                        </tr>
                                        <tr>
                                            <td class="CaptionTd" style="font-weight:bold;">Yeni Tez Başlığı İngilizce</td>
                                            <td class="CaptionTd" style="font-weight:bold;">:</td>
                                            <td class="ValueTd">@juriOneriFormu.YeniTezBaslikEn</td>
                                        </tr>
                                    }
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Form Çıktısı</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">
                                            <div class="btn-group">
                                                <a href="javascript:void(0);" data-toggle="dropdown" class="btn dropdown-toggle" aria-expanded="false">Form Çıktılarını İndir <span class="caret"></span></a>
                                                <ul class="dropdown-menu" role="menu">
                                                    @if (Model.OgrenimTipKod.IsDoktora())
                                                    {
                                                        <li>
                                                            <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Mezuniyet Jüri Öneri Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.MezuniyetJuriOneriFormuRaporu&ID=@Model.MezuniyetBasvurulariID' , 'auto', 'modal-dialog modal-lg' )">
                                                                <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0339 Yüksek Lisans Tez Jüri Öneri Formunu İndir
                                                            </a>
                                                        </li>
                                                        if (juriOneriFormu.EYKDaOnaylandi == true)
                                                        {
                                                            if (!Model.DanismanImzaliFormDosyaAdi.IsNullOrWhiteSpace())
                                                            {
                                                                <li>
                                                                    <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Tez Teslim Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.MezuniyetJuriUyelerineTezTeslimFormu&MezuniyetJuriOneriFormID=@juriOneriFormu.MezuniyetJuriOneriFormID' , 'auto', 'modal-dialog modal-lg' )">
                                                                        <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0341 Yüksek Lisans Jüri Üyelerine Tez Teslim Formunu İndir
                                                                    </a>
                                                                </li>
                                                                <li>
                                                                    <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Yayınları Değerlendirme Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.MezuniyetTezdenUretilenYayinlariDegerlendirmeFormu&MezuniyetJuriOneriFormID=@juriOneriFormu.MezuniyetJuriOneriFormID' , 'auto', 'modal-dialog modal-lg' )">
                                                                        <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0304 Tezden Üretilen Yayınları Değerlendirme Formunu İndir
                                                                    </a>
                                                                </li>

                                                            }
                                                        }

                                                    }
                                                    else
                                                    {
                                                        <li>
                                                            <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Mezuniyet Jüri Öneri Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.MezuniyetJuriOneriFormuRaporu&ID=@Model.MezuniyetBasvurulariID' , 'auto', 'modal-dialog modal-lg' )">
                                                                <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0300 Doktora Tez Jüri Öneri Formunu İndir
                                                            </a>
                                                        </li>
                                                        if (juriOneriFormu.EYKDaOnaylandi == true)
                                                        {
                                                            if (!Model.DanismanImzaliFormDosyaAdi.IsNullOrWhiteSpace())
                                                            {
                                                                <li>
                                                                    <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Tez Teslim Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.MezuniyetJuriUyelerineTezTeslimFormu&MezuniyetJuriOneriFormID=@juriOneriFormu.MezuniyetJuriOneriFormID' , 'auto', 'modal-dialog modal-lg' )">
                                                                        <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0302 Doktora Jüri Üyelerine Tez Teslim Formunu İndir
                                                                    </a>
                                                                </li>
                                                                <li>
                                                                    <a href="javascript:void(0);" onclick="yeniDialogBB(null, 'Yayınları Değerlendirme Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipleri.MezuniyetTezdenUretilenYayinlariDegerlendirmeFormu&MezuniyetJuriOneriFormID=@juriOneriFormu.MezuniyetJuriOneriFormID' , 'auto', 'modal-dialog modal-lg' )">
                                                                        <i class="fa fa-file-pdf-o" style="font-size:13pt;font-weight:bold;"></i> FR-0304 Tezden Üretilen Yayınları Değerlendirme Formunu İndir
                                                                    </a>
                                                                </li>
                                                            }

                                                        }

                                                    }
                                                </ul>
                                            </div>

                                        </td>
                                    </tr>
                                </table>
                                <table class="table" style="font-size:9pt;margin:0px;">
                                    <thead>
                                        <tr class="info">
                                            <th width="35" height="30"></th>
                                            <th width="100">Unvan</th>
                                            <th width="240">Ad Soyad</th>
                                            <th>Dil Sınavı</th>
                                            <th width="120" style="text-align:center;">Jüri Seçim Durumu</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td colspan="5" style="padding:0px;">
