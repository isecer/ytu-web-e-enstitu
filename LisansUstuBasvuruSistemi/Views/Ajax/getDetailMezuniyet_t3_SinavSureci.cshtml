@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model MezuniyetBasvuruDetayDto
@{


    Layout = null;
    bool KayitYetki = RoleNames.MezuniyetGelenBasvurularKayit.InRoleCurrent();
    bool SrTalepYetki = Model.KullaniciID == UserIdentity.Current.Id || RoleNames.MezuniyetGelenBasvurularSrTalebiYap.InRoleCurrent();
    var JuriOneriFormu = Model.MezuniyetJuriOneriFormlaris.FirstOrDefault();
    var tbName = TabAdlari.MezuniyetBasvurulariTN + "-" + Model.MezuniyetBasvurulariID.ToString();

    var IsOgrenci = Model.KullaniciID == UserIdentity.Current.Id;
    var IsDanismani = Model.TezDanismanID == UserIdentity.Current.Id;
    var IsTezliYlOrDr = Model.OgrenimTipKod == OgrenimTipi.TezliYuksekLisans;
    var SonSR = Model.MezuniyetSRModel.SalonRezervasyonlari.FirstOrDefault();

    bool IsJuriDegerlendirmeVar = false;
    bool IsSrTalebiYapilabilir = false;
    if (SonSR != null)
    {
        IsJuriDegerlendirmeVar = SonSR.SRTaleplerJuris.Any(a => !a.UnvanAdi.IsNullOrWhiteSpace() || a.IsLinkGonderildi == true);
        if (SonSR.MezuniyetSinavDurumID == MezuniyetSinavDurum.Uzatma)
        {
            if (IsJuriDegerlendirmeVar) { IsSrTalebiYapilabilir = SonSR.IsDanismanUzatmaSonrasiOnay == true; }
            else { IsSrTalebiYapilabilir = true; }
        }
        else if (SonSR.SRDurumID == SRTalepDurum.IptalEdildi || SonSR.SRDurumID == SRTalepDurum.Reddedildi) { IsSrTalebiYapilabilir = true; }
    }
    else { IsSrTalebiYapilabilir = true; }

}

<div class="tab-pane @(Model.SelectedTabIndex == 3 ? "active" : "") " id="@tbName-3">
    <div class="col-md-12">
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-edit fa-lg"></i> Sınav Süreci</td>
                        <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
                            @if (IsSrTalebiYapilabilir)
                            {
                                <span class="label label-primary" style="cursor:pointer;" onclick="showSRDialog(@Model.MezuniyetBasvurulariID,0)">Yeni Sınav Talebi Oluştur</span>
                            }
                            else if (Model.EYKTarihi.HasValue == false)
                            {
                                <span class="label label-danger" style="cursor:pointer;">Enstitü tarafından EYK Tarihi girilmeden rezervasyon işlemi yapılamaz</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">

                            @if (Model.MezuniyetSRModel.SalonRezervasyonlari.Count == 0)
                            {
                                <table style="width:100%;table-layout:fixed;">
                                    <tbody>
                                        <tr>
                                            <td style="color:maroon;font-size:13pt; text-align:center;height:250px;">

                                                @if (IsSrTalebiYapilabilir)
                                                {
                                                    if (Model.MezuniyetSRModel.IsSrEykSureAsimi)
                                                    {
                                                        @("Belirlenen Eyk tarihine göre salon rezervasyonu " + Model.MezuniyetSRModel.EykIlkSrMaxTarih.ToFormatDate() + " tarihine kadar alınmamış ve rezervasyon için belirlenen süre aşılmıştır.")
                                                    }
                                                    else
                                                    {
                                                        @("Belirlenen Eyk tarihine göre salon rezervasyonu işlemi en geç " + Model.MezuniyetSRModel.EykIlkSrMaxTarih.ToFormatDate() + " tarihine kadar yapılması gerekmektedir.")
                                                    }
                                                }
                                                else
                                                {
                                                    @("Kayıtlı Salon Rezervasyonu Bilgisi Bulunamadı.")
                                                }
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <table class="table" style="width:100%;table-layout:fixed; font-size:9pt;margin:0px;">

                                    <thead>
                                        <tr class="info">
                                            <th height="30" width="50"></th>
                                            <th width="145" style="font-size:9pt;">Sınav Tarihi</th>
                                            <th width="130" style="font-size:9pt;">Rezervasyon Onayı</th>
                                            <th style="font-size:9pt;">Jüri Değerlendirme Sonucu</th>
                                            <th style="font-size:9pt;">Değerlendirme Enstitü Onayı</th>
                                            <th width="40" style="padding-right:12px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td colspan="6" style="padding:0px;">
                                                <table class="table table-hover" style="width:100%;table-layout:fixed;@Model.DurumColor;margin:0px;">
                                                    @{
                                                        int RowIndex = Model.MezuniyetSRModel.SalonRezervasyonlari.Count;
                                                        foreach (var item in Model.MezuniyetSRModel.SalonRezervasyonlari)
                                                        {
                                                            var JuriOnayiOlmayacak = item.MezuniyetSinavDurumID > MezuniyetSinavDurum.SonucGirilmedi && !(item.JuriSonucMezuniyetSinavDurumID > MezuniyetSinavDurum.SonucGirilmedi);
                                                            var IsJuriSonucGirildi = item.JuriSonucMezuniyetSinavDurumID > MezuniyetSinavDurum.SonucGirilmedi;
                                                            var IsJuriDegerlendirmeBasladi = item.SRTaleplerJuris.Any(a => a.MezuniyetSinavDurumID > MezuniyetSinavDurum.SonucGirilmedi);
                                                            var IsEnstituSonucuGirdi = item.MezuniyetSinavDurumID > MezuniyetSinavDurum.SonucGirilmedi;
                                                            var IsSrTalebiDuzeltilebilir = item.SRDurumID == SRTalepDurum.TalepEdildi && item.IsSonSRTalebi && !IsEnstituSonucuGirdi && (IsJuriDegerlendirmeVar ? !IsJuriDegerlendirmeBasladi : true);
                                                            <tr>
                                                                <td width="55">
                                                                    <table>
                                                                        <tr>
                                                                            <td style="width:20px;font-size:12pt;">@RowIndex)</td>
                                                                            <td>
                                                                                <ul class="panel-controls">
                                                                                    <li id="iShow_Ap_@item.SRTalepID" onclick="showDetailY('Ap_@item.SRTalepID')">
                                                                                        <a href="javascript:void(0)"><span class="fa @(RowIndex == Model.MezuniyetSRModel.SalonRezervasyonlari.Count ? "fa-angle-down" : "fa-angle-up")"></span> </a>
                                                                                    </li>
                                                                                </ul>
                                                                            </td>
                                                                        </tr>
                                                                    </table>
                                                                </td>
                                                                <td width="145">
                                                                    @item.Tarih.ToString("dd.MM.yyyy") @item.HaftaGunAdi <br />@string.Format("{0:hh\\:mm}", item.BasSaat) - @string.Format("{0:hh\\:mm}", item.BitSaat)
                                                                </td>
                                                                <td width="130" style="color:@item.Color">

                                                                    @if (!item.SRDurumAciklamasi.IsNullOrWhiteSpace())
                                                                    {
                                                                        <span data-style="blue" title="@item.SRDurumAciklamasi">
                                                                            <i class="@item.ClassName"></i>
                                                                        </span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <i class="@item.ClassName"></i>
                                                                    }
                                                                    @Html.Raw(item.DurumListeAdi)

                                                                </td>
                                                                <td style="color:@item.SColor">

                                                                    @if (item.SRDurumID != SRTalepDurum.Onaylandı)
                                                                    {

                                                                    }
                                                                    else if (item.JuriSonucMezuniyetSinavDurumID == MezuniyetSinavDurum.Basarili)
                                                                    {
                                                                        <span style="color:green;" aria-hidden="true"><i class="fa fa-thumbs-o-up"></i> @(item.IsOyBirligiOrCouklugu == true ? "Oy Birliği İle" : "Oy Çokluğu İle") Başarılı</span>
                                                                    }
                                                                    else if (item.JuriSonucMezuniyetSinavDurumID == MezuniyetSinavDurum.Basarisiz)
                                                                    {
                                                                        <span style="color:maroon;" aria-hidden="true"><i class="fa fa-thumbs-o-down"></i> @(item.IsOyBirligiOrCouklugu == true ? "Oy Birliği İle" : "Oy Çokluğu İle") Başarısız</span>

                                                                    }
                                                                    else if (item.JuriSonucMezuniyetSinavDurumID == MezuniyetSinavDurum.Uzatma)
                                                                    {
                                                                        <span style="color:maroon;" aria-hidden="true"><i class="fa fa-calendar"></i> @(item.IsOyBirligiOrCouklugu == true ? "Oy Birliği İle" : "Oy Çokluğu İle") Uzatma</span>

                                                                    }
                                                                    else
                                                                    {
                                                                        if (IsEnstituSonucuGirdi)
                                                                        {
                                                                            <i class="@item.SClassName"></i> @item.SDurumListeAdi
                                                                        }
                                                                        else
                                                                        {
                                                                            <span aria-hidden="true"><i class="fa fa-clock-o"></i> Değerlendirme Sürecinde.</span>

                                                                        }

                                                                    }
                                                                </td>
                                                                <td style="color:@item.SColor">
                                                                    @if (item.SRDurumID == SRTalepDurum.Onaylandı)
                                                                    {
                                                                        <i class="@item.SClassName"></i> <span>@item.SDurumListeAdi</span>
                                                                    }
                                                                </td>
                                                                <td width="40">
                                                                    @if (IsSrTalebiDuzeltilebilir)
                                                                    {
                                                                        <a href="javascript:void(0)" onclick="showSRDialog(@Model.MezuniyetBasvurulariID,@item.SRTalepID)"><i class="fa fa-edit fa-lg" title="Rezervasyonu Düzenle"></i></a>
                                                                    }
                                                                </td>
                                                            </tr>

                                                            <tr class="MainRow2 cls-Ap_@item.SRTalepID" style="@(RowIndex == Model.MezuniyetSRModel.SalonRezervasyonlari.Count ? "" : "display:none;")">
                                                                <td id="cls-Ap_@item.SRTalepID" colspan="6" style="padding: 1px 1px 2px 50px;">

                                                                    <div class="widget widget-default" style="border-top:1px solid;color:@item.Color;border-top-color:@item.Color; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                                                        <table style="width:100%;">
                                                                            <tbody>
                                                                                <tr>
                                                                                    <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-calendar fa-lg" aria-hidden="true"></i> Rezervasyon Bilgisi</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td>
                                                                                        <table style="width:100%;">

                                                                                            <tr>
                                                                                                <td class="CaptionTd" width="140">Salon Adı</td>
                                                                                                <td class="CaptionTd" width="10">:</td>
                                                                                                <td class="ValueTd">
                                                                                                    @item.SalonAdi
                                                                                                </td>
                                                                                            </tr>
                                                                                            <tr>
                                                                                                <td class="CaptionTd" width="140">Sınav Tarihi</td>
                                                                                                <td class="CaptionTd" width="10">:</td>
                                                                                                <td class="ValueTd">

                                                                                                    <table>
                                                                                                        <tr>
                                                                                                            <td id="SrSinavTarihLblContent_@item.SRTalepID">
                                                                                                                @item.Tarih.ToString("dd.MM.yyyy") @item.HaftaGunAdi  @string.Format("{0:hh\\:mm}", item.BasSaat) - @string.Format("{0:hh\\:mm}", item.BitSaat)

                                                                                                            </td>
                                                                                                            <td id="SrSinavTarihiContent_@item.SRTalepID" class="hide">
                                                                                                                <input class="form-control form-control-inline input-medium" autocomplete="off" size="16" type="text" value="@item.Tarih.AddHours(item.BasSaat.Hours).AddMinutes(item.BasSaat.Minutes).ToString("dd-MM-yyyy HH:mm")" id="SrSinavTarihiIInput_@item.SRTalepID">
                                                                                                            </td>
                                                                                                            @if (KayitYetki)
                                                                                                            {
                                                                                                                <td width="25" style="text-align:right;font-size:10pt;">
                                                                                                                    <a href="javascript:void(0)" onclick="ShowSinavTarihi(@item.SRTalepID)"><i class="fa fa-edit fa-lg" title="EYK Tarihini Düzenle"></i></a>
                                                                                                                    <script>
                                                                                                                        $('#SrSinavTarihiIInput_@item.SRTalepID').datetimepicker({
                                                                                                                            lang: 'tr',
                                                                                                                            timepicker: true,
                                                                                                                            format: 'd-m-Y H:i'
                                                                                                                        });

                                                                                                                        function ShowSinavTarihi(id) {
                                                                                                                            if ($('#SrSinavTarihLblContent_' + id).hasClass('hide')) {
                                                                                                                                $('#SrSinavTarihLblContent_' + id).removeClass('hide');
                                                                                                                                $('#SrSinavTarihiContent_' + id).addClass('hide');
                                                                                                                                $('#SrSinavTarihiIKayitContent_' + id).addClass('hide');

                                                                                                                            }
                                                                                                                            else {
                                                                                                                                $('#SrSinavTarihLblContent_' + id).addClass('hide');
                                                                                                                                $('#SrSinavTarihiContent_' + id).removeClass('hide');
                                                                                                                                $('#SrSinavTarihiIKayitContent_' + id).removeClass('hide');
                                                                                                                            }
                                                                                                                        }

                                                                                                                    </script>
                                                                                                                </td>
                                                                                                                <td id="SrSinavTarihiIKayitContent_@item.SRTalepID" width="25" style="text-align:right;font-size:10pt;" class="hide">
                                                                                                                    <a href="javascript:void(0)" onclick="SaveSinavTarihiTarihi(@item.SRTalepID)"><i class="fa fa-save fa-lg" title="Sınav Tarihini Kaydet"></i></a>
                                                                                                                    <script>

                                                                                                                            function SaveSinavTarihiTarihi(id) {
                                                                                                                                var val = $('#SrSinavTarihiIInput_' + id).val();
                                                                                                                                var _panel = $('#bsvrDet_@Model.MezuniyetBasvurulariID');
                                                                                                                                _pRefresh(_panel, false);
                                                                                                                                $.ajax({
                                                                                                                                    url: '@Url.Action("SinavTarihiKaydet", "MezuniyetGelenBasvurular")',
                                                                                                                                    data: { 'id': id, 'SinavTarihi': val },
                                                                                                                                    success: function (result) {
                                                                                                                                        _pRefresh(_panel, true);
                                                                                                                                        getMsg(result.MmMessage);
                                                                                                                                        if (result.IsSuccess) {
                                                                                                                                            getDetailx(@Model.MezuniyetBasvurulariID);
                                                                                                                                        }
                                                                                                                                    },
                                                                                                                                    error: function (err) {
                                                                                                                                        _pRefresh(_panel, true);
                                                                                                                                        alert(err.responseText);
                                                                                                                                    }
                                                                                                                                });
                                                                                                                            }

                                                                                                                    </script>
                                                                                                                </td>



                                                                                                            }
                                                                                                        </tr>
                                                                                                    </table>
                                                                                                </td>
                                                                                            </tr>
                                                                                            <tr>
                                                                                                <td class="CaptionTd" width="140">Salon Talep Durumu</td>
                                                                                                <td class="CaptionTd" width="10">:</td>
                                                                                                <td class="ValueTd">
                                                                                                    @if (KayitYetki && Model.IsMezunOldu.HasValue == false && item.IsSonSRTalebi && (IsJuriDegerlendirmeVar ? !IsJuriDegerlendirmeBasladi : true) && !IsEnstituSonucuGirdi)
                                                                                                    {
                                                                                                        @Html.DropDownList("SRDurumID", item.SrDurumSelectList.SRDurumID, new { id = "SRDurumID_" + item.SRTalepID, onchange = "DurumKontrol(" + item.SRTalepID + ")", style = "width:120px;" })
                                                                                                        <span class="label label-primary" style="cursor:pointer;font-size:8pt;" onclick="SrDurumKaydet(@Model.MezuniyetBasvurulariID,@item.SRTalepID)"><i class="fa fa-save" aria-hidden="true"></i> Kaydet</span>
                                                                                                    }
                                                                                                    else
                                                                                                    {
                                                                                                        @item.DurumListeAdi
                                                                                                    }
                                                                                                </td>
                                                                                            </tr>
                                                                                            <tr class="@(item.SRDurumID == SRTalepDurum.Reddedildi ? "" : "hide")" id="aciklamabilgi_@item.SRTalepID">
                                                                                                <td class="CaptionTd">Açıklama</td>
                                                                                                <td class="CaptionTd">:</td>
                                                                                                <td class="ValueTd">
                                                                                                    @if (KayitYetki && Model.IsMezunOldu.HasValue == false && item.IsSonSRTalebi)
                                                                                                    {
                                                                                                        <textarea style="width:100%;resize:vertical;" id="SRDurumAciklamasi_@item.SRTalepID" name="SRDurumAciklamasi_">@item.SRDurumAciklamasi.toStrObjEmptString().Trim()</textarea>

                                                                                                    }
                                                                                                    else
                                                                                                    {
                                                                                                        @item.SRDurumAciklamasi
                                                                                                    }
                                                                                                </td>
                                                                                            </tr>
                                                                                        </table>
                                                                                    </td>
                                                                                </tr>

                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    @if (item.SRDurumID == SRTalepDurum.Onaylandı)
                                                                    {
                                                                        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
                                                                            <table style="width:100%;">
                                                                                <tr>
                                                                                    <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-file-text-o fa-lg" aria-hidden="true"></i> Tez Bilgileri</td>
                                                                                </tr>
                                                                                @if (item.IsTezBasligiDegisti.HasValue)
                                                                                {
                                                                                    <tr>
                                                                                        <td class="CaptionTd" width="140">Tez Başlığı Değişti Mi</td>
                                                                                        <td class="CaptionTd" width="10">:</td>
                                                                                        <td class="ValueTd">
                                                                                            @(item.IsTezBasligiDegisti == true ? "Tez Başlığı Değişti" : "Tez Başlığı Değişmedi")
                                                                                        </td>
                                                                                    </tr>
                                                                                }
                                                                                <tr>
                                                                                    <td class="CaptionTd" width="140">Tez Dili</td>
                                                                                    <td class="CaptionTd" width="10">:</td>
                                                                                    <td class="ValueTd">
                                                                                        @(item.IsTezDiliTr == true ? "Türkçe" : "İngilizce")
                                                                                    </td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td class="CaptionTd" width="140">@(item.IsTezBasligiDegisti == true ? "Yeni " : "")Tez Başlığı Türkçe</td>
                                                                                    <td class="CaptionTd" width="10">:</td>
                                                                                    <td class="ValueTd">
                                                                                        @(item.IsTezBasligiDegisti == true ? item.YeniTezBaslikTr : item.TezBaslikTr)
                                                                                    </td>
                                                                                </tr>

                                                                                <tr>
                                                                                    <td class="CaptionTd" width="140">@(item.IsTezBasligiDegisti == true ? "Yeni " : "")Tez Başlığı İngilizce</td>
                                                                                    <td class="CaptionTd" width="10">:</td>
                                                                                    <td class="ValueTd">
                                                                                        @(item.IsTezBasligiDegisti == true ? item.YeniTezBaslikEn : item.TezBaslikEn)
                                                                                    </td>
                                                                                </tr>

                                                                                <tr>
                                                                                    <td class="CaptionTd" width="300">Tez Sanayi İş Birliği Kapsamında Mı Gerçekleşti?</td>
                                                                                    <td class="CaptionTd" width="10">:</td>
                                                                                    <td class="ValueTd">
                                                                                        @if (JuriOneriFormu.IsTezSanayiVeIsBirligiKapsamindaGerceklesti == null)
                                                                                        {
                                                                                            <span>
                                                                                                <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;"></i> Değerlendirme Yapılması Bekleniyor.</span>
                                                                                            </span>
                                                                                        }
                                                                                        else if (JuriOneriFormu.IsTezSanayiVeIsBirligiKapsamindaGerceklesti == true)
                                                                                        {
                                                                                            <span>Tez Sanayi ile İş Birliği Kapsamında Gerçekleşti</span>

                                                                                        }
                                                                                        else if (JuriOneriFormu.IsTezSanayiVeIsBirligiKapsamindaGerceklesti == false)
                                                                                        {
                                                                                            <span>Tez Sanayi ile İş Birliği Kapsamında Gerçekleşmedi</span>
                                                                                        }
                                                                                    </td>
                                                                                </tr>
                                                                                @if (new List<int> { OgrenimTipi.Doktra, OgrenimTipi.ButunlesikDoktora }.Contains(Model.OgrenimTipKod) && item.IsYokDrBursiyeriVar.HasValue)
                                                                                {
                                                                                    <tr>
                                                                                        <td class="CaptionTd" width="140">100/2000 YÖK Bursiyeri</td>
                                                                                        <td class="CaptionTd" width="10">:</td>
                                                                                        <td class="ValueTd">
                                                                                            @(item.IsYokDrBursiyeriVar == true ? "Var " : "Yok")
                                                                                        </td>
                                                                                    </tr>
                                                                                    if (item.IsYokDrBursiyeriVar == true)
                                                                                    {
                                                                                        <tr>
                                                                                            <td class="CaptionTd" width="140">Öncelikli Alt Alan Adı</td>
                                                                                            <td class="CaptionTd" width="10">:</td>
                                                                                            <td class="ValueTd">
                                                                                                @item.YokDrOncelikliAlan
                                                                                            </td>
                                                                                        </tr>
                                                                                    }
                                                                                }
                                                                            </table>
                                                                            <br />
                                                                            <table class="table" style="width:100%;margin:0px;">
                                                                                <tbody>
                                                                                    <tr>
                                                                                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg" aria-hidden="true"></i> Jüri Üyeleri Değerlendirme Bilgileri</td>
                                                                                        <td width="40" style=" border-bottom:1px solid;">
                                                                                            @if (KayitYetki && !IsJuriSonucGirildi && !IsEnstituSonucuGirdi && item.SRTaleplerJuris.Any(a => (a.JuriTipAdi.Contains("YtuIci") || a.JuriTipAdi.Contains("YtuDisi")) && !a.MezuniyetSinavDurumID.HasValue))
                                                                                            {
                                                                                                <span class="label label-info" style="cursor:pointer;font-size:8pt;" onclick="SrJuriDegistir(@Model.MezuniyetBasvurulariID,'@item.UniqueID')"><i class="fa fa-group"></i> Jüri Değiştir</span>
                                                                                            }
                                                                                        </td>
                                                                                    </tr>
                                                                                    <tr>
                                                                                        <td colspan="2">

                                                                                            <table class="table" style="width:100%;margin:0px;">
                                                                                                <tr class="info">
                                                                                                    <th width="35"></th>
                                                                                                    <th width="100" class="clsHide">Unvanı</th>
