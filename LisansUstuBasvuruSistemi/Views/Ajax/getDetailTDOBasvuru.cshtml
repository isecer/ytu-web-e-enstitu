@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model TdoBasvuruDetayDto
@{
    Layout = null;
    var isKullaniciGormeYetki = RoleNames.Kullanicilar.InRoleCurrent(); 
    var tdoEykyaGonderimYetkisi = RoleNames.TdoeyKyaGonderimYetkisi.InRoleCurrent();
    var tdoEykdaOnayYetkisi = RoleNames.TdoeyKdaOnayYetkisi.InRoleCurrent();
    var tdoFormOlusturmaYetkisi = RoleNames.TdoFormOlusturmaYetkisi.InRoleCurrent();
    var kayitYetki = RoleNames.TdoGelenBasvuruKayit.InRoleCurrent();


}
<style>

    .CaptionTd {
        font-weight: bold;
        font-size: 9pt;
        margin: 0px;
    }

    .ValueTd {
        font-size: 9pt;
        margin: 0px;
        text-align: left;
    }
</style>
<div class="panel" style="border:none;" id="bsvrDet_@Model.TDOBasvuruID">


<div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
    <table style="width:100%;">
        <tr>
            <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-id-card-o fa-lg"></i> Öğrenci Bilgileri</td>
            <td class="clsHide" width="100" style="font-weight:bold;font-size:15pt; border-bottom:1px solid; text-align:right;">
                <a href="javascript:void(0);" onclick="GetDetail('@Model.TDOBasvuruID')" class="panel-refresh"><span class="fa fa-refresh" aria-hidden="true"></span></a>
            </td>

        </tr>
        <tr>

            <td style="padding-left:10px;text-align:left;">

                <table style="width:100%;">
                    <tr>
                        <td class="CaptionTd" width="140">Ad Soyad</td>
                        <td class="CaptionTd" width="10">:</td>
                        <td class="ValueTd">
                            @Model.Ad @Model.Soyad (@Model.OgrenciNo)
                        </td>
                    </tr>
                    @if (!Model.DegerlendirenUniqueID.HasValue)
                    {
                        <tr>
                            <td class="CaptionTd">Öğrenim Seviyesi</td>
                            <td class="CaptionTd">:</td>
                            <td class="ValueTd">@Model.OgrenimTipAdi</td>
                        </tr>
                    }
                    <tr>
                        <td class="CaptionTd">Program</td>
                        <td class="CaptionTd">:</td>
                        <td class="ValueTd">@Model.AnabilimdaliAdi / @Model.ProgramAdi</td>
                    </tr>
                    @if (!Model.DegerlendirenUniqueID.HasValue)
                    {
                        <tr>
                            <td class="CaptionTd">Kayıt Tarihi</td>
                            <td class="CaptionTd">:</td>
                            <td class="ValueTd">@Model.KayitDonemi , @Model.KayitTarihi.ToDateString()</td>
                        </tr>
                    }
                </table>
            </td>
            <td class="clsHide" width="100" style="text-align:center;">
                <img src="@(Model.ResimAdi.ToKullaniciResim())" style="width:90px;height:90px;" class="img-circle img-thumbnail">
            </td>
        </tr>

    </table>
</div>
<div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:0px;padding:6px 10px;">
<table style="width:100%;">
<tr>
    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-list fa-lg"></i> Tez danışmanı öneri formları</td>
    <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
        @if (Model.TdoBasvurusuYapabilir)
        {
            if (Model.IsYeniDanismanOneriOrDegisiklik)
            {
                <span class="label label-info" id="YeniRaporBtn_@Model.TDOBasvuruID" style="cursor: pointer;" onclick="GetTdoYeniDanismanFormu(@Model.TDOBasvuruID);"><i class="fa fa-plus"></i> Yeni Tez Danışmanı Öneri Formu Oluştur</span>
            }
            else
            {
                <div class="btn-group btn-group-sm">
                    <a href="javascript:void(0);" data-toggle="dropdown" class="btn btn-danger dropdown-toggle"><i class="fa fa-cogs"></i> Değişiklik Talebi İşlemi İçin Tıklayınız</a>
                    <ul class="dropdown-menu" role="menu">
                        <li>
                            <a href="javascript:void(0)" onclick="GetTdoDanismanDilBaslikDegisiklikFormu(@Model.TDOBasvuruID,0)"><i class="fa fa-edit"></i>Tez Danışman/Dil/Başlık Değişikliği</a>
                        </li>
                        <li>
                            <a href="javascript:void(0)" onclick="GetTdoDanismanDegisiklikFormu(@Model.TDOBasvuruID,0)"><i class="fa fa-edit"></i>Sadece Tez Danışmanı Değişikliği</a>
                        </li>
                        <li>
                            <a href="javascript:void(0)" onclick="GetTdoDilBaslikDegisiklikFormu(@Model.TDOBasvuruID,0)"><i class="fa fa-edit"></i>Sadece Tez Dil/Başlığı Değişikliği</a>
                        </li>
                    </ul>
                </div>
            }
        }
    </td>

</tr>
<tr>
<td colspan="2" style="padding-left:10px;text-align:left;">
@if (Model.TDOBasvuruDanismanList.Any() == false)
{
    <table style="width:100%;table-layout:fixed;">
        <tr>
            <td style="color:maroon;font-size:13pt; text-align:center;height:250px;">Herhangi bir Tez danışmanı öneri formu bulunamadı</td>
        </tr>
    </table>
}
else
{
    int inxRw = 0;
    <table class="table">
    <tr class="info">
        <th width="40"></th>
        <th width="120">Başvuru Tarihi</th>
        <th>Talep Türü</th>
        <th>Danışman Onay Durumu</th>
        <th>Eş Danışman Onay Durumu</th>
        <th width="60"></th>
    </tr>
    @foreach (var item in Model.TDOBasvuruDanismanList)
    {
        inxRw++;
        bool showRow = inxRw == 1;
        var isTezDiliTr = item.IsYeniTezDiliTr.HasValue ? item.IsYeniTezDiliTr == true : item.IsTezDiliTr;

        <tr>
            <td>
                @if (!Model.DegerlendirenUniqueID.HasValue)
                {
                    <ul class="panel-controls">
                        <li id="iShow_Rpr_@item.TDOBasvuruDanismanID" onclick="showDetailY('Rpr_@item.TDOBasvuruDanismanID')">
                            <a href="javascript:void(0)"><span class="fa fa-angle-@(showRow ? "down" : "up")"></span> </a>
                        </li>
                    </ul>
                }
            </td>
            <td>@item.DonemAdi <br />@item.BasvuruTarihi</td>
            <td>@item.TalepTipAdi</td>
            <td>
                @if (!item.EYKYaGonderildi.HasValue)
                {
                    var danismanDegisiklik = item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniDegisikligi || item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniVeBaslikDegisikligi;
                    if (danismanDegisiklik && !item.DanismanOnayladi.HasValue && !item.VarolanDanismanOnayladi.HasValue)
                    {
                        <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> Varolan Danışman Onayı Bekleniyor.</span>
                    }
                    else if (danismanDegisiklik && !item.DanismanOnayladi.HasValue && item.VarolanDanismanOnayladi == true)
                    {
                        <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> Varolan Danışman Onayladı.</span>
                    }
                    else if (danismanDegisiklik && !item.DanismanOnayladi.HasValue && item.VarolanDanismanOnayladi == false)
                    {
                        <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> Varolan Danışman Onaylamadı.</span>

                    }
                    else if (!item.DanismanOnayladi.HasValue)
                    {
                        <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> @(item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniDegisikligi || item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniVeBaslikDegisikligi ? "Yeni " : "")Danışman Onayı Bekleniyor.</span>
                    }
                    else if (item.DanismanOnayladi == true)
                    {
                        <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> @(item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniDegisikligi || item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniVeBaslikDegisikligi ? "Yeni " : "") Danışman Onayladı.</span>
                    }
                    else
                    {
                        <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> @(item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniDegisikligi || item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniVeBaslikDegisikligi ? "Yeni " : "") Danışman Onaylamadı.</span>

                    }
                }
                else if (item.EYKYaGonderildi.HasValue && !item.EYKDaOnaylandi.HasValue)
                {
                    if (!item.EYKYaGonderildi.HasValue)
                    {
                        <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> EYK'ya Gönderim Onayı Bekleniyor.</span>
                    }
                    else if (item.EYKYaGonderildi == true)
                    {
                        <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> EYK'ya Gönderimi Onaylandı.</span>
                    }
                    else
                    {
                        <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> EYK'ya Gönderimi Onaylanmadı.</span>

                    }
                }
                else
                {
                    if (!item.EYKDaOnaylandi.HasValue)
                    {
                        <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> EYK'da onay işlemi Bekleniyor.</span>
                    }
                    else if (item.EYKDaOnaylandi == true)
                    {
                        <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> EYK'da Onaylandı.</span>
                    }
                    else
                    {
                        <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> EYK'da Onaylanmadı.</span>

                    }
                }
            </td>
            <td>
                @if (item.EsDanismanBilgi == null)
                {
                    <span style="color:maroon;font-size:10pt;" aria-hidden="true">Eş Danışman Önerisi Yok.</span>
                }
                else if (!item.EsDanismanBilgi.EYKDaOnaylandi.HasValue)
                {
                    if (!item.EsDanismanBilgi.EYKYaGonderildi.HasValue)
                    {
                        <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> EYK'ya Gönderim Onayı Bekleniyor.</span>
                    }
                    else if (item.EsDanismanBilgi.EYKYaGonderildi == true)
                    {
                        <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> EYK'ya Gönderimi Onaylandı.</span>
                    }
                    else
                    {
                        <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> EYK'ya Gönderimi Onaylanmadı.</span>

                    }
                }
                else
                {
                    if (!item.EsDanismanBilgi.EYKDaOnaylandi.HasValue)
                    {
                        <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i> EYK'da onay işlemi Bekleniyor.</span>
                    }
                    else if (item.EsDanismanBilgi.EYKDaOnaylandi == true)
                    {
                        <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i> EYK'da Onaylandı.</span>
                    }
                    else
                    {
                        <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i> EYK'da Onaylanmadı.</span>

                    }
                }

            </td>
            <td>
                @if (item.IsDuzeltSilYapabilir && (tdoFormOlusturmaYetkisi || Model.KullaniciID == UserIdentity.Current.Id) && !item.IsObsData)
                {
                    if (item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniDegisikligi)
                    {
                        <a href="javascript:void(0)" onclick="GetTdoDanismanDegisiklikFormu(@Model.TDOBasvuruID,@item.TDOBasvuruDanismanID)"><i style="font-size:11pt;" class="fa fa-edit" data-style="blue" data-original-title="Danışman Değişikliği Formunu Düzelt"></i></a>
                    }
                    else if (item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezBasligiDegisikligi)
                    {
                        <a href="javascript:void(0)" onclick="GetTdoDilBaslikDegisiklikFormu(@Model.TDOBasvuruID,@item.TDOBasvuruDanismanID)"><i style="font-size:11pt;" class="fa fa-edit" data-style="blue" data-original-title="Tez Dili/Başlığı Değişikliği Formunu Düzelt"></i></a>
                    }
                    else if (item.TDODanismanTalepTipID == TdoDanismanTalepTip.TezDanismaniVeBaslikDegisikligi)
                    {
                        <a href="javascript:void(0)" onclick="GetTdoDanismanDilBaslikDegisiklikFormu(@item.TDOBasvuruID,@item.TDOBasvuruDanismanID)"><i style="font-size:11pt;" class="fa fa-edit" data-style="blue" data-original-title="Danışman/Tez Dili/Tez Başlığı Öneri Formunu Düzelt"></i></a>
                    }
                    else
                    {
                        <a href="javascript:void(0)" onclick="GetTdoYeniDanismanFormu(@item.TDOBasvuruID,@item.TDOBasvuruDanismanID)"><i style="font-size:11pt;" class="fa fa-edit" data-style="blue" data-original-title="Danışman Öneri Formunu Düzelt"></i></a>
                    }
                    <a href="javascript:void(0)" onclick="DetayDanismanSil('@item.TDOBasvuruID',@item.TDOBasvuruDanismanID,'@item.BasvuruTarihi.ToFormatDateAndTime()','@item.TalepTipAdi')"><i style="font-size:11pt;" class="glyphicon glyphicon-trash" data-style="blue" data-original-title="Danışman Öneri Formunu Sil"></i></a>
                }
            </td>
        </tr>
        <tr class="MainRow2 cls-Rpr_@item.TDOBasvuruDanismanID" style="@(showRow ? "" : "display:none;")">
        <td></td>
        <td colspan="5">

        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:60px;">
            <table style="width:100%;">
                <tr>
                    <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book"></i> Öğrenci & Tez Bilgileri</td>
                </tr>
                @if (!isTezDiliTr)
                {
                    <tr>
                        <td class="CaptionTd" width="200">Dil Sınavı Adı / Yılı / Puanı</td>
                        <td class="CaptionTd" width="10">:</td>
                        <td class="ValueTd">
                            @if (item.IsObsData)
                            {
                                @("OBS'de doğrulandı")
                            }
                            else
                            {
                                @($"{item.SinavAdi} / {item.SinavYili} / {item.SinavPuani}")
                            }

                        </td>
                    </tr>
                }
                <tr>
                    <td class="CaptionTd" width="200">Tez Dili</td>
                    <td class="CaptionTd" width="10">:</td>
                    <td class="ValueTd">@(item.IsTezDiliTr ? "Türkçe" : "İngilizce")</td>
                </tr>
                <tr>
                    <td class="CaptionTd">Tez Başlığı Türkçe</td>
                    <td class="CaptionTd">:</td>
                    <td class="ValueTd">@item.TezBaslikTr</td>
                </tr>
                <tr>
                    <td class="CaptionTd">Tez Başlığı İngilizce</td>
                    <td class="CaptionTd">:</td>
                    <td class="ValueTd">@item.TezBaslikEn</td>
                </tr>
                @if (item.IsYeniTezDiliTr.HasValue)
                {
                    <tr>
                        <td class="CaptionTd" width="200">Yeni Tez Dili</td>
                        <td class="CaptionTd" width="10">:</td>
                        <td class="ValueTd">@(item.IsYeniTezDiliTr==true ? "Türkçe" : "İngilizce")</td>
                    </tr>
                }
                @if (item.IsYeniTezBasligiGozuksun)
                {

                    <tr>
                        <td class="CaptionTd">Yeni Tez Başlığı Türkçe</td>
                        <td class="CaptionTd">:</td>
                        <td class="ValueTd">@item.YeniTezBaslikTr</td>
                    </tr>
                    <tr>
                        <td class="CaptionTd">Yeni Tez Başlığı İngilizce</td>
                        <td class="CaptionTd">:</td>
                        <td class="ValueTd">@item.YeniTezBaslikEn</td>
                    </tr>
                }
            </table>
        </div>

        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:60px;">
        <table style="width: 100%;">
            @if (Model.AktifTDOBasvuruDanismanID == item.TDOBasvuruDanismanID && item.EYKDaOnaylandi == true)
            {

                <tr>
                    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-user-o"></i> Danışman Bilgileri</td>
                    <td style="border-bottom: 1px solid; text-align: right;"></td>
                </tr>
            }


        </table>
        @if (item.VarolanDanismanGozuksun)
        {
            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:60px;">
                <table style="width:100%;">
                    <tr>
                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-check-square-o"></i> Varolan Danışman Onayı</td>
                    </tr>
                    <tr>
                        <td class="CaptionTd" width="200">Ad Soyad</td>
                        <td class="CaptionTd" width="10">:</td>
                        <td class="ValueTd">
                            @if (isKullaniciGormeYetki)
                            {
                                <a href="javascript:void(0)" onclick="detayGor(@item.VarolanTezDanismanID)">
                                    @item.VarolanDanismanAd
                                </a>
                            }
                            else
                            { @item.VarolanDanismanAd}
                        </td>
                    </tr>
                    @if (item.VarolanDanismanOnayIslemiAcik)
                    {

                        <tr class="form-group">
                            <td class="CaptionTd" width="200">Onay Durumu</td>
                            <td class="CaptionTd" width="10">:</td>
                            <td class="ValueTd">
                                <table>
                                    <tr>
                                        <td>
                                            <select class="form-control" id="VarolanDanismanOnayladi_@item.TDOBasvuruDanismanID" onchange="DVarolanOnayChange(@item.TDOBasvuruDanismanID)">
                                                <option @(!item.VarolanDanismanOnayladi.HasValue ? "selected" : "")></option>
                                                <option value="true" @(item.VarolanDanismanOnayladi == true ? "selected" : "")>Onaylandı</option>
                                                <option value="false" @(item.VarolanDanismanOnayladi == false ? "selected" : "")>Onaylanmadı</option>
                                            </select>
                                        </td>
                                        <td>
                                            <label class="btn btn-primary btn-sm" onclick="DVarolanOnay(@item.TDOBasvuruDanismanID,@Model.TDOBasvuruID)"><i class="fa fa-save" aria-hidden="true">&nbsp;</i>Kaydet</label>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr id="VarolanDanismanOnayAciklamaRow_@item.TDOBasvuruDanismanID" class="form-group @(item.VarolanDanismanOnayladi == false ? "" : "hide")">
                            <td class="CaptionTd">Onaylanmama Açıklaması</td>
                            <td class="CaptionTd">:</td>
                            <td class="ValueTd">
                                <textarea class="form-control" style="min-height:100px;" id="VarolanDanismanOnaylanmadiAciklama_@item.TDOBasvuruDanismanID" maxlength="512">@item.VarolanDanismanOnaylanmadiAciklama</textarea>
                            </td>
                        </tr>
                    }
                    else
                    {

                        <tr class="form-group">
                            <td class="CaptionTd" width="200">Onay Durumu</td>
                            <td class="CaptionTd" width="10">:</td>
                            <td class="ValueTd">
                                @if (!item.VarolanDanismanOnayladi.HasValue)
                                {

                                    <span aria-hidden="true" style="font-size:9pt;"><i class="fa fa-clock-o" style="font-size:12pt;" aria-hidden="true"></i>Onay Bekleniyor.</span>
                                }
                                else if (item.VarolanDanismanOnayladi == true)
                                {

                                    <span style="color:green;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-up" style="font-size:12pt;" aria-hidden="true"></i>Onaylandı. (@item.VarolanDanismanOnayTarihi.ToFormatDateAndTime())</span>

                                }
                                else
                                {
                                    <span style="color:maroon;font-size:10pt;" aria-hidden="true"><i class="fa fa-thumbs-o-down" style="font-size:12pt;" aria-hidden="true"></i>Onaylanmadı.</span>

                                }
                            </td>
                        </tr>
                        if (item.VarolanDanismanOnayladi == false)
                        {
                            <tr>
                                <td class="CaptionTd">Onaylanmama Açıklaması</td>
                                <td class="CaptionTd">:</td>
                                <td class="ValueTd">
                                    @item.VarolanDanismanOnaylanmadiAciklama
                                </td>
                            </tr>
                        }
                    }
                </table>
            </div>

        }
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:60px;">
        <table style="width:100%;">
        <tr>
            <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-check-square-o"></i> @(item.VarolanDanismanGozuksun ? "Yeni " : "")Danışman Onayı</td>
        </tr>
        <tr>
            <td class="CaptionTd" width="200">Ad Soyad</td>
