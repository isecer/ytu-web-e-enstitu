        function GetTdoDanismanDegisiklikFormu(TDOBasvuruID, TDOBasvuruDanismanID) {

         var _panel = $('#bsvrDet_' + TDOBasvuruID);
         PanelRefresh(_panel, false);
         $.ajax({
             url: '@Url.Action("GetTdoDanismanDegisiklikFormu", "TDOBasvuru")',
             data: {
                 TDOBasvuruID,
                 TDOBasvuruDanismanID
             },
             success: function (resultG) {
                 PanelRefresh(_panel, true);
                 if (resultG.IsSuccess) {
                     var btbxxFS = bootbox.dialog({
                         message: resultG.Content,
                         title: "<i class='fa fa-book'></i> Tez Danışmanı Değişiklik İşlemi",
                         buttons: {
                             success: {
                                 label: 'Kaydet',
                                 className: "btn-info DanDegKayit_" + TDOBasvuruDanismanID,
                                 callback: function (event) {
                                     var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                     PanelRefresh(pnlx, false);
                                     $('#FrmTdoFormu').ajaxForm({
                                         success: function (result) {
                                             $('.DanDegKayit_' + TDOBasvuruDanismanID).addClass('disabled');
                                             if (result.IsSuccess) {
                                                 if (result.Messages.length > 0) toastr["success"](result.Messages.join('<br/>'), result.Title, { timeOut: 8000 });
                                                 var _clsBtn = $('.bootbox-close-button').first();
                                                 $(_clsBtn).click();
                                                 GetDetail(TDOBasvuruID);

                                             }
                                             else {
                                                 if (result.Messages.length > 0) getMsg(result);
                                                 return false;
                                             }
                                             PanelRefresh(pnlx, true);
                                         },
                                         complete: function (cmp) {
                                             $('.DanDegKayit_' + TDOBasvuruDanismanID).removeClass('disabled');
                                             PanelRefresh(pnlx, true);
                                         }

