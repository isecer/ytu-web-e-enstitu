@model LisansUstuBasvuruSistemi.Utilities.MailManager.MailMainContentDto
@{
    Layout = null;
}

<div style="max-width: 800px; margin: 20px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
    <!-- Vertical Header Section -->
    <div style="background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); padding: 10px; text-align: center;">
        <img alt="Logo" src="@Model.LogoPath" style="width: 70px; height: auto; margin-bottom: 12px;" />
        <div>
            <h1 style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 600; letter-spacing: 0.5px; font-family: 'Segoe UI', Arial, sans-serif;">
                @Model.UniversiteAdi.ToUpper()
            </h1>
            <h2 style="margin: 5px 0 0; color: #e5e7eb; font-size: 16px; font-weight: 400; font-family: 'Segoe UI', Arial, sans-serif;">
                @Model.EnstituAdi.ToUpper()
            </h2>
        </div>
    </div>

    <!-- Content Section -->
    <div style="padding: 20px 25px; background: #ffffff;">
        <div style="line-height: 1.7; color: #374151; font-size: 15px; font-family: 'Segoe UI', Arial, sans-serif;">
            @Html.Raw(Model.Content)
        </div>

        <!-- Right-aligned Contact Info Section -->
        <div style="margin-top: 20px; padding-top: 10px; border-top: 1px solid #e5e7eb;">
            <div style="width: 250px; margin-left: auto; text-align: center;">
                <div style="color: #4b5563; font-size: 15px; font-weight: 600; margin-bottom: 5px; font-family: 'Segoe UI', Arial, sans-serif;">
                    YTÜ @Model.EnstituAdi
                </div>
                <div>
                    <a href="@Model.WebAdresi" style="color: #2563eb; text-decoration: none; font-size: 14px; font-family: 'Segoe UI', Arial, sans-serif;" target="_blank">
                        @Model.WebAdresi
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Enhanced Footer -->
    <div style="background: linear-gradient(to right, #1e3a8a, #2563eb); padding: 15px; text-align: center; position: relative; overflow: hidden;">
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle at center, rgba(255,255,255,0.1) 0%, transparent 70%);"></div>

        <a href="@Model.SistemErisimAdresi" style="
            color: #ffffff;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            letter-spacing: 1px;
            position: relative;
            display: inline-block;
            padding: 2px 10px;
            font-family: 'Segoe UI', Arial, sans-serif;
            text-shadow: 0 1px 2px rgba(0,0,0,0.2);
            background: linear-gradient(to right, rgba(255,255,255,0.1), transparent, rgba(255,255,255,0.1));
            border-radius: 4px;
            " target="_blank">
            © 2015 - @(DateTime.Now.Year) <span style="font-weight: 600;">e-enstitü</span>
        </a>
    </div>
</div>