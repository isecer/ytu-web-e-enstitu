@model LisansUstuBasvuruSistemi.Utilities.MailManager.MailMainContentDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Arial, sans-serif;">
    <div style="max-width: 800px; margin: 20px auto; background: #fff;">

        <!-- Header Section -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #1e3a8a;">
            <tr>
                <td style="padding: 10px; text-align: center;">
                    <img alt="Logo" src="@Model.LogoPath" style="width: 70px; height: auto; margin-bottom: 12px; display: block; margin-left: auto; margin-right: auto;" />
                    <h1 style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 600; letter-spacing: 0.5px; font-family: 'Segoe UI', Arial, sans-serif;">
                        @Model.UniversiteAdi.ToUpper()
                    </h1>
                    <h2 style="margin: 5px 0 0; color: #e5e7eb; font-size: 16px; font-weight: 400; font-family: 'Segoe UI', Arial, sans-serif;">
                        @Model.EnstituAdi.ToUpper()
                    </h2>
                </td>
            </tr>
        </table>

        <!-- Content Section -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td style="padding: 20px 25px; background: #ffffff;">
                    <div style="line-height: 1.7; color: #374151; font-size: 15px; font-family: 'Segoe UI', Arial, sans-serif;">
                        @Html.Raw(Model.Content)
                    </div>
                </td>
            </tr>
        </table>

        <!-- Contact Info Section -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
                <td style="padding: 20px 25px; background: #ffffff; border-top: 1px solid #e5e7eb;">
                    <div style="text-align: right;">
                        <div style="color: #4b5563; font-size: 15px; font-weight: 600; margin-bottom: 5px; font-family: 'Segoe UI', Arial, sans-serif;">
                            YTÜ @Model.EnstituAdi
                        </div>
                        <div>
                            <a href="@Model.WebAdresi" style="color: #2563eb; text-decoration: none; font-size: 14px; font-family: 'Segoe UI', Arial, sans-serif;" target="_blank">
                                @Model.WebAdresi
                            </a>
                        </div>
                    </div>
                </td>
            </tr>
        </table>

        <!-- Footer -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #1e3a8a;">
            <tr>
                <td style="padding: 15px; text-align: center;">
                    <a href="@Model.SistemErisimAdresi" style="color: #ffffff; text-decoration: none; font-size: 15px; font-weight: 500; letter-spacing: 1px; font-family: 'Segoe UI', Arial, sans-serif;" target="_blank">
                        © 2015 - @(DateTime.Now.Year) <span style="font-weight: 600;">e-enstitü</span>
                    </a>
                </td>
            </tr>
        </table>

    </div>
</body>
</html>