@if (degerlendirmeDuzeltmeYetki || degerlendirmeYetki || Model.DegerlendirenUniqueID.HasValue)
{
    <script>

        function TosDegerlendirmeKaydet(toUniqueId, tosKomiteUniqueId) {
            var ToBasvuruSavunmaDurumID = $('#ToBasvuruSavunmaDurumID_' + tosKomiteUniqueId).val();
            var IsCalismaRaporuAltAlanUygun = $('#IsCalismaRaporuAltAlanUygun_' + tosKomiteUniqueId).val();
            var Aciklama = $('#Aciklama_' + tosKomiteUniqueId).val();
            var YeniTezBaslikTr = $('#YeniTezBaslikTr_' + tosKomiteUniqueId).val();
            var YeniTezBaslikEn = $('#YeniTezBaslikEn_' + tosKomiteUniqueId).val();
            var _panel = $('#bsvrDet_' + toUniqueId);
            Swal.fire({
                text: "Tez Önerisi Savunma değerlendirmenizi kaydetmek istediğinize emin misiniz?",
                type: 'warning',
                icon: "question",
                showCancelButton: true,
                confirmButtonText: 'Evet',
                confirmButtonColor: "green",
                cancelButtonText: 'Vazgeç',
                showLoaderOnConfirm: true,
                backdrop: true,
                padding: '2em',
                backdrop: true,
                allowOutsideClick: false,
                preConfirm: function () {
                    $('.swal2-cancel').first().text("kaydediliyor...");
                    return new Promise(function (resolve) {
                        PanelRefresh(_panel, false);
                        $.ajax({
                            url: '@Url.Action("TosDegerlendir", "TosBasvuru")',
                            data: {
                                tosKomiteUniqueId,
                                IsCalismaRaporuAltAlanUygun,
                                ToBasvuruSavunmaDurumID,
                                YeniTezBaslikTr,
                                YeniTezBaslikEn,
                                Aciklama

                            },
                            success: function (result) {
                                PanelRefresh(_panel, true);
                                if (result.IsSuccess || result.IsRefresh) {
                                    GetDetail(toUniqueId);
                                }
                                swal.fire({
                                    html: result.messageView,
                                    icon: (result.IsSuccess ? "success" : "error"),
                                    type: (result.IsSuccess ? "success" : "error"),
                                    confirmButtonText: 'tamam',
                                    padding: '2em'
                                });

                            },
                            error: function (err) {
                                PanelRefresh(_panel, true);
                                alert(err.responseText);

                            }
                        });
                    });
                }
            });
        }


    </script>

}
@if (formOlusturmaYetki)
{
    <script>
        function GetToSavunmaFormu(toUniqueId, tosUniqueId) {
            var _panel = $('#bsvrDet_' + toUniqueId);
            PanelRefresh(_panel, false);
            $.ajax({
                url: '@Url.Action("GetToSavunmaFormu", "TosBasvuru")',
                data: {
                    'toUniqueId': toUniqueId,
                    'tosUniqueId': tosUniqueId
                },
                success: function (resultG) {
                    PanelRefresh(_panel, true);
                    if (resultG.IsSuccess) {
                        var btbxxFS = bootbox.dialog({
                            message: resultG.Content,
                            title: "||",
                            buttons: {
                                success: {
                                    label: 'Kaydet',
                                    className: "btn-info btnKaydet",
                                    callback: function (event) {
                                        var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                        PanelRefresh(pnlx, false);
                                        $('#FrmToSavunmaFormu').ajaxForm({
                                            success: function (result) {
                                                if (result.mMessage.IsSuccess) {
                                                    if (result.mMessage.Messages.length > 0) toastr["success"](result.mMessage.Messages.join('<br/>'), result.Title, { timeOut: 8000 });
                                                    var _clsBtn = $('.bootbox-close-button').first();
                                                    $(_clsBtn).click();
                                                    GetDetail(toUniqueId);

                                                }
                                                else {
                                                    if (result.mMessage.Messages.length > 0) GetMsg(result.mMessage);
                                                    return false;
                                                }
                                            },
                                            complete: function (cmp) {
                                                PanelRefresh(pnlx, true);
                                            },
                                            error: function (err) {
                                                PanelRefresh(pnlx, true);
                                            }

                                        });
                                        $('#FrmToSavunmaFormu').submit();
                                        return false;
                                    }
                                },
                                danger: {
                                    label: 'Vazgeç',
                                    className: "btn-primary",
                                    callback: function () {
                                    }
                                }
                            }
                        });
                        $(btbxxFS).find('.modal-dialog').first().addClass('modal-lg');
                        if (resultG.Messages.trim()!="") ShowMmMessage(resultG.Messages, 'Tamam');

                    }
                    else {
                        ShowMmMessage(resultG.Messages, 'Tamam');
                    }

                },
                error: function (err) {
                    PanelRefresh(_panel, true);
                    alert(err.responseText);
                }
            })
        }
