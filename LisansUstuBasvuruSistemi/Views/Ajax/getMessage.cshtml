@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@model MmMessage

@if (Model.Messages.Count > 0)
{
    var cls = Model.MessageType == MsgTypeEnum.Success ? "success" : (Model.MessageType == MsgTypeEnum.Warning ? "warning" : (Model.MessageType == MsgTypeEnum.Error ? "danger" : "info"));
    <div class="panel-body panel-body-pricing">
        @if (!Model.Title.IsNullOrWhiteSpace())
        {
            <h3 class="text-@cls">@Html.Raw(Model.Title)</h3>
        }
        <div style="width:100%;max-height:300px;overflow-x:auto;">
            @foreach (var itemmsg in Model.Messages)
            {
                <p style="margin: 0px; padding: 0px;">
                    <span class="fa fa-caret-right text-@cls"></span>@Html.Raw(itemmsg)
                </p>
            }
        </div>
    </div>
}
