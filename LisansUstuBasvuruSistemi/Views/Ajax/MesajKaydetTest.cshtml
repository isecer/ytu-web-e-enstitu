                gap: 8px;
            }

            .e-btn {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 6px 12px;
                border-radius: 4px;
                font-size: 13px;
                border: none;
                cursor: pointer;
                transition: background-color 0.15s;
            }

            .e-btn-primary {
                background-color: white;
                color: #4a6cf7;
            }

                .e-btn-primary:hover {
                    background-color: rgba(255,255,255,0.9);
                }

            .e-btn-close {
                background-color: rgba(255,255,255,0.15);
                color: white;
            }

