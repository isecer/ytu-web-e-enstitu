@using Entities.Entities
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Utilities.Helpers
@model Mesajlar
@{
    var mmMessage = ViewBag.MmMessage as MmMessage;
    Layout = null;
    var enstituAdi = (string)ViewBag.EnstituAdi;
}

<div class="elegant-form">
    @using (Ajax.BeginForm("MesajKaydetPost", "Ajax", new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "_Form" }))
    {
        @Html.Hidden("MesajID", Model.MesajID)
        @Html.Hidden("GroupID", Model.GroupID) 
            <div class="panel panel-danger e-form-panel" style="padding-bottom: 0px;" id="pnlMailGonder">
                <div class="panel-body" style="padding: 0px;">
                    <div class="panel panel-default form-horizontal" style="margin: 0px;">
                        <div class="panel-body form-group-separated">


                            @if (UserIdentity.Current.IsAuthenticated || Model.MesajID > 0)
                            {
                                if (Model.MesajID > 0)
                                {
                                    <div class="form-group">
                                        <label class="col-md-2 col-xs-2 control-label">Enstitü</label>
                                        <div class="col-md-10 col-xs-10">
                                            @Html.HiddenFor(p => p.EnstituKod)
                                            @enstituAdi
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-group">
                                        <label class="col-md-2 col-xs-2 control-label">Enstitü Seçiniz</label>
                                        <div class="col-md-10 col-xs-10">
                                            @Html.DropDownList("EnstituKod", null, new { @class = "form-control", onChange = "getMsjKategoris(this)" })
                                        </div>
                                    </div>
                                }
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Ad Soyad</label>
                                    <div class="col-md-10 col-xs-10">
                                        @Model.AdSoyad
                                        <input type="hidden" name="AdSoyad" id="AdSoyad" value="@Model.AdSoyad" class="form-control">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Email</label>
                                    <div class="col-md-10 col-xs-10">
                                        @Model.Email
                                        <input type="hidden" name="Email" id="Email" value="@Model.Email" class="form-control">
                                    </div>
                                </div>
                            }
                            else
                            {
                                if (Model.MesajID > 0)
                                {
                                    <div class="form-group">
                                        <label class="col-md-2 col-xs-2 control-label">Enstitü</label>
                                        <div class="col-md-10 col-xs-10">
                                            @Html.HiddenFor(p => p.EnstituKod)
                                            @enstituAdi
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-group">
                                        <label class="col-md-2 col-xs-2 control-label">Enstitü Seçiniz</label>
                                        <div class="col-md-10 col-xs-10">
                                            @Html.DropDownList("EnstituKod", null, new { @class = "form-control", onChange = "getMsjKategoris(this)" })
                                        </div>
                                    </div>
                                }
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Ad Soyad</label>
                                    <div class="col-md-10 col-xs-10">
                                        <input type="text" name="AdSoyad" id="AdSoyad" value="@Model.AdSoyad" class="form-control">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Email</label>
                                    <div class="col-md-10 col-xs-10">
                                        <input type="text" name="Email" id="Email" value="@Model.Email" class="form-control">
                                    </div>
                                </div>
                            }

                            @if (Model.MesajID > 0)
                            {
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Kategori Seçiniz</label>
                                    <div class="col-md-10 col-xs-10">
                                        @Model.MesajKategorileri.KategoriAdi
                                        @Html.Hidden("MesajKategoriID", Model.MesajKategoriID)
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Mesaj Konusu</label>
                                    <div class="col-md-10 col-xs-10">
                                        @Model.Konu
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Kategori Seçiniz</label>
                                    <div class="col-md-10 col-xs-10">
                                        @Html.DropDownList("MesajKategoriID", null, new { @class = "form-control", id = "mkID", onchange = "getKtNot(this)" })
                                    </div>
                                </div>
                                <div class="form-group hide" id="mkAck">
                                    <label class="col-md-2 col-xs-2 control-label">Kategori Açıklaması</label>
                                    <div class="col-md-10 col-xs-10" id="acklmT">

                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-2 col-xs-2 control-label">Mesaj Konusu</label>
                                    <div class="col-md-10 col-xs-10">
                                        <input type="text" name="Konu" id="Konu" value="@Model.Konu" class="form-control">
                                    </div>
                                </div>
                            }
                            <div class="form-group">
                                <div class="col-md-12 col-xs-12" style="padding: 0px;">
                                    <div>
                                        <textarea style="height:100%;" id="AciklamaHtml" name="AciklamaHtml" class="form-control">@Model.AciklamaHtml</textarea>
                                        <textarea style="display: none;" id="Aciklama" name="Aciklama">@Model.Aciklama</textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-md-12 col-xs-12">
                                    <div>
                                        <div class="e-upload-hint">
                                            <i class="fa fa-cloud-upload-alt"></i>
                                            Dosyaları <span class="e-upload-trigger" onclick="document.getElementById('file-input').click()">tıklayarak</span> veya buraya sürükleyerek ekleyebilirsiniz
                                            <input type="file" id="file-input" multiple style="display: none;">
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="e-form-panel" id="pnlMailGonder">

                <!-- Form İçeriği -->
                <div class="e-body">
                    <!-- Sol Kolon - Temel Bilgiler -->
                    <div class="e-col">
                        @if (Model.MesajID > 0)
                        {
                            <div class="e-field">
                                <label>Enstitü</label>
                                <div class="e-readonly">
                                    @Html.HiddenFor(p => p.EnstituKod)
                                    @enstituAdi
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="e-field">
                                <label>Enstitü</label>
                                @Html.DropDownList("EnstituKod", null, new { @class = "e-input", onChange = "getMsjKategoris(this)" })
                            </div>
                        }

                        @if (UserIdentity.Current.IsAuthenticated || Model.MesajID > 0)
                        {
                            <div class="e-field">
                                <label>Ad Soyad</label>
                                <div class="e-readonly">
                                    @Model.AdSoyad
                                    <input type="hidden" name="AdSoyad" id="AdSoyad" value="@Model.AdSoyad">
                                </div>
                            </div>
                            <div class="e-field">
                                <label>Email</label>
                                <div class="e-readonly">
                                    @Model.Email
                                    <input type="hidden" name="Email" id="Email" value="@Model.Email">
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="e-field">
                                <label>Ad Soyad</label>
                                <input type="text" name="AdSoyad" id="AdSoyad" value="@Model.AdSoyad" class="e-input">
                            </div>
                            <div class="e-field">
                                <label>Email</label>
                                <input type="email" name="Email" id="Email" value="@Model.Email" class="e-input">
                            </div>
                        }
                    </div>

                    <!-- Sağ Kolon - Kategori ve Konu -->
                    <div class="e-col">
                        @if (Model.MesajID > 0)
                        {
                            <div class="e-field">
                                <label>Kategori</label>
                                <div class="e-readonly">
                                    @Model.MesajKategorileri.KategoriAdi
                                    @Html.Hidden("MesajKategoriID", Model.MesajKategoriID)
                                </div>
                            </div>
                            <div class="e-field">
                                <label>Konu</label>
                                <div class="e-readonly">
                                    @Model.Konu
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="e-field">
                                <label>Kategori</label>
                                @Html.DropDownList("MesajKategoriID", null, new { @class = "e-input", id = "mkID", onchange = "getKtNot(this)" })
                            </div>
                            <div id="mkAck" class="e-note" style="display: none;">
                                <div id="acklmT"></div>
                            </div>
                            <div class="e-field">
                                <label>Konu</label>
                                <input type="text" name="Konu" id="Konu" value="@Model.Konu" class="e-input">
                            </div>
                        }

                        <div class="e-upload-hint">
                            <i class="fa fa-cloud-upload-alt"></i>
                            Dosyaları <span class="e-upload-trigger" onclick="document.getElementById('file-input').click()">tıklayarak</span> veya buraya sürükleyerek ekleyebilirsiniz
                            <input type="file" id="file-input" multiple style="display: none;">
                        </div>
                    </div>
                </div>

                <!-- İçerik -->
                <div class="e-editor">
                    <textarea id="AciklamaHtml" name="AciklamaHtml">@Model.AciklamaHtml</textarea>
                    <textarea style="display: none;" id="Aciklama" name="Aciklama">@Model.Aciklama</textarea>
                </div>

                <!-- Ekler -->
                <div id="e-attachments-container" class="e-attachments" style="display: @(Model.MesajEkleris.Any() ? "block" : "none")">
                    <div class="e-attachments-header">
                        <i class="fa fa-paperclip"></i> Ekler (<span id="attachment-count">@Model.MesajEkleris.Count()</span>)
                    </div>
                    <div id="attachmentList" class="e-attachments-list">
                        @foreach (var item in Model.MesajEkleris.Select((s, inx) => new { s, inx }))
                        {
                            <div class="e-attachment">
                                <div class="e-attachment-icon">
                                    <i class="fa fa-file"></i>
                                </div>
                                <div class="e-attachment-details">
                                    <input type="hidden" name="MesajEkiID" value="@item.s.MesajEkiID" />
                                    <input type="text" name="EkAdi" value="@item.s.EkAdi" class="e-attachment-name">
                                    <a href="@Url.CustomUrlContent(item.s.EkDosyaYolu)" target="_blank" class="e-attachment-link">Görüntüle</a>
                                </div>
                                <button type="button" class="e-attachment-delete" onclick="EkSil(this)">
                                    <i class="fa fa-times"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
            }
        </div>

        <div id="notification-container"></div>

        <script src="~/Content/ckeditor/ckeditor.js"></script>
        <script src="~/Content/ckeditor/showCk.js"></script>

        @if (mmMessage.IsCloseDialog)
        {
            <script>
        setTimeout(function () { window.top.dialogKapat('@mmMessage.DialogID'); }, 2000);
            </script>
        }
