                cursor: pointer;
                transition: color 0.15s;
            }

                .e-upload-trigger:hover {
                    text-decoration: underline;
                }

            /* Editor */
            .e-editor {
                margin-top: 0;
                flex: 1;
                min-height: 200px;
            }

