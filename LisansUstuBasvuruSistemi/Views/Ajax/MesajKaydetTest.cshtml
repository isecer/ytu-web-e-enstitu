                border-radius: 4px;
                font-size: 13px;
                color: #475569;
            }

            /* Note for category */
            .e-note {
                padding: 8px 10px;
                background-color: #f8faff;
                border-left: 3px solid #4a6cf7;
                border-radius: 0 4px 4px 0;
                margin-top: -4px;
                margin-bottom: 8px;
