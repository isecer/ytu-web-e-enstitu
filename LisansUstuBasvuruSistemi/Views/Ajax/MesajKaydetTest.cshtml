        <script>
    $(function() {

    // Dosya yükleme işlemleri
    initFileUpload();

    // Sayfa açılışında kategori notu kontrolü
    setTimeout(function() {
        getKtNot($('#mkID'));
    }, 200);

    // Ek sayısını güncelle
    updateAttachmentCount();
});



// Dosya yükleme işlemleri
function initFileUpload() {
    const fileInput = document.getElementById('file-input');
    const formPanel = document.querySelector('.e-form-panel');

    // Dosya seçimi
    fileInput.addEventListener('change', function() {
        if (this.files.length > 0) {
            handleFiles(this.files);
        }
    });

    // Sürükle bırak olayları
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        formPanel.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e) {
        e.preventDefault();
        e.stopPropagation();
    }

    // Drag olaylarında görsel geri bildirim
    ['dragenter', 'dragover'].forEach(eventName => {
        formPanel.addEventListener(eventName, highlight, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        formPanel.addEventListener(eventName, unhighlight, false);
    });

    function highlight() {
        formPanel.classList.add('e-drag-over');
    }

    function unhighlight() {
        formPanel.classList.remove('e-drag-over');
    }

    // Dosya bırakma
    formPanel.addEventListener('drop', function(e) {
        const dt = e.dataTransfer;
        const files = dt.files;

        if (files.length > 0) {
            handleFiles(files);
        }
    });

    // Ekran görüntüsü yapıştırma
    document.addEventListener('paste', function(e) {
        const items = Array.from(e.clipboardData.items)
            .filter(item => item.type.indexOf('image') !== -1);

        if (items.length === 0) return;

        const item = items[0];
        const blob = item.getAsFile();

        if (!blob) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const img = new Image();
            img.src = e.target.result;

            img.onload = function() {
                const canvas = document.createElement('canvas');
                canvas.width = img.width;
                canvas.height = img.height;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0);

                canvas.toBlob(function(blob) {
                    const file = new File(
                        [blob],
                        "ekran_goruntusu_" + new Date().getTime() + ".png",
                        { type: "image/png" }
                    );
                    handleFiles([file]);
                }, 'image/png');
            };
        };
        reader.readAsDataURL(blob);
    });
}

// Dosyaları işleme ve ekleme
function handleFiles(files) {
    Array.from(files).forEach(file => {
        uploadFile(file);
    });

    // Ek sayısını güncelle
    updateAttachmentCount();

    // Ek panelini göster
    document.getElementById('e-attachments-container').style.display = 'flex';
}

// Dosya yükleme
function uploadFile(file) {
    // Dosya uzantısına göre ikon belirleme
    const fileIcon = getFileIcon(file.type);

    // Dosya adını temizleme
    const fileName = file.name.replace(/[^a-zA-Z0-9-_. ]/g, '');

    // Dosya HTML'i
    const attachmentHTML = `
        <div class="e-attachment">
            <div class="e-attachment-icon">
                <i class="fa ${fileIcon}"></i>
            </div>
            <div class="e-attachment-details">
                <input type="hidden" name="DuyuruDosyaEkID">
                <input type="text" name="DosyaEkiAdi" value="${fileName}" class="e-attachment-name">
                <div class="e-progress">
                    <div class="e-progress-bar" style="width: 0%"></div>
                </div>
            </div>
            <button type="button" class="e-attachment-delete" onclick="EkSil(this)">
                <i class="fa fa-times"></i>
            </button>
        </div>
    `;

    // DOM'a ekleme
    const attachmentList = document.getElementById('attachmentList');
    if (attachmentList) {
        attachmentList.insertAdjacentHTML('beforeend', attachmentHTML);
        const newAttachment = attachmentList.lastElementChild;

        // Dosya girdisi ekleme
        const fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.name = 'DosyaEki';
        fileInput.style.display = 'none';
        newAttachment.appendChild(fileInput);

        // Dosyayı form verisine ekle
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(file);
        fileInput.files = dataTransfer.files;

        // Yükleme animasyonu
        simulateUploadProgress(newAttachment);
    }
}

// Dosya türüne göre ikon belirleme
function getFileIcon(fileType) {
    if (fileType.match('image.*')) return 'fa-file-image';
    if (fileType.match('video.*')) return 'fa-file-video';
    if (fileType.match('audio.*')) return 'fa-file-audio';
    if (fileType.match('text.*')) return 'fa-file-alt';
    if (fileType.match('application/pdf')) return 'fa-file-pdf';
    if (fileType.match('application/msword') || fileType.match('application/vnd.openxmlformats-officedocument.wordprocessingml.document')) return 'fa-file-word';
    if (fileType.match('application/vnd.ms-excel') || fileType.match('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet')) return 'fa-file-excel';
    if (fileType.match('application/vnd.ms-powerpoint') || fileType.match('application/vnd.openxmlformats-officedocument.presentationml.presentation')) return 'fa-file-powerpoint';
    if (fileType.match('application/zip') || fileType.match('application/x-rar-compressed')) return 'fa-file-archive';
    return 'fa-file';
}

// Yükleme ilerleme çubuğu simulasyonu
function simulateUploadProgress(element) {
    const progressBar = element.querySelector('.e-progress-bar');
    let width = 0;

    const interval = setInterval(function() {
        if (width >= 100) {
            clearInterval(interval);
            // Yükleme tamamlandıktan sonra progress bar'ı gizle
            setTimeout(function() {
                const progressElement = element.querySelector('.e-progress');
                progressElement.style.display = 'none';

                // Yüklendi link'i ekle
                const detailsElement = element.querySelector('.e-attachment-details');
                const linkElement = document.createElement('a');
                linkElement.className = 'e-attachment-link';
                linkElement.textContent = 'Görüntüle';
                linkElement.href = 'javascript:void(0)';
                detailsElement.appendChild(linkElement);
            }, 300);
        } else {
            width += 5;
            progressBar.style.width = width + '%';
        }
    }, 30);
}

// Ek sayısını güncelleme
function updateAttachmentCount() {
    const attachmentList = document.getElementById('attachmentList');
    const countElement = document.getElementById('attachment-count');

    if (attachmentList && countElement) {
        const count = attachmentList.querySelectorAll('.e-attachment').length;
        countElement.textContent = count;
    }
}

// Ek silme
function EkSil(element) {
    const attachment = element.closest('.e-attachment');

    // Silme animasyonu
    attachment.style.opacity = '0';
    attachment.style.transform = 'scale(0.9)';

    setTimeout(function() {
        attachment.remove();
        updateAttachmentCount();

        // Ek yoksa paneli gizle
        const attachmentList = document.getElementById('attachmentList');
        if (attachmentList.querySelectorAll('.e-attachment').length === 0) {
            document.getElementById('e-attachments-container').style.display = 'none';
        }
    }, 200);
}

// Mesaj gönderme
function mesajGonder() {
    if (validateForm()) {
        // CKEditor içeriğini güncelle
        for (const instance in CKEDITOR.instances) {
            CKEDITOR.instances[instance].updateElement();
        }

        // Bildirim göster
        showNotification('success', 'Mesaj Gönderiliyor', 'Lütfen bekleyiniz...');

        // Formu gönder
        document.getElementById('_Form').submit();
    }
}

// Form doğrulama
function validateForm() {
    let isValid = true;

    // Önceki hataları temizle
    clearErrors();

    // Kullanıcı kimlik doğrulaması
    if (document.getElementById('AdSoyad') && document.getElementById('AdSoyad').type !== 'hidden') {
        // Ad Soyad kontrolü
        if (!document.getElementById('AdSoyad').value.trim()) {
            addError(document.getElementById('AdSoyad'), 'Ad Soyad alanı zorunludur');
            isValid = false;
        }

        // Email kontrolü
        const email = document.getElementById('Email').value.trim();
        if (!email) {
            addError(document.getElementById('Email'), 'Email alanı zorunludur');
            isValid = false;
        } else if (!validateEmail(email)) {
            addError(document.getElementById('Email'), 'Geçerli bir email adresi giriniz');
            isValid = false;
        }
    }

    // Kategori kontrolü
    if (document.getElementById('mkID') && !document.getElementById('mkID').value) {
        addError(document.getElementById('mkID'), 'Kategori seçimi zorunludur');
        isValid = false;
    }

    // Konu kontrolü
    if (document.getElementById('Konu') && !document.getElementById('Konu').value.trim()) {
        addError(document.getElementById('Konu'), 'Konu alanı zorunludur');
        isValid = false;
    }

    // İçerik kontrolü
    if (typeof CKEDITOR !== 'undefined') {
        const content = CKEDITOR.instances.AciklamaHtml.getData().trim();
        if (!content) {
            const editor = document.querySelector('.e-editor');
            addError(editor, 'Mesaj içeriği zorunludur');
            isValid = false;
        }
    }

    // Ek adı kontrolü
    document.querySelectorAll('.e-attachment-name').forEach(function(input) {
        if (!input.value.trim()) {
            input.classList.add('e-error');
            isValid = false;
        }
    });

    // Hata varsa bildirim göster
    if (!isValid) {
        showNotification('error', 'Form Hatası', 'Lütfen zorunlu alanları doldurunuz');
    }

    return isValid;
}

// Hata ekleme
function addError(element, message) {
    element.classList.add('e-error');

    const errorMessage = document.createElement('div');
    errorMessage.className = 'e-error-message';
    errorMessage.textContent = message;

    element.parentNode.appendChild(errorMessage);
}

// Hataları temizleme
function clearErrors() {
    document.querySelectorAll('.e-error').forEach(function(element) {
        element.classList.remove('e-error');
    });

    document.querySelectorAll('.e-error-message').forEach(function(element) {
        element.remove();
    });
}

// Email doğrulama
function validateEmail(email) {
    const re = /^(([^<>()\[\]\\.,;:\s@@"]+(\.[^<>()\[\]\\.,;:\s@@"]+)*)|(".+"))@@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
    return re.test(String(email).toLowerCase());
}

// Kategori seçimi
function getMsjKategoris(sndr) {
    const enstituKod = $(sndr).val();
    const panel = $('#pnlMailGonder');

    panel.addClass('e-loading');

    $.ajax({
        url: '@Url.Action("GetMsjKategoris", "Ajax")',
        data: { 'EnstituKod': enstituKod },
        type: 'POST',
        dataType: "json",
        enctype: "multipart/form-data",
        success: function (result) {
            $('#mkID').empty();

            for (let i = 0; i < result.length; i++) {
                const valR = result[i].Value;
                const _value = valR != null ? valR : "";
                $('#mkID').append(`<option value="${_value}">${result[i].Caption}</option>`);
            }

            panel.removeClass('e-loading');
            getKtNot($('#mkID'));
        },
        error: function (err) {
            showNotification('error', 'Hata', 'Kategori listesi alınamadı');
            panel.removeClass('e-loading');
        }
    });
}

// Kategori notu getirme
function getKtNot(sndr) {
    const kategoriID = $(sndr).val();

    if (!kategoriID) {
        $('#acklmT').html("");
        $('#mkAck').hide();
        return;
    }

    $('#pnlMailGonder').addClass('e-loading');

    $.ajax({
        url: '@Url.Action("GetKtNot", "Ajax")',
        data: { 'MesajKategoriID': kategoriID },
        type: 'POST',
        dataType: "json",
        success: function (result) {
            if (result.NotBilgisi && result.NotBilgisi.trim()) {
                $('#acklmT').html(result.NotBilgisi);
                $('#mkAck').show();
            } else {
                $('#acklmT').html("");
                $('#mkAck').hide();
            }
            $('#pnlMailGonder').removeClass('e-loading');
        },
        error: function (err) {
            showNotification('error', 'Hata', 'Kategori notu alınamadı');
            $('#pnlMailGonder').removeClass('e-loading');
        }
    });
}

    function showNotification(type, title, message) {
        // Toastr ayarları
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": type === 'success' ? "5000" : "0",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        };

        // Bildirim türüne göre toastr metodunu çağır
        switch (type) {
            case 'success':
                toastr.success(message, title);
                break;
            case 'error':
                toastr.error(message, title);
                break;
            case 'warning':
                toastr.warning(message, title);
                break;
            case 'info':
                toastr.info(message, title);
                break;
            default:
                toastr.info(message, title);
        }
    }
        </script>
