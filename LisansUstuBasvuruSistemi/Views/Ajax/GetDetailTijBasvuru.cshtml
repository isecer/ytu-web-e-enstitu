@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model TijBasvuruDetayDto
@{

    //Model.DegerlendirenUniqueID = new Guid("60b7a378-df50-4bb3-aa3d-0b164a795c9e");
    Layout = null;

    var isDanismani = Model.TezDanismanID == UserIdentity.Current.Id;
    var isOgrenci = Model.KullaniciID == UserIdentity.Current.Id;
    var tiJuriOnerileriEykYaGonre = RoleNames.TiJuriOnerileriEykYaGonder.InRoleCurrent();
    var tiJuriOnerileriEykYaHazirlandi = RoleNames.TiJuriOnerileriEykyaHazirlandiYetkisi.InRoleCurrent();
    var tiJuriOnerileriEykDaOnay = RoleNames.TiJuriOnerileriEykDaOnay.InRoleCurrent();
    var formOlusturmaYetki = RoleNames.TiJuriOnerileriOgrenciAdina.InRole() || isOgrenci;
    var yaziGormeYetki = tiJuriOnerileriEykYaGonre || tiJuriOnerileriEykYaHazirlandi || tiJuriOnerileriEykDaOnay;
}
<style>

    .CaptionTd {
        font-weight: bold;
        font-size: 9pt;
        margin: 0px;
    }

    .ValueTd {
        font-size: 9pt;
        margin: 0px;
        text-align: left;
    }
</style>
<div class="panel" style="border:none;" id="bsvrDet_@Model.UniqueID">
    <div>

        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
            <table style="width:100%;">
                <tr>
                    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-id-card-o fa-lg"></i> Öğrenci Bilgileri</td>
                    <td width="100" style="font-weight:bold;font-size:15pt; border-bottom:1px solid; text-align:right;">
                        <a href="javascript:void(0);" onclick="GetDetail('@Model.UniqueID')"><span class="fa fa-refresh" aria-hidden="true"></span></a>
                    </td>

                </tr>
                <tr>

                    <td style="padding-left:10px;text-align:left;">

                        <table style="width:100%;">
                            <tr>
                                <td class="CaptionTd" width="140">Ad Soyad</td>
                                <td class="CaptionTd" width="10">:</td>
                                <td class="ValueTd">
                                    @Model.Ad @Model.Soyad (@Model.OgrenciNo)
                                </td>
                            </tr>
                            <tr>
                                <td class="CaptionTd">Öğrenim Seviyesi</td>
                                <td class="CaptionTd">:</td>
                                <td class="ValueTd">@Model.OgrenimTipAdi</td>
                            </tr>
                            <tr>
                                <td class="CaptionTd">Program</td>
                                <td class="CaptionTd">:</td>
                                <td class="ValueTd">@Model.AnabilimdaliAdi / @Model.ProgramAdi</td>
                            </tr>
                            <tr>
                                <td class="CaptionTd">Kayıt Tarihi</td>
                                <td class="CaptionTd">:</td>
                                <td class="ValueTd">@Model.KayitDonemi , @Model.KayitTarihi.ToFormatDate()</td>
                            </tr>

                        </table>
                    </td>
                    <td width="100" style="text-align:center;">
                        <img src="@(Model.ResimAdi.ToKullaniciResim())" style="width:90px;height:90px;" class="img-circle img-thumbnail">
                    </td>
                </tr>

            </table>
        </div>
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:0px;padding:6px 10px;">
            <table style="width:100%;">
                <tr>
                    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-list fa-lg"></i> Jüri Öneri / Değişiklik İşlemleri</td>
                    <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
                        @if (Model.IsYeniBasvuruYapilabilir && formOlusturmaYetki)
                        {
                            <span class="label label-info" id="YeniRaporBtn_@Model.TijBasvuruID" style="cursor:pointer;" onclick="GetTiJuriOneriForm(@Model.KullaniciID,'@Model.UniqueID');"><i class="fa fa-plus"></i> Jüri Değişiklik Formu Oluştur</span>
                        }
                    </td>

                </tr>
                <tr>
                    <td colspan="2" style="padding-left:10px;text-align:left;">
                        @if (Model.TijBasvuruOneriList.Any() == false)
                        {
                            <table style="width:100%;table-layout:fixed;">
                                <tr>
                                    <td style="color:maroon;font-size:13pt; text-align:center;height:250px;">Herhangi bir Rapor girişi bulunamadı</td>
                                </tr>
                            </table>
                        }
                        else
                        {
                            int inxRw = 0;
                            <table class="table">
                                <tr>
                                    <th width="40"></th>
                                    <th width="240">Öneri Tipi</th>
                                    <th width="160">Dönem / Öneri Tarihi</th>
                                    <th>Öneri Durumu</th>
                                    <th width="120"></th>
                                </tr>
                                @foreach (var item in Model.TijBasvuruOneriList)
                                {
                                    inxRw++;
                                    bool showRow = inxRw == 1;
                                    var kayitYetki = isDanismani || (isOgrenci && !item.DanismanOnayladi.HasValue) || UserIdentity.Current.IsYetkiliTij;
                                    <tr>
                                        <td>
                                            <ul class="panel-controls">
                                                <li id="iShow_Rpr_@item.TijBasvuruOneriID" onclick="ShowDetailY('Rpr_@item.TijBasvuruOneriID')">
                                                    <a href="javascript:void(0)"><span class="fa fa-angle-@(showRow ? "up" : "down")"></span> </a>
                                                </li>
                                            </ul>
                                        </td>
                                        <td>@item.TijFormTipAdi <br />@(item.TijDegisiklikTipID.HasValue?item.TijDegisiklikTipAdi:"Yeni Jüri Önerisi")</td>
                                        <td>
                                            @if (item.IsObsData)
                                            {
                                                @("OBS de doğrulandı")
                                            }
                                            else
                                            {
                                                @item.DonemAdi <br />@item.BasvuruTarihi.ToFormatDateAndTime()
                                            }

                                        </td>
                                        <td>
                                            @if (item.IsObsData)
                                            {
                                                @("OBS de doğrulandı")
                                            }
                                            else
                                            {
                                                @item.ToTijBasvuruDurumView()
                                            }
                                        </td>
                                        <td>
                                            @if (item.IsSonBasvuru && !item.EYKYaGonderildi.HasValue && kayitYetki)
                                            {
                                                if (!item.IsObsData)
                                                {
                                                    <a href="javascript:void(0)" onclick="GetTiJuriOneriForm(@Model.KullaniciID,'@Model.UniqueID','@item.UniqueID')"><i style="font-size: 11pt;" class="fa fa-edit"></i> Öneriyi Düzelt</a>
                                                    <br />
                                                }

                                                <a href="javascript:void(0)" onclick="SilDetay('@Model.UniqueID','@item.UniqueID','@Model.Ad @Model.Soyad','@item.BasvuruTarihi.ToFormatDateAndTime()')"><i style="font-size: 11pt;" class="glyphicon glyphicon-trash"></i> Öneriyi Sil</a>

                                            }
                                        </td>
                                    </tr>
                                    <tr class="MainRow2 cls-Rpr_@item.TijBasvuruOneriID" style="@(showRow ? "" : "display:none;")">
                                        <td></td>
                                        <td colspan="5">

                                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
                                                <table style="width:100%;">
                                                    <tr>
                                                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg"></i> Öneri / Tez Bilgileri</td>
                                                    </tr>

                                                    <tr>
                                                        <td class="CaptionTd" width="160">Yeterlik Sözlü Sınav Tarihi</td>
                                                        <td class="CaptionTd" width="10">:</td>
                                                        <td class="ValueTd">@(item.SozluSinavBasariTarihi.ToFormatDate())</td>
                                                    </tr>
                                                    @if (!item.DegisiklikAciklamasi.IsNullOrWhiteSpace())
                                                    {
                                                        <tr>
                                                            <td class="CaptionTd">
                                                                Değişiklik Açıklaması
                                                            </td>
                                                            <td class="CaptionTd">:</td>
                                                            <td class="ValueTd">
                                                                @item.DegisiklikAciklamasi
                                                            </td>
                                                        </tr>
                                                    }
                                                    <tr>
                                                        <td class="CaptionTd" width="160">Tez Dili</td>
                                                        <td class="CaptionTd" width="10">:</td>
                                                        <td class="ValueTd">@(item.IsTezDiliTr ? "Türkçe" : "İngilizce")</td>
                                                    </tr>
                                                    @if (!item.TezBaslikTr.IsNullOrWhiteSpace())
                                                    {
                                                        <tr>
                                                            <td class="CaptionTd">Tez Başlığı Türkçe</td>
                                                            <td class="CaptionTd">:</td>
                                                            <td class="ValueTd">@item.TezBaslikTr</td>
                                                        </tr>
                                                    }
                                                    @if (!item.TezBaslikEn.IsNullOrWhiteSpace())
                                                    {
                                                        <tr>
                                                            <td class="CaptionTd">Tez Başlığı İngilizce</td>
                                                            <td class="CaptionTd">:</td>
                                                            <td class="ValueTd">@item.TezBaslikEn</td>
                                                        </tr>
                                                    }
                                                    @if (item.TezDanismanID.HasValue)
                                                    {
                                                        <tr>
                                                            <td class="CaptionTd">
                                                                Danışman
                                                            </td>
                                                            <td class="CaptionTd">:</td>
                                                            <td class="ValueTd">
                                                                <a href="javascript:void(0)" onclick="DetayGor('@item.TezDanismaniUserKey','#kulPnl')"><i class="fa fa-graduation-cap"></i> @item.DanismanAdi</a>
                                                            </td>
                                                        </tr>
                                                    }

                                                    @if (!item.IsObsData && item.DanismanOnayladi == true)
                                                    {
                                                        var title = (item.TijFormTipID == TijFormTipiEnum.YeniForm ? "FR-0306 Doktora Tez İzleme Komitesi Öneri Formu" : "FR-1460 Doktora Tez İzleme Komitesi Değişikliği Formu");
                                                        var title2 = title + "nu";
                                                        <tr>
                                                            <td class="CaptionTd">Form Kodu</td>
                                                            <td class="CaptionTd">:</td>
                                                            <td class="ValueTd">@item.FormKodu</td>
                                                        </tr>
                                                        <tr>
                                                            <td class="CaptionTd">Form</td>
                                                            <td class="CaptionTd">:</td>
                                                            <td class="ValueTd">
                                                                <a href="javascript:void(0);" onclick="YeniDialogBB('@title','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipiEnum.TezIzlemeJuriOneriFormu&UniqueID=@item.UniqueID' , 'auto', 'modal-dialog modal-lg' )">
                                                                    <i class="fa fa-print"></i> @title2 İndir
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    }
                                                </table>
                                            </div>

                                            @if (item.TijFormTipID != TijFormTipiEnum.YeniForm)
                                            {
                                                <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
                                                    <table class="table" style="width:100%;margin:0px;">
                                                        <tr>
                                                            <td colspan="5" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg"></i> Varolan Jüriler</td>
                                                        </tr>

                                                        <tr class="info">
                                                            <th width="35"></th>
                                                            <th width="100">Unvanı</th>
                                                            <th>Ad Soyad</th>
                                                            <td width="90"></td>
                                                        </tr>
                                                        <tbody>

                                                            @foreach (var itemJr in item.TijBasvuruOneriJurilers.Where(p => !p.IsYeniOrOnceki))
                                                            {
                                                                <tr>
                                                                    <td>

                                                                        <ul class="panel-controls">
                                                                            <li id="iShow_Jo_@itemJr.TijBasvuruOneriJuriID" onclick="ShowDetailY('Jo_@itemJr.TijBasvuruOneriJuriID')">
                                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span> </a>
                                                                            </li>
                                                                        </ul>
                                                                    </td>
                                                                    <td>
                                                                        @itemJr.UnvanAdi
                                                                        <br />
                                                                        @(itemJr.IsTezDanismani ? "Tez Danışmanı" : "Jüri Üyesi")
                                                                    </td>
                                                                    <td>
                                                                        @itemJr.AdSoyad
                                                                        <br /><span style="font-size:7pt;">@itemJr.UniversiteAdi</span>
                                                                    </td>
                                                                    <td style="text-align:center;color:@(item.EYKDaOnaylandi==true?"green":"maroon");">
                                                                        @if (!itemJr.IsTezDanismani)
                                                                        {
                                                                            if (itemJr.IsYtuIciJuri && (item.TijDegisiklikTipID == TijDegisiklikTipiEnum.YtuIciDegisiklik || item.TijDegisiklikTipID == TijDegisiklikTipiEnum.YtuIciVeDisiDegisiklik))
                                                                            {
                                                                                <span><b>@(item.EYKDaOnaylandi==true?"Değişti": "Değişecek")</b></span>
                                                                            }
                                                                            else if (!itemJr.IsYtuIciJuri && (item.TijDegisiklikTipID == TijDegisiklikTipiEnum.YtuDisiDegisiklik || item.TijDegisiklikTipID == TijDegisiklikTipiEnum.YtuIciVeDisiDegisiklik))
                                                                            {
                                                                                <span><b>@(item.EYKDaOnaylandi==true?"Değişti": "Değişecek")</b></span>
                                                                            }
                                                                        }
                                                                    </td>
                                                                </tr>
                                                                <tr class="MainRow2 cls-Jo_@itemJr.TijBasvuruOneriJuriID" style="display:none">
                                                                    <td id="cls-Jo_@itemJr.TijBasvuruOneriJuriID" colspan="5" style="padding: 1px 1px 2px 50px;">
                                                                        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                                                            <table style="table-layout:fixed; font-size:9pt;margin:0px;">
                                                                                <tbody>
                                                                                    <tr>
                                                                                        <td class="CaptionTd" width="150">E-Posta Adresi</td>
                                                                                        <td class="CaptionTd" width="10">:</td>
                                                                                        <td class="ValueTd">@itemJr.EMail</td>
                                                                                    </tr>
                                                                                    <tr>
                                                                                        <td class="CaptionTd">Üniversitesi</td>
                                                                                        <td class="CaptionTd">:</td>
                                                                                        <td class="ValueTd">@itemJr.UniversiteAdi</td>
                                                                                    </tr>
                                                                                    <tr>
                                                                                        <td class="CaptionTd">Anabilim Dalı</td>
                                                                                        <td class="CaptionTd">:</td>
                                                                                        <td class="ValueTd">@itemJr.AnabilimdaliAdi</td>
                                                                                    </tr>
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    </td>
                                                                </tr>

                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }

                                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
                                                <table class="table" style="width:100%;margin:0px;">
                                                    <tr>
                                                        <td colspan="5" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;">
                                                            <i class="fa fa-group fa-lg"></i>
                                                            @if (item.TijFormTipID != TijFormTipiEnum.YeniForm)
                                                            {
                                                                @("Önerilen Jüriler")
                                                            }
                                                            else
                                                            {
                                                                @(item.IsObsData? "Jüriler (OBS de doğrulandı)" : "Önerilen Jüriler")
                                                            }

                                                        </td>
                                                    </tr>

                                                    <tr class="info">
                                                        <th width="35"></th>
                                                        <th width="100">Unvanı</th>
                                                        <th>Ad Soyad</th>
                                                        <th width="90" style="text-align: center;">
                                                            Asil Seçim
                                                        </th>
                                                    </tr>
                                                    <tbody>

                                                        @foreach (var itemJr in item.TijBasvuruOneriJurilers.Where(p => p.IsYeniOrOnceki))
                                                        {
                                                            <tr>
                                                                <td>

                                                                    <ul class="panel-controls">
                                                                        <li id="iShow_Jo_@itemJr.TijBasvuruOneriJuriID" onclick="ShowDetailY('Jo_@itemJr.TijBasvuruOneriJuriID')">
                                                                            <a href="javascript:void(0)"><span class="fa fa-angle-down"></span> </a>
                                                                        </li>
                                                                    </ul>
                                                                </td>
                                                                <td>
                                                                    @itemJr.UnvanAdi
                                                                    <br />
                                                                    @(itemJr.IsTezDanismani ? "Tez Danışmanı" : "Jüri Üyesi")
                                                                </td>
                                                                <td>
                                                                    @itemJr.AdSoyad
                                                                    <br /><span style="font-size:7pt;">@itemJr.UniversiteAdi</span>
                                                                </td>
                                                                <td style="text-align: center;">
                                                                    @if (item.IsSonBasvuru && !item.IsObsData && !itemJr.IsTezDanismani && item.EYKYaGonderildi == true && !item.EYKDaOnaylandi.HasValue)
                                                                    {
                                                                        <select class="form-control" id="IsAsil_@itemJr.TijBasvuruOneriJuriID" name="IsAsil" onchange="SetAsilOrYedek(this,'@Model.UniqueID',@itemJr.TijBasvuruOneriJuriID)" style="text-align-last: center">
                                                                            <option value=""></option>
                                                                            <option value="true" @(itemJr.IsAsil == true ? "selected" : "")>Asil</option>
                                                                        </select>
                                                                    }
                                                                    else
                                                                    {
                                                                        <b>@(itemJr.IsAsil == true?"Asil":"")</b>
                                                                    }
                                                                </td>
                                                            </tr>
                                                            <tr class="MainRow2 cls-Jo_@itemJr.TijBasvuruOneriJuriID" style="display:none">
                                                                <td id="cls-Jo_@itemJr.TijBasvuruOneriJuriID" colspan="5" style="padding: 1px 1px 2px 50px;">
                                                                    <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                                                        <table style="table-layout:fixed; font-size:9pt;margin:0px;">
                                                                            <tbody>
                                                                                <tr>
                                                                                    <td class="CaptionTd" width="150">E-Posta Adresi</td>
                                                                                    <td class="CaptionTd" width="10">:</td>
                                                                                    <td class="ValueTd">@itemJr.EMail</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td class="CaptionTd">Üniversitesi</td>
                                                                                    <td class="CaptionTd">:</td>
                                                                                    <td class="ValueTd">@itemJr.UniversiteAdi</td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <td class="CaptionTd">Anabilim Dalı</td>
                                                                                    <td class="CaptionTd">:</td>
                                                                                    <td class="ValueTd">@itemJr.AnabilimdaliAdi</td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                </td>
                                                            </tr>

                                                        }
                                                    </tbody>
                                                </table>
                                            </div>

                                            @if (!item.IsObsData)
                                            {
                                                <div class="widget widget-default" style="border-top: 1px solid; border-top-color: lightgray; margin-bottom: 8px; padding: 6px 10px; min-height: 60px;">
                                                    <table style="width: 100%;">
                                                        <tr>
                                                            <td colspan="3" style="font-weight: bold; font-size: 11pt; border-bottom: 1px solid;"><i class="fa fa-check-square-o"></i> Danışman Onay İşlemi</td>
                                                        </tr>

                                                        @if (item.IsSonBasvuru && !item.EYKYaGonderildi.HasValue && (isDanismani || tiJuriOnerileriEykDaOnay || tiJuriOnerileriEykYaGonre))
                                                        {

                                                            <tr class="form-group">
                                                                <td class="CaptionTd" width="200">Onay Durumu</td>
                                                                <td class="CaptionTd" width="10">:</td>
                                                                <td class="ValueTd">
                                                                    <table>
                                                                        <tr>
                                                                            <td>
                                                                                <select id="DanismanOnayladi_@item.UniqueID" class="form-control" onchange="DanismanOnayDurumAcklmVisible(this,'@item.UniqueID');">
                                                                                    <option></option>
                                                                                    <option value="true" @(item.DanismanOnayladi == true ? "selected" : "")>Jüri Önerisi Başvurusunu Onaylıyorum </option>
                                                                                    <option value="false" @(item.DanismanOnayladi == false ? "selected" : "")>Jüri Önerisi Başvurusunu Reddediyorum</option>
                                                                                </select>
                                                                            </td>
                                                                            <td>
                                                                                <label class="btn btn-primary btn-sm" onclick="DanismanOnayDurumKayit('@Model.UniqueID', '@item.UniqueID');"><i class="fa fa-save" aria-hidden="true">&nbsp;</i>Kaydet</label>
                                                                            </td>
                                                                        </tr>
                                                                    </table>
                                                                </td>
                                                            </tr>

                                                            <tr id="DanismanOnaylanmaTaahhutRow1_@item.UniqueID" class="@(item.DanismanOnayladi == true ? "" : "hide")">
                                                                <td colspan="3">
                                                                    <div class="tasks">
                                                                        <div class="task-item task-info" style="margin-bottom: 0px; cursor: auto;">
                                                                            <div class="task-text" style="padding-bottom: 0px; font-size: 8pt;">
                                                                                <br/><b>Taahhüt1:</b> Önerilen tez izleme komite üyeleri arasında İkinci Danışman bulunmadığını kabul ediyorum.
                                                                                <br/><b>Taahhüt2:</b> Seçilen jüri üyeleri için ‘Yükseköğretim kurumlarında yabancı dil öğretimi ve yabancı dille öğretim yapılmasında uyulacak esaslara ilişkin yönetmeliğe göre dil şartını sağlamaktadır’ tahhütünü kabul ediyorum.
                                                                                <br/><b>Taahhüt3:</b>  Önerilen jüri üyeleri, danışman ve öğrenci arasında akrabalık ilişkisi bulunmadığını kabul ediyorum.
                                                                            </div>
                                                                            <div class="task-footer" style="padding-top:0pt;padding-bottom:0px;color:green;">
                                                                                <div class="pull-left"><span class="fa fa-check-circle-o"></span> @item.DanismanOnayTarihi.ToFormatDateAndTime()</div>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                </td>
                                                            </tr>
                                                            <tr id="DanismanOnaylanmamaAciklamasiAckRow_@item.UniqueID" class="form-group @(item.DanismanOnayladi == false ? "" : "hide")">
                                                                <td class="CaptionTd">Onaylanmama Açıklaması</td>
                                                                <td class="CaptionTd">:</td>
                                                                <td class="ValueTd">
