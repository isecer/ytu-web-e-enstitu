            success: function (result) {
                $('#DpBasvuruDurum_' + donemProjesiUniqueId).html(result.dpBasvuruDurumView);
                $('#DpBasvuruDonem_' + donemProjesiUniqueId).html(result.dpBasvuruDonemView);
                PanelRefresh(panel, true);
            },
            error: function (err) {
                alert(err.responseText);
                PanelRefresh(panel, true);
            },
            complete: function (cmp) {
                PanelRefresh(panel, true);
            },
        });
    }
    function ShowSrDialog(donemProjesiUniqueId, donemProjesiBasvuruUniqueId, isSrTalebiYapildi) {
        var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        $.ajax({
            url: '@Url.Action("RezervasyonAl", "DpBasvuru")',
            data: { donemProjesiBasvuruUniqueId },
            success: function (result) {

                PanelRefresh(panel, true);
                var btbxxFS = bootbox.dialog({
                    message: result,
                    title: "<i class='fa fa-calendar fa-lg'></i> " + (isSrTalebiYapildi=='true' ? 'Yeni Dönem Projesi Sınavı Toplantı Bilgi Girişi' : 'Dönem Projesi Sınavı Toplantı Bilgileri Düzenleme'),
                    buttons: {
                        success: {
                            label: "Kaydet",
                            className: "btn-info btnSrKayit_" + donemProjesiUniqueId,
                            callback: function (event) {
                                var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                $('.btnSrKayit_' + donemProjesiUniqueId).addClass('disabled');
                                PanelRefresh(pnlx, false);
                                $('#DonemProjesiSrForm').ajaxForm({
                                    success: function (result) {
                                        if (result.IsSuccess) {
                                            toastr["success"](result.Messages.join('<br/>'), result.Title, { timeOut: 8000 });
                                            GetDetail(donemProjesiUniqueId);
                                            var _clsBtn = $('.modal-header').find('button').first();
                                            $(_clsBtn).click();
                                        }
                                        else {
                                            GetMsg(result);
                                            return false;
                                        }
                                        PanelRefresh(pnlx, true);

                                    },
                                    complete: function (cmp) {
                                        $('.btnSrKayit_' + donemProjesiUniqueId).removeClass('disabled');
                                        PanelRefresh(pnlx, true);
                                    }

                                });
                                $('#DonemProjesiSrForm').submit();

                                return false;
                            }
                        },
                        danger: {
                            label: "Kapat",
                            className: "btn-primary",
                            callback: function () {
                            }
                        }
                    }
                });
            },
            error: function (err) {
                PanelRefresh(panel, true);
                alert(err.responseText);
            }
        });
    }
    function EykOnayChange(sndr, donemProjesiBasvuruUniqueId) {
        var val = $(sndr).val().toLowerCase();
        if (val == 'false') {
            $('#jOneriFormOnayAckRow_' + donemProjesiBasvuruUniqueId).removeClass("hide");
        }
        else {
            $('#jOneriFormOnayAckRow_' + donemProjesiBasvuruUniqueId).addClass("hide");
        }
        if (val == '') {

            $('#EYKTarihi_' + donemProjesiBasvuruUniqueId).addClass("hide");

        }
        else {
            var eykTarih = $('#EYKTarihi_' + donemProjesiBasvuruUniqueId).val();
            if (eykTarih == "") {
                var today = new Date(), year = today.getFullYear(), month = today.getMonth() + 1, day = today.getDate();
                if (month < 10) month = "0" + month;
                if (day < 10) day = "0" + day;
                var formattedDate = year + "-" + month + "-" + day;
                $('#EYKTarihi_' + donemProjesiBasvuruUniqueId).val(formattedDate);
            }
            $('#EYKTarihi_' + donemProjesiBasvuruUniqueId).removeClass("hide");
        }
    }
    function EykYaOnayChange(id) {
      var val = $('#EykYaGonderildi_' + id).val().toLowerCase();
      if (val == 'false') {
          $('#EYKYaGonderimAciklamaRow_' + id).removeClass('hide');
      }
      else {
          $('#EYKYaGonderimAciklamaRow_' + id).addClass('hide');
      }
  }
    function EykDurumKayit(donemProjesiUniqueId, donemProjesiBasvuruUniqueId, onayTipId) {
        var panel = $('#cls-' + donemProjesiUniqueId);
        PanelRefresh(panel, false);
        var sndrId = "";
        var eykDaOnaylanmadiDurumAciklamasi = "";
        var eykDaOnaylandiOnayTarihi = "";
        if (onayTipId == @EykTipEnum.EykDaOnaylandi) {
            sndrId = '#EykDaOnaylandi_' + donemProjesiBasvuruUniqueId;
            if ($(sndrId).val().toLowerCase() == 'false') eykDaOnaylanmadiDurumAciklamasi = $('#EYKDaOnaylanmadiDurumAciklamasi_' + donemProjesiBasvuruUniqueId).val();
            eykDaOnaylandiOnayTarihi = $('#EYKTarihi_' + donemProjesiBasvuruUniqueId).val();
        }
        else if (onayTipId == @EykTipEnum.EykYaHazirlandi) sndrId = '#EykYaHazirlandi_' + donemProjesiBasvuruUniqueId;
        else if (onayTipId == @EykTipEnum.EykYaGonderildi) {
            sndrId = '#EykYaGonderildi_' + donemProjesiBasvuruUniqueId;
            if ($(sndrId).val().toLowerCase() == 'false') eykDaOnaylanmadiDurumAciklamasi = $('#EYKYaGonderimOnaylanmadiDurumAciklamasi_' + donemProjesiBasvuruUniqueId).val();
        }
        var onaylandi = $(sndrId).val().toLowerCase();
        $.ajax({
            url: '@Url.Action("EykDurumKayit", "DpBasvuru")',
            data: {
                donemProjesiBasvuruUniqueId,
                onayTipId,
                'Onaylandi': onaylandi,
                'Aciklama': eykDaOnaylanmadiDurumAciklamasi,
                'OnayTarihi': eykDaOnaylandiOnayTarihi
            },
            success: function (result) {
                PanelRefresh(panel, true);
                if (result.IsSuccess) {
                    toastr["success"](result.mmMessage.Messages[0], result.mmMessage.Title);
                    GetDetail(donemProjesiUniqueId);

                }
                else ShowMmMessage(result.Messages, 'Tamam');

            },
            error: function (err) {
                PanelRefresh(panel, true);
                alert(err.responseText);

            }
        });
    }
</script>