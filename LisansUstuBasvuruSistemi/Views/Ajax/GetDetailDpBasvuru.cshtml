                                                    @if (showDegerlendirme)
                                                    {
                                                        var isDanismanKatilmadiSecti = item.DonemProjesiJurileris.Any(a => a.IsTezDanismani && a.DonemProjesiJuriOnayDurumID == DonemProjesiJuriOnayDurumEnum.BasarisizKatilmadi);

