@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.Helpers
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model DpBasvuruDetayDto
@{

    Layout = null;

    var isDanismani = Model.TezDanismanID == UserIdentity.Current.Id;
    var isOgrenci = Model.KullaniciID == UserIdentity.Current.Id;
    var formOlusturmaYetki = RoleNames.DonemProjesiBasvuruYapmaYetkisi.InRoleCurrent();
    var enstituBasvuruOnayYetkisi = RoleNames.DonemProjesiEnstituBasvuruOnayYetkisi.InRoleCurrent();
    var danismanBasvuruOnayYetkisi = RoleNames.DonemProjesiDanismanBasvuruOnayYetkisi.InRoleCurrent();
    var juriOlusturmaYetkisi = RoleNames.DonemProjesiJuriOlusturmaYetkisi.InRoleCurrent();
    var degerlendirmeDuzeltmeYetki = RoleNames.DonemProjesiSinavDegerlendirmeDuzeltme.InRoleCurrent();
    var sinavOlusturmaYetkisi = isDanismani || RoleNames.DonemProjesiSinaviOlusturmaYetkisi.InRoleCurrent();
    var eykYaGondermeYetkisi = RoleNames.DonemProjesiEykYaGonder.InRoleCurrent();
    var eykYaHazrilamaYetkisi = RoleNames.DonemProjesiEykYaHazirlandi.InRoleCurrent();
    var eykDaOnayYetkisi = RoleNames.DonemProjesiEykDaOnay.InRoleCurrent();


}
<style>

    .CaptionTd {
        font-weight: bold;
        font-size: 9pt;
        margin: 0px;
    }

    .ValueTd {
        font-size: 9pt;
        margin: 0px;
        text-align: left;
    }
</style>

@if (Model.DegerlendirenUniqueID.HasValue)
{
    var item = Model.DonemProjesiBasvurus.First(p => p.DonemProjesiJurileris.Any(a => a.UniqueID == Model.DegerlendirenUniqueID));
    var itemJr = item.DonemProjesiJurileris.First(a => a.UniqueID == Model.DegerlendirenUniqueID);
    var showDegerlendirme = !itemJr.DonemProjesiJuriOnayDurumID.HasValue;
    var isDegerlendirmeAcik = showDegerlendirme || degerlendirmeDuzeltmeYetki;
    var isDanismanDegerlendirmeYapti = item.DonemProjesiJurileris.Any(a => a.IsTezDanismani && a.DonemProjesiJuriOnayDurumID.HasValue);
    if (showDegerlendirme && !itemJr.IsTezDanismani)
    {
        showDegerlendirme = isDanismanDegerlendirmeYapti;
    }

    <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray;padding:6px 10px;margin-bottom:0px;margin-top:0px; min-height:20px;">
        @if (isDegerlendirmeAcik)
        {
            <table style="width:100%;">
                <tr>
                    <td style="font-weight:bold;font-size:11pt;"><i class="fa fa-check fa-lg"></i> Dönem Projesi Değerlendirme İşlemi</td>
                    <td class="clsHide" width="100" style="font-weight:bold;font-size:15pt; text-align:right;">
                        <a href="javascript:void(0);" onclick="GetDetail('@Model.UniqueID')" title="Ekranı Yenile"><span class="fa fa-refresh" aria-hidden="true"></span></a>
                    </td>
                </tr>
                <tr>
                    <td colspan="2" style="padding-left:10px;text-align:left;">
