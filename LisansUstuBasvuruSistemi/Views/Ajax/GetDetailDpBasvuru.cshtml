                            <table style="width:100%;">
                                <tr>
                                    <td colspan="2" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-id-card-o fa-lg"></i> Öğrenci Bilgileri</td>

                                </tr>
                                <tr>
                                    <td style="padding-left:10px;text-align:left;">

                                        <table style="table-layout:fixed;">
                                            <tr>
                                                <td class="CaptionTd" width="140">Ad Soyad</td>
                                                <td class="CaptionTd" width="10">:</td>
                                                <td class="ValueTd">
                                                    @Model.Ad @Model.Soyad (@Model.OgrenciNo)
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="CaptionTd">Öğrenim Seviyesi</td>
                                                <td class="CaptionTd">:</td>
                                                <td class="ValueTd">@Model.OgrenimTipAdi</td>
                                            </tr>
                                            <tr>
                                                <td class="CaptionTd">Program</td>
                                                <td class="CaptionTd">:</td>
                                                <td class="ValueTd">@Model.AnabilimdaliAdi / @Model.ProgramAdi</td>
                                            </tr>


                                        </table>
                                    </td>
                                    <td class="clsHide" width="100" style="text-align:center;">
                                        <img src="@(Model.ResimAdi.ToKullaniciResim())" style="width:70px;height:70px;" class="img-circle img-thumbnail">
                                    </td>
                                </tr>

                            </table>
                        </div>
                        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg"></i> Jüri Üyesi Bilgileri</td>
                                    </tr>
                                    <tr>
                                        <td style="padding-left:10px;text-align:left;">
                                            <table style="width:100%;">
                                                <tr>
                                                    <td class="CaptionTd" width="140">Adı Soyadı</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td class="ValueTd">@itemJr.UnvanAdi @itemJr.AdSoyad</td>
                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd" style="font-weight:bold;">E-Posta Adresi</td>
                                                    <td class="CaptionTd" style="font-weight:bold;">:</td>
                                                    <td class="ValueTd">@itemJr.EMail</td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                            <table style="width:100%;">
                                <tr>
                                    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg"></i> Dönem Projesi Bilgileri</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:10px;text-align:left;">
                                        <table style="table-layout:fixed;">
                                            <tr>
                                                <td class="CaptionTd" width="140">Proje Başlığı</td>
                                                <td class="CaptionTd" width="10">:</td>
                                                <td class="ValueTd">@item.ProjeBasligi</td>
                                            </tr>

                                            <tr>
                                                <td class="CaptionTd">Proje Özeti</td>
                                                <td class="CaptionTd">:</td>
                                                <td class="ValueTd">
                                                    <div style="max-height:80px;overflow:auto;">@item.ProjeOzeti</div>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>

                            </table>
                        </div>

                        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                            <table style="width:100%;">
                                <tr>
                                    <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;">
                                        <i style="font-size:16pt;" class="glyphicon glyphicon-info-sign" aria-hidden="true"></i> Jüri Üyesi Rapor Değerlendirmesi
                                    </td>
                                </tr>
