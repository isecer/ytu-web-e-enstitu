                                                            <option></option>
                                                            <option class="@(!itemJr.IsTezDanismani && isDanismanKatilmadiSecti ? "hide" : "")" value="@DonemProjesiJuriOnayDurumEnum.Basarili" @(itemJr.DonemProjesiJuriOnayDurumID == DonemProjesiJuriOnayDurumEnum.Basarili ? "selected" : "")>Başarılı</option>
                                                            <option class="@(!itemJr.IsTezDanismani && isDanismanKatilmadiSecti ? "hide" : "")" value="@DonemProjesiJuriOnayDurumEnum.Basarisiz" @(itemJr.DonemProjesiJuriOnayDurumID == DonemProjesiJuriOnayDurumEnum.Basarisiz ? "selected" : "")>Başarısız</option>
                                                            <option class="@(itemJr.IsTezDanismani || isDanismanKatilmadiSecti?"":"hide")" value="@DonemProjesiJuriOnayDurumEnum.BasarisizKatilmadi" @(itemJr.DonemProjesiJuriOnayDurumID == DonemProjesiJuriOnayDurumEnum.BasarisizKatilmadi ? "selected" : "")>Başarısız (Katılmadı)</option>
                                                        </select>
                                                    }
                                                    else
                                                    {
                                                        if (!isDanismanDegerlendirmeYapti)
                                                        {
                                                            <span style="font-size:10pt;">Proje Yürütücüsü henüz değerlendirme yapmadığından değerlendirme işlemini yapamazsınız.</span>
                                                        }
                                                        else
                                                        {
                                                            <span style="font-size:10pt;">@itemJr.DonemProjesiJuriOnayDurumlari.JuriOnayDurumAdi</span>
                                                        }

                                                    }
                                                </td>
                                            </tr>
                                            @if (itemJr.IsTezDanismani)
                                            {
                                                <tr class="RwDpDetay_@itemJr.DonemProjesiJuriID @(itemJr.DonemProjesiJuriOnayDurumID==DonemProjesiJuriOnayDurumEnum.Basarili  ? "" : "hide")">
                                                    <td class="CaptionTd ctWidth" width="220">En Fazla Tek Kaynak Oranı</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td>
                                                        @if (showDegerlendirme)
                                                        {
                                                            <input type="text" style="width:160px;" id="TekKaynakOrani_@itemJr.UniqueID" value="@item.TekKaynakOrani" />
                                                        }
                                                        else
                                                        {
                                                            @(item.TekKaynakOrani.HasValue? "%" + item.TekKaynakOrani:"")
                                                        }
                                                    </td>
                                                </tr>
                                                <tr class="RwDpDetay_@itemJr.DonemProjesiJuriID @(itemJr.DonemProjesiJuriOnayDurumID==DonemProjesiJuriOnayDurumEnum.Basarili  ? "" : "hide")">
                                                    <td class="CaptionTd ctWidth" width="220">Toplam Kaynak Oranı</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td>
                                                        @if (showDegerlendirme)
                                                        {
                                                            <input type="text" style="width:160px;" id="ToplamKaynakOrani_@itemJr.UniqueID" value="@item.ToplamKaynakOrani" />
                                                        }
                                                        else
                                                        {
                                                            @(item.ToplamKaynakOrani.HasValue? "%" + item.ToplamKaynakOrani:"")
                                                        }
                                                    </td>
                                                </tr>
                                                <tr class="RwDpDetay_@itemJr.DonemProjesiJuriID @(itemJr.DonemProjesiJuriOnayDurumID==DonemProjesiJuriOnayDurumEnum.Basarili  ? "" : "hide")">
                                                    <td class="CaptionTd ctWidth" width="220">Benzerlik Raporu Pdf Dosyası</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td>
                                                        <table style="width:100%;">
                                                            <tr>
                                                                <td>
                                                                    @if (item.IntihalRaporuDosyaYolu.IsNullOrWhiteSpace() == false)
                                                                    {
                                                                        <a href="javascript:void(0);" title="Yüklenen pdf dosyasını aç" onclick="PopupCenter('@Url.CustomUrlContent(item.IntihalRaporuDosyaYolu)','@item.IntihalRaporuDosyaAdi',800,600);"><i class="fa fa-file-pdf-o" style="color:green;font-size:11pt;"></i> @item.IntihalRaporuDosyaAdi</a>
                                                                    }
                                                                </td>
                                                                @if (showDegerlendirme)
                                                                {
                                                                    <td>
                                                                        <input type="file" name="IntihalDosya" id="intihalDosya_@itemJr.UniqueID">
                                                                    </td>

                                                                }
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>

                                            }
                                            <tr class="RwJAck_@itemJr.DonemProjesiJuriID @(itemJr.DonemProjesiJuriOnayDurumID.HasValue ? "" : "hide")">
                                                <td class="CaptionTd ctWidth" width="220">Değerlendirme Açıklaması</td>
                                                <td class="CaptionTd" width="10">:</td>
                                                <td class="ValueTd">
                                                    @if (showDegerlendirme)
                                                    {
                                                        <textarea id="Aciklama_@itemJr.UniqueID" maxlength="2048" style="width: 100%; resize: vertical;" rows="2" class="form-control">@itemJr.Aciklama</textarea>
                                                    }
                                                    else
                                                    {
                                                        @itemJr.Aciklama
                                                    }
                                                </td>
                                            </tr>
                                            @if (showDegerlendirme)
                                            {
                                                <tr class="RwKBtn_@itemJr.DonemProjesiJuriID" style="border-top:1px solid;">
                                                    <td class="CaptionTd"></td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd" style="padding-top:5px;">
                                                        <span class="label label-primary" style="cursor:pointer;font-size:9pt;" onclick="DonemProjesiDegerlendir('@Model.UniqueID','@itemJr.UniqueID')"><i class="fa fa-save"></i> Değerlendirmeyi Kaydet</span>
                                                    </td>
                                                </tr>
                                            }
                                        </table>
                                    </td>
                                </tr>

                            </table>

                        </div>
                    </td>
                </tr>
            </table>
        }
        else
        {
            <br />
            <span style="color:green;font-size:12pt;">  <b>@itemJr.DegerlendirmeIslemTarihi.Value.ToFormatDateAndTime()</b>  tarihinde Dönem Projesi değerlendirmeniz başarıyla gerçekleşmiştir.</span>
            <br />
            <br />
        }
    </div>


}
else
{
    <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
        <table style="width:100%;">
            <tr>
                <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-id-card-o fa-lg"></i> Öğrenci Bilgileri</td>
                <td class="clsHide" width="100" style="font-weight:bold;font-size:15pt; border-bottom:1px solid; text-align:right;">
                    <a href="javascript:void(0);" onclick="GetDetail('@Model.UniqueID')"><span class="fa fa-refresh" aria-hidden="true"></span></a>
                </td>

            </tr>
            <tr>

                <td style="padding-left:10px;text-align:left;">

                    <table style="width:100%;">
                        <tr>
                            <td class="CaptionTd" width="140">Ad Soyad</td>
                            <td class="CaptionTd" width="10">:</td>
                            <td class="ValueTd">
                                @Model.Ad @Model.Soyad (@Model.OgrenciNo)
                            </td>
                        </tr>
                        <tr>
                            <td class="CaptionTd">Öğrenim Seviyesi</td>
                            <td class="CaptionTd">:</td>
                            <td class="ValueTd">@Model.OgrenimTipAdi</td>
                        </tr>

                        <tr>
                            <td class="CaptionTd">Program</td>
                            <td class="CaptionTd">:</td>
                            <td class="ValueTd">@Model.ProgramAdi</td>
                        </tr>
                        <tr>
                            <td class="CaptionTd">Kayıt Tarihi</td>
                            <td class="CaptionTd">:</td>
                            <td class="ValueTd">@Model.KayitDonemi , @Model.KayitTarihi.ToFormatDate()</td>
                        </tr>
                    </table>
                </td>
                <td class="clsHide" width="100" style="text-align:center;">
                    <img src="@(Model.ResimAdi.ToKullaniciResim())" style="width:90px;height:90px;" class="img-circle img-thumbnail">
                </td>
            </tr>

        </table>
    </div>
    <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:0px;padding:6px 10px;">
        <table style="width:100%;">
            <tr>
                <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-list fa-lg"></i> Dönem Projesi Sınavı Başvuruları</td>
                <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
                    @if ((formOlusturmaYetki || isOgrenci) && Model.IsYeniBasvuruYapilabilir)
                    {
                        <span class="label label-info" style="cursor:pointer;" onclick="YeniBasvuruDuyuruKontrol2('@Model.UniqueID');"><i class="fa fa-plus"></i> Yeni Dönem Projesi Sınavı Başvurusu Oluştur</span>
                    }
                </td>

            </tr>
            <tr>
                <td colspan="2" style="padding-left:10px;text-align:left;">
                    @if (Model.DonemProjesiBasvurus.Any() == false)
                    {
                        <table style="width:100%;table-layout:fixed;">
                            <tr>
                                <td style="color:maroon;font-size:13pt; text-align:center;height:250px;">Herhangi bir dönem projesi başvurusu bulunamadı</td>
                            </tr>
                        </table>
                    }
                    else
                    {
                        int inxRw = 0;

                        <table class="table">
                            <tr>
                                <th width="40"></th>
                                <th width="170">Başvuru Tarihi</th>
                                <th>Başvuru Durumu</th>
                                <th width="120"></th>
                            </tr>
                            @foreach (var item in Model.DonemProjesiBasvurus)
                            {
                                inxRw++;
                                bool showRow = inxRw == 1 || Model.DegerlendirenUniqueID.HasValue && item.DonemProjesiJurileris.Any(a => a.UniqueID == Model.DegerlendirenUniqueID);
                                var srTalebiYapildi = item.SRModel != null;

                                <tr>
                                    <td>
                                        @if (!Model.DegerlendirenUniqueID.HasValue)
                                        {
                                            <ul class="panel-controls">
                                                <li id="iShow_Rpr_@item.DonemProjesiBasvuruID" onclick="ShowDetailY('Rpr_@item.DonemProjesiBasvuruID')">
                                                    <a href="javascript:void(0)"><span class="fa fa-angle-@(showRow ? "up" : "down")"></span> </a>
                                                </li>
                                            </ul>
                                        }
                                    </td>
                                    <td>@item.DonemProjesiDurumDto.ToDpBasvuruDonemView()</td>
                                    <td>
                                        @item.DonemProjesiDurumDto.ToDpBasvuruDurumView()
                                    </td>
                                    <td>
                                        @if (inxRw == 1 && formOlusturmaYetki && item.DonemProjesiDurumID < DonemProjesiDurumEnum.YurutucuOnaySureci && !item.DonemProjesiEnstituOnayDurumID.HasValue)
                                        {
                                            <a href="javascript:void(0)" onclick="GetDonemProjesiBasvuruFormu('@Model.UniqueID','@item.UniqueID')"><i style="font-size:11pt;" class="fa fa-edit" data-original-title="Düzelt"></i> Düzelt</a>
                                            <a href="javascript:void(0)" onclick="BasvuruFormuSil('@Model.UniqueID','@item.UniqueID','@item.BasvuruTarihi.ToFormatDateAndTime()')"><i style="font-size:11pt;" class="glyphicon glyphicon-trash" title="Başvuru Formunu Sil"></i> Sil</a>

                                        }
                                    </td>
                                </tr>
                                <tr class="MainRow2 cls-Rpr_@item.DonemProjesiBasvuruID" style="@(showRow ? "" : "display:none;")">
                                    <td></td>
                                    <td colspan="5">

                                        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
                                            <table style="width:100%;">
                                                <tr>
                                                    <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg"></i> Dönem Projesi & Başvuru Bilgileri</td>
                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd" width="160">Proje Yürütücüsü</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td class="ValueTd">
                                                        @if ((isDanismani || degerlendirmeDuzeltmeYetki || enstituBasvuruOnayYetkisi || formOlusturmaYetki || isOgrenci || eykYaGondermeYetkisi))
                                                        {
                                                            <a href="javascript:void(0)" onclick="DetayGor('@item.TezDanismaniUserKey','#kulPnl')"><i class="fa fa-graduation-cap"></i> @item.DanismanAdi</a>
                                                        }
                                                        else
                                                        {
                                                            @item.DanismanAdi
                                                        }
                                                    </td>

                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd" width="160">Proje Başlığı</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td class="ValueTd">@item.ProjeBasligi</td>
                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd">Proje Özeti</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        <div style="max-height:80px;overflow:auto;">@item.ProjeOzeti</div>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd">Başvuru Dönem No</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">@(item.OkuduguDonemNo+". Dönem")</td>
                                                </tr>
                                                @if (item.DonemProjesiJurileris.Any(a => a.IsTezDanismani && a.DonemProjesiJuriOnayDurumID == DonemProjesiJuriOnayDurumEnum.Basarili))
                                                {
                                                    <tr>
                                                        <td class="CaptionTd">En Fazla Tek Kaynak Oranı</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">%@item.TekKaynakOrani</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="CaptionTd">Toplam Kaynak Oranı</td>
                                                        <td class="CaptionTd">:</td>
