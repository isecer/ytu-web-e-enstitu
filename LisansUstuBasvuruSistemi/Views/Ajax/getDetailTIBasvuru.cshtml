                                                                        <option></option>
                                                                        <option value="true" @(itemJr.IsTezIzlemeRaporuAltAlanUygun == true ? "selected" : "")>Uyumlu</option>
                                                                        <option value="false" @(itemJr.IsTezIzlemeRaporuAltAlanUygun == false ? "selected" : "")>Uyumlu Değil</option>
                                                                    </select>
                                                                }
                                                                else
