                                <span class="label label-info" id="YeniRaporBtn_@Model.TIBasvuruID" style="cursor:pointer;" onclick="GetTIAraRaporFormu(@Model.TIBasvuruID);"><i class="fa fa-plus"></i> Yeni Rapor Oluştur</span>
                            }
