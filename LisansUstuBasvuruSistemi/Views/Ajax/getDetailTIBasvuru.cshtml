                                                                    </table>
                                                                }
                                                                else if (item.TIBasvuruAraRaporDurumID <= TiAraRaporDurumuEnum.DegerlendirmeSureciBaslatildi)
                                                                {
                                                                    <table style="width:100%;table-layout:fixed;">
                                                                        <tr>
                                                                            <td style="color:maroon;font-size:13pt; text-align:center;height:80px;">Komite Üyelerinin Değerlendirmesi Henüz Tamamlanmadı</td>
                                                                        </tr>
                                                                    </table>
                                                                }
                                                                else
                                                                {
                                                                    var basariliCount = item.TIBasvuruAraRaporKomites.Count(c => c.IsBasarili != null && c.IsBasarili.Value);
                                                                    var basarisizCount = item.TIBasvuruAraRaporKomites.Count(c => c.IsBasarili != null && !c.IsBasarili.Value);
                                                                    bool isbasarili = basariliCount > basarisizCount;
                                                                    bool isOyBirligiOrCoklugu = (isbasarili ? basariliCount : basarisizCount) == item.TIBasvuruAraRaporKomites.Count;


                                                                    <table style="width:350px; font-size:12pt;margin:5px auto; color:@(isbasarili ? "green" : "maroon")">
                                                                        <tr>
                                                                            <td width="140" style="text-align:left;">Oy Birliği İle</td>
                                                                            <td width="2"></td>
                                                                            <td style="text-align:left;"><span class="@(isOyBirligiOrCoklugu ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                            <td width="90" style="text-align:left;">Başarılı</td>
                                                                            <td width="2"></td>
                                                                            <td style="text-align:left"><span class="@(isbasarili ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                        </tr>
                                                                        <tr>
                                                                            <td style="text-align:left;">Oy Çokluğu İle</td>
                                                                            <td></td>
                                                                            <td style="text-align:left;"><span class="@(!isOyBirligiOrCoklugu ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                            <td style="text-align:left;">Başarısız</td>
                                                                            <td></td>
                                                                            <td style="text-align:left"><span class="@(!isbasarili ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                        </tr>


                                                                    </table>
                                                                }
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </table>

                        }
                    </td>

                </tr>

            </table>
        </div>
    }
</div>

<script>
    onSpecialCharacterBlockerLoaded();
    const inputElementsTr = document.querySelectorAll('.UpperTextTr,.UpperTextEn');
    inputElementsTr.forEach(inputElement => {
        inputElement.addEventListener('input', convertToTrOrEnUpperCase);
        convertToTrOrEnUpperCase({ target: inputElement });
    });
</script>