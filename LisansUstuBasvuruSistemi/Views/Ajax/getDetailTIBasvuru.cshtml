                                        inxRw++;
                                        bool ShowRow = !IsDelete && (inxRw == 1);
                                        if (Model.DegerlendirenUniqueID.HasValue && item.TIBasvuruAraRaporKomites.Any(a => a.UniqueID == Model.DegerlendirenUniqueID)) { ShowRow = true; }
