    bool FormOlusturmaYetki = (DegerlendirmeYetki || DegerlendirmeDuzeltmeYetki || IsDanismani || Model.KullaniciID == UserIdentity.Current.Id);

}
<style>

    .CaptionTd {
        font-weight: bold;
        font-size: 9pt;
        margin: 0px;
    }

    .ValueTd {
