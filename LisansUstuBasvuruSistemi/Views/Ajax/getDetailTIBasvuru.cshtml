                                                                    <option value="true" @(itemJr.IsBasarili == true ? "selected" : "")>Başarılı</option>
                                                                    <option value="false" @(itemJr.IsBasarili == false ? "selected" : "")>Başarısız</option>
                                                                </select>
                                                            }
                                                            else
                                                            {
                                                                var Uygun = itemJr.IsBasarili;
                                                                var Text = (Uygun.HasValue ? (Uygun.Value ? "Başarılı" : "Başarısız") : "Henüz Değerlendirilmedi");
                                                                <span style="font-size:10pt;">@Text</span>
                                                            }
