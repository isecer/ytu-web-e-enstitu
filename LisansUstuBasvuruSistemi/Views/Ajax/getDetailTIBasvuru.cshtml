                                                                <select style="width:100px;" onchange="if($(this).val()!=''){ $('.RwJAck_@itemJr.TIBasvuruAraRaporKomiteID').removeClass('hide'); }else{$('.RwJAck_@itemJr.TIBasvuruAraRaporKomiteID').addClass('hide');}" id="IsBasarili_@itemJr.UniqueID">
