                                                                            </tr>
                                                                        </table>
                                                                    }
                                                                    else
                                                                    {
                                                                        var BasariliCount = item.TIBasvuruAraRaporKomites.Count(c => c.IsBasarili.Value);
                                                                        var BasarisizCount = item.TIBasvuruAraRaporKomites.Count(c => !c.IsBasarili.Value);
                                                                        bool Isbasarili = BasariliCount > BasarisizCount;
                                                                        bool IsOyBirligiOrCoklugu = (Isbasarili ? BasariliCount : BasarisizCount) == item.TIBasvuruAraRaporKomites.Count;


                                                                        <table style="width:350px; font-size:12pt;margin:5px auto; color:@(Isbasarili ? "green" : "maroon")">
                                                                            <tr>
                                                                                <td width="140" style="text-align:left;">Oy Birliği İle</td>
                                                                                <td width="2"></td>
                                                                                <td style="text-align:left;"><span class="@(IsOyBirligiOrCoklugu ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                                <td width="90" style="text-align:left;">Başarılı</td>
                                                                                <td width="2"></td>
                                                                                <td style="text-align:left"><span class="@(Isbasarili ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                            </tr>
                                                                            <tr>
                                                                                <td style="text-align:left;">Oy Çokluğu İle</td>
                                                                                <td></td>
                                                                                <td style="text-align:left;"><span class="@(!IsOyBirligiOrCoklugu ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                                <td style="text-align:left;">Başarısız</td>
                                                                                <td></td>
                                                                                <td style="text-align:left"><span class="@(!Isbasarili ? "fa fa-check-square-o fa-lg" : "fa fa-square-o fa-lg")"></span></td>
                                                                            </tr>


                                                                        </table>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </table>

                            }
                        </td>

                    </tr>

                </table>
            </div>
        }


    </div>
</div>
<script>
    $(function () {
        $('.tooltips').tooltip();
        jQuery('._popover').popover({ trigger: 'hover' });

    })

</script>