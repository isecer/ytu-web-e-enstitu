@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.Helpers
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@using LisansUstuBasvuruSistemi.Utilities.SystemSetting
@model TiBasvuruDetayDto
@{

    Layout = null;

    var isDanismani = Model.TezDanismanID == UserIdentity.Current.Id;
    var isOgrenci = Model.KullaniciID == UserIdentity.Current.Id;
    var toplantiYetki = RoleNames.TiToplantiTalebiYap.InRoleCurrent();
    var degerlendirmeYetki = RoleNames.TiTezDegerlendirmeYap.InRoleCurrent();
    var degerlendirmeDuzeltmeYetki = RoleNames.TiTezDegerlendirmeDuzeltme.InRoleCurrent();
    var formOlusturmaYetki = (degerlendirmeYetki || degerlendirmeDuzeltmeYetki || isDanismani || Model.KullaniciID == UserIdentity.Current.Id);

}
<style>

    .CaptionTd {
        font-weight: bold;
        font-size: 9pt;
        margin: 0px;
    }

    .ValueTd {
        font-size: 9pt;
        margin: 0px;
        text-align: left;
    }
</style>
<div class="panel" style="border:none;" id="bsvrDet_@Model.TIBasvuruID">

    @if (Model.DegerlendirenUniqueID.HasValue)
    {
        var item = Model.TIBasvuruAraRaporList.First(p => p.TIBasvuruAraRaporKomites.Any(a => a.UniqueID == Model.DegerlendirenUniqueID));
        var itemJr = item.TIBasvuruAraRaporKomites.First(a => a.UniqueID == Model.DegerlendirenUniqueID);
        var showDegerlendirme = !itemJr.IsBasarili.HasValue;
        var isDegerlendirmeAcik = showDegerlendirme || degerlendirmeDuzeltmeYetki;
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray;padding:6px 10px;margin-bottom:0px;margin-top:0px; min-height:20px;">
            @if (isDegerlendirmeAcik)
            {
                <table style="width:100%;">
                    <tr>
                        <td style="font-weight:bold;font-size:11pt;"><i class="fa fa-check fa-lg"></i> Tez İzleme Komite Üyesi Rapor Değerlendirme</td>
                        <td class="clsHide" width="100" style="font-weight:bold;font-size:15pt; text-align:right;">
                            <a href="javascript:void(0);" onclick="GetDetail('@Model.TIBasvuruID')" title="Ekranı Yenile"><span class="fa fa-refresh" aria-hidden="true"></span></a>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding-left:10px;text-align:left;">
                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                <table style="width:100%;">
                                    <tr>
                                        <td colspan="2" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-id-card-o fa-lg"></i> Öğrenci Bilgileri</td>

                                    </tr>
                                    <tr>
                                        <td style="padding-left:10px;text-align:left;">

                                            <table style="table-layout:fixed;">
                                                <tr>
                                                    <td class="CaptionTd" width="140">Ad Soyad</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td class="ValueTd">
                                                        @Model.Ad @Model.Soyad (@Model.OgrenciNo)
                                                    </td>
                                                </tr>
                                                @if (!Model.DegerlendirenUniqueID.HasValue)
                                                {
                                                    <tr>
                                                        <td class="CaptionTd">Öğrenim Seviyesi</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">@Model.OgrenimTipAdi</td>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td class="CaptionTd">Program</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">@Model.AnabilimdaliAdi / @Model.ProgramAdi</td>
                                                </tr>
                                                @if (!Model.DegerlendirenUniqueID.HasValue)
                                                {
                                                    <tr>
                                                        <td class="CaptionTd">Kayıt Tarihi</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">@Model.KayitDonemi , @Model.KayitTarihi.ToFormatDate()</td>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td class="CaptionTd">
                                                        Danışman
                                                    </td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        @if ((isDanismani || degerlendirmeYetki) && Model.TezDanismanID.HasValue)
                                                        {
                                                            <a href="javascript:void(0)" onclick="DetayGor('@Model.TezDanismaniUserKey','#kulPnl')"><i class="fa fa-graduation-cap"></i> @Model.TezDanismanBilgiEslesen</a>
                                                        }
                                                        else
                                                        {
                                                            @Model.TezDanismanBilgiEslesen
                                                        }
                                                    </td>

                                                </tr>
                                            </table>
                                        </td>
                                        <td class="clsHide" width="100" style="text-align:center;">
                                            <img src="@(Model.ResimAdi.ToKullaniciResim())" style="width:70px;height:70px;" class="img-circle img-thumbnail">
                                        </td>
                                    </tr>

                                </table>
                            </div>
                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                <table style="width:100%;">
                                    <tbody>
                                        <tr>
                                            <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-group fa-lg"></i> Komite Üyesi Bilgileri</td>
                                        </tr>
                                        <tr>
                                            <td style="padding-left:10px;text-align:left;">
                                                <table style="width:100%;">
                                                    <tr>
                                                        <td class="CaptionTd" width="140">Adı Soyadı</td>
                                                        <td class="CaptionTd" width="10">:</td>
                                                        <td class="ValueTd">@itemJr.UnvanAdi @itemJr.AdSoyad</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="CaptionTd" style="font-weight:bold;">E-Posta Adresi</td>
                                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                                        <td class="ValueTd">@itemJr.EMail</td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>

                                    </tbody>
                                </table>
                            </div>
                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                <table style="width:100%;">
                                    <tr>
                                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg"></i> Tez & Ara Rapor Bilgileri</td>
                                    </tr>
                                    <tr>
                                        <td style="padding-left:10px;text-align:left;">
                                            <table style="table-layout:fixed;">
                                                <tr>
                                                    <td class="CaptionTd" width="140">Tezin Mevcut Başlığı</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td class="ValueTd">@item.TezBaslikTr</td>
                                                </tr>
                                              
                                                    <tr>
                                                        <td class="CaptionTd">Tez Başlığı Değişti mi?</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">@(item.IsTezBasligiDegisti?"Evet":"Hayır")</td>
                                                    </tr>
                                                
                                                @if (item.IsTezBasligiDegisti)
                                                {
                                                    <tr>
                                                        <td class="CaptionTd">Yeni Tez Başlığı Türkçe</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">@item.YeniTezBaslikTr</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="CaptionTd">Yeni Tez Başlığı Çevirisi</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">@item.YeniTezBaslikEn</td>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td class="CaptionTd">Rapor Sayısı</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        @(item.AraRaporSayisi + ". Rapor")

                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd">Rapor Dönemi</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        @item.DonemAdi
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="CaptionTd">Rapor Dosyası</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd"><a href="javascript:void(0);" onclick="PopupCenter('@Url.CustomUrlContent(item.TICalismaRaporDosyaYolu)','@item.TICalismaRaporDosyaAdi',800,600);"><i class="fa fa-file-pdf-o"></i> @item.TICalismaRaporDosyaAdi</a></td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>

                                </table>
                            </div>

                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                                <table style="width:100%;">
                                    <tr>
                                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;">
                                            <i style="font-size:16pt;" class="glyphicon glyphicon-info-sign" aria-hidden="true"></i> Komite Üyesi Rapor Değerlendirmesi
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding-left:10px;text-align:left;">
                                            <table style="width:100%;">

                                                <tr>
                                                    <td class="CaptionTd" width="275">Tez İzleme ile Tez Önerisi Uyumluluğu</td>
                                                    <td class="CaptionTd" width="10">:</td>
                                                    <td class="ValueTd">
                                                        @if (showDegerlendirme)
                                                        {
                                                            <select style="width:100px;" id="IsTezIzlemeRaporuTezOnerisiUygun_@itemJr.UniqueID">
                                                                <option></option>
                                                                <option value="true" @(itemJr.IsTezIzlemeRaporuTezOnerisiUygun == true ? "selected" : "")>Uyumlu</option>
                                                                <option value="false" @(itemJr.IsTezIzlemeRaporuTezOnerisiUygun == false ? "selected" : "")>Uyumlu Değil</option>
                                                            </select>
                                                        }
                                                        else
                                                        {
                                                            var text = (itemJr.IsTezIzlemeRaporuTezOnerisiUygun.HasValue ? (itemJr.IsTezIzlemeRaporuTezOnerisiUygun.Value ? "Uyumlu" : "Uyumlu Değil") : "Henüz Değerlendirilmedi");
                                                            <span style="font-size:10pt;">@text</span>
                                                        }
                                                    </td>
                                                </tr>
                                                @if (item.IsYokDrBursiyeriVar && (degerlendirmeYetki || degerlendirmeDuzeltmeYetki) && itemJr.JuriTipAdi == "TezDanismani")
                                                {

                                                    <tr>
                                                        <td class="CaptionTd">Tez İzleme Raporu ile 100/2000 YÖK Bursu Alt Alan Uyumlu mu?</td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd">
                                                            @if (showDegerlendirme)
                                                            {
                                                                <select style="width:100px;" id="IsTezIzlemeRaporuAltAlanUygun_@itemJr.UniqueID">
                                                                    <option></option>
                                                                    <option value="true" @(itemJr.IsTezIzlemeRaporuAltAlanUygun == true ? "selected" : "")>Uyumlu</option>
                                                                    <option value="false" @(itemJr.IsTezIzlemeRaporuAltAlanUygun == false ? "selected" : "")>Uyumlu Değil</option>
                                                                </select>
                                                            }
                                                            else
                                                            {
                                                                var text = (itemJr.IsTezIzlemeRaporuAltAlanUygun.HasValue ? (itemJr.IsTezIzlemeRaporuAltAlanUygun.Value ? "Uyumlu" : "Uyumlu Değil") : "Henüz Değerlendirilmedi");
                                                                <span style="font-size:10pt;" aria-hidden="true">@text</span>

                                                            }
                                                        </td>
                                                    </tr>

                                                }

                                                <tr>
                                                    <td class="CaptionTd">Tez İzleme Raporunun Değerlendirme Sonucu</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        @if (showDegerlendirme)
                                                        {
                                                            <select style="width:100px;" onchange="if($(this).val()!=''){ $('.RwJAck_@itemJr.TIBasvuruAraRaporKomiteID').removeClass('hide'); }else{$('.RwJAck_@itemJr.TIBasvuruAraRaporKomiteID').addClass('hide');}" id="IsBasarili_@itemJr.UniqueID">
                                                                <option></option>
                                                                <option value="true" @(itemJr.IsBasarili == true ? "selected" : "")>Başarılı</option>
                                                                <option value="false" @(itemJr.IsBasarili == false ? "selected" : "")>Başarısız</option>
                                                            </select>
                                                        }
                                                        else
                                                        {
                                                            var text = (itemJr.IsBasarili.HasValue ? (itemJr.IsBasarili.Value ? "Başarılı" : "Başarısız") : "Henüz Değerlendirilmedi");
                                                            <span style="font-size:10pt;">@text</span>
                                                        }
                                                    </td>
                                                </tr>
                                                <tr class="RwJAck_@itemJr.TIBasvuruAraRaporKomiteID @(itemJr.IsBasarili.HasValue && !itemJr.Aciklama.IsNullOrWhiteSpace() ? "" : "hide")">
                                                    <td colspan="3">
                                                        <table style="width:100%;margin-top:5px;">
                                                            <tr>
                                                                <td class="CaptionTd"></td>
                                                            </tr>
                                                            <tr>
                                                                <td class="ValueTd">
                                                                    @if (showDegerlendirme)
                                                                    {
                                                                        <textarea placeholder="Tez İzleme Raporu Değerlendirme Açıklaması" id="Aciklama_@itemJr.UniqueID" maxlength="2048" style="min-height:140px;resize:vertical;border:1px solid;" class="form-control">@itemJr.Aciklama</textarea>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span style="font-size:10pt;">@itemJr.Aciklama</span>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>
                                                @if (showDegerlendirme)
                                                {
                                                    <tr class="RwKBtn_@itemJr.TIBasvuruAraRaporKomiteID" style="border-top:1px solid;">
                                                        <td class="CaptionTd"></td>
                                                        <td class="CaptionTd">:</td>
                                                        <td class="ValueTd" style="padding-top:5px;">
                                                            <span class="label label-primary" style="cursor:pointer;font-size:9pt;" onclick="AraRaporDegerlendir('@itemJr.UniqueID','@item.IsYokDrBursiyeriVar.ToString().ToLower()',@item.TIBasvuruID)"><i class="fa fa-save"></i> Değerlendirmeyi Kaydet</span>
                                                        </td>
                                                    </tr>
                                                }
                                            </table>
                                        </td>
                                    </tr>

                                </table>

                            </div>
                        </td>
                    </tr>
                </table>
            }
            else
            {
                <br />
                <span style="color:green;font-size:12pt;">  <b>@itemJr.DegerlendirmeIslemTarihi.Value.ToFormatDateAndTime()</b>  tarihinde Tez İzleme Raporu değerlendirmeniz başarıyla gerçekleşmiştir.</span>
                <br />
                <br />
            }
        </div>


    }
    else
    {
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
            <table style="width:100%;">
                <tr>
                    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-id-card-o fa-lg"></i> Öğrenci Bilgileri</td>
                    <td class="clsHide" width="100" style="font-weight:bold;font-size:15pt; border-bottom:1px solid; text-align:right;">
                        <a href="javascript:void(0);" onclick="GetDetail('@Model.TIBasvuruID')"><span class="fa fa-refresh" aria-hidden="true"></span></a>
                    </td>

                </tr>
                <tr>

                    <td style="padding-left:10px;text-align:left;">

                        <table style="width:100%;">
                            <tr>
                                <td class="CaptionTd" width="140">Ad Soyad</td>
                                <td class="CaptionTd" width="10">:</td>
                                <td class="ValueTd">
                                    @Model.Ad @Model.Soyad (@Model.OgrenciNo)
                                </td>
                            </tr>
                            @if (!Model.DegerlendirenUniqueID.HasValue)
                            {
                                <tr>
                                    <td class="CaptionTd">Öğrenim Seviyesi</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">@Model.OgrenimTipAdi</td>
                                </tr>
                            }
                            <tr>
                                <td class="CaptionTd">Program</td>
                                <td class="CaptionTd">:</td>
                                <td class="ValueTd">@Model.AnabilimdaliAdi / @Model.ProgramAdi</td>
                            </tr>
                            @if (!Model.DegerlendirenUniqueID.HasValue)
                            {
                                <tr>
                                    <td class="CaptionTd">Kayıt Tarihi</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">@Model.KayitDonemi , @Model.KayitTarihi.ToFormatDate()</td>
                                </tr>
                            }
                            @if (Model.TezDanismanID.HasValue)
                            {
                                <tr>
                                    <td class="CaptionTd">
                                        Danışman
                                    </td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">
                                        @if ((isDanismani || degerlendirmeYetki) && Model.TezDanismanID.HasValue)
                                        {
                                            <a href="javascript:void(0)" onclick="DetayGor('@Model.TezDanismaniUserKey','#kulPnl')"><i class="fa fa-graduation-cap"></i> @Model.TezDanismanBilgiEslesen</a>
                                        }
                                        else
                                        {
                                            @Model.TezDanismanBilgiEslesen
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    </td>
                    <td class="clsHide" width="100" style="text-align:center;">
                        <img src="@(Model.ResimAdi.ToKullaniciResim())" style="width:90px;height:90px;" class="img-circle img-thumbnail">
                    </td>
                </tr>

            </table>
        </div>
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:0px;padding:6px 10px;">
            <table style="width:100%;">
                <tr>
                    <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-list fa-lg"></i> Tez İzleme Raporları</td>
                    <td width="100" style="font-size:11pt;border-bottom:1px solid; text-align:right;padding-bottom:2px;">
                        @if (formOlusturmaYetki)
                        {
                            <span class="label label-info" id="YeniRaporBtn_@Model.TIBasvuruID" style="cursor:pointer;" onclick="YeniBasvuruDuyuruKontrol2(@Model.TIBasvuruID);"><i class="fa fa-plus"></i> Yeni Rapor Oluştur</span>
                        }
                    </td>

                </tr>
                <tr>
                    <td colspan="2" style="padding-left:10px;text-align:left;">
                        @if (Model.TIBasvuruAraRaporList.Any() == false)
                        {
                            <table style="width:100%;table-layout:fixed;">
                                <tr>
                                    <td style="color:maroon;font-size:13pt; text-align:center;height:250px;">Herhangi bir Rapor girişi bulunamadı</td>
                                </tr>
                            </table>
                        }
                        else
                        {
                            int inxRw = 0;
                            <table class="table">
                                <tr>
                                    <th width="40"></th>
                                    <th width="90">Rapor Sayısı</th>
                                    <th width="120">Rapor Dönemi</th>
                                    <th class="clsHide" width="120">Oluşturma Tarihi</th>
                                    <th>Rapor Durumu</th>
                                    <th width="120"></th>
                                </tr>
                                @foreach (var item in Model.TIBasvuruAraRaporList)
                                {
                                    inxRw++;
                                    bool showRow = inxRw == 1 || Model.DegerlendirenUniqueID.HasValue && item.TIBasvuruAraRaporKomites.Any(a => a.UniqueID == Model.DegerlendirenUniqueID);
                                    var srTalebiYapildi = item.SRModel != null;
                                    <tr>
                                        <td>
                                            @if (!Model.DegerlendirenUniqueID.HasValue)
                                            {
                                                <ul class="panel-controls">
                                                    <li id="iShow_Rpr_@item.TIBasvuruAraRaporID" onclick="ShowDetailY('Rpr_@item.TIBasvuruAraRaporID')">
                                                        <a href="javascript:void(0)"><span class="fa fa-angle-@(showRow ? "up" : "down")"></span> </a>
                                                    </li>
                                                </ul>
                                            }
                                        </td>
                                        <td>@(item.AraRaporSayisi + ". Rapor")</td>
                                        <td>@item.DonemAdi</td>
                                        <td class="clsHide">@item.RaporTarihi</td>
                                        <td>
                                            @item.TIBasvuruAraaRaporDurumAdi
                                        </td>
                                        <td>
                                            @if (inxRw == 1 && formOlusturmaYetki && item.TIBasvuruAraRaporDurumID < TiAraRaporDurumuEnum.DegerlendirmeSureciBaslatildi)
                                            {
                                                <a href="javascript:void(0)" onclick="GetTIAraRaporFormu(@item.TIBasvuruID,@item.TIBasvuruAraRaporID)"><i style="font-size:11pt;" class="fa fa-edit" data-original-title="Raporu Düzelt"></i> Düzelt</a>

                                                <a href="javascript:void(0)" onclick="silDetay(this,'@item.TIBasvuruID',@item.TIBasvuruAraRaporID,'@(item.AraRaporSayisi + ". Rapor")')"><i style="font-size:11pt;" class="glyphicon glyphicon-trash" title="Raporu Sil"></i> Sil</a>

                                            }
                                        </td>
                                    </tr>
                                    <tr class="MainRow2 cls-Rpr_@item.TIBasvuruAraRaporID" style="@(showRow ? "" : "display:none;")">
                                        <td></td>
                                        <td colspan="5">

                                            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;">
                                                <table style="width:100%;">
                                                    <tr>
                                                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg"></i> Tez Bilgileri</td>
                                                    </tr>
                                                    <tr>
                                                        <td class="CaptionTd" width="160">Tez Dili</td>
                                                        <td class="CaptionTd" width="10">:</td>
                                                        <td class="ValueTd">@(item.IsTezDiliTr ? "Türkçe" : "İngilizce")</td>
