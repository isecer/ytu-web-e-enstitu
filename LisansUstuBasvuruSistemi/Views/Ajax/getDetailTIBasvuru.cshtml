                                                                    var Text = (Uygun.HasValue ? (Uygun.Value ? "Uyumlu" : "Uyumlu Değil") : "Henüz Değerlendirilmedi");
                                                                    <span style="font-size:10pt;" aria-hidden="true">@Text</span>

                                                                }
