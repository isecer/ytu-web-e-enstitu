@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.Helpers
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model MezuniyetBasvuruDetayDto
@{
    Layout = null;

    var kayitYetki = RoleNames.MezuniyetGelenBasvurularKayit.InRoleCurrent();
    var tdKayitYetki = kayitYetki || RoleNames.MezuniyetGelenBasvurularTezKontrol.InRoleCurrent();
    var isKendiBasvuruSu = Model.KullaniciID == UserIdentity.Current.Id;

    var tbName = TabAdiEnum.MezuniyetBasvurulariTn + "-" + (Model.IsDelete ? Model.MezuniyetBasvurulariID.ToString() + "_cp" : Model.MezuniyetBasvurulariID.ToString());
    var isTezDanisman = Model.TezDanismanID == UserIdentity.Current.Id;
    var sonucGirisSureciAktif = (Model.SonucGirisSureciAktif || kayitYetki);// && Model.MezuniyetJuriOneriFormlaris.All(a => a.EYKYaGonderildi != true);
    var yayinInfos = MezuniyetBus.YayinKontrol(Model.MezuniyetSurecID, Model.KullaniciID, Model.MezuniyetBasvurulariID);
}
<div class="tab-pane @(Model.SelectedTabIndex==1?"active":"") " id="@tbName-1">
    <div class="col-md-12">
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg"></i> Tez Bilgisi</td>
                    </tr>
                    <tr>
                        <td style="padding-left:10px;text-align:left;">
                            <table style="width:100%;">
                                <tr>
                                    <td class="CaptionTd" width="220">Tez Dili</td>
                                    <td class="CaptionTd" width="10">:</td>
                                    <td class="ValueTd">@(Model.IsTezDiliTr.HasValue ? (Model.IsTezDiliTr == true ? "Türkçe" : "İngilizce") : "")</td>
                                </tr>
                                <tr>
                                    <td class="CaptionTd">Tez Başlığı (Türkçe)</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">@Model.TezBaslikTr</td>
                                </tr>
                                <tr>
                                    <td class="CaptionTd">Tez Başlığı (İngilizce)</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">@Model.TezBaslikEn</td>
                                </tr>
                                <tr>
                                    <td class="CaptionTd">Danışman Adı</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">@Model.TezDanismanAdi</td>
                                </tr>
                                @if (!Model.TezEsDanismanAdi.IsNullOrWhiteSpace())
                                {
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Tez Eş Danışmanı</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">@Model.TezEsDanismanAdi @(Model.TezEsDanismanEMail.IsNullOrWhiteSpace() ? "" : "(" + Model.TezEsDanismanEMail + ")")</td>
                                    </tr>
                                }
                                <tr>
                                    <td class="CaptionTd">Tez Özeti (Türkçe)</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">
                                        <div style="max-height:80px;overflow:auto;">
                                            @Model.TezOzet
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="CaptionTd">Tez Özeti (İngilizce)</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">
                                        <div style="max-height:80px;overflow:auto;">
                                            @Model.TezAbstract
                                        </div>
                                        <br />
                                    </td>
                                </tr>

                                <tr>
                                    <td class="CaptionTd">Tez Özeti Anahtar Kelimeler (Türkçe)</td>
                                    <td class="CaptionTd">:</td>
                                    <td class="ValueTd">
                                        @Model.OzetAnahtarKelimeler
                                    </td>
                                </tr>
                                @if (Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.KabulEdildi)
                                {
                                    if ((Model.IsTekKaynakOraniGirisiYapilacak || Model.IsToplamKaynakOraniGirisiYapilacak) && (Model.TekKaynakOrani.HasValue || Model.SonTekKaynakOrani.HasValue || Model.ToplamKaynakOrani.HasValue || Model.SonToplamKaynakOrani.HasValue))
                                    {
                                        <tr>
                                            <td class="CaptionTd">Tez Benzerlik Oranları</td>
                                            <td class="CaptionTd">:</td>
                                            <td class="ValueTd">
                                                <table class="table table-hover" style="margin:0px;">
                                                    <tr class="info">
                                                        <th width="190"></th>
                                                        @if (Model.TekKaynakOrani.HasValue || Model.ToplamKaynakOrani.HasValue)
                                                        {
                                                            <th>İlk Kontrol</th>
                                                        }
                                                        @if (Model.SonTekKaynakOrani.HasValue || Model.SonToplamKaynakOrani.HasValue)
                                                        {
                                                            <th>Son Kontrol</th>
                                                        }
                                                    </tr>
                                                    @if (Model.IsTekKaynakOraniGirisiYapilacak && (Model.TekKaynakOrani.HasValue || Model.SonTekKaynakOrani.HasValue))
                                                    {
                                                        <tr>
                                                            <td>Tek Kaynak Benzerlik Oranı</td>
                                                            @if (Model.TekKaynakOrani.HasValue)
                                                            {
                                                                <td>%@Model.TekKaynakOrani</td>
                                                            }
                                                            @if (Model.SonTekKaynakOrani.HasValue)
                                                            {
                                                                <td>
                                                                    %@Model.SonTekKaynakOrani
                                                                </td>
                                                            }
                                                        </tr>
                                                    }
                                                    @if (Model.IsToplamKaynakOraniGirisiYapilacak && (Model.ToplamKaynakOrani.HasValue || Model.SonToplamKaynakOrani.HasValue))
                                                    {
                                                        <tr>
                                                            <td>Toplam Benzerlik Oranı</td>
                                                            @if (Model.ToplamKaynakOrani.HasValue)
                                                            {
                                                                <td>%@Model.ToplamKaynakOrani</td>
                                                            }
                                                            @if (Model.SonToplamKaynakOrani.HasValue)
                                                            {
                                                                <td>
                                                                    %@Model.SonToplamKaynakOrani
                                                                </td>
                                                            }
                                                        </tr>
                                                    }
                                                </table>
                                            </td>
                                        </tr>
                                    }
                                }

                            </table>
                        </td>
                    </tr>

                </tbody>
            </table>

        </div>

        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="glyphicon glyphicon-info-sign" style="font-size:14pt;"></i> Danışman Onayı</td>
                        <td style="font-size:9pt; border-bottom:1px solid;text-align:right;">
                            @if (!Model.DanismanImzaliFormDosyaYolu.IsNullOrWhiteSpace())
                            {
                                <a href="javascript:void(0);" class="openFl" FPath="@Url.CustomUrlContent(Model.DanismanImzaliFormDosyaYolu)" FName=" @(Model.OgrenimTipKod.IsDoktora()? "Danışman İmzalı FR-0338 (DR) Formu" : "Danışman İmzalı FR-0338 (YL) Formu")"><span class="fa fa-download" style="color: green;"></span>&nbsp;@Model.DanismanImzaliFormDosyaAdi</a>
                            }
                            else if (Model.IsDanismanOnay == true && Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.KabulEdildi)
                            {
                                <a href="javascript:void(0);" onclick="YeniDialogBB('FR-0338 Mezuniyet Tez Teslim Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipiEnum.MezuniyetTezTeslimFormu&UniqueID=@Model.RowID&IlkTeslim=true' , 'auto', 'modal-dialog modal-lg' )">
                                    <i class="fa fa-file-pdf-o"></i> FR-0338 Mezuniyet Tez Teslim Formunu İndir
                                </a>
                            }
                            else if (kayitYetki && !Model.IsDanismanOnay.HasValue && !Model.GuncellenebilirBasvuruDanismanAdi.IsNullOrWhiteSpace())
                            {
                                <a href="javascript:void(0);" onclick="DanismanDegistir(@Model.MezuniyetBasvurulariID,'@Model.GuncellenebilirBasvuruDanismanAdi')">
                                    <i class="fa fa-refresh"></i> Öğrenci Mezuniyet Başvurusu Danışmanını Güncelle
                                </a>
                                <script>
                                    function DanismanDegistir(id, danismanAdi) {

                                        Swal.fire({
                                            text: "Seçilen mezuniyet başvurusundaki Danışman bilgisini " + danismanAdi +" olarak güncellemek istiyor musunuz?",
                                            type: 'warning',
                                            icon: "question",
                                            showCancelButton: true,
                                            confirmButtonText: 'Danışmanı Güncelle',
                                            confirmButtonColor: "maroon",
                                            cancelButtonText: 'Vazgeç',
                                            showLoaderOnConfirm: true,
                                            backdrop: true,
                                            padding: '2em',
                                            backdrop: true,
                                            allowOutsideClick: false,
                                            preConfirm: function () {
                                                $('.swal2-cancel').first().text("Güncelleniyor...");
                                                return new Promise(function (resolve) {
                                                    $.ajax({
                                                        url: '@Url.Action("DanismanGuncelle", "Mezuniyet")',
                                                        data: { id },
                                                        success: function (result) {
                                                            if (result.IsSuccess) {
                                                                GetDetailx(id);
                                                            }
                                                            swal.fire({
                                                                html: result.MessageView,
                                                                icon: (result.IsSuccess ? "success" : "error"),
                                                                type: (result.IsSuccess ? "success" : "error"),
                                                                confirmButtonText: 'tamam',
                                                                padding: '2em'
                                                            });
                                                        }
                                                    });

                                                });
                                            }
                                        });

                                    }

                                </script>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding-left:10px;text-align:left;">
                            @if (!Model.YayinBilgileri.Any(a => a.Onaylandi.HasValue) && (isTezDanisman || tdKayitYetki) && (Model.MezuniyetYayinKontrolDurumID != MezuniyetYayinKontrolDurumuEnum.Taslak))
                            {
                                <table style="width:100%;">
                                    <tr>
                                        <td class="CaptionTd" width="100">Danışman Adı</td>
                                        <td class="CaptionTd" width="10">:</td>
                                        <td class="ValueTd">@Model.TezDanismanAdi</td>
                                    </tr>
                                    <tr>
                                        <td class="CaptionTd" style="font-weight:bold;">Onay Durumu</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">
                                            <select id="DanismanBasvuruOnay_@Model.MezuniyetBasvurulariID" onchange="DanOnayChange(this,@Model.MezuniyetBasvurulariID);">
                                                <option></option>
                                                <option value="true" @(Model.IsDanismanOnay == true ? "selected" : "")>Öğrenci Başvurusunu Onaylıyorum </option>
                                                <option value="false" @(Model.IsDanismanOnay == false ? "selected" : "")>Öğrenci Başvurusunu Ret Ediyorum</option>
                                            </select>
                                            <a href="javascript:void(0);" onclick="DanismanBasvuruOnayKayit(@Model.MezuniyetBasvurulariID)" class="btn btn-primary btn-xs"><i class="fa fa-save" aria-hidden="true"></i> Kaydet</a>
                                            <script>
                                                function DanOnayChange(sndr, basvuruId) {
                                                    var SndrVal = $(sndr).val();
                                                    if (SndrVal == 'false') {
                                                        $('#BasvuruDanismanOnayAciklamaRw_' + basvuruId).removeClass('hide');
                                                    }
                                                    else {
                                                        $('#BasvuruDanismanOnayAciklamaRw_' + basvuruId).addClass('hide');
                                                    }
                                                    if (SndrVal == 'true') {
                                                        $('.BasvuruDanismanOnayTaahhutRw_' + basvuruId).removeClass('hide');
                                                    }
                                                    else {
                                                        $('.BasvuruDanismanOnayTaahhutRw_' + basvuruId).addClass('hide');
                                                    }
                                                }
                                            </script>
                                        </td>
                                    </tr>
                                    <tr class="BasvuruDanismanOnayTaahhutRw_@Model.MezuniyetBasvurulariID @(Model.IsDanismanOnay == true ? "" : "hide")">
                                        <td colspan="3">
                                            <div class="tasks ui-sortable">
                                                <div class="task-item task-@(Model.IsDanismanOnay.HasValue ? "info" : "warning")" style="margin-bottom:0px;">
                                                    <div class="task-text ui-sortable-handle" style="padding-bottom: 0px; font-size: 8pt;">
                                                        <b>Taahhüt 1:</b> Aşağıda belirtilen yayınlar tezden üretilmiş olup öğrenci, kaydolduğu tarihte yürürlükte olan YTÜ Lisansüstü Eğitim ve Öğretim Yönetmeliği Senato Esaslarında belirtilen yayın şartlarını sağlamaktadır. Lisansüstü tezin bilimsel, şekilsel ve etik kurallar çerçevesinde incelenmesi sonucunda, tez savunma sınavında savunulabilir olduğu görülmüş olup öğrencinin lisansüstü tezini teslim ederek savunabileceği kanaatine varılmıştır.
                                                        <br /><br />
                                                        <b>Taahhüt 2:</b> Tez Çalışması Orijinallik Raporu Uygulama Esasları uyarınca, belirtilen azami benzerlik oranlarına göre öğrencinin lisansüstü tezi herhangi bir intihal içermemekte olup aksinin tespit edileceği muhtemel durumda tüm hukuki sorumluğu kabul ediyorum.
                                                    </div>
                                                    @if (Model.IsDanismanOnay.HasValue)
                                                    {
                                                        <div class="task-footer" style="padding-top:0pt;padding-bottom:0px; color: green;">
                                                            <div class="pull-left"><span class="fa fa-check-circle-o"></span> @Model.DanismanOnayTarihi.ToFormatDateAndTime() tarihinde @Model.TezDanismanAdi tarafından onaylandı </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr id="BasvuruDanismanOnayAciklamaRw_@Model.MezuniyetBasvurulariID" class="@(Model.IsDanismanOnay == false ? "" : "hide")">
                                        <td class="CaptionTd" style="font-weight:bold;">Açıklama</td>
                                        <td class="CaptionTd" style="font-weight:bold;">:</td>
                                        <td class="ValueTd">
                                            <textarea placeholder="Onaylanmama Sebebi" id="BasvuruDanismanOnayAciklama_@Model.MezuniyetBasvurulariID" maxlength="2048" style="min-height:140px;resize:vertical;border:1px solid;" class="form-control">@Model.DanismanOnayAciklama</textarea>
                                        </td>
                                    </tr>
                                    @if (Model.IsDanismanOnay == false)
                                    {
                                        <tr>
                                            <td class="CaptionTd" style="font-weight:bold;">@(Model.IsDanismanOnay.Value ? "Onay" : "Ret") Tarihi</td>
                                            <td class="CaptionTd" style="font-weight:bold;">:</td>
                                            <td class="ValueTd">
                                                @Model.DanismanOnayTarihi.ToFormatDateAndTime()
                                            </td>
                                        </tr>

                                    }
                                </table>
                            }
                            else
                            {
                                <table style="width:100%;">

                                    @if (Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.Taslak)
                                    {
                                        <tr>
                                            <td class="CaptionTd" width="100">Danışman Adı</td>
                                            <td class="CaptionTd" width="10">:</td>
                                            <td class="ValueTd">@Model.TezDanismanAdi</td>
                                        </tr>
                                        <tr>
                                            <td class="CaptionTd">Onay Durumu</td>
                                            <td class="CaptionTd">:</td>
                                            <td class="ValueTd">
                                                <i class="fa fa-clock-o" aria-hidden="true"></i> Başvuru Öğrenci Tarafından Henüz Onaylanmadı.
                                            </td>
                                        </tr>
                                    }
                                    else if (Model.IsDanismanOnay == true)
                                    {
                                        <tr>
                                            <td colspan="3">
                                                <div class="tasks">
                                                    <div class="task-item task-@(Model.IsDanismanOnay.HasValue ? "info" : "warning")" style="margin-bottom: 0px; cursor: auto;">
                                                        <div class="task-text" style="padding-bottom: 0px; font-size: 8pt;">
                                                            <b>Taahhüt 1:</b> Aşağıda belirtilen yayınlar tezden üretilmiş olup öğrenci, kaydolduğu tarihte yürürlükte olan YTÜ Lisansüstü Eğitim ve Öğretim Yönetmeliği Senato Esaslarında belirtilen yayın şartlarını sağlamaktadır. Lisansüstü tezin bilimsel, şekilsel ve etik kurallar çerçevesinde incelenmesi sonucunda, tez savunma sınavında savunulabilir olduğu görülmüş olup öğrencinin lisansüstü tezini teslim ederek savunabileceği kanaatine varılmıştır.
                                                            <br /><br /><b>Taahhüt 2:</b> Tez Çalışması Orijinallik Raporu Uygulama Esasları uyarınca, belirtilen azami benzerlik oranlarına göre öğrencinin lisansüstü tezi herhangi bir intihal içermemekte olup aksinin tespit edileceği muhtemel durumda tüm hukuki sorumluğu kabul ediyorum.
                                                        </div>
                                                        @if (Model.IsDanismanOnay.HasValue)
                                                        {
                                                            <div class="task-footer" style="padding-top:0pt;padding-bottom:0px;color:green;">
                                                                <div class="pull-left"><span class="fa fa-check-circle-o"></span> @Model.DanismanOnayTarihi.ToFormatDateAndTime() tarihinde @Model.TezDanismanAdi tarafından onaylandı </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>

                                    }
                                    else if (Model.IsDanismanOnay == false)
                                    {
                                        <tr>
                                            <td class="CaptionTd" width="100">Danışman Adı</td>
                                            <td class="CaptionTd" width="10">:</td>
                                            <td class="ValueTd">@Model.TezDanismanAdi</td>
                                        </tr>
                                        <tr>
                                            <td class="CaptionTd">Onay Durumu</td>
                                            <td class="CaptionTd">:</td>
                                            <td class="ValueTd">
                                                <span style="color:maroon;"><i class="fa fa-thumbs-o-down" aria-hidden="true"></i> Danisman Tarafından Reddedildi (@Model.DanismanOnayTarihi.ToFormatDateAndTime())</span>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr>
                                            <td class="CaptionTd" width="100">Danışman Adı</td>
                                            <td class="CaptionTd" width="10">:</td>
                                            <td class="ValueTd">@Model.TezDanismanAdi</td>
                                        </tr>
                                        <tr>
                                            <td class="CaptionTd">Onay Durumu</td>
                                            <td class="CaptionTd">:</td>
                                            <td class="ValueTd">
                                                <i class="fa fa-clock-o" aria-hidden="true"></i> Danışman Tarafından Onay İşlemi Henüz Yapılmadı.
                                            </td>
                                        </tr>



                                    }


                                </table>
                            }

                        </td>
                    </tr>

                </tbody>
            </table>

        </div>
        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="fa fa-book fa-lg" style="font-size:14pt;"></i> Yayın Bilgisi</td>
                        <td style="font-size:9pt; border-bottom:1px solid;">
                            @if (false && Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.KabulEdildi)
                            {
                                <a style="float:right;" href="javascript:void(0);" onclick="YeniDialogBB('Mezuniyet Yayın Şartı Onayı Formu','@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=@RaporTipiEnum.MezuniyetBasvuruRaporu&MezuniyetBasvurulariID=@Model.MezuniyetBasvurulariID' , 'auto', 'modal-dialog modal-lg' )">
                                    <i class="fa fa-file-pdf-o"></i>  Yayın Onayını İndir
                                </a>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td style="padding-left:10px;text-align:left;" colspan="2">
                            @if (yayinInfos.Any())
                            {

                                <div class="tasks">
                                    <div class="task-item task-info" style="margin-bottom: 0px; cursor: auto;">
                                        <div class="task-text" style="padding-bottom: 0px; font-size: 8pt;">
                                            @Html.Raw(string.Join("<br/>", yayinInfos))
                                        </div>

                                    </div>
                                </div>
                            }
                            @if (Model.YayinBilgileri.Any())
                            {
                                <table id="yTable" class="table table-hover" style="width:100%;table-layout:fixed;">
                                    <thead>

                                        <tr class="info">
                                            <th width="20">#</th>
                                            <th width="35"></th>
                                            <th width="150">Eklenen Yayın Türü</th>
                                            <th>Yayın Başlığı</th>
                                            @if (Model.MezuniyetYayinKontrolDurumID != MezuniyetYayinKontrolDurumuEnum.Taslak && Model.IsDanismanOnay == true)
                                            {
                                                <th width="120"></th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.YayinBilgileri.Count > 0)
                                        {
                                            int inx = 0;
                                            foreach (var item in Model.YayinBilgileri)
                                            {
                                                inx++;
                                                item.RowNum = inx;
                                                item.DegerlendirmeKolonu = Model.MezuniyetYayinKontrolDurumID != MezuniyetYayinKontrolDurumuEnum.Taslak && Model.IsDanismanOnay == true;
                                                item.DegerlendirmeAktif = sonucGirisSureciAktif && (!isKendiBasvuruSu || Model.GelenBasvuru) && kayitYetki && (Model.MezuniyetYayinKontrolDurumID != MezuniyetYayinKontrolDurumuEnum.KaydiSilindi);
                                                item.sonucGirisSureciAktif = sonucGirisSureciAktif;
                                                item.IsDataShow = true;
                                                @Html.Raw(ViewRenderHelper.RenderPartialView("Mezuniyet", "AddRow", item))
                                            }
                                        }
                                    </tbody>
                                </table>
                            }
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>


        <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
            <table style="width:100%;">
                <tbody>
                    <tr>
                        <td colspan="3" style="font-weight:bold;font-size:11pt; border-bottom:1px solid;"><i class="@Model.DurumClassName fa-lg"></i> Enstitü Onay İşlemi</td>
                    </tr>
                    <tr>
                        <td style="padding-left:10px;text-align:left;">
                            <div class="tasks">
                                <div class="task-item task-info" style="margin-bottom: 0px; cursor: auto; border-left-color:@Model.DurumColor">
                                    <div class="task-text" style="padding-bottom: 0px; font-size: 8pt;">
                                        <table style="width:100%;">
                                            <tr>
                                                <td class="CaptionTd" width="185">Başvuru Durumu</td>
                                                <td class="CaptionTd">:</td>
                                                <td class="ValueTd">
                                                    @if (sonucGirisSureciAktif && Model.GelenBasvuru && kayitYetki)
                                                    {
                                                        @Html.DropDownList("MezuniyetYayinKontrolDurumID", Model.SMezuniyetYayinKontrolDurum, new { id = "MezuniyetYayinKontrolDurumID_" + Model.MezuniyetBasvurulariID, @class = "form-control", onchange = "BDurumChange(this,'" + Model.MezuniyetBasvurulariID + "')" })
                                                    }
                                                    else
                                                    {
                                                        @Model.MezuniyetYayinKontrolDurumAdi
                                                        @(" (" + Model.IslemTarihi + ")")
                                                    }
                                                </td>
                                            </tr>
                                            @if (Model.IsTekKaynakOraniGirisiYapilacak && sonucGirisSureciAktif && Model.GelenBasvuru && kayitYetki)
                                            {
                                                <tr class="intihalRwBasvuru_@Model.MezuniyetBasvurulariID @(Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.KabulEdildi ? "" : "hide")">
                                                    <td class="CaptionTd">Tek Kaynak Benzerlik Oranı %</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        <input type="text" id="TekKaynakOrani_@Model.MezuniyetBasvurulariID" maxlength="3" value="@Model.TekKaynakOrani" class="form-control" style="color:black;" />
                                                    </td>
                                                </tr>
                                            }
                                            @if (Model.IsToplamKaynakOraniGirisiYapilacak && sonucGirisSureciAktif && Model.GelenBasvuru && kayitYetki)
                                            {
                                                <tr class="intihalRwBasvuru_@Model.MezuniyetBasvurulariID @(Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.KabulEdildi ? "" : "hide")">
                                                    <td class="CaptionTd">Toplam Benzerlik Oranı %</td>
                                                    <td class="CaptionTd">:</td>
                                                    <td class="ValueTd">
                                                        <input type="text" id="ToplamKaynakOrani_@Model.MezuniyetBasvurulariID" maxlength="3" value="@Model.ToplamKaynakOrani" class="form-control" style="color:black;" />
                                                    </td>
                                                </tr>
                                            }
                                            @if (kayitYetki)
                                            {
                                                <tr class="taahhutRwBasvuru_@Model.MezuniyetBasvurulariID @(Model.MezuniyetYayinKontrolDurumID == MezuniyetYayinKontrolDurumuEnum.KabulEdildi ? "" : "hide")">
                                                    <td class="CaptionTd">Enstitü Yayın Kabul Taahhütü</td>
                                                    <td class="CaptionTd"></td>
                                                    <td class="ValueTd" style="padding-top: 10px; padding-bottom: 10px;">
                                                        <div class="tasks ui-sortable">
                                                            <div class="task-item task-info" id="YayinKontrolKabulTaahhutEdildiContent-@Model.MezuniyetBasvurulariID" style="margin-bottom: 0px; cursor: pointer;" onclick="toggleCheckbox('@Model.MezuniyetBasvurulariID')">
                                                                <div class="task-text ui-sortable-handle" style="padding-bottom: 0px; font-size: 8pt;">
                                                                    <div class="task-checkbox" style="display: inline-block; margin-right: 10px;">
                                                                        <input type="checkbox" id="YayinKontrolKabulTaahhutEdildiChk-@Model.MezuniyetBasvurulariID" style="transform: scale(1.5);" onclick="event.stopPropagation();" @(Model.YayinKontrolKabulTaahhutEdildi == true ? "checked" : "")>
                                                                    </div>
                                                                    OBS sistemi üzerinden öğrencinin kayıt tarihi ve dönemi kontrol edilerek yayın şartı onaylanmıştır.
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <script>
                                                            function toggleCheckbox(id) {
                                                                const checkbox = document.getElementById(`YayinKontrolKabulTaahhutEdildiChk-${id}`);
                                                                if (checkbox) {
                                                                    checkbox.checked = !checkbox.checked;
                                                                }
                                                            }
                                                        </script>



                                                    </td>
                                                </tr>
                                            }
                                            <tr id="bdurumRowID_@Model.MezuniyetBasvurulariID" class="">
                                                <td class="CaptionTd">Açıklama / Not</td>
                                                <td class="CaptionTd">:</td>
                                                <td class="ValueTd">
                                                    @if (sonucGirisSureciAktif && Model.GelenBasvuru && kayitYetki)
                                                    {
                                                        <textarea style="width:100%; resize:vertical;" maxlength="512" id="MezuniyetYayinKontrolDurumAciklamasi_@Model.MezuniyetBasvurulariID">@Model.MezuniyetYayinKontrolDurumAciklamasi</textarea>
                                                    }
                                                    else
                                                    {
                                                        @Model.MezuniyetYayinKontrolDurumAciklamasi
                                                    }
                                                </td>
                                            </tr>
                                            @if (sonucGirisSureciAktif && Model.GelenBasvuru && kayitYetki)
                                            {
                                                <tr>
                                                    <td></td>
                                                    <td>:</td>
                                                    <td class="ValueTd">
                                                        <a href="javascript:void(0);" onclick="BDurumKayit(@Model.MezuniyetBasvurulariID)" class="btn btn-primary "><i class="fa fa-save" aria-hidden="true"></i> Kaydet</a>
                                                    </td>
                                                </tr>
                                            }
                                            
                                        </table>
                                    </div>
                                    @if (Model.MezuniyetYayinKontrolDurumOnayYapanKullaniciID.HasValue && RoleNames.MezuniyetGelenBasvurular.InRoleCurrent())
                                    {
                                        <div class="task-footer" style="padding-top:0pt;padding-bottom:0px;color:@Model.DurumColor;">
                                            <div class="pull-left"><span class="@Model.DurumClassName"></span>   İşlem Yapan Yetkili:  @Model.MezuniyetYayinKontrolDurumOnayYapanKullaniciAdi - @Model.MezuniyetYayinKontrolDurumOnayTarihi.ToFormatDateAndTime()</div>
                                        </div>
                                    }
                                </div>
                            </div>

                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

    </div>
</div>