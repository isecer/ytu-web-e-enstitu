    }

        function SinavDegerlendir(UniqueID, MBasvuruID, IsDanisman) {
            var IsTezBasligiDegisti = $('#IsTezBasligiDegisti_' + UniqueID).val();
            var TezOrjinalBasligi = $('#TezOrjinalBasligi_' + UniqueID).val();
            var TezOrjinalBasligiCevirisi = $('#TezOrjinalBasligiCevirisi_' + UniqueID).val();
            var IsTezSanayiVeIsBirligiKapsamindaGerceklesti = $('#IsTezSanayiVeIsBirligiKapsamindaGerceklesti_' + UniqueID).val();
            var MezuniyetSinavDurumID = $('#MezuniyetSinavDurumID_' + UniqueID).val();
            var Aciklama = $('#Aciklama_' + UniqueID).val();
            var IsYokDrBursiyeriVar = $('#IsYokDrBursiyeriVar_' + UniqueID).val();
            var YokDrOncelikliAlan = $('#YokDrOncelikliAlan_' + UniqueID).val();
            if (!IsDanisman) {
                IsTezBasligiDegisti = null;
                TezOrjinalBasligi = null;
                TezOrjinalBasligiCevirisi = null;
                IsYokDrBursiyeriVar = null;
                YokDrOncelikliAlan = null;
            }
            var _panel = $('#bsvrDet_' + MBasvuruID);
            bootbox.dialog({
                message: "Tez sınavı değerlendirmenizi kaydetmek istediğinize emin misiniz?",
                title: "<i class='glyphicon glyphicon-info-sign'></i> Tez Sınavı Değerlendirmesi",
                buttons: {
                    success: {
                        label: "Evet",
                        className: "btn-success",
                        callback: function (event) {
                            _pRefresh(_panel, false);
                            $.ajax({
                                url: '@Url.Action("SinavDegerlendir", "Mezuniyet")',
                                data: {
                                    'UniqueID': UniqueID,
                                    'IsTezBasligiDegisti': IsTezBasligiDegisti,
                                    'TezOrjinalBasligi': TezOrjinalBasligi,
                                    'TezOrjinalBasligiCevirisi': TezOrjinalBasligiCevirisi,
                                    'IsTezSanayiVeIsBirligiKapsamindaGerceklesti': IsTezSanayiVeIsBirligiKapsamindaGerceklesti,
                                    'MezuniyetSinavDurumID': MezuniyetSinavDurumID,
                                    'Aciklama': Aciklama,
                                    'YokDrOncelikliAlan': YokDrOncelikliAlan,
                                    'IsYokDrBursiyeriVar': IsYokDrBursiyeriVar

                                },
                                success: function (result) {
                                    _pRefresh(_panel, true);
                                    if (result.IsSuccess || result.IsRefresh) {
                                        getDetailx(MBasvuruID);

                                    }
                                    showMmMessage(result.Messages, 'Tamam');

                                },
                                error: function (err) {
                                    _pRefresh(_panel, true);
                                    alert(err.responseText);

                                }
                            });
                        }
                    },
                    danger: {
                        label: "Hayır",
                        className: "btn-primary",
                        callback: function () {
                        }
                    }
                }
            });
        }


    </script>
}