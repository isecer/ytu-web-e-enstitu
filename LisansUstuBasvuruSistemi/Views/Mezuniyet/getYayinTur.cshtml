<div id="clone"></div>
<div class="form-group">
    <label class="col-md-3 col-xs-4 control-label"></label>
    <div class="col-md-9 col-xs-8">
        <a style="width: 120px; margin: 0px auto;" href="javascript:void(0);" class="btn btn-success btn-block" onclick="yayiniEkle()">Yayını Ekle</a>
    </div>
</div>

<script>
    $('.fileinputx').bootstrapFileInput();
    $('.date-pickerx').datetimepicker({
        timepicker: false,
        format: 'd-m-Y'
    });
    $.datetimepicker.setLocale('tr');
    function yayiniEkle() {
        var _panel = $('#yayinPanel');
        var _panel2=$('#yayinListPanel') ;
        _pRefresh(_panel, false);
        var rowNum=$('#yRows').find('tr').length+1;
        var yayinTurID = $('#MezuniyetYayinTurID').val();
        var yayinTurAdi = $("#MezuniyetYayinTurID :selected").text();
        var YayinBasligi = $('#YayinBasligi').val();
        var MezuniyetYayinBelgeDosya =$('#MezuniyetYayinBelgeAdi').length>0? $('#MezuniyetYayinBelgeAdi').val().split('/').pop().split('\\').pop().replace("'",""):"";
        var MezuniyetYayinKaynakLinki =$('#MezuniyetYayinKaynakLinki').length>0? $('#MezuniyetYayinKaynakLinki').val().replace("'",""):"";
        var YayinMetniDosya = $('#MezuniyetYayinMetniBelgeAdi').length>0?$('#MezuniyetYayinMetniBelgeAdi').val().split('/').pop().split('\\').pop().replace("'",""):"";
        var MezuniyetYayinKabulEdilmisMakaleAdi = $('#MezuniyetYayinKabulEdilmisMakaleAdi').length>0?$('#MezuniyetYayinKabulEdilmisMakaleAdi').val().split('/').pop().split('\\').pop().replace("'",""):"";
        var MezuniyetYayinLinki = $('#MezuniyetYayinLinki').length>0?$('#MezuniyetYayinLinki').val():"";
        var MezuniyetYayinIndexTurID = $('#MezuniyetYayinIndexTurID').length>0?$('#MezuniyetYayinIndexTurID').val():"";
        var MezuniyetYayinTarih = $('#MezuniyetYayinTarih').length>0?$('#MezuniyetYayinTarih').val():"";
        var Yayinlanmis = $('#Yayinlanmis').length > 0 ? $('#Yayinlanmis').val().replace("'", "") : "";

        var YazarAdi = $('#YazarAdi').length > 0 ? $('#YazarAdi').val() : "";
        var DergiAdi = $('#DergiAdi').length > 0 ? $('#DergiAdi').val() : "";
        var YilCiltSayiSS = $('#YilCiltSayiSS').length > 0 ? $('#YilCiltSayiSS').val() : "";
        var MezuniyetYayinProjeTurID = $('#MezuniyetYayinProjeTurID').length > 0 ? $('#MezuniyetYayinProjeTurID').val() : "";
        var IsProjeTamamlandiOrDevamEdiyor = $('#IsProjeTamamlandiOrDevamEdiyor').length > 0 ? $('#IsProjeTamamlandiOrDevamEdiyor').val() : "";
        var ProjeEkibi = $('#ProjeEkibi').length > 0 ? $('#ProjeEkibi').val() : "";
        var ProjeDeatKurulus = $('#ProjeDeatKurulus').length > 0 ? $('#ProjeDeatKurulus').val() : "";
        var TarihAraligi = $('#TarihAraligi').length > 0 ? $('#TarihAraligi').val() : "";
        var YerBilgisi = $('#YerBilgisi').length > 0 ? $('#YerBilgisi').val() : "";
        var EtkinlikAdi = $('#EtkinlikAdi').length > 0 ? $('#EtkinlikAdi').val() : ""; 
        var frmD = {
            "MezuniyetSurecID": @Model.MezuniyetSurecID,
            "MezuniyetYayinTurID": yayinTurID,
            "YayinBasligi": YayinBasligi,
            "Yayinlanmis": Yayinlanmis,
            "MezuniyetYayinBelgeAdi": MezuniyetYayinBelgeDosya,
            "MezuniyetYayinKaynakLinki": MezuniyetYayinKaynakLinki,
            "MezuniyetYayinMetniBelgeAdi": YayinMetniDosya,
            "MezuniyetYayinLinki": MezuniyetYayinLinki,
            "MezuniyetYayinIndexTurID": MezuniyetYayinIndexTurID,
            "MezuniyetYayinTarih": MezuniyetYayinTarih,
            "MezuniyetYayinKabulEdilmisMakaleAdi": MezuniyetYayinKabulEdilmisMakaleAdi,
            "YazarAdi": YazarAdi,
            "DergiAdi": DergiAdi,
            "YilCiltSayiSS": YilCiltSayiSS,
            "MezuniyetYayinProjeTurID": MezuniyetYayinProjeTurID,
            "IsProjeTamamlandiOrDevamEdiyor": IsProjeTamamlandiOrDevamEdiyor,
            "ProjeEkibi": ProjeEkibi,
            "ProjeDeatKurulus": ProjeDeatKurulus,
            "TarihAraligi": TarihAraligi,
            "YerBilgisi": YerBilgisi,
            "EtkinlikAdi": EtkinlikAdi
        };
        var mFrmD=getEklenenYayinTurs(frmD,2);

        var _gd = guid().substring(0, 4);
        $.ajax({
            url: '@Url.Action("YayinEklemeKontrol", "Mezuniyet")',
            data: mFrmD ,
            type: 'POST',
            cache: false,
            dataType: "json",
            success: function (result) {
                _pRefresh(_panel, true);
                if (result.msg.IsSuccess == true) {
                    _pRefresh(_panel2, false);
                    $('#yRows').append(result._Row);
                    if ($('#MezuniyetYayinBelgeAdi').length > 0) {
                        $('#MezuniyetYayinBelgeAdi').attr('class', '').attr('title', '').attr('id', '_' + _gd).attr('name', '_MezuniyetYayinBelgesi').attr('style', 'display:none;').insertBefore($('#cls-' + result._guID).find(".fileYayinBelge").find('input').first());
                    }
                    else {
                        $('#cls-' + result._guID).find(".fileYayinBelge").append("<input type='file' class='hide' name='_MezuniyetYayinBelgesi'>");
                    }
                    if ($('#MezuniyetYayinMetniBelgeAdi').length > 0) {
                        $('#MezuniyetYayinMetniBelgeAdi').attr('class', '').attr('title', '').attr('id', '_x' + _gd).attr('name', '_YayinMetniBelgesi').attr('style', 'display:none;').insertBefore($('#cls-' + result._guID).find(".fileYayinMetni").find('input').first());
                    }
                    else {
                        $('#cls-' + result._guID).find(".fileYayinMetni").append("<input type='file' class='hide' name='_YayinMetniBelgesi'>");
                    }
                    if ($('#MezuniyetYayinKabulEdilmisMakaleAdi').length > 0) {
                        $('#MezuniyetYayinKabulEdilmisMakaleAdi').attr('class', '').attr('title', '').attr('id', '_xK' + _gd).attr('name', '_MezuniyetYayinKabulEdilmisMakaleBelgesi').attr('style', 'display:none;').insertBefore($('#cls-' + result._guID).find(".fileKabulEdilenYayin").find('input').first());

                    }
                    else {
                        $('#cls-' + result._guID).find(".fileKabulEdilenYayin").append("<input type='file' class='hide' name='_MezuniyetYayinKabulEdilmisMakaleBelgesi'>");
                    }
                    yayinSiraNoDuzenle();
                    $('.tooltips').tooltip();
                    _pRefresh(_panel2, true);
                    yTurKontrol($('#MezuniyetYayinTurID'));

                }
                getMsg(result.msg);
            },
            error: function (err) {
                _pRefresh(_panel, true);
            }
        });

    }

    function handleFileSelect(evt) {

        var files = evt.target.files; // FileList object

        // use the 1st file from the list
        f = files[0];

        var reader = new FileReader();

        // Closure to capture the file information.
        reader.onload = (function (theFile) {
            var filex = $('#YayinMetniDosya')
            var data = new FormData();
            jQuery.each($(filex)[0].files, function (i, file) {
                data.append('[' + i + ']', file);
            });
            return function (e) {
                $.ajax({
                    url: '@Url.Action("file", "Mezuniyet")',
                    data: { Dosya: data },
                    cache: false,
                    contentType: 'multipart/form-data',
                    processData: false,
                    type: 'POST',
                    success: function (result) {

                    },
                    error: function (err) {
                    }
                });
            };
        })(f);

        // Read in the image file as a data URL.
        reader.readAsText(f);
    }

    //document.getElementById('YayinMetniDosya').addEventListener('change', handleFileSelect, false);
</script>