    <div class="form-group pkurulus  @(Model.MezuniyetYayinTurID.makaleYayinDurumIsteniyormu() ? ( Model.Yayinlanmis.HasValue ? (Model.Yayinlanmis.Value?(Model.MezuniyetYayinTurID==3?"":"hide"):"hide") : "hide"):(Model.MezuniyetYayinTurID==3?"":"hide"))">
