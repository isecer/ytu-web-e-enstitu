@using BiskaUtil
@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Models.FilterModel @using LisansUstuBasvuruSistemi.Utilities.Enums
@model YayinBilgiModel
@{
    Layout = null; 
}
@if (Model.MezuniyetYayinTurID.makaleYayinDurumIsteniyormu())
{
    <div class="form-group">
        <label class="col-md-3 col-xs-4 control-label">Yayın Durumu</label>
        <div class="col-md-9 col-xs-8">
            <select id="Yayinlanmis" name="Yayinlanmis" class="form-control" onchange="yChange(this)">
                <option @(Model.Yayinlanmis.HasValue == false ? "selected" : "")></option>
                <option value="true" @(Model.Yayinlanmis == true ? "selected" : "")>Yayınlanmış</option>
                <option value="false" @(Model.Yayinlanmis == false ? "selected" : "")>Yayınlanmamış</option>
            </select>
            <script>
                function yChange(sndr) {
                    var sval = $('#Yayinlanmis').val();
                    if (sval == "") {
                        $('.yBaslik').addClass("hide");
                        $('.yTarih').addClass("hide");
                        $('.yBelge').addClass("hide");
                        $('.kLink').addClass("hide");
                        $('.yMetni').addClass("hide");
                        $('.yLinki').addClass("hide");
                        $('.yIndex').addClass("hide");
                        $('.yMak').addClass("hide");

                        $('.ptur').addClass("hide");
                        $('.pekip').addClass("hide");
                        $('.pdurum').addClass("hide");
                        $('.pkurulus').addClass("hide");
                        $('.dergis').addClass("hide");
                        $('.yilCilts').addClass("hide");
                        $('.etkinlik').addClass("hide");
                        $('.yerbilgisi').addClass("hide");
                        $('.yazars').addClass("hide");

                    }
                    else if (sval == "true") {
                        $('.yBaslik').removeClass("hide");
                        $('.yTarih').addClass("hide");
                        $('.yBelge').addClass("hide");
                        $('.kLink').removeClass("hide");
                        $('.yMetni').removeClass("hide");
                        $('.yLinki').removeClass("hide");
                        $('.yIndex').removeClass("hide");
                        $('.yMak').addClass("hide");
                        $('.ptur').removeClass("hide");
                        $('.pekip').removeClass("hide");
                        $('.pdurum').removeClass("hide");
                        if ($('#MezuniyetYayinProjeTurID').val() == "3") { $('.pkurulus').removeClass("hide"); }
                        $('.dergis').removeClass("hide");
                        $('.yilCilts').removeClass("hide");
                        $('.etkinlik').removeClass("hide");
                        $('.yerbilgisi').removeClass("hide");
                        $('.yazars').removeClass("hide");
                        $('.yilCints').removeClass("hide");
                        
                    }
                    else {
                        $('.yBaslik').removeClass("hide");
                        $('.yTarih').addClass("hide");
                        $('.yBelge').removeClass("hide");
                        $('.kLink').removeClass("hide");
                        $('.yMetni').addClass("hide");
                        $('.yLinki').addClass("hide");
                        $('.yIndex').removeClass("hide");
                        $('.yMak').removeClass("hide");
                        $('.ptur').removeClass("hide");
                        $('.pekip').removeClass("hide");
                        $('.pdurum').removeClass("hide");
                        if ($('#MezuniyetYayinProjeTurID').val() == "3") { $('.pkurulus').removeClass("hide"); }
                        $('.dergis').removeClass("hide");
                        $('.yilCilts').removeClass("hide");
                        $('.etkinlik').removeClass("hide");
                        $('.yerbilgisi').removeClass("hide");
                        $('.yazars').removeClass("hide");
                        $('.yilCints').removeClass("hide");
                    }
                }
            </script>
        </div>
    </div>
}
<div class="form-group yBaslik  @(Model.MezuniyetYayinTurID.makaleYayinDurumIsteniyormu() ? ( Model.Yayinlanmis.HasValue ? (Model.Yayinlanmis.Value?"":"") : "hide"):"")">
    <label class="col-md-3 col-xs-4 control-label">Yayın Başlığı</label>
    <div class="col-md-9 col-xs-8 " style="text-align: left;">
        <input type="text" class="form-control" autocomplete="off" value="" name="YayinBasligi" id="YayinBasligi">
    </div>
</div>
@if (Model.YayinYazarlarIstensin)
{
    <div class="form-group yazars  @(Model.MezuniyetYayinTurID.makaleYayinDurumIsteniyormu() ? ( Model.Yayinlanmis.HasValue ? (Model.Yayinlanmis.Value?"":"hide") : "hide"):"")">
        <label class="col-md-3 col-xs-4 control-label">Yazarlar</label>
        <div class="col-md-9 col-xs-8">
            <input type="text" class="form-control" autocomplete="off" placeholder="Yazar1; Yazar2; Yazar3 şeklinde girilmelidir." value="" name="YazarAdi" id="YazarAdi">
        </div>
    </div>
}
@if (Model.YayinProjeTurIstensin)
{
    <div class="form-group ptur  @(Model.MezuniyetYayinTurID.makaleYayinDurumIsteniyormu() ? ( Model.Yayinlanmis.HasValue ? (Model.Yayinlanmis.Value?"":"hide") : "hide"):"")">
        <label class="col-md-3 col-xs-4 control-label">Proje Türü</label>
        <div class="col-md-9 col-xs-8">
            <select id="MezuniyetYayinProjeTurID" name="MezuniyetYayinProjeTurID" class="form-control" onchange="ProjeTurKontrol(this)">
                <option value=""></option>
                @foreach (var item in Model.MezuniyetYayinProjeTurleris)
                {
                    <option value="@item.MezuniyetYayinProjeTurID">@item.ProjeTurAdi</option>
                }
            </select>
        </div>
        <script>
            function ProjeTurKontrol(sndr) { 
                if ($(sndr).val() == "3") {
                    $('.pkurulus').removeClass('hide');

                }
                else {
                    $('.pkurulus').addClass('hide');
                }
            }
        </script>
    </div>
}
@if (Model.YayinProjeTurIstensin)
