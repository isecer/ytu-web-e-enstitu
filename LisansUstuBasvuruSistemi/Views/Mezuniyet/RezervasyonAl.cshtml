@using LisansUstuBasvuruSistemi.Utilities.Dtos
@model KmSRTalep
@{ 
    Layout = null;
}

@using (Ajax.BeginForm("RezervasyonAlPost", null, new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "MezuniyetSRForm" }))
{
    @Html.HiddenFor(p => p.SRTalepID)
    @Html.HiddenFor(p => p.TalepYapanID)
    @Html.HiddenFor(p => p.MezuniyetBasvurulariID)
    <div class="panel panel-info" style="margin: 0px; padding: 0px;">
        <div class="panel-body" style="padding: 0px;">
            <div class="panel panel-default form-horizontal" id="_PnpEADP">
                <div class="panel-body form-group-separated">
                    @if (Model.IsSalonSecilsin)
                    {
                        
                        <div class="form-group">
                            <label class="col-md-2 col-xs-2 control-label">Salon Seçiniz</label>
                            <div class="col-md-10 col-xs-10">
                                @Html.DropDownList("SRSalonID", null, new { @class = "form-control", onChange = "getSaatler()" })
                            </div>
                        </div>
                        <div class="form-group srTarih hide">
                            <label class="col-md-2 col-xs-2 control-label"></label>
                            <div class="col-md-10 col-xs-10 ">
                                <div class="panel panel-default pnlRfrsh" style="margin:0px;">
                                    <div class="panel-body" style="padding:0px;">
                                        <table style="width:100%;table-layout:fixed;">
                                            <tr>
                                                <td width="240" style="vertical-align:top;">
                                                    <input type="text" id="Tarih" name="Tarih" value="@Model.Tarih.ToString("yyyy-MM-dd")" />

                                                </td>
                                                <td style="vertical-align:top;padding:3px;">
                                                    <div class="form-group" id="saatLstContnt">

                                                    </div>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <script>
                            $(function () {
                                getSaatler();
                                var dttme = $('#Tarih').datetimepicker({
                                    inline: true,
                                    timepicker: false,
                                    format: 'Y-m-d',
                                    onSelectDate: function () {
                                        getSaatler();
                                    },
                                    onChangeMonth: function (sndr) {
                                        var date = new Date(sndr);
                                        var qdate = getFormattedDate(date);
                                        $('#Tarih').val(qdate); getSaatler();
                                    },
                                    onChangeYear: function (sndr) {
                                        var date = new Date(sndr);
                                        var qdate = getFormattedDate(date);
                                        $('#Tarih').val(qdate);
                                        getSaatler();
                                    },
                                });
                            });
                            function getSaatler(date) {
                                var tarih = $('#Tarih').val();
                                var salon = $('#SRSalonID').val();
                                if (salon != "" && salon != null) {
                                    $('.srTarih').removeClass('hide');
                                }
                                else {
                                    $('.srTarih').addClass('hide');
                                }
                                if (tarih != null && salon != null && tarih != "" && salon != "") {
                                    $('#saatLstContnt').css("display", "block");
                                    var _panel = $('.pnlRfrsh');
                                    PanelRefresh(_panel, false);
                                    $.ajax({
                                        url: '@Url.Action("GetSaatList", "Ajax")',
                                        data: { 'SRSalonID': salon,'IsPopupFrame':'true', 'SRTalepTipID': 1, 'Tarih': tarih, 'SRTalepID': '@(Model.SRTalepID <= 0 ? "" : Model.SRTalepID.ToString())','MzRowID':'@Model.MzRowID' },
                                        success: function (result) {
                                            $('#saatLstContnt').html(result.Deger);
                                            PanelRefresh(_panel, true);
                                        },
                                        error: function (err) {
                                            alert(err.responseText);
                                            PanelRefresh(_panel, true);
                                        }
                                    });
                                }
                                else {
                                    $('#saatLstContnt').css("display", "none");
                                }
                            }

                            function getFormattedDate(date) {
                                var year = date.getFullYear();
                                var month = (1 + date.getMonth()).toString();
                                month = month.length > 1 ? month : '0' + month;
                                var day = date.getDate().toString();
                                day = day.length > 1 ? day : '0' + day;
                                return year + "-" + month + "-" + day;
                            }


                        </script>

                    }
                    else
                    {
                        <div class="panel">
                            <div class="panel-body">
                                Öğrencilerimiz sınav salon rezervasyonları için öncelikle salonun bulunduğu bölümlerden müsaitlik durumlarını öğrenmeleri ve teyit almaları gerekmektedir. Salonun istenilen tarih ve saatte boş ve sınav yapılabilir durumda ise salon onayını gerçekleştiriniz.
                                <br />   <br />
                                <b>Önemli Not:</b> Bölümlerden salon teyidi alınmadan gerçekleştirilen salon rezervasyonlarında çakışma olması durumunda sınavınız yapılamayacaktır!!!
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-md-2 col-xs-2 control-label">Salon Adı</label>
                            <div class="col-md-10 col-xs-10">
                                <input type="text" id="SalonAdi" name="SalonAdi" value="@Model.SalonAdi" class="form-control" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="col-md-2 col-xs-2 control-label">Tarih</label>
                            <div class="col-md-10 col-xs-10">
                                <input class="form-control form-control-inline input-medium" autocomplete="off" size="16" type="text" value="@(Model.Tarih == DateTime.MinValue ? "" : Model.Tarih.ToString("yyyy-MM-dd HH:mm"))" name="Tarih" id="Tarih">
                            </div>
                        </div>

                        <script type="text/javascript">
                            var _times = [];
                            for (var i = 8; i <= 23; i++) {
                                var _saat = i;
                                if (i < 10) _saat = "0" + i;
                                for (var i2 = 0; i2 <= 30; i2 += 30) {
                                    var _dkk = i2;
                                    if (i2 == 0) _dkk = "00";
                                    _times.push(_saat + ":" + _dkk);
                                }
                            }
                            $('#Tarih').datetimepicker({
                                allowTimes: _times,
                                step: 30,
                                timepicker: true,
                                format: 'Y-m-d H:i'
                            });
                            $.datetimepicker.setLocale('tr');
                        </script>
                    }
                </div>
            </div>
        </div>
    </div>
}
 