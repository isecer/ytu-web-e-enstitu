@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using BiskaUtil
@model  FmAnabilimDallariDto
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    { 
        <div class="col-md-12">  
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp; Anabilim Dalı Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-success label-form">T:@IndexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@IndexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@IndexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th class="sirala" field="EnstituAd" width="140">Enstitü Adı</th>
                                <th class="sirala" field="AnabilimDaliKod" width="50">Abd Kod</th>
                                <th class="sirala" field="AnabilimDaliAdi">Anabilim Dalı Adı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="50">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th>
                                    <input name="AnabilimDaliKod" type="text" value="@Model.AnabilimDaliKod" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    <input name="AnabilimDaliAdi" type="text" value="@Model.AnabilimDaliAdi" class="form-control" />
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                foreach (var item in Model.FrAnabilimDallaris)
                                {
                                    <tr>
                                        <td>@item.EnstituAd</td>
                                        <td>@item.AnabilimDaliKod</td>
                                        <td id="tdMad_@item.AnabilimDaliID">
                                            @item.AnabilimDaliAdi
                                        </td>

                                        <td id="tdIa_@item.AnabilimDaliID" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit")"><i class="fa fa-plus tooltips" data-style="blue" data-original-title="Yeni"></i></a>
                                            <a href="@Url.Action("Kayit", "AnabilimDallari", new { id = item.AnabilimDaliID })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.AnabilimDaliID');"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>

                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>

<script type="text/javascript">
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Anabilim Dalı Adı: " + gMesaj + " <br/> Seçilen Anabilim Dalını Silmek İstiyor Musunuz?",
            title: "Anabilim Dalı Silme İşlemi",
            buttons: {
                success: {
                    label: "Anabilim Dalı Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "AnabilimDallari")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Anabilim Dalı Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    // $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
