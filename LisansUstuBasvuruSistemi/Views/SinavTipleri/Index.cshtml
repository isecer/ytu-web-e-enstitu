@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil
@model  FmSinavTipleri
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp; Sınav Tipi Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-success label-form">T:@indexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@indexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@indexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="EnstituAd">Enstitü Adı</th>
                                <th class="sirala" field="SinavTipGrupAdi" width="150">Grup Adı</th> 
                                <th class="sirala" field="SinavAdi" width="140">Sınav Tipi</th>
                                <th class="sirala" field="WebService" width="60" title="Web servisi">Ws</th>
                                <th class="sirala" field="OzelTarih" width="60" title="Özel tarih girişi">Ot</th>
                                <th class="sirala" field="OzelNot" width="60" title="Özel not girişi">On</th>
                                <th class="sirala" field="KusuratVar" width="60" title="Küsürat girişi">Kv</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="50">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    @Html.DropDownList("SinavTipGrupID", null, new { @class = "form-control", style = "padding:0px;" })
                                </th> 
                                <th>
                                    <input name="SinavAdi" type="text" value="@Model.SinavAdi" class="form-control" />
                                </th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.FrSinavTipleris)
                                {
                                    rowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.SinavTipID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="showDetail('@item.SinavTipID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>@item.EnstituAd</td>

                                        <td>@item.SinavTipGrupAdi</td>

                                       
                                        <td id="tdMad_@item.SinavTipID">
                                            @item.SinavAdi
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.WebService ? "success" : "danger")">@item.WebService.ToEvetHayir()</span>
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.OzelTarih ? "success" : "danger")">@item.OzelTarih.ToEvetHayir()</span>
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.OzelNot ? "success" : "danger")">@item.OzelNot.ToEvetHayir()</span>
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.KusuratVar ? "success" : "danger")">@item.KusuratVar.ToEvetHayir()</span>
                                        </td>
                                        <td id="tdIa_@item.SinavTipID" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit")"><i class="fa fa-plus tooltips" data-style="blue" data-original-title="Yeni"></i></a>
                                            <a href="@Url.Action("Kayit", "SinavTipleri", new { id = item.SinavTipID })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="getDetail('@item.SinavTipID',true,this)"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.SinavTipID" style="display:none">
                                        <td id="cls-@item.SinavTipID" colspan="11" style="padding: 1px 1px 2px 75px;"></td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function showDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);
        if (unTogled) getDetail(id);
    }
    function getDetail(id, Isdelete, sndr) {
        var _panel = $('#STDetay_' + id);
        _pRefresh(_panel, false);
        var tbName = "@TabAdlari.SinavTipTN-" + id;
        var tID = getSelectedTabID(tbName);
        $.ajax({
            url: '@Url.Action("GetDetail", "SinavTipleri")',
            data: { id: id, tbInx: tID },
            success: function (result) {
                if (Isdelete != true) {
                    $('#cls-' + id).html(result);
                    _pRefresh(_panel, true);
                }
                else {
                    _pRefresh(_panel, true);
                    var btbx = bootbox.dialog({
                        message: result + " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Seçili olan sınav tipi silinsin mi?</td></tr></table>",
                        title: "Sınav tipi silme işlemi",
                        buttons: {
                            success: {
                                label: 'Sınav tipini sil',
                                className: "btn-danger",
                                callback: function () {
                                    sil(sndr, id);
                                }
                            },
                            danger: {
                                label: 'Vazgeç',
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });
                    $(btbx).find('.modal-dialog').addClass('modal-lg');

                }
                onload();
            },
            error: function (err) {
                alert(err.responseText);
                _pRefresh(_panel, true);
            }
        });
    }
    function sil(sndr, id, enstKod) {
        $.ajax({
            url: '@Url.Action("Sil", "SinavTipleri")',
            data: { id: id, 'EnstituKod': enstKod },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Sınav Tipi Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
    function STPKSil(id,STipID) {
        var btbx = bootbox.dialog({
            message: " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Seçili olan Programa özel not kriteri silinsin mi?</td></tr></table>",
            title: "Programa özel not kriteri silme işlemi",
            buttons: {
                success: {
                    label: 'Not kriterini sil',
                    className: "btn-danger",
                    callback: function () {
                        $.ajax({
                            url: '@Url.Action("SilStpk", "SinavTipleri")',
                            data: { id: id },
                            success: function (result) {
                                toastr[result.success ? "success" : "error"](result.message, "Programa özel not kriteri silme işlemi")
                                if (result.success) {
                                    getDetail(STipID, false, null)
                                }

                            },
                            error: function (err) {
                                alert(err.responseText);
                            }
                        });
                    }
                },
                danger: {
                    label: 'Vazgeç',
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });


    }

    function STProgramaOzelNotKriteriEkle(url) {
        yeniDialogBB(null, 'Sınav tipi özel not ekleme işlemi', url, 650, '@ModalSizeClass.Large');

    }
</script>
