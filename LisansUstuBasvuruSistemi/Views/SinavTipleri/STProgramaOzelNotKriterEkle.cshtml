@using Entities.Entities  
@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model KmSinavTipleriSpna
@{
    var mmMessage = ViewBag.MmMessage as MmMessage;
    Layout = "~/Views/Shared/_LayoutPupupFrame.cshtml";
    var stip = (SinavTipleri)ViewBag.stip;
    var stipAdi = stip.SinavAdi;
    var programlar = (List<KulaniciProgramYetkiModel>)ViewBag.Programlar;
}



<div class="row">
    <form method="post" class="form-horizontal" role="form">
        <input type="text" style="display:none;" id="SinavTipID" name="SinavTipID" value="@Model.SinavTipID" />
        <input type="text" style="display:none;" id="SinavTipleriOT_SNAID" name="SinavTipleriOT_SNAID" value="@Model.SinavTipleriOT_SNAID" />
        <div class="col-md-12">
            <div class="panel panel-success" style="padding:0px;margin:0px;">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i>  @(Model.SinavTipleriOT_SNAID == 0 ? "Programa özel sınav tipi notu tanımlama işlemi (" + stipAdi + ")" : "Programa ait özel sınav tipi notu düzenleme işlemi (" + stipAdi + ")")</h3>
                </div>
                <div class="panel-body">
                    <div class="panel panel-default form-horizontal" style="padding:0px;margin:0px;">
                        <div class="panel-body form-group-separated"> 
                            <div class="_OzelNot2 form-group">
                                <label class="col-md-2 col-xs-3 control-label">Sınavın isteneceği Öğrenim Seviyeleri ve Not Aralıkları</label>
                                <div class="col-md-10 col-xs-9">
                                    <table class="table" style="width:100%;table-layout:fixed;padding:0px;margin:0px;">
                                        <thead>
                                            <tr>
                                                <th>Öğrenim Tipi</th>
                                                <th width="30">Dil</th>
                                                <th width="100">Geçerlilik</th>
                                                <th width="100">İstensin</th>
                                                <th width="80" class="NANotG">Min</th>
                                                <th width="80" class="NANotG">Max</th>
                                            </tr>
                                        </thead>
                                        <tbody id="_ozelNotRow">
                                            @foreach (var item in Model.KrSinavTipleriOtNotAraliklaris)
                                            {
                                                var dil = item.Ingilizce ? "En" : "Tr";
                                                <tr>
                                                    <td>
                                                        <div class="form-group" title="@item.OgrenimTipAdi">
                                                            <input type="text" class="hide" name="NAOgrenimTipKod" value="@item.OgrenimTipKod" />
                                                            @item.OgrenimTipAdi
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <input type="text" class="hide" name="NAIngilizce" value="@(item.Ingilizce.ToString().ToLower())" />
                                                        @dil
                                                    </td>
                                                    <td>
                                                        <div style="height:31px;" class="make-switch" data-on-label="Gçrli" data-off-label="Gçrsz" data-on="info" data-off="danger">
                                                            <input type="checkbox" disabled="disabled"  id="chkIsGecerli_@(item.OgrenimTipKod)_@dil" onchange="NANotGKontrol2(this,'@(item.OgrenimTipKod)_@dil')" class="toggle" @item.IsGecerli.ToChecked() />
                                                        </div>
                                                        <input type="text" class="hide" name="NAIsGecerli" id="NAIsGecerli_@(item.OgrenimTipKod)_@dil" value="@(item.IsGecerli ? 1 : 0)" />
                                                    </td>
                                                    <td>
                                                        <div style="height:31px;" class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="info" data-off="danger">
                                                            <input type="checkbox"  disabled="disabled"  id="chkIsIstensil_@(item.OgrenimTipKod)_@dil" onchange="NANotGKontrol(this,'@(item.OgrenimTipKod)_@dil')" class="toggle" @item.IsIstensin.ToChecked() />
                                                        </div>
                                                        <input type="text" class="hide" name="NAIsIstensin" id="NAIsIstensin_@(item.OgrenimTipKod)_@dil" value="@(item.IsIstensin ? 1 : 0)" />
                                                    </td>
                                                    <td class="NANotG">
                                                        <div class="form-group NANotG_@(item.OgrenimTipKod)_@dil @(item.IsOzelNotAralik ? "" : "hide") @(item.SuccessRow.HasValue && item.PropName.Contains("NAMin") && item.SuccessRow.Value == false ? "has-error" : "")">
                                                            <input type="text" class="form-control" name="NAMin" value="@item.Min" />
                                                        </div>
                                                    </td>
                                                    <td class="NANotG">
                                                        <div class="form-group NANotG_@(item.OgrenimTipKod)_@dil @(item.IsOzelNotAralik ? "" : "hide") @(item.SuccessRow.HasValue && item.PropName.Contains("NAMax") && item.SuccessRow.Value == false ? "has-error" : "")">
                                                            <input type="text" class="form-control" name="NAMax" value="@item.Max" />
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>

                                </div>
                            </div>
                            @*<div class="form-group">
                                <label class="col-md-2 col-xs-3 control-label">Not Dönüşümü</label>
                                <div class="col-md-10 col-xs-9">
