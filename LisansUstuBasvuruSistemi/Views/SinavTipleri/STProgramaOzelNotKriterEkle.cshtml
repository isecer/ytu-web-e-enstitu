                                    </div>
                                </div>
                            </div>
                            <div class="form-group @(Model.NotDonusum ?"":"hide")" id="NtFormulDv">
                                <label class="col-md-2 col-xs-3 control-label">Formül</label>
                                <div class="col-md-10 col-xs-9">
                                    <textarea style="min-height:100px;" type="text" class="form-control" name="NotDonusumFormulu" id="NotDonusumFormulu" autocomplete="off">@Model.NotDonusumFormulu</textarea>
                                </div>
                            </div>*@
                            <div class="form-group">
                                <label class="col-md-2 col-xs-3 control-label">Programlar</label>
                                <div class="col-md-10 col-xs-9">
                                     
                                    <table class="table" style="width:100%;table-layout:fixed;">
                                        <thead>
                                            <tr>
                                                <th>Program Adı</th>      
                                            </tr>
                                            <tr>
                                                <td colspan="2">
                                                    <table style="width: 100%;">
                                                        <tr>
                                                            <td>
                                                                <div style="width: 100%;" class="checkbox pull-left">
                                                                    <label style="width: 100%;">
                                                                        <input style="color: red; width: 100%;" type="text" name="search" id="filterBInp" placeholder="ara..." class="form-control">
                                                                    </label>
                                                                </div>
                                                            </td>
                                                            <td><a href="javascript:void(0);" onclick="Filtrele()" class="label label-warning">Ara</a></td>
                                                        </tr>
                                                    </table>

                                                </td>
                                            </tr>
                                        </thead>
                                        <tbody>   
                                                <tr>
                                                    <td colspan="2">
                                                        <div style="overflow-x:auto;height:160px;">
                                                            <table id="prgList" style="width:100%;padding:0px;margin:0px;">
                                                                @foreach (var item in programlar)
                                                                {
                                                                    <tr class="_rows" @(item.YetkiVar ? "style=color:blue" : "")>
                                                                        <td width="600">
                                                                            <div class="checkbox pull-left">
                                                                                <label>
                                                                                    <input type="checkbox" class="icheckbox chkAll" name="IPProgramKod" value="@item.ProgramKod" @item.YetkiVar.ToChecked()>
                                                                                    <span class="programAdlari" style="font-size:8pt;">@item.ProgramAdi </span>
                                                                                </label>
                                                                            </div>
                                                                        </td>                                               
                                                                    </tr>
                                                                }
                                                            </table>
                                                        </div>
                                                    </td>
                                                </tr>   
                                            <tr>
                                                <td id="filtreKelime" colspan="2"></td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <div class="panel-footer" style="text-align:center;height:35px;padding-top:1px;padding-bottom:1px;">

                    <button class="btn btn-primary"><i class="fa fa-save"></i>Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>                                                                         
