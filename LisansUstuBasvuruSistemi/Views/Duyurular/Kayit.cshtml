@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model Duyurular
@{
    var MmMessage = ViewBag.MmMessage as MmMessage;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var duyuruPopupTipleris = (List<DuyuruPopupTipleri>)ViewBag.DuyuruPopupTipleris;
    var allChecked = duyuruPopupTipleris.All(a => Model.DuyuruPopuplars.Any(d => d.DuyuruPopupTipID == a.DuyuruPupupTipID));
}

<div class="row">
    <form method="post" class="form-horizontal" enctype="multipart/form-data" role="form">
        <input type="text" style="display:none;" id="DuyuruID" name="DuyuruID" value="@Model.DuyuruID" />
        <div class="col-md-12">
            <div class="panel panel-success">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-bullhorn"></i> Duyuru Yayınlama İşlemi</h3>
                    <ul class="panel-controls">
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Kayit", Model.DuyuruID)';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>


                <div class="panel-body">
                    <div class="panel panel-default form-horizontal">
                        <div class="panel-body form-group-separated">
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Enstitü</label>
                                <div class="col-md-9 col-xs-8">
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Duyuru Tarihi</label>
                                <div class="col-md-9 col-xs-8">
                                    <input class="form-control form-control-inline input-medium" autocomplete="off" size="16" type="text" value="@Model.Tarih.ToFormatDateAndTimeInput()" name="Tarih" id="Tarih">
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Duyurunun Yayınlanacağı Son Tarih</label>
                                <div class="col-md-9 col-xs-8">
                                    <input class="form-control form-control-inline input-medium" autocomplete="off" size="16" type="text" value="@Model.YayinSonTarih.ToFormatDateAndTimeInput()" name="YayinSonTarih" id="YayinSonTarih">
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Duyuruyu En Üste Sabitle</label>
                                <div class="col-md-9 col-xs-8">
                                    <div class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="info" data-off="danger">
                                        <input type="checkbox" value="true" name="IsEnUsteSabitle" class="toggle" @Model.IsEnUsteSabitle.ToChecked() />
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Ana Sayfada Gözüksün</label>
                                <div class="col-md-9 col-xs-8">
                                    <div class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="info" data-off="danger">
                                        <input type="checkbox" value="true" name="AnaSayfadaGozuksun" class="toggle" @Model.AnaSayfadaGozuksun.ToChecked() />
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label"></label>
                                <div class="col-md-9 col-xs-8"> 
                                    <div class="panel panel-default">
                                        <div class="panel-heading padding-0">
                                            <h3 class="panel-title" style="font-size:9pt;">Duyurunun Popup Olarak Açılacağı Sayfalar</h3>
                                            <ul class="panel-controls">
                                                <li>
                                                    Tümü:<div class="make-switch switch-small" data-on-label="Evet" data-off-label="Hayır">
                                                        <input type="checkbox" value="true"  onchange="tumunusec(this)" class="toggle" @allChecked.ToChecked() />
                                                    </div>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="panel-body padding-0" style="height: 300px; overflow: auto;">
                                            <table class="chks" style="width:100%;table-layout:fixed;">
                                                @foreach (var duyuruPopupTipi in duyuruPopupTipleris)
                                                {
                                                    var isChecked = Model.DuyuruPopuplars.Any(a => a.DuyuruPopupTipID == duyuruPopupTipi.DuyuruPupupTipID);
                                                    <tr>
                                                        <td>
                                                            <div class="checkbox pull-left">
                                                                <label>
                                                                    <input type="checkbox" class="icheckbox" name="duyuruPopupTipIds" value="@duyuruPopupTipi.DuyuruPupupTipID" @isChecked.ToChecked()/> 
                                                                    @duyuruPopupTipi.PopupTipAdi 
                                                                </label>
                                                            </div>
                                                        </td>
                                                    </tr>

                                                }

                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Başlık</label>
                                <div class="col-md-9 col-xs-8">
                                    <input type="text" name="Baslik" id="Baslik" value="@Model.Baslik" class="form-control">

                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-md-12 col-xs-12">
                                    <div>
                                        <textarea id="AciklamaHtml" name="AciklamaHtml" class="form-control Ckeditor">@Model.AciklamaHtml</textarea>
                                        <textarea style="display: none;" id="Aciklama" name="Aciklama">@Model.Aciklama</textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-md-12 col-xs-12">
                                    <div>
                                        <img src="~/Images/Attachment.png" style="height: 16px;" /><span> Duyuru Ekleri:</span>
                                        <table id="tableEk" class="table table-striped table-hover table-bordered" style="width: 100%; table-layout: fixed;">

                                            <tr class="AnaRow">
                                                <th style="width: 30px; padding:0px;">S.No</th>
                                                <th style="padding: 0px;">Ek Adı</th>
                                                <th style="padding: 0px;">Ek </th>
                                                <th style="padding: 0px; width: 35px;"></th>
                                            </tr>
                                            @foreach (var item in Model.DuyuruEkleris.Select((s, inx) => new { s, inx }))
                                            {
                                                <tr class="Detay">
                                                    <td style="padding:0px;vertical-align:middle;" class="Sno">
                                                        @(item.inx + 1))
                                                    </td>
                                                    <td style='padding: 0px;'>
                                                        <input type="text" name="DuyuruDosyaEkID" style="display: none;" value="@item.s.DuyuruDosyaEkID" />
                                                        <input type="text" name="DosyaEkiAdi" style="padding: 0px; height: 22px; " value="@item.s.DosyaEkAdi" maxlength="250" placeholder="Ek Adı Giriniz" class="form-control" />
                                                    </td>
                                                    <td style='padding: 0px; vertical-align: middle;'>
                                                        <a href="@item.s.DosyaYolu" target="_blank"><span class="fa fa-download" style="color: green;"></span>&nbsp;@item.s.DosyaEkAdi</a>
                                                    </td>
                                                    <td style='padding-top: 0px;padding-bottom:0px; vertical-align: middle;text-align:center;'>
                                                        <span style="cursor:pointer;" onclick="EkSil(this)" class="fa fa-trash-o" data-original-title="Eki Sil"></span>
                                                    </td>
                                                </tr>
                                            }

                                            <tr class="foterRow">
                                                <td colspan="4" style="text-align: center;">
                                                    <a href="javascript:void(0)" onclick="yeniEkEkle()" class="btn btn-xs btn-success"><i class="fa fa-plus tooltips" data-style="blue" data-original-title=""></i> Yeni Ek Ekle</a>
                                                </td>
                                            </tr>
                                        </table>

                                    </div>
                                </div>
                            </div>
                            @if (Model.DuyuruID > 0)
                            {
                                <div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">Durum</label>
                                    <div class="col-md-9 col-xs-8">
                                        <div class="make-switch" data-on-label="Aktif" data-off-label="Pasif" data-on="info" data-off="danger">
                                            <input type="checkbox" value="true" name="IsAktif" class="toggle" @Model.IsAktif.ToChecked() />
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply"></i>Geri Dön</a>
                    <a class="btn btn-primary pull-right" onclick="sbmtDosyaKontrol()"><i class="fa fa-save"></i>Kaydet</a>
                </div>
            </div>
        </div>
    </form>
</div>
<script src="~/Content/ckeditor/ckeditor.js"></script>
<script src="~/Content/ckeditor/showCk.js"></script>
<script>
    function tumunusec(sndr) {
        var parBox = $(sndr).parents(".panel").first();
        var kategori = $(parBox).find('.chks').first();
        var chkD = $(sndr).prop("checked");
        $(kategori).find(":checkbox").each(function (inx, itmx) {
            if (chkD) { $(itmx).parent().addClass("checked"); }
            else { $(itmx).parent().removeClass("checked"); }
            $(itmx).prop("checked", chkD);
        });


    }
    $(function () {
        $('#Tarih').datetimepicker({
            lang: 'tr',
            timepicker: true,
            format: 'Y-m-d H:i'
        });
        $('#YayinSonTarih').datetimepicker({
            lang: 'tr',
            timepicker: true,
            format: 'Y-m-d H:i'
        });

        var model = '@Html.Raw(Json.Encode(MmMessage))';
        validateControl(model);
    });

    $("form").submit(function (event) {
        var txt = CKEDITOR.instances.AciklamaHtml.document.getBody().getText();
        $('#Aciklama').val(txt);
    });

    function yeniEkEkle() {
        var row = "<tr class='Detay'>" +
                       "<td style='padding:0px;vertical-align:middle;' class='Sno'></td>" +
                        "<td style='padding:0px;' ><input type='text' name='DuyuruDosyaEkID' style='display: none;'/><input type='text'name='DosyaEkiAdi' maxlength='250' style='padding: 0px; height: 22px;' placeholder='Ek Adı Giriniz' class='form-control' /></td>" +
                        "<td style='padding:0px;'><input type='file' name='DosyaEki' style='padding: 0px; height: 22px;'  class='form-control' /></td>" +
                        "<td style='padding-top:0px;padding-bottom:0px;vertical-align:middle;text-align:center;'>" +
                             "<span style='cursor:pointer;' onclick='EkSil(this)' class='fa fa-trash-o' data-original-title='Eki Sil'></span>" +
                        "</td>" +
                   "</tr>";

        $(row).insertBefore('.foterRow');
        SnoVer();
    }
    function EkSil(sndr) {
        $(sndr).parents('tr').first().remove();
        SnoVer();
    }
    function SnoVer() {
        setTimeout(function () {
            $('#tableEk').find('.Detay').each(function (inx, itmx) {
                var sNoTd = $(itmx).find('td').first().text((inx + 1) + ")");
            })
        }, 200);
    }
    function sbmtDosyaKontrol() {

        var saveOk = true;
        $('#tableEk').find('.Detay').each(function (inx, itmx) {
            var duyuruDosyaAdi = $(itmx).find('td').eq(1).find("input[name='DosyaEkiAdi']").first().val();
            var duyuruDosyaEki = "";
            if ($(itmx).find('td').eq(1).find("input").first() != null && $(itmx).find('td').eq(1).find("input").first() != "") {
                duyuruDosyaEki = $(itmx).find('td').eq(2).find("input").first().val();
            }
            if (duyuruDosyaAdi == "") {
                saveOk = false;
                $(itmx).find('td').eq(1).pulsate({
                    color: "#fdbe41",
                    reach: 100,
                    repeat: 3,
                    speed: 400,
                    glow: true
                });
            }
            if (duyuruDosyaEki == "") {
                $(itmx).find('td').eq(2).pulsate({
                    color: "#fdbe41",
                    reach: 100,
                    repeat: 3,
                    speed: 400,
                    glow: true
                });
            }
        });

        if ($('#Baslik').val() == "") {
            saveOk = false;
            $('#Baslik').parents('div').first().pulsate({
                color: "#fdbe41",
                reach: 100,
                repeat: 3,
                speed: 400,
                glow: true
            });
        }
        var txt = CKEDITOR.instances.AciklamaHtml.document.getBody().getText().trim();
        if (txt == "") {
            saveOk = false;
            $('#AciklamaHtml').parents('div').first().pulsate({
                color: "#fdbe41",
                reach: 100,
                repeat: 3,
                speed: 400,
                glow: true
            });
        }
        if ($('#Tarih').val() == "") {
            saveOk = false;
            $('#Tarih').parents('div').first().pulsate({
                color: "#fdbe41",
                reach: 100,
                repeat: 3,
                speed: 400,
                glow: true
            });
        }
        if (saveOk) $('form').submit();
        else return saveOk;
    }
</script>

