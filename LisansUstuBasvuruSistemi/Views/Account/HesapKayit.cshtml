                                                        <img class="pImageD" src="@Model.ResimAdi.ToKullaniciResim()" alt="Profil" />
                                                    </div>
                                                    <div class="actions _EditImg">
                                                        <button type="button" class="btn-soft" onclick="ShowFileD()">
                                                            <i class="fa fa-image"></i> @(Model.ResimAdi.IsNullOrWhiteSpace() ? "Resim Yükle" : "Resmi Değiştir")
                                                        </button>
                                                    </div>
                                                    @if (!Model.ResimAdi.IsNullOrWhiteSpace() && !Model.ResimAdi.Contains("whoisUsr.png"))
                                                    {
                                                        <div class="actions _EditImg">
                                                            <button type="button" class="btn-rotate" onclick="RotateImage(true)">
                                                                <i class="fa fa-rotate-left"></i> Sola Döndür
                                                            </button>
                                                            <button type="button" class="btn-rotate" onclick="RotateImage(false)">
                                                                <i class="fa fa-rotate-right"></i> Sağa Döndür
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                         
                                        <tr>
                                            <td width="140">YTÜ Öğrencisi Misiniz?</td>
