                                                    @{
                                                        var ogrenimDurumList = ViewBag.OgrenimDurumID as SelectList;
                                                        var ogrenimDurumAdi = ogrenimDurumList?.FirstOrDefault(o => o.Value == Model.OgrenimDurumID.ToString())?.Text ?? "";
                                                    }
                                                    <input type="text" value="@ogrenimDurumAdi" class="form-control" readonly style="background-color:#f5f5f5;">
                                                    @Html.HiddenFor(m => m.OgrenimDurumID)
                                                </td>
                                            </tr>
