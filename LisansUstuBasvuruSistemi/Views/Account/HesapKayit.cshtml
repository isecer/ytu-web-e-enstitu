<script src="~/Scripts/inputTextChangeUpperCase.js"></script>
<script>
    var globalIsOgrenci = @(isOgrenci ? "true" : "false");
    var globalIsGuncelleme = @(isGuncelleme ? "true" : "false");

    $('.date-pickerx').datetimepicker({
        timepicker: false,
        format: 'Y-m-d'
    });
    $.datetimepicker.setLocale('tr');

    $('#frmHesapKayit').find('input').each(function (ix, inx) {
        $(inx).attr('autocomplete', 'off');
    });
    $("#CepTel").on('input', function () {
        this.value = this.value.replace(/\D/g, '');
        if (this.value.length > 11) {
            this.value = this.value.substr(0, 11);
        }
    });

    $(document).ready(function() {
        var ptipID = $('#KullaniciTipID').val();
        if (ptipID != null && ptipID != "") {
            KullaniciTipKontrol();
        }

        ytuOgrKontrol();
    });

    function KullaniciTipKontrol() {
        var ptipID = $('#KullaniciTipID').val();
        if (ptipID == null || ptipID == "") {
            $('.cKayitGrup').addClass("hide");
            return;
        }

        $.ajax({
            url: '@Url.Action("KullaniciTipKontrol", "Account")',
            data: { id: ptipID },
            success: function (result) {
                $('.cKayitGrup').removeClass("hide");
                $('#IsKurumIci').val(result.KurumIci);
                $('#IsYerli').val(result.Yerli);

                var isOgrenciTip = !result.KurumIci;
                globalIsOgrenci = isOgrenciTip;

                if (isOgrenciTip) {
                    $('#YtuOgrencisi').val('true');
                    $('#YtuOgrencisi').prop('disabled', true).css('background-color', '#f5f5f5');
                    ytuOgrKontrol();
                } else {
                    $('#YtuOgrencisi').prop('disabled', false).css('background-color', '#fff');
                }

                if (result.KurumIci) {
                    $('#adresRow').hide();
                    $('#personelBilgi').show();
                } else {
                    $('#adresRow').show();
                    $('#personelBilgi').hide();
                }

                if (ptipID == '@((int)KullaniciTipiEnum.AkademikPersonel)' || ptipID == '@((int)KullaniciTipiEnum.IdariPersonel)') {
                    getUnvanlar();
                }
            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }

    function ytuOgrKontrol() {
        var isYtuOgrenci = $('#YtuOgrencisi').val() === 'true';

        if (isYtuOgrenci) {
            // YTÜ Öğrencisi EVET
            $('.ytuOgrenciAlanlari').show();
            $('#tcKimlikRow').hide(); // Alt TC gizle
            $('#kimlikAyirici').hide(); // Ayırıcı gizle

            // TC Kimlik değerini üstteki alana taşı
            if ($('#TcKimlikNo_Yedek').val()) {
                $('#TcKimlikNo').val($('#TcKimlikNo_Yedek').val());
            }

            // Normal inputları gizle
            $('.normalInput').remove();

            // İletişim bilgilerini gizle (doğrulamadan sonra gösterilecek)
            if (!globalIsGuncelleme || $('#ogrenciDogrulandiMi').val() !== 'true') {
                $('#EMail').closest('tr').hide();
                $('#CepTel').closest('tr').hide();
                $('#Adres').closest('tr').hide();
            }
        }
        else {
            // YTÜ Öğrencisi HAYIR
            $('.ytuOgrenciAlanlari').hide();
            $('#tcKimlikRow').show(); // Alt TC göster
            $('#kimlikAyirici').show(); // Ayırıcı göster
            $('#ogrenciDogrulandiMi').val('true'); // Doğrulama gerekmiyor

            // TC Kimlik değerini alt alana taşı
            if ($('#TcKimlikNo').val()) {
                $('#TcKimlikNo_Yedek').val($('#TcKimlikNo').val());
            }

            // Eğer personel ise normal inputları göster
            if (!globalIsOgrenci) {
                // Kimlik bilgileri - normal inputlar ekle
                if ($('.normalInput').length === 0 && !$('.obsReadonlyField').length) {
                    var adInput = '<tr class="normalInput">' +
                        '<td width="140">Ad</td>' +
                        '<td width="10">:</td>' +
                        '<td class="form-group">' +
                        '<input type="text" name="Ad" id="Ad" value="" class="form-control UpperTextTr">' +
                        '</td>' +
                        '</tr>';
                    var soyadInput = '<tr class="normalInput">' +
                        '<td>Soyad</td>' +
                        '<td>:</td>' +
                        '<td class="form-group">' +
                        '<input type="text" name="Soyad" id="Soyad" value="" class="form-control UpperTextTr">' +
                        '</td>' +
                        '</tr>';
                    var cinsiyetInput = '<tr class="normalInput">' +
                        '<td>Cinsiyet</td>' +
                        '<td>:</td>' +
                        '<td class="form-group">' +
                        '<select name="CinsiyetID" id="CinsiyetID" class="form-control">' +
                        '<option value="">Seçiniz</option>' +
                        '<option value="1">Erkek</option>' +
                        '<option value="2">Kadın</option>' +
                        '</select>' +
                        '</td>' +
                        '</tr>';

                    $('#tcKimlikRow').after(adInput + soyadInput + cinsiyetInput);
                }

                // İletişim bilgilerini göster + Kullanıcı adı uyarısı
                $('#EMail').closest('tr').show();
                $('#CepTel').closest('tr').show();
                $('#Adres').closest('tr').show();

                // E-posta kullanıcı adı uyarısı ekle - SADECE YENİ KAYITLARDA
                if ($('#emailNote').length && $('#emailNote').text().trim() === '' && !globalIsGuncelleme) {
                    $('#emailNote').html('<i class="fa fa-info-circle"></i> <strong>E-posta adresiniz sisteme giriş için kullanıcı adınız olacaktır.</strong>').show();
                }
            }
        }
    }

    function getUnvanlar() {
        var kullaniciTipId = $('#KullaniciTipID').val();
        var selectedUnvanId = '@Model.UnvanID';
        var _panel = $('#personelBilgi');
        PanelRefresh(_panel, false);

        if (kullaniciTipId != null && kullaniciTipId != "") {
            $.ajax({
                url: '@Url.Action("GetUnvanlar", "Ajax")',
                data: { 'kullaniciTipId': kullaniciTipId },
                success: function (result) {
                    PanelRefresh(_panel, true);
                    var opt = "";
                    for (var i = 0; i < result.length; i++) {
                        var isSelected = result[i].Value == selectedUnvanId ? ' selected="selected"' : '';
                        opt += "<option value='" + result[i].Value + "'" + isSelected + ">" + result[i].Caption + "</option>";
                    }
                    $('#UnvanID').empty();
                    $('#UnvanID').append(opt);
                },
                error: function (err) {
                    PanelRefresh(_panel, true);
                    alert(err.responseText);
                }
            });
        }
    }

    function RotateImage(rotate) {
        var _panel = $('#pImageD');
        PanelRefresh(_panel, false);
        var ResimAdi = $('#ResimAdi').val();

        setTimeout(function () {
            $.ajax({
                url: '@Url.Action("RotateImage", "Account")',
                data: { LeftOrRight: rotate, ResimAdi: ResimAdi },
                type: "POST",
                success: function (result) {
                    PanelRefresh(_panel, true);
                    var src = result.YeniResimYolu + "?time=" + new Date();
                    $('#userMainImage').attr('src', src);
                    $('.pImageD').first().attr('src', src);
                },
                error: function (err) {
                    alert(err.responseText);
                    PanelRefresh(_panel, true);
                }
            });
        }, 1000);
    }

    function ShowFileD() {
        var _panel = $('#pImageD');
        let input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = _this => {
            let files = Array.from(input.files);
            if (files.length > 0) {
                PanelRefresh(_panel, false);
                var EskiResimAdi = $('#ResimAdi').val();
                var formdata = new FormData();
                formdata.append("KullaniciID", @Model.KullaniciID);
                formdata.append("EskiResimAdi", EskiResimAdi);
                formdata.append("KImage", files[0]);

                $.ajax({
                    url: '@Url.Action("ImageUploadPost", "Account")',
                    data: formdata,
                    type: "POST",
                    contentType: false,
                    processData: false,
                    success: function (result) {
                        PanelRefresh(_panel, true);
                        if (result.mMessage.IsSuccess) {
                            var src = result.YeniResimYolu + "?time=" + new Date();
                            $('.pImageD').first().attr('src', src);
                            $('#ResimAdi').val(result.YeniResimAdi);
                            $('#userMainImage').attr('src', src);

                            if ($('#pImageD .btn-rotate').length === 0) {
                                var rotateButtons = '<div class="actions _EditImg">' +
                                    '<button type="button" class="btn-rotate" onclick="RotateImage(true)">' +
                                    '<i class="fa fa-rotate-left"></i> Sola Döndür' +
                                    '</button>' +
                                    '<button type="button" class="btn-rotate" onclick="RotateImage(false)">' +
                                    '<i class="fa fa-rotate-right"></i> Sağa Döndür' +
                                    '</button>' +
                                    '</div>';
                                $('#pImageD').append(rotateButtons);
                            }

                            toastr["success"](result.mMessage.Title, result.mMessage.Messages[0]);
                        }
                        else {
                            GetMsg(result.mMessage);
                        }
                    },
                    error: function (err) {
                        PanelRefresh(_panel, true);
                        alert(err.responseText);
                    }
                });
            }
        };
        input.click();
    }

    function OgrenciDogrula() {
        var tcKimlik = $('#TcKimlikNo').val();
        var ogrenciNo = $('#OgrenciNo').val();

        if (!tcKimlik || tcKimlik.length !== 11) {
            toastr.error('Lütfen geçerli bir T.C. Kimlik No giriniz (11 haneli)');
            $('#TcKimlikNo').focus();
            return;
        }

        if (!ogrenciNo || ogrenciNo.trim() === '') {
            toastr.error('Lütfen Öğrenci No giriniz');
            $('#OgrenciNo').focus();
            return;
        }

        var btn = $('#btnOgrenciDogrula');
        btn.prop('disabled', true);
        btn.html('<i class="fa fa-spinner fa-spin"></i> Doğrulanıyor...');
        $('#dogrulamaStatus').hide();

        $.ajax({
            url: '@Url.Action("OgrenciDogrulaVeMailGonder", "Account")',
            type: 'POST',
            data: {
                tcKimlikNo: tcKimlik,
                ogrenciNo: ogrenciNo
            },
            success: function (result) {
                if (result.IsSuccess) {
                    btn.hide();

                    $('#dogrulamaStatus').show();
                    $('#dogrulamaBasarili').show();
                    $('#dogrulamaHata').hide();
                    $('#dogrulamaEmail').text('Doğrulama kodu ' + result.Email + ' adresine gönderildi.');

                    $('#dogrulamaKoduRow').show();
                    $('#TcKimlikNo').prop('readonly', true).css('background-color', '#f5f5f5');
                    $('#OgrenciNo').prop('readonly', true).css('background-color', '#f5f5f5');

                    toastr.success('Lütfen e-postanızı kontrol ederek doğrulama kodunu giriniz.');
                } else {
                    btn.prop('disabled', false);
                    btn.html('<i class="fa fa-check-circle"></i> Öğrenci Bilgilerini Doğrula');

                    $('#dogrulamaStatus').show();
                    $('#dogrulamaBasarili').hide();
                    $('#dogrulamaHata').show();
                    $('#dogrulamaHataMesaj').html(result.Messages.join('<br>'));
                    toastr.error(result.Messages[0]);
                }
            },
            error: function (xhr) {
                btn.prop('disabled', false);
                btn.html('<i class="fa fa-check-circle"></i> Öğrenci Bilgilerini Doğrula');
                toastr.error('Bir hata oluştu. Lütfen tekrar deneyiniz.');
            }
        });
    }

    function DogrulamaKoduKontrol() {
        var kod = $('#dogrulamaKodu').val();
        var tcKimlik = $('#TcKimlikNo').val();

        if (!kod || kod.trim() === '') {
            toastr.error('Lütfen doğrulama kodunu giriniz');
            $('#dogrulamaKodu').focus();
            return;
        }

        $.ajax({
            url: '@Url.Action("DogrulamaKoduKontrol", "Account")',
            type: 'POST',
            data: {
                tcKimlikNo: tcKimlik,
                dogrulamaKodu: kod
            },
            success: function (result) {
                if (result.IsSuccess && result.Data) {
                    $('#ogrenciDogrulandiMi').val('true');
                    $('#dogrulamaKoduRow').hide();
                    $('#dogrulamaButonRow').hide();

                    // Güncelleme modunda ise butonu göster
                    if (globalIsGuncelleme) {
                        $('#ogrenciBilgiGuncelleRow').show();
                    }

                    $('#dogrulamaBilgi').html('<div><i class="fa fa-check-circle"></i> <strong>Doğrulama Tamamlandı!</strong><br><small>Bilgileriniz OBS\'den başarıyla alındı. Lütfen aşağıdaki bilgilerinizi kontrol ediniz ve sayfanın <strong>en altındaki "Kaydet" butonuna</strong> tıklayarak kaydınızı tamamlayınız.</small></div>');

                    var data = result.Data;

                    // TC Kimlik - Readonly yap
                    $('#TcKimlikNo').val(data.TcKimlikNo).prop('readonly', true).css('background-color', '#f5f5f5');

                    // Ad - Readonly input oluştur veya güncelle
                    if ($('#Ad').length) {
                        $('#Ad').val(data.Ad).prop('readonly', true).css('background-color', '#f5f5f5');
                    } else {
                        var adRow = '<tr class="obsReadonlyField">' +
                            '<td width="140">Ad</td>' +
                            '<td width="10">:</td>' +
                            '<td class="form-group">' +
                            '<input type="text" name="Ad" id="Ad" value="' + data.Ad + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                            '</td>' +
                            '</tr>';
                        $('#tcKimlikRow').after(adRow);
                    }

                    // Soyad
                    if ($('#Soyad').length) {
                        $('#Soyad').val(data.Soyad).prop('readonly', true).css('background-color', '#f5f5f5');
                    } else {
                        var soyadRow = '<tr class="obsReadonlyField">' +
                            '<td>Soyad</td>' +
                            '<td>:</td>' +
                            '<td class="form-group">' +
                            '<input type="text" name="Soyad" id="Soyad" value="' + data.Soyad + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                            '</td>' +
                            '</tr>';
                        $('#Ad').closest('tr').after(soyadRow);
                    }

                    // Cinsiyet
                    if ($('#CinsiyetID').length) {
                        $('#CinsiyetID').val(data.CinsiyetID).prop('disabled', true).css('background-color', '#f5f5f5');
                        if ($('#CinsiyetID_Hidden').length === 0) {
                            $('#CinsiyetID').after('<input type="hidden" name="CinsiyetID" id="CinsiyetID_Hidden" value="' + data.CinsiyetID + '">');
                        } else {
                            $('#CinsiyetID_Hidden').val(data.CinsiyetID);
                        }
                    } else {
                        var cinsiyetText = data.CinsiyetID == 1 ? 'Erkek' : (data.CinsiyetID == 2 ? 'Kadın' : '');
                        var cinsiyetRow = '<tr class="obsReadonlyField">' +
                            '<td>Cinsiyet</td>' +
                            '<td>:</td>' +
                            '<td class="form-group">' +
                            '<input type="text" value="' + cinsiyetText + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                            '<input type="hidden" name="CinsiyetID" value="' + data.CinsiyetID + '">' +
                            '</td>' +
                            '</tr>';
                        $('#Soyad').closest('tr').after(cinsiyetRow);
                    }

                    // E-posta - DEĞİŞTİRİLEBİLİR
                    if ($('#EMail').val() === '' || $('#EMail').val() === null) {
                        $('#EMail').val(data.EMail);
                    }

                    // E-posta notu - SADECE BİR KEZ
                    if ($('#emailNote').length) {
                        $('#emailNote').html('<i class="fa fa-info-circle"></i> OBS\'den gelen: ' + data.EMail + ' (İsterseniz değiştirebilirsiniz)').show();
                    }

                    if (data.CepTel && data.CepTel.trim() !== '') {
                        var clean = data.CepTel.trim().replace(/\D/g, '');
                        if (clean.length === 10) clean = '0' + clean;
                        $('#CepTel').val(clean);
                    }

                    // Öğrenim Bilgileri
                    var ogrenimBilgileriHTML = '<tr class="obsOgrenimBilgileri"><td colspan="3"><table style="width:100%; margin-top:15px; border-top:2px solid #dee2e6; padding-top:15px;">' +
                        '<tbody>' +
                        '<tr><td colspan="3" style="background:#e8f4f8; padding:8px; border-radius:4px; margin-bottom:10px;"><strong><i class="fa fa-check-circle text-success"></i> Öğrenim Bilgileriniz (OBS\'den Alındı)</strong></td></tr>' +
                        '<tr>' +
                        '<td width="140">Enstitü</td>' +
                        '<td width="10">:</td>' +
                        '<td class="form-group">' +
                        '<input type="text" value="' + data.EnstituAdi + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                        '<input type="hidden" name="OgrenimEnstituKod" value="' + data.OgrenimEnstituKod + '">' +
                        '<input type="hidden" name="EnstituKod" value="' + data.EnstituKod + '">' +
                        '</td>' +
                        '</tr>' +
                        '<tr>' +
                        '<td>Program</td>' +
                        '<td>:</td>' +
                        '<td class="form-group">' +
                        '<input type="text" value="' + data.ProgramAdi + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                        '<input type="hidden" name="ProgramKod" value="' + data.ProgramKod + '">' +
                        '</td>' +
                        '</tr>' +
                        '<tr>' +
                        '<td>Öğrenim Seviyesi</td>' +
                        '<td>:</td>' +
                        '<td class="form-group">' +
                        '<input type="text" value="' + data.OgrenimTipAdi + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                        '<input type="hidden" name="OgrenimTipKod" value="' + data.OgrenimTipKod + '">' +
                        '</td>' +
                        '</tr>' +
                        '<tr>' +
                        '<td>Öğrenim Durumu</td>' +
                        '<td>:</td>' +
                        '<td class="form-group">' +
                        '<input type="text" value="' + data.OgrenimDurumAdi + '" class="form-control" readonly style="background-color:#f5f5f5;">' +
                        '<input type="hidden" name="OgrenimDurumID" value="' + data.OgrenimDurumID + '">' +
                        '</td>' +
                        '</tr>' +
                        '</tbody>' +
                        '</table></td></tr>';

                    if ($('.obsOgrenimBilgileri').length === 0) {
                        $('#OgrenciNo').closest('tr').after(ogrenimBilgileriHTML);
                    } else {
                        $('.obsOgrenimBilgileri').replaceWith(ogrenimBilgileriHTML);
                    }
                    debugger
                    // İletişim bilgilerini göster
                    $('#EMail').closest('tr').show();
                    $('#CepTel').closest('tr').show();
                    if (!$('#IsKurumIci').val() || $('#IsKurumIci').val() === 'false') {
                        $('#Adres').closest('tr').show();
                    }

                    // Bilgilendirme mesajı ekle - SADECE YENİ KAYITLARDA
                    if ($('#dogrulamaTamamBilgi').length === 0 && !globalIsGuncelleme) {
                        var bilgiMesaji = '<tr id="dogrulamaTamamBilgi">' +
                            '<td colspan="3">' +
                            '<div style="background:#fff3cd; border-left:4px solid #ffc107; padding:15px; margin:15px 0; border-radius:4px;">' +
                            '<strong style="color:#856404;"><i class="fa fa-exclamation-triangle"></i> Kaydınızı Tamamlamak İçin:</strong>' +
                            '<ul style="margin:8px 0 0 0; padding-left:20px; font-size:13px; color:#856404;">' +
                            '<li><strong>E-posta adresiniz</strong> sisteme giriş için <strong>kullanıcı adınız</strong> olacaktır.</li>' +
                            '<li>İsterseniz e-posta adresinizi değiştirebilirsiniz.</li>' +
                            '<li>Tüm bilgilerinizi kontrol ettikten sonra <strong>sayfanın en altındaki "Kaydet" butonuna</strong> tıklayınız.</li>' +
                            '<li>Kayıt tamamlandıktan sonra <strong>şifreniz e-posta adresinize gönderilecektir.</strong></li>' +
                            '<li>Gönderilen şifre ile sisteme giriş yapabilirsiniz.</li>' +
                            '</ul>' +
                            '</div>' +
                            '</td>' +
                            '</tr>';
                        $('.obsOgrenimBilgileri').last().after(bilgiMesaji);
                    }

                    toastr.success('Doğrulama başarılı! Lütfen bilgilerinizi kontrol edip KAYDET butonuna tıklayınız.', '', {timeOut: 5000});
                } else {
                    toastr.error(result.Messages[0] || 'Doğrulama kodu hatalı!');
                }
            },
            error: function () {
                toastr.error('Bir hata oluştu. Lütfen tekrar deneyiniz.');
            }
        });
    }

    function OgrenciBilgileriniGuncelle() {
        $('.obsReadonlyField').remove();
        $('.obsOgrenimBilgileri').remove();
        $('#dogrulamaTamamBilgi').remove();

        $('#ogrenciDogrulandiMi').val('false');

        $('#TcKimlikNo').prop('readonly', false).css('background-color', '#fff').val('');
        $('#OgrenciNo').prop('readonly', false).css('background-color', '#fff').val('');

        // Butonu gizle
        $('#ogrenciBilgiGuncelleRow').hide();

        // İletişim bilgilerini GİZLEME - görünür kalsın

        $('#dogrulamaButonRow').show();
        $('#btnOgrenciDogrula').show().prop('disabled', false).html('<i class="fa fa-check-circle"></i> Öğrenci Bilgilerini Doğrula');
        $('#dogrulamaBilgi').html(
            '<strong><i class="fa fa-info-circle"></i> Öğrenci Bilgilerini Güncelleme:</strong>' +
            '<ul style="margin:8px 0 0 0; padding-left:20px; font-size:12px;">' +
            '<li>Yeni <strong>TC Kimlik ve Öğrenci Numaranızı</strong> giriniz.</li>' +
            '<li><strong>"Öğrenci Bilgilerini Doğrula"</strong> butonuna tıklayarak güncel bilgilerinizi alınız.</li>' +
            '</ul>').show();

        $('#emailNote').html('').hide();

        toastr.info('Öğrenci bilgilerinizi güncellemek için doğrulama yapınız.');
    }

    $('#frmHesapKayit').on('submit', function (e) {
        var cepTel = $('#CepTel').val();
        if (cepTel && cepTel.trim() !== '') {
            var clean = cepTel.replace(/\D/g, '');

            // 10 haneli ve 0 ile başlamıyorsa başına 0 ekle
            if (clean.length === 10 && !clean.startsWith('0')) {
                clean = '0' + clean;
            }

            // Validasyonlar
            if (clean.length !== 11) {
                e.preventDefault();
                toastr.error('Cep telefonu 11 haneli olmalıdır');
                $('#CepTel').focus();
                return false;
            }

            if (!clean.startsWith('05')) {
                e.preventDefault();
                toastr.error('Cep telefonu 05 ile başlamalıdır');
                $('#CepTel').focus();
                return false;
            }

            $('#CepTel').val(clean);
        }
        // TC Kimlik alanlarını birleştir
        var ytuOgrencisi = $('#YtuOgrencisi').val() === 'true';
        if (ytuOgrencisi) {
            // YTÜ Evet ise - üstteki TC'yi kullan
            $('#TcKimlikNo_Yedek').val($('#TcKimlikNo').val());
        } else {
            // YTÜ Hayır ise - alttaki TC'yi kullan ve üste kopyala
            $('#TcKimlikNo').val($('#TcKimlikNo_Yedek').val());
        }

        var ogrenciNo = $('#OgrenciNo').val();

        if (globalIsOgrenci && !ytuOgrencisi) {
            e.preventDefault();
            toastr.error('Öğrenci kullanıcı tipi için "YTÜ Öğrencisi" alanı zorunludur!');
            return false;
        }

        if (ytuOgrencisi && ogrenciNo && ogrenciNo.trim() !== '') {
            var dogrulandiMi = $('#ogrenciDogrulandiMi').val();
            if (dogrulandiMi !== 'true') {
                e.preventDefault();
                toastr.error('Lütfen önce öğrenci bilgilerinizi doğrulayınız!');
                $('html, body').animate({
                    scrollTop: $('#btnOgrenciDogrula').offset().top - 100
                }, 500);
                return false;
            }
        }
    });
</script>
