@using Entities.Entities
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model Kullanicilar
@{
    Layout = null;
    var isKurumIci = (bool)ViewBag.IsKurumIci;
    var isYerli = (bool)ViewBag.IsYerli;
    var kullaniciYetki = RoleNames.KullanicilarKayit.InRoleCurrent();
    var kulTipAdi = (string)ViewBag.KullaniciTipAdi;
    var isOgrenci = new List<int> { (int)KullaniciTipiEnum.YerliOgrenci, (int)KullaniciTipiEnum.YabanciOgrenci }.Contains(Model.KullaniciTipID);
    var isGuncelleme = Model.KullaniciID > 0;
    var dogrulanmisMi = isGuncelleme && Model.YtuOgrencisi && !string.IsNullOrWhiteSpace(Model.OgrenciNo);
}
<style>
    .profile-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 20px 15px;
        border-radius: 8px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
        margin: 10px auto 15px auto;
        max-width: 320px;
        position: relative;
    }

    .profile-card .panel-refresh {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        right: 0 !important;
        bottom: 0 !important;
        width: 100% !important;
        height: 100% !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        background: rgba(248, 249, 250, 0.95) !important;
        border-radius: 8px !important;
        z-index: 10 !important;
    }

    .profile-card .preview {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #fff;
        box-shadow: 0 2px 6px rgba(0,0,0,.12);
        background: #fff;
    }

    .profile-card .preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-card .actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn-soft {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 0;
        border-radius: 6px;
        padding: 8px 18px;
        font-weight: 600;
        font-size: 13px;
        background: #007bff;
        color: #fff;
        cursor: pointer;
        transition: all .2s ease;
    }

    .btn-soft:hover {
        background: #0056b3;
    }

    .btn-rotate {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border: 1px solid #6c757d;
        border-radius: 5px;
        background: #fff;
        color: #6c757d;
        font-weight: 500;
        font-size: 12px;
        cursor: pointer;
        transition: all .2s ease;
    }

    .btn-rotate:hover {
        background: #6c757d;
        color: #fff;
    }

    .ytuOgrenciAlanlari {
        display: none;
    }

    input:disabled, select:disabled, input:read-only {
        background-color: #f5f5f5 !important;
        cursor: not-allowed;
        opacity: 0.8;
    }

    @@media (max-width: 768px) {
        .profile-card {
            max-width: 100%;
            padding: 18px 12px;
        }

        .profile-card .preview {
            width: 90px;
            height: 90px;
        }
    }
</style>

<div class="row">
    @using (Ajax.BeginForm("HesapKayit", "Account", null, new AjaxOptions() { HttpMethod = "POST" }, new { enctype = "multipart/form-data", id = "frmHesapKayit", @class = "form-horizontal" }))
    {
        @Html.HiddenFor(h => h.KullaniciID)
        @Html.HiddenFor(h => h.ResimAdi)
        @Html.Hidden("IsKurumIci", isKurumIci)
