            <!-- 1. HESAP SEÇİMİ -->
            <div class="widget widget-default" style="border-top:1px solid;border-top-color:lightgray; margin-bottom:8px;padding:6px 10px;min-height:20px;">
                <table style="width:100%;">
                    <tbody>
                        <tr>
                            <td style="font-weight:bold;font-size:11pt; border-bottom:1px solid;">
                                <i class="fa fa-home fa-lg"></i> Hesap Seçimi
                            </td>
                        </tr>
                        <tr>
                            <td style="padding-left:10px;text-align:left;">
                                <table style="width:100%;">
                                    <tbody>
                                        <tr>
                                            <td width="140">Kullanıcı Tipi</td>
                                            <td width="10">:</td>
                                            <td class="form-group">
                                                @if (kullaniciYetki || Model.KullaniciID <= 0)
                                                {
                                                    @Html.DropDownList("KullaniciTipID", null, new { @class = "form-control", onChange = "KullaniciTipKontrol()" })
                                                }
                                                else
                                                {
                                                    @kulTipAdi
                                                    @Html.HiddenFor(h => h.KullaniciTipID)
                                                }
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

