                                                                            window.open(url, '_blank');
                                                                        }
                                                                    </script>*@

                                                                </div>

                                                                <input type="hidden" id="ogrenciDogrulandiMi" value="@(dogrulanmisMi ? "true" : "false")">
                                                            </td>
                                                        </tr>
                                                         
                                                        <tr id="dogrulamaKoduRow" style="display:none;">
                                                            <td>Doğrulama Kodu</td>
                                                            <td>:</td>
                                                            <td class="form-group">
                                                                <input type="text" id="dogrulamaKodu" maxlength="6" class="form-control"
                                                                       placeholder="E-postanıza gelen 6 haneli kodu giriniz">
                                                                <button type="button" class="btn btn-success" onclick="DogrulamaKoduKontrol()"
                                                                        style="margin-top:5px; width:100%;">
                                                                    <i class="fa fa-key"></i> Doğrulama Kodunu Onayla
                                                                </button>
                                                            </td>
                                                        </tr>

                                                        @if (isGuncelleme && Model.YtuOgrencisi && !string.IsNullOrWhiteSpace(Model.OgrenciNo) && dogrulanmisMi)
                                                        {
                                                            <tr id="ogrenciBilgiGuncelleRow">
                                                                <td colspan="3" style="text-align:center; padding:10px 0;">
                                                                    <button type="button" class="btn btn-warning btn-sm" onclick="OgrenciBilgileriniGuncelle()" style="width:auto;">
