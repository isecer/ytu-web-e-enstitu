@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using BiskaUtil
@model kmKotalar
@{
    var MmMessage = ViewBag.MmMessage as MmMessage;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <form method="post" class="form-horizontal" role="form">
        <input type="text" style="display:none;" id="KotaID" name="KotaID" value="@Model.KotaID" />
        <div class="col-md-12 col-md-12 col-md-12">
            <div class="panel panel-default" id="pnglKT">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i>&nbsp; @(Model.KotaID == 0 ? "Yeni Yatay Geçiş kotası tanımlama işlemi" : "Yatay Geçiş kota bilgisi düzenleme işlemi")</h3>
                    <ul class="panel-controls">
                        <li><a href="@Url.Action("Kayit", Model.KotaID)" class=""><span class="fa fa-refresh panel-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <div class="panel panel-default form-horizontal">
                        <div class="panel-body form-group-separated">
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Enstitü</label>
                                <div class="col-md-9 col-xs-8">
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", onChange = "getData(this);getOgrenimTips(this);" })
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Anabilim Dalı</label>
                                <div class="col-md-9 col-xs-8">
                                    @Html.DropDownList("AnabilimDaliKod", null, new { @class = "form-control", onChange = "getData(this);" })
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Program</label>
                                <div class="col-md-9 col-xs-8">
                                    @Html.DropDownList("ProgramKod", null, new { @class = "form-control" })
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Öğrenim Tipi</label>
                                <div class="col-md-9 col-xs-8">
                                    @Html.DropDownList("OgrenimTipKod", null, new { @class = "form-control", onchange = "mlktKontrol(this)" })
                                    <script>
                                        function mlktKontrol() {
                                            var sVal = $("#OgrenimTipKod").val();

                                            if (sVal == "@OgrenimTipi.TezliYuksekLisans") {
                                                $('.mlktC').removeClass('hide');
                                            }
                                            else {

                                                $('.mlktC').addClass('hide');
                                            }
                                            var EnstituKodVal = $('#EnstituKod').val();
                                            if (EnstituKodVal == '@EnstituKodlari.SosyalBilimleri') {

                                                    $('.dsyC').removeClass('hide');

                                            }
                                            else {
                                                $('.dsyC').addClass('hide');
                                            }
                                        }
                                    </script>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Ortak Kota</label>
                                <div class="col-md-9 col-xs-8">
                                    <div class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="warning" data-off="info">
                                        <input type="checkbox" value="true" name="OrtakKota" id="OrtakKota" onchange="kotaKontrol();" class="toggle" @Model.OrtakKota.ToChecked() />
                                    </div>
                                </div>
                            </div>
                            <div id="_OrtakKota1" class="form-group @(Model.OrtakKota? "hide" : "")">
                                <div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">Alaniçi Kota</label>
                                    <div class="col-md-9 col-xs-8">
                                        <input type="text" name="AlanIciKota" id="AlanIciKota" value="@Model.AlanIciKota" class="form-control" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">Alandışı Kota</label>
                                    <div class="col-md-9 col-xs-8">
                                        <input type="text" name="AlanDisiKota" id="AlanDisiKota" value="@Model.AlanDisiKota" class="form-control" />
                                    </div>
                                </div>
                            </div>
                            <div id="_OrtakKota2" class="form-group @(Model.OrtakKota? "" : "hide")">
                                <div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">Ortak Kota Sayısı</label>
                                    <div class="col-md-9 col-xs-8">
                                        <input type="text" name="OrtakKotaSayisi" id="OrtakKotaSayisi" value="@Model.OrtakKotaSayisi" class="form-control" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-group mlktC @(Model.OgrenimTipKod==OgrenimTipi.TezliYuksekLisans?"":"hide")">
                                <label class="col-md-3 col-xs-4 control-label">Mülakata Girecek mi?</label>
                                <div class="col-md-9 col-xs-8">
                                    <div class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="info" data-off="danger">
                                        <input type="hidden" name="MulakatSurecineGirecek" id="MulakatSurecineGirecek" value="@Model.MulakatSurecineGirecek.Value.ToString().ToLower()" />
                                        <input type="checkbox" value="true" onchange="$('#MulakatSurecineGirecek').val($(this).prop('checked').toString().toLowerCase()); mlktKontrol();" class="toggle" @Model.MulakatSurecineGirecek.Value.ToChecked() />
                                    </div>

                                </div>
                            </div>
                            <div class="form-group dsyC">
                                <label class="col-md-3 col-xs-4 control-label">Ales yerine Dosya Notu istensin mi?</label>
                                <div class="col-md-9 col-xs-8">
                                    <div class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="info" data-off="danger">
                                        <input type="checkbox" value="true" name="IsAlesYerineDosyaNotuIstensin" id="IsAlesYerineDosyaNotuIstensin" class="toggle" @Model.IsAlesYerineDosyaNotuIstensin.Value.ToChecked() />
                                    </div>

                                </div>
                            </div>

                            @*<div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">MinAles</label>
                                    <div class="col-md-9 col-xs-8">
                                        <input type="text" name="MinAles" id="MinAles" value="@Model.MinAles" class="form-control" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">MinAGNO</label>
                                    <div class="col-md-9 col-xs-8">
                                        <input type="text" name="MinAGNO" id="MinAGNO" value="@Model.MinAGNO" class="form-control" />
                                    </div>
                                </div>*@

                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply">&nbsp</i>Geri Dön</a>
                    <button class="btn btn-primary pull-right"><i class="fa fa-save">&nbsp</i>Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>
<script type='text/javascript' src='/Content/js/plugins/icheck/icheck.min.js'></script>
<script>
    function kotaKontrol() {
        var $sndr = $('#OrtakKota');
        if ($sndr.prop('checked')) {
            $('#_OrtakKota1').addClass('hide');
            $('#_OrtakKota2').removeClass('hide');
        }
        else {
            $('#_OrtakKota1').removeClass('hide');
            $('#_OrtakKota2').addClass('hide');
        }

    }
    $(function () {
        var model = '@Html.Raw(Json.Encode(MmMessage))';
        validateControl(model);
        mlktKontrol();
    });
    function getData(sndr) {
        var _panel = $('#pnglKT');
        _pRefresh(_panel, false);
        var sndrVal = $(sndr).val();
        var tip = $(sndr).attr('id') == "EnstituKod" ? "bolum" : "program";
        var EnstituKod = $('#EnstituKod').val();



        if (tip == "bolum") {
            $('#AnabilimDaliKod').empty();
            $('#ProgramKod').empty();
        }
        else {
            $('#ProgramKod').empty();
        }
        if (sndrVal != null && sndrVal != "") {
            $.ajax({
                url: '@Url.Action("getKullaniciBolumProgramList", "Ajax")',
                data: { 'EnstituKod': EnstituKod, 'BolumKod': sndrVal, 'Tip': tip },
                success: function (result) {
                    var opt = "";
                    for (var i = 0; i < result.length; i++) {
                        opt += "<option value=" + result[i].Value + ">" + result[i].Caption + "</option>"
                    }
                    if (tip == "bolum") {
                        $('#AnabilimDaliKod').empty();
                        $('#ProgramKod').empty();
                        $('#AnabilimDaliKod').append(opt);
                    }
                    else {
                        $('#ProgramKod').empty();
                        $('#ProgramKod').append(opt);
                    }
                    _pRefresh(_panel, true);

                },
                error: function (err) {
                    alert(err.responseText);
                    _pRefresh(_panel, true);
                }
            });
        }
        else {
            _pRefresh(_panel, true);

        }
    }
    function getOgrenimTips(sndr) {
        var sndrVal = $(sndr).val();
        mlktKontrol();
        if (sndrVal != null && sndrVal != "") {
            $.ajax({
                url: '@Url.Action("getOts", "Ajax")',
                data: { 'EnstituKod': sndrVal },
                success: function (result) {
                    var opt = "";
                    for (var i = 0; i < result.length; i++) {
                        opt += "<option value=" + result[i].Value + ">" + result[i].Caption + "</option>"
                    }

                    $('#OgrenimTipKod').empty();
                    $('#OgrenimTipKod').append(opt);


                },
                error: function (err) {
                    alert(err.responseText);

                }
            });
        }
        else {
            $('#OgrenimTipKod').empty();
        }
    }
</script>
