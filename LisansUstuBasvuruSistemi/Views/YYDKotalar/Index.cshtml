@using LisansUstuBasvuruSistemi.Models @using LisansUstuBasvuruSistemi.Models.FilterModel
@using BiskaUtil
@model  fmKotalar
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm("Index", "YYDKotalar", FormMethod.Post, new { id = "frmKotalar" }))
    {
        <div class="col-md-12">
            @Html.Hidden("export", false)
            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <table style="width:100%;table-layout:fixed;">
                        <tr>
                            <td><h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp;YTU Yeni Mezun DR Kota Listesi</h3></td>
                            <td style="width:380px;">
                                <table>
                                    <tr>
                                        <td style="width:150px;">@Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;", onChange = "$('#frmKotalar').submit()" })</td>
                                        <td><a href="javascript:void(0);" class="btn btn-success btn-sm" onclick="kotaGuncelle()"><i class="fa fa-copy"></i> Kotaları Çek</a></td>
                                        <td width="120px;text-align:right;">
                                            @if (Model.RowCount > 0)
                                            {

                                                <a href="javascript:void(0);" class="btn btn-info btn-sm" onclick="$('#export').val('true'); $('#frmKotalar').submit(); $('#export').val('false');" title="Listelenen kaydı excel e aktar"><i class="fa fa-download"></i> Excel Olarak İndir</a>


                                            }
                                        </td>
                                    </tr>
                                </table>


                            </td>
                            <td style="width:90px;">
                                <ul class="panel-controls">

                                    <li><span class="label label-success label-form">T:@IndexModel.Toplam</span></li>
                                    @*<li><span class="label label-info label-form">A:@IndexModel.Aktif</span></li>*@
                                    @* <li><span class="label label-danger label-form">P:@IndexModel.Pasif</span></li>*@
                                    <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                                </ul>
                            </td>
                        </tr>
                    </table>


                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                                <th class="sirala" field="OgrenimTipAdi" width="140">Öğrenim Tipi</th>
                                <th class="sirala" field="ProgramAdi">P Adı</th>
                                <th class="sirala" field="AlanIciKota" width="60">A içi</th>
                                <th class="sirala" field="AlanDisiKota" width="60">A Dışı</th>
                                <th class="sirala" field="IsAktif" width="80" title="Program için mülaka var mı?">Mlk Drm</th>
                                <th class="sirala" field="IsAlesYerineDosyaNotuIstensin"width="80" title="Ales yerine Dosya Notu alınsın mı?">Dsy Drm</th>
                                <th width="30"> </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("OgrenimTipKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    <input name="ProgramAdi" type="text" value="@Model.ProgramAdi" class="form-control" />
                                </th>
                                <th></th>
                                <th></th>
                                <th>
                                    @Html.DropDownList("MulakatSurecineGirecek", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    @Html.DropDownList("IsAlesYerineDosyaNotuIstensin", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex; string trCls = "odd";
                                foreach (var item in Model.data)
                                {
                                    RowIndex++;
                                    trCls = RowIndex % 2 == 1 ? "" : "even";
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.KotaID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="showDetail('@item.KotaID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>

                                        <td>
                                            @item.EnstituAd<br />
                                            @item.OgrenimTipAdi <br />
                                            @item.KullaniciTipAdi
                                        </td>
                                        <td id="tdMad_@item.KotaID">
                                            @item.AnabilimDaliAdi <br />
                                            @item.ProgramAdi<br />
                                            <b>İşlem Tarihi:@item.IslemTarihi.ToString("dd.MM.yyyy HH:mm")</b>
                                        </td>
                                        @if (item.OrtakKota)
                                        {
                                            <td colspan="2" style="text-align:center;">
                                                Ortak:<br />  <span style="font-size:17pt;color:@(item.OrtakKotaSayisi.Value > 0 ? "green" : "red")">@item.OrtakKotaSayisi.Value</span>
                                            </td>
                                        }
                                        else
                                        {
                                            <td>
                                                <span style="font-size:17pt;color:@(item.AlanIciKota > 0 ? "green" : "red")">@item.AlanIciKota</span>
                                            </td>
                                            <td>
                                                <span style="font-size:17pt;color:@(item.AlanDisiKota > 0 ? "green" : "red")">@item.AlanDisiKota</span>
                                            </td>
                                        }
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.MulakatSurecineGirecek ? "success" : "danger")">@(item.MulakatSurecineGirecek ? "Evet" : "Hayır")</span>
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="label label-@(item.IsAlesYerineDosyaNotuIstensin ? "success" : "danger")">@(item.IsAlesYerineDosyaNotuIstensin ? "Evet" : "Hayır")</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "YYDKotalar", new {id=item.KotaID })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.KotaID')"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.KotaID" style="display:none">
                                        <td id="cls-@item.KotaID" colspan="8" style="padding: 1px 1px 2px 75px;">

                                            <div class="panel panel-success">
                                                <div class="panel-heading padding-0">
                                                    <div class="portlet-title">
                                                        <h3 class="panel-title"><i class="fa fa-file-text"></i>&nbsp;Detay</h3>
                                                    </div>
                                                </div>
                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">

                                                        <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                <div class="panel-body form-group-separated">
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Enstitü</label>
                                                                        <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">@item.EnstituAd</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">P Kod</label>
                                                                        <div class="col-md-9">@item.ProgramKod</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Ales Tipi</label>
                                                                        <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">@item.AlesTipAdi</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Anabilim Dalı Adı</label>
                                                                        <div class="col-md-9">@item.AnabilimDaliAdi</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Başvurabilecek Öğrenci</label>
                                                                        <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">
                                                                            @item.KullaniciTipAdi
                                                                        </div>
                                                                    </div>
                                                                     

                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Eğitim Dili Ing</label>
                                                                        <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">
                                                                            <span class="label label-@(item.Ingilizce ? "success" : "danger")">@(item.Ingilizce ? "Evet" : "Hayır")</span>
                                                                        </div>
                                                                    </div>
                                                                    @if (item.OrtakKota)
                                                                    {
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 control-label">Ortak Kota</label>
                                                                            <div class="col-md-9">
                                                                                <span style="font-size:13pt;color:@(item.OrtakKotaSayisi.Value > 0 ? "green" : "red")">@item.OrtakKotaSayisi.Value</span>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 control-label">Alaniçi Kota</label>
                                                                            <div class="col-md-9">
                                                                                <span style="font-size:13pt;color:@(item.AlanIciKota > 0 ? "green" : "red")">@item.AlanIciKota</span>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 control-label">Alandışı Kota</label>
                                                                            <div class="col-md-9">
                                                                                <span style="font-size:13pt;color:@(item.AlanDisiKota > 0 ? "green" : "red")">@item.AlanDisiKota</span>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Durum</label>
                                                                        <div class="col-md-9" style="text-align: left;">
                                                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@(item.IsAktif ? "Aktif" : "Pasif")</span>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">İşlem Yapan</label>
                                                                        <div class="col-md-9">@item.IslemYapan [@item.IslemTarihi.ToFormatDateAndTime()]</div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function kotaGuncelle() {
        var _enst = $("#EnstituKod").val();
        if (_enst != "" && _enst != null) {
            var btbx = bootbox.dialog({
                message: "<table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Web servisinden kotalar çeikip güncellenecek. Bu güncelleme sonucunda havuzdaki kotalar silinip yeni kotalar havuza atılacaktır.<br/> İşleme devam edilsin mi?</td></tr></table>",
                title: "Web Servisinden Kota Bilgilerini Kopyala İşlemi",
                buttons: {
                    success: {
                        label: 'Web Servisinden Kota Bilgilerini Kopyala',
                        className: "btn-danger",
                        callback: function () {
                            $.ajax({
                                url: '@Url.Action("getWsData", "YYDKotalar")',
                                data: { EnstituKod: _enst },
                                success: function (result) {
                                    toastr[result.success ? "success" : "error"](result.message, "Kota Bilgileri Kopyalama İşlemi")
                                    //if (result.success) {
                                    //    setTimeout($('#frmKotalar').submit(),3000);
                                    //}

                                },
                                error: function (err) {
                                    alert(err.responseText);
                                }
                            });
                        }
                    },
                    danger: {
                        label: 'Vazgeç',
                        className: "btn-primary",
                        callback: function () {
                        }
                    }
                }
            });
            //$(btbx).find('.modal-dialog').addClass('modal-lg');
        }
        else {
            alert("Enstitü Seçiniz!");
        }
    }
    function showDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Program Adı: " + gMesaj + " <br/> Seçilen Programın Kota Bilgisini Silmek İstiyor Musunuz?",
            title: "Program Kotası Silme İşlemi",
            buttons: {
                success: {
                    label: "Program Kotasını Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "YYDKotalar")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Program Kotası Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
