@using LisansUstuBasvuruSistemi.Models
@using BiskaUtil;
@model List<TIAyarlar>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var grup = Model.Select(s => s.Kategori).Distinct();
    var dctGrupToggle = (Dictionary<string, bool>)ViewBag.PanelToggled;
}
<style>
    .glow-on-hover {
        border: none;
        outline: none;
        color: #fff;
        background: #111;
        cursor: pointer;
        position: relative;
        z-index: 0;
        border-radius: 10px;
    }

        .glow-on-hover:before {
            content: '';
            background: linear-gradient(45deg, #ff0000, #ff7300, #fffb00, #48ff00, #00ffd5, #002bff, #7a00ff, #ff00c8, #ff0000);
            position: absolute;
            top: -2px;
            left: -2px;
            background-size: 400%;
            z-index: -1;
            filter: blur(5px);
            width: calc(100% + 4px);
            height: calc(100% + 4px);
            animation: glowing 20s linear infinite;
            opacity: 0;
            transition: opacity .3s ease-in-out;
            border-radius: 10px;
        }

        .glow-on-hover:active {
            color: #000
        }

            .glow-on-hover:active:after {
                background: transparent;
            }

        .glow-on-hover:hover:before {
            opacity: 1;
        }

        .glow-on-hover:after {
            z-index: -1;
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: #111;
            left: 0;
            top: 0;
            border-radius: 10px;
        }

    @@keyframes glowing {
        0% {
            background-position: 0 0;
        }

        50% {
            background-position: 400% 0;
        }

        100% {
            background-position: 0 0;
        }
    }
</style>
<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">
            <div class="panel panel-danger">
                <div class="panel-body">

                    @foreach (var cat in grup)
                    {
                        var ayar = Model.Where(p => p.Kategori == cat).ToArray();
                        var toggleC = dctGrupToggle.First(p => p.Key == cat);

                        <div class="panel panel-warning">
                            <div class="panel-heading padding-0">
                                <div class="portlet-title">
                                    <h3 class="panel-title"><i class="fa fa-cogs"></i>&nbsp;@cat</h3>
                                    <ul class="panel-controls">
                                        <li>
                                            <input type="hidden" name="PanelToggled" value="@(cat)__@toggleC.Value.ToString().ToLower()" />
                                            <a href="javascript:void(0);" onclick="toogleControl(this, '@cat');" class="panel-collapse"><span class="fa fa-angle-down"></span> </a>

                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <div class="panel-body" style="padding:0px;margin:0px;">
                                <div class="panel panel-default form-horizontal" style="padding:0px;margin:0px;">
                                    <div class="panel-body form-group-separated">
                                        <table class="table table-hover" style="width:100%;table-layout:fixed;">
                                            @foreach (var item in ayar)
                                            {
                                                <tr>
                                                    <td style="text-align:right;" width="360">
                                                        @item.AyarAdi
                                                    </td>
                                                    <td width="30" style="padding-left:10px;">
                                                        @if (!item.Aciklama.IsNullOrWhiteSpace())
                                                        {
                                                            <button style="padding-left:3px;padding-right:2px;" type="button" class="btn btn-info popover-dismiss glow-on-hover" title="@item.AyarAdi" data-content="@item.Aciklama">
                                                                <i class="fa fa-info-circle fa-lg" style="margin:0px;"></i>
                                                            </button>

                                                        }
                                                    </td>
                                                    <td>
                                                        <div class="inputContent input-icon right">
                                                            <input type="text" style="width:100%;display:none;" name="AyarAdi" value="@item.AyarAdi" />

                                                            @if (item.InpType == "text")
                                                            {
                                                                <input type="text" style="width:100%;" name="AyarDegeri" class="form-control" value="@item.AyarDegeri" />
                                                            }
                                                            else if (item.InpType == "password")
                                                            {
                                                                <input type="password" style="width:100%;" name="AyarDegeri" class="form-control" value="@item.AyarDegeri" />
                                                            }
                                                            else if (item.InpType == "textarea")
                                                            {
                                                                <textarea style="height: 160px;" name="AyarDegeri" class="form-control">@item.AyarDegeri</textarea>
                                                            }
                                                            else if (item.InpType == "checkbox")
                                                            {
                                                                var itms = item.SItems.Split(',');
                                                                var dataOnL = "Evet";
                                                                var dataOfL = "Hayır";
                                                                if (itms.Length > 1)
                                                                {
                                                                    dataOnL = itms[0];
                                                                    dataOfL = itms[1];
                                                                }
                                                                var chkD = item.AyarDegeri.IsNullOrWhiteSpace() ? false : Convert.ToBoolean(item.AyarDegeri);
                                                                <input type="text" name="AyarDegeri" value="@item.AyarDegeri" style="display: none;" />
                                                                <div class="make-switch" data-on-label="@dataOnL" data-off-label="@dataOfL">
                                                                    <input type="checkbox" value="true" class="toggle" @chkD.ToChecked() onchange="checkControl(this)" />
                                                                </div>
                                                            }
                                                            else if (item.InpType == "select")
                                                            {
                                                                var itms = item.SItems.Split(',');
                                                                <select class="form-control" name="AyarDegeri" style="width: 100%;">
                                                                    @foreach (var val in itms)
                                                                    {
                                                                        <option value="@val" @(val == item.AyarDegeri ? "selected='selected'" : "")>@val</option>
                                                                    }
                                                                </select>
                                                            }

                                                        </div>
                                                    </td>
                                                </tr>

                                            }
                                        </table>
                                    </div>
                                </div>
                            </div>

                        </div>

                    }

                </div>

                <div class="panel-footer">
                    <button class="btn btn-primary pull-right"><i class="fa fa-save">&nbsp</i>Kaydet</button>
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    $(function () {
        $(".popover-dismiss").popover({ trigger: 'hover', html: true });
    });

    function toogleControl(sndr, cat) {
        var _val = $(sndr).prev().val();
        var nval = _val.replace(cat + '__', '') == 'true';
        $(sndr).prev().val(cat + '__' + (!nval).toString());

    }
    function checkControl(sndr) {
        var chk = $(sndr).prop("checked");
        var pContent = $(sndr).parents('.inputContent').first();
        var pvalFielt = $(pContent).find("input[name='AyarDegeri']").first();
        $(pvalFielt).val(chk);
    }

</script>
