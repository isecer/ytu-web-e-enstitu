@using BiskaUtil
@using LisansUstuBasvuruSistemi.Business
@using LisansUstuBasvuruSistemi.Models 
@using LisansUstuBasvuruSistemi.Utilities.Dtos 
@using LisansUstuBasvuruSistemi.Utilities.Enums
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@using LisansUstuBasvuruSistemi.Utilities.MenuAndRoles
@model FmBasvuruSureciDto
@{
    /**/

    Layout = "~/Views/Shared/_Layout.cshtml";
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    var kayit = RoleNames.YydBasvuruSureciKayit.InRoleCurrent();
    var silme = RoleNames.YydBasvuruSureciSil.InRoleCurrent(); 
 

}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-clock-o"></i>&nbsp; YTU Yeni Mezun DR Başvuru Süreçleri</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-success label-form">T:@IndexModel.Toplam</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="125"></th>
                                <th class="sirala" field="EnstituAd">Enstitu</th>
                                <th width="180" class="sirala" field="OgretimYili">Öğretim Yılı</th>
                                <th width="105" class="sirala" field="BaslangicTarihi">Başlangıç Tar.</th>
                                <th width="105" class="sirala" field="BitisTarihi">Bitiş Tar.</th>

                            </tr>

                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th>
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                                <th></th>
                                <th></th>

                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex;
                                foreach (var item in Model.FrBasvuruSureciDtos)
                                {
                                    var OtipJsonStr = Json.Encode(item.CmbOgrenimTipBilgi);
                                    bool suanAktif = (item.BaslangicTarihi <= DateTime.Now && item.BitisTarihi >= DateTime.Now) || (item.AGNOGirisBaslangicTarihi <= DateTime.Now && item.AGNOGirisBitisTarihi >= DateTime.Now) || (item.SonucGirisBaslangicTarihi <= DateTime.Now && item.SonucGirisBitisTarihi >= DateTime.Now);
                                    bool KopyalamaAktif = (item.BaslangicTarihi <= DateTime.Now && item.BitisTarihi >= DateTime.Now) || item.BaslangicTarihi > DateTime.Now;
                                    RowIndex++;
                                    <tr class="delrw_@item.BasvuruSurecID" style="@(suanAktif?"color:green;font-weight:bold;":"")">
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td style="width: 50px;">
                                                        <div class="btn-group">
                                                            <a href="javascript:void(0);" data-toggle="dropdown" class="btn btn-primary dropdown-toggle"><i class="fa fa-cogs"></i></a>
                                                            <ul class="dropdown-menu" role="menu">
                                                                <li role="presentation" class="dropdown-header" style="font-weight:bold;">İşlemler</li>
                                                                @*<li class="divider" style="padding-top: 0px; margin-top: 4px;"></li>*@

                                                                @if (kayit)
                                                                {
                                                                    <li>
                                                                        <a href="@Url.Action("Kayit")"><i class="fa fa-pencil"></i>Yeni</a>
                                                                    </li>
                                                                    <li>
                                                                        <a href="@Url.Action("Kayit", new { id = item.BasvuruSurecID })"><i class="fa fa-edit"></i>Düzenle</a>
                                                                    </li>
                                                                }
                                                                @if (silme)
                                                                {
                                                                    <li>
                                                                        <a href="javascript:void(0)" onclick="getDetail(@item.BasvuruSurecID,true,$(this))"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i>Sil</a>
                                                                    </li>
                                                                }

                                                                @if (kayit && (item.SonucGirisBitisTarihi ?? item.BitisTarihi).AddMonths(1) > DateTime.Now) //1 ay geçen süreçlerde işlem yapılamasın
                                                                {
                                                                    if (item.Hesaplandi)
                                                                    {
                                                                        <li role="presentation" class="dropdown-header" style="font-weight:bold;">Toplu Kayıt Kapatma</li>
                                                                        <li>
                                                                            <a href="javascript:void(0);" onclick="TopluKayitKapatma(@item.BasvuruSurecID,@MulakatSonucTipi.Asil,'@OtipJsonStr')"> <i class="fa fa-save"></i> Toplu Kayıt Kapatma (Asil)</a>
                                                                        </li>
                                                                        <li>
                                                                            <a href="javascript:void(0);" onclick="TopluKayitKapatma(@item.BasvuruSurecID,@MulakatSonucTipi.Yedek,'@OtipJsonStr')"> <i class="fa fa-save"></i> Toplu Kayıt Kapatma (Yedek)</a>
                                                                        </li>
                                                                    }

                                                                    <li role="presentation" class="dropdown-header" style="font-weight:bold;">Veri Kopyalama</li>
                                                                    <li>
                                                                        @if (KopyalamaAktif || UserIdentity.Current.IsAdmin)
                                                                        {
                                                                            <a href="javascript:void(0)" onclick="Kopyala(@item.BasvuruSurecID,'@item.EnstituKod',true,@item.Hesaplandi.ToString().ToLower())"><i class="fa fa-copy fa-lg"></i>Sınav Bilgilerini Kopyala</a>

                                                                            <a href="javascript:void(0)" onclick="Kopyala(@item.BasvuruSurecID,'@item.EnstituKod',false,@item.Hesaplandi.ToString().ToLower())"><i class="fa fa-copy fa-lg"></i>Kota Bilgilerini Kopyala</a>
                                                                        }
                                                                    </li>


                                                                }

                                                                <li role="presentation" class="dropdown-header" style="font-weight:bold;">Raporlar</li>
                                                                @if (item.Hesaplandi)
                                                                {
                                                                    <li>
                                                                        <a href="@Url.Action("GetProgramKotalari", new { id = item.BasvuruSurecID })" class="tooltips" data-style="blue"><i class="fa fa-picture-o "></i>Kalan Kontenjan bilgilerini İndir</a>
                                                                    </li>
                                                                }
                                                                <li>
                                                                    <a href="@Url.Action("getImages", new { id = item.BasvuruSurecID })" class="tooltips" data-style="blue" data-original-title="Kesin kaydı yapılan öğrencilerin başvuru fotoğraflarını indir"><i class="fa fa-picture-o "></i>Başvuru Fotoğraflarını İndir</a>
                                                                </li>
                                                                <li>
                                                                    <a href="javascript:void(0)" onclick="kkOgrList(@item.BasvuruSurecID)" class="tooltips" data-style="blue" data-original-title="Kesin kaydı yapılan öğrencilerin listesini indir"><i class="fa fa-picture-o "></i>Kayıt olan öğrenci listesini indir</a>
                                                                </li>

                                                            </ul>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow-ana-@item.BasvuruSurecID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="showDetail(@item.BasvuruSurecID,'ana-')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>@item.EnstituAdi</td>
                                        <td>@item.BaslangicYil / @item.BitisYil @item.DonemAdi</td>
                                        <td>
                                            @item.BaslangicTarihi.ToFormatDateAndTime()
                                        </td>
                                        <td>
                                            @item.BitisTarihi.ToFormatDateAndTime()
                                        </td>


                                    </tr>
                                    <tr class="cls-ana-@item.BasvuruSurecID delrw_@item.BasvuruSurecID" style="display:none;">
                                        <td id="cls-ana-@item.BasvuruSurecID" colspan="5" style="height:566px;"></td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function showDetail(id, tip) {
        var rwID = $('#iShow-' + tip + id);
        var cls = 'cls-' + tip + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(rwID, cls, unTogled);
        if (unTogled && tip == "ana-") setTimeout(getDetail(id), 400);
    }

    function getDetail(id, Isdelete, sndr) {
       var tbName = "@TabAdlari.BasvuruSureciTN-" + id;
        var tID = getSelectedTabID(tbName);
        if ($('#SelectedTb-' + tbName).length > 0) {
            subData(id, Isdelete, sndr);
        }
        else {
            $.ajax({
                url: '@Url.Action("getBsDetail", "YYDBasvuruSureci")',
                data: { id: id, tbInx: tID, IsDelete: (Isdelete == true) },
                async: false,
                success: function (result) {
                    if (Isdelete != true) {
                        $('#cls-ana-' + id).html(result);
                        subData(id, Isdelete);
                    }
                    else {
                        subData(id, Isdelete, result);
                    }
                },
                error: function (err) {
                    alert(err.responseText);
                }
            });
        }

    }
     
    function subData(id, Isdelete, mContent) {
        var _panel = $('#pnglDB_' + id);

        var tbName = "@TabAdlari.BasvuruSureciTN-" + id;
        var tID = getSelectedTabID(tbName);
        if (Isdelete == true) tID = 1;
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("getBsSubData", "YYDBasvuruSureci")',
            data: { id: id, tbInx: tID, IsDelete: (Isdelete == true) },
            // async: false,
            success: function (result) {
                if (Isdelete != true) {
                    $('#' + tbName + '-' + tID).html(result);
                    _pRefresh(_panel, true);
                }
                else {

                    var _nme = tbName+ '-1';
                    $(mContent).find('#' + _nme).html(result);
                    var btbx = bootbox.dialog({
                        message: result + " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Seçilen Başvuru Sürecini Silmek İstiyor Musunuz?</td></tr></table>",
                        title: "Yatay Geçiş Başvuru Süreci Silme İşlemi",
                        buttons: {
                            success: {
                                label: "Başvuru Sürecini Sil",
                                className: "btn-danger",
                                callback: function () {
                                    sil(id);
                                }
                            },
                            danger: {
                                label: "Kapat",
                                className: "btn-primary",
                                callback: function () {
                                }
                            }
                        }
                    });
                    $(btbx).find('.modal-dialog').addClass('modal-lg');
                    _pRefresh(_panel, true);
                }
            },
            error: function (err) {
                alert(err.responseText);
                _pRefresh(_panel, true);
            }
        });
    }

    function getMsncPrDetay(bsrID, otID, prKod) {
        var cID = (bsrID + "_" + otID + "_" + prKod);
        var _panel = $('#pnglDB_' + bsrID);
        var tbName = "@TabAdlari.MulakatDetayTN-" + cID;
        var tID = getSelectedTabID(tbName);
        _pRefresh(_panel, false);
        $.ajax({
            url: '@Url.Action("getMulakatDetay", "YYDBasvuruSureci")',
            data: { BasvuruSurecID: bsrID, OgrenimTipKod: otID, ProgramKod: prKod, tbInx: tID, IsDelete: false, IsBootBox: true },
            success: function (result) {
                var btbx = bootbox.dialog({
                    message: result,//+ " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Mülakat bilgisi</td></tr></table>",
                    title: "Yatay Geçiş Mülakat detayı",
                    buttons: {
                        danger: {
                            label: "Kapat",
                            className: "btn-primary",
                            callback: function () {
                            }
                        }
                    }
                });
                $(btbx).find('.modal-dialog').addClass('modal-lg');
                _pRefresh(_panel, true);

            },
            error: function (err) {
                alert(err.responseText);
                _pRefresh(_panel, true);
            }
        });
    }
    function getBsncPrDetay(id, prKod, otID) {
        var _panel = $('#pnglDB_' + id);
        _pRefresh(_panel, false);
        var tbName = "@TabAdlari.BasvuruSonucDetayTN-" + id;
        var tID = getSelectedTabID(tbName);
        $.ajax({
            url: '@Url.Action("getBasvuruSonucDetay", "YYDBasvuruSureci")',
            data: { id: id, ProgramKod: prKod, OgrenimTipKod: otID, tbInx: tID, IsDelete: false, IsBootBox: true },
            success: function (result) {
                var btbx = bootbox.dialog({
                    message: result,//+ " <br/><br/><table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Mülakat bilgisi</td></tr></table>",
                    title: "Yatay Geçiş Başvuru sonuçları detayı",
                    buttons: {
                        //success: {
                        //    label: "Başvuru Sürecini Sil",
                        //    className: "btn-danger",
                        //    callback: function () {
                        //        sil(sndr, id);
                        //        _pRefresh(_panel, true);
                        //    }

                        //},
                        danger: {
                            label: "Kapat",
                            className: "btn-primary",
                            callback: function () {
                            }
                        }
                    }
                });
                $(btbx).find('.modal-dialog').addClass('modal-lg');
                _pRefresh(_panel, true);


            },
            error: function (err) {
                alert(err.responseText);
                _pRefresh(_panel, true);
            }
        });
    }

    function getBSonucHesap(id) {

        var _panel = $('#pnglDB_' + id);
        var btbx = bootbox.dialog({
            message: " <table style='table-layout:fixed;width:100%;'><tr><td style='font-size:14pt;text-align:center;color:maroon;'>Başvuru sonuçları hesaplanıp kayıt edilecek. İşleme devam etmek istiyor musunuz?</td></tr></table>",
            title: "Yatay Geçiş Başvuru sonuçlarını hesapla",
            buttons: {
                success: {
                    label: "Başvuruları Hesapla",
                    className: "btn-danger",
                    callback: function () {
                        _pRefresh(_panel, false);
                        $.ajax({
                            url: '@Url.Action("BasvuruSonucHesap", "YYDBasvuruSureci")',
                            data: { id: id },
                            success: function (result) {
                                _pRefresh(_panel, true);
                                if (result.IsSuccess) {
                                    getDetail(id);
                                }
                                showMmMessage(result.Messages, 'Tamam');
                            },
                            error: function (err) {
                                alert(err.responseText);
                                _pRefresh(_panel, true);
                            }
                        });
                    }

                },
                danger: {
                    label: "Kapat",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
        $(btbx).find('.modal-dialog');//.addClass('modal-lg');

    }
    function bbRprtShowD(id, show) {

        if (show) {
            $('.detRow_' + id).removeClass("hide");
        }
        else {
            $('.detRow_' + id).addClass("hide");
        }
    }
    function kkOgrList(id) {
        yeniDialogBB(null, 'Kayıt olan öğrenci listesi', '@Url.Action("GetDxReport", "Ajax")?IsPdfStream=true&RaporTipi=' +@RaporTipleri.KesinKayitListesi +'&BasvuruSurecID=' + id + '', 'auto', 'modal-dialog modal-lg')

    }
    function setchkRtEkBilgi(sndr) {
        if ($(sndr).attr('id') == '_rprsncTip') {
            if ($(sndr).prop('checked')) {
                $('#_rprsncIletisim').prop('checked', false);
            }
        }
        else {
            if ($(sndr).prop('checked')) {
                $('#_rprsncTip').prop('checked', false);
            }
        }
    }
    function getReportType(id, _AnabilimdaliKod, _ProgramKod, _OgrenimTipKod, oTips) {
        _AnabilimdaliKod = (_AnabilimdaliKod == "null" || _AnabilimdaliKod == null) ? "" : _AnabilimdaliKod;
        _OgrenimTipKod = (_OgrenimTipKod == "null" || _OgrenimTipKod == null) ? "" : _OgrenimTipKod;
        _ProgramKod = (_ProgramKod == "null" || _ProgramKod == null) ? "" : _ProgramKod;
        var otipRw = "";
        var IsShowOtips = false;
        if (_AnabilimdaliKod == "" && _OgrenimTipKod == "" && _ProgramKod=="") {
            IsShowOtips = true;
        }
        if (IsShowOtips) {
            otipRw = "<tr><td>Öğrenim Seviyeleri </td><td>";
            var OtipList = eval(oTips);
            for (var i = 0; i < OtipList.length; i++) {
                var sOtip = OtipList[i];
                otipRw += "<input type='checkbox' value='" + sOtip.Value + "' class='ChkSonucRprOtip' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>" + sOtip.Caption + "</span><br/>";

            }
            otipRw += "</td></tr>";
        }
        var mdlS = "<table class='table' style='width:100%;table-layout:fixed;'>" +
                    "<tr> " +
                      "<td style='width:200px;'>Liste Durumu</td>" +
                      "<td id='_rdG'>" +
                        "<input type='radio'name='rdGroup' value='1' checked='checked' onchange='bbRprtShowD(" + id + "," + true + ")' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Tüm Sonuçlar</span><br/>" +
                        "<input type='radio'name='rdGroup' value='2' onchange='bbRprtShowD(" + id + "," + false + ")'/> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Tam Yedek Listesi</span><br/>" +
                        "<input type='radio'name='rdGroup' value='3' onchange='bbRprtShowD(" + id + "," + false + ")'/> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Tam Yedek Listesi (İşlem Görmeyenler)</span><br/>" +
                        "<input type='radio'name='rdGroup' value='4' onchange='bbRprtShowD(" + id + "," + false + ")'/> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Kalan Kontenjan Kadar Yedek</span>" +
                      "</td>" +
                        "</tr>" +
                        otipRw+
                      
                    @*"<tr class='detRow_" + id + "'>" +
                      "<td>Program Liste Türü </td>" +
                      "<td><input type='checkbox' id='chkUyrkTip_@KullaniciTipBilgi.YerliOgrenci' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Yerli Öğrenci Listesi</span>" +
                           "<br/>" +
                           "<input type='checkbox' id='chkUyrkTip_@KullaniciTipBilgi.YabanciOgrenci' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Yabancı Öğrenci Listesi</span>" +
                        "</td>" +
                    "</tr>" +*@

                    "<tr class='detRow_" + id + "'>" +
                        "<td>Listelenecek Sonuç Tipleri </td>" +
                        "<td>" +
                               "<input type='checkbox' class='ChkMSonucTp' value='@MulakatSonucTipi.Asil' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Asil</span><br/>" +
                               "<input type='checkbox' class='ChkMSonucTp' value='@MulakatSonucTipi.Yedek' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Yedek</span><br />" +
                               "<input type='checkbox' class='ChkMSonucTp' value='@MulakatSonucTipi.Kazanamadı' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Kazanamadı</span>" +
                    "</td>" +
                    "</tr>" +
                    "<tr class='detRow_" +
                    id +
                    "'>" +
                    "<td>Kayıt Durumu</td>" +
                    "<td><select id='_KayitDurum'><option value='' selected='selected'>Tümü</option><option value='0'>Ön Kayıt</option><option value='1'>Kayıt Olanlar</option><option value='2'>Kayıt Olmayanlar</option></select></td>" +
                    "</tr>" +
                    "<tr> " +
                    "<td>Ek Bilgi</td>" +
                    "<td id='_rdGP'>" +
                    "<input type='radio'name='rdGroupP' value='1' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Sadece Sonuç Gösterilsin</span><br/>" +
                    "<input type='radio'name='rdGroupP' value='2'/> <span style='cursor:pointer;' onclick='$(this).prev().click()'>GNBNO + Sonuç Gösterilsin</span><br/>" +
                    "<input type='radio'name='rdGroupP' value='3'/> <span style='cursor:pointer;' onclick='$(this).prev().click()'>Tüm Puanlar + Sonuç Gösterilsin</span><br/>" +
                    "<input type='radio'name='rdGroupP' value='4'/> <span style='cursor:pointer;' onclick='$(this).prev().click()'>İletişim Bilgisi + Sonuç Gösterilsin</span><br/>" +
                    "</td>" +
                    "</tr>" +
                    "</table>";
        var btbx = bootbox.dialog({
            message: mdlS,
            title: "Yatay Geçiş Başvuru sonuç rapor alma işlemi",
            buttons: {
                success: {
                    label: "Rapor Al",
                    className: "btn-danger",
                    callback: function() {
                        var _sncTp = "";
                        var _KayitDurumID = $('#_KayitDurum').val(); 
                        var Otips = "";
                        if (IsShowOtips) {
                            var OtipVal = [];
                            $('.ChkSonucRprOtip').each(function(inx, chk) {
                                if ($(chk).prop('checked')) OtipVal.push(parseInt($(chk).val()));
                            });
                            Otips = OtipVal.join(',');
                        }
                        var SubRaporTipID = $('input[name=rdGroup]:checked', '#_rdG').val();
                        if (SubRaporTipID == "1") {
                            var _sncTpVal = [];
                            $('.ChkMSonucTp').each(function (inx, chk) {
                                if ($(chk).prop('checked')) _sncTpVal.push(parseInt($(chk).val()));
                            });
                            _sncTp = _sncTpVal.join(',');
                        }
                        else KayitDurum = '';

                        var EkBilgiTipID = $('input[name=rdGroupP]:checked', '#_rdGP').val();
                        var _rGtip = "";
                        if (_AnabilimdaliKod == "" && _ProgramKod == "") {
                            _rGtip =  "Başvuru Sonuç Tüm Liste";
                        }
                        else if (_AnabilimdaliKod != "" && _ProgramKod == "") {
                            _rGtip =  "Başvuru Sonuç ABD Listesi";
                        }
                        else if (_AnabilimdaliKod != "" && _ProgramKod != "") {
                            _rGtip =   "Başvuru Sonuç Program Listesi";
