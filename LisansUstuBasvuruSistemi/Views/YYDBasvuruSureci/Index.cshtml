<script type="text/javascript">
    function TopluKayitKapatma(id, mulakatSonucTipID, oTips) {
        var topiRw = "<tr><td width='120'>Öğrenim Seviyeleri </td><td>";
        var otipList = eval(oTips);
        for (var i = 0; i < otipList.length; i++) {
            var sOtip = otipList[i];
            topiRw += "<input type='checkbox' value='" + sOtip.Value + "' class='ChkTKKOtip' checked='checked' /> <span style='cursor:pointer;' onclick='$(this).prev().click()'>" + sOtip.Caption + "</span><br/>";

        }
        topiRw += "</td></tr>";

        if (mulakatSonucTipID === 1) {
            topiRw += "<tr><td colspan='2' style='font-size:12pt;color:maroon;'>Yukarıda seçilen Öğrenim Seviyelerine göre İşlem görmeyen Asil öğrenci kayıtları Kayıt olmadı şeklinde güncellenecek! İşlemi Onaylıyor Musunuz?</td></tr>";
        }
        else {
            topiRw += "<tr><td colspan='2' style='font-size:12pt;color:maroon;'>Yukarıda seçilen Öğrenim Seviyelerine göre İşlem görmeyen Yedek öğrenci kayıtları Kayıt olmadı şeklinde güncellenecek! İşlemi Onaylıyor Musunuz?</td></tr>";
        }

        window.bootbox.dialog({
            message: "<table style='table-layout:fixed;width:100%;'>" + topiRw+"</table>",
            title: "Yatay Geçiş Toplu Kayıt Kapatma İşlemi",
            buttons: {
                success: {
                    label: 'Evet',
                    className: "btn-danger",
                    callback: function() {
                        var _panel = $('#pnglDB_' + id);
                        _pRefresh(_panel, false);
                        var OtipVal = [];
                        $('.ChkTKKOtip').each(function (inx, chk) {
                            if ($(chk).prop('checked')) OtipVal.push(parseInt($(chk).val()));
                        });
                        var OgrenimTipKods = OtipVal.join(',');
                        $.ajax({
                            url: '@Url.Action("TopluKayitKapatma", "YYDBasvuruSureci")',
                            data: { BasvuruSurecID: id, 'MulakatSonucTipID': mulakatSonucTipID,  "OgrenimTipKods": OgrenimTipKods},
                            success: function(result) {
                                if (result.Messages.length > 0)
                                    showMmMessage(result.Messages, 'Tamam');
                                _pRefresh(_panel, true);
                            },
                            error: function(err) {
                                alert(err.responseText);
                                _pRefresh(_panel, true);
                            }
                        });
                    }
                },
                danger: {
                    label: 'Hayır',
                    className: "btn-primary",
                    callback: function() {
                    }
                }
            }
        });

    }

