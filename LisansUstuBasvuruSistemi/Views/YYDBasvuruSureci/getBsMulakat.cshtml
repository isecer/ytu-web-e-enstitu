@using LisansUstuBasvuruSistemi.Models @using LisansUstuBasvuruSistemi.Models.FilterModel
@using BiskaUtil;
@using LisansUstuBasvuruSistemi.Utilities.Dtos.CmbDtos
@model bsUrecDetay
@{
    Layout = null;
    var IsDelete = Model.IsDelete;
    var nowDate = DateTime.Now;
    bool KayitYetki = RoleNames.BasvuruSureciKayit.InRoleCurrent();
    bool MailGondermeYetkisi = RoleNames.MailGonder.InRoleCurrent();

    bool MulakatBilgiGirisAcik = Model.BaslangicTarihi <= nowDate && Model.BitisTarihi >= nowDate;
    bool MulakatNotGirisAcik = Model.SonucGirisBaslangicTarihi.HasValue && Model.SonucGirisBaslangicTarihi <= nowDate && Model.SonucGirisBitisTarihi >= nowDate;

    var toplamProgram = Model.MulakatBilgi.MulakatNotGirisDetay.Count;
    var toplamMulakataGirecekProgram = Model.MulakatBilgi.MulakatNotGirisDetay.Where(p => p.MulakatSurecineGirecek).Count();
    var toplamMulakataGirmeyecekProgram = toplamProgram - toplamMulakataGirecekProgram;

    var toplamMBilgiGirisiTamamlanan = Model.MulakatBilgi.MulakatNotGirisDetay.Where(p => p.MulakatSurecineGirecek && p.YerJuriBilgisiGirildi).Count();
    var toplamMBilgiGirisiEksikOlan = toplamMulakataGirecekProgram - toplamMBilgiGirisiTamamlanan;




    string _colorAna = "#268a8b";
    string _colorMul = "green";
    string _colorSG = "gray";
    string _colorUyari = "red";
}

<div class="panel panel-info" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-list-alt"></i> Başvuru/Mülakat Genel Bilgi
        </h3>
        <ul class="panel-controls">
            <li>
                @if (Model.SinavYerBilgisiOgrenciMailiGonderildi && KayitYetki)
                {
                    var mailGcnt = new List<CmbStringDto>();
                    mailGcnt.Add(new CmbStringDto { Caption = "success", Value = "Sınav giriş bilgileri " + Model.SinavYerBilgisiOgrenciMailiGonderimTarihi.Value.ToFormatDateAndTime() + " tarihinde Öğrencilere mail olarak gönderildi" });
                    <span class="badge badge-success" style="cursor:pointer;" onclick="bMailGonderimCnt(@Json.Encode(mailGcnt),'Öğrencilere gönderilen mailler')">Oğrencilere Toplu Mail Gönderildi</span>
                }
                @if (MulakatBilgiGirisAcik == false && Model.BitisTarihi <= nowDate && Model.SonucGirisBaslangicTarihi.HasValue && Model.SonucGirisBaslangicTarihi.Value > nowDate && KayitYetki)
                {
                    if (IsDelete == false)
                    {
                        <span style="cursor:pointer;" onclick="getMJSendMailBB(@Model.BasvuruSurecID)" class="label label-success label-form"><i class="fa fa-envelope"></i>@(Model.SinavYerBilgisiOgrenciMailiGonderildi ? " Öğrencilere Tekrar mail Gönder" : " Öğrencilere mail Gönder")</span>
                    }
                }
            </li>
        </ul>
    </div>
    <div class="portlet-body">

        <div class="col-md-12 col-xs-12" style="text-align: left;font-size:9pt;font-weight:bold;">
            <table style="width:100%;table-layout:fixed;text-align:center;font-weight:bold;background-color:gainsboro;border:1px solid;">
                <tr>
                    <td colspan="5" style="border-bottom:1px solid;background-color:antiquewhite;">Program Sayısal Bilgi</td>
                </tr>
                <tr>
                    <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                        <span style="color:@_colorAna;">Toplam</span>
                    </td>
                    <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                        <span style="color:@_colorAna;">M.Açılmayacak</span>
                    </td>
                    <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                        <span style="color:@_colorMul;">M.Açılacak</span>
                    </td>
                    <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                        <span style="color:@_colorAna;">M.Açılan</span>
                    </td>
                    <td style="font-size:8.2pt;border-bottom:1px solid;border-right:1px solid;">
                        <span style="color:@(toplamMBilgiGirisiEksikOlan>0?_colorUyari:_colorAna);">M.Açılmayan</span>
                    </td>
                </tr>
                <tr>
                    <td style="font-size:14pt;border-right:1px solid;">
                        <span style="color:@_colorAna;">@toplamProgram</span>
                    </td>
                    <td style="font-size:14pt;border-right:1px solid;">
                        <span style="color:@_colorAna;">@toplamMulakataGirmeyecekProgram</span>
                    </td>
                    <td style="font-size:14pt;border-right:1px solid;">
                        <span style="color:@_colorMul;">@toplamMulakataGirecekProgram</span>
                    </td>
                    <td style="font-size:14pt;border-right:1px solid;">
                        <span style="color:@_colorAna;">@toplamMBilgiGirisiTamamlanan</span>
                    </td>
                    <td style="font-size:14pt;border-right:1px solid;">
                        <span style="color:@(toplamMBilgiGirisiEksikOlan>0?_colorUyari:_colorAna);">@toplamMBilgiGirisiEksikOlan</span>
                    </td>
                </tr>
            </table>
        </div>

    </div>
</div>
<div class="panel panel-info" style="margin:0px;">
    <div class="panel-heading padding-0" style="padding:0px;margin:0px;">
        <h3 class="panel-title">
            <i class="fa fa-list-alt"></i> Başvuru/Mülakat Detayı
            @if (KayitYetki && MailGondermeYetkisi)
            {
                <a href="javascript:void(0);" title="Program Yetkililerine Toplu Mail Gönder" onclick="mGonder('', '', '', '', @Model.BasvuruSurecID, 'true', '')"><img src="~/Images/mail_send_B.png" style="width:30px;height:25px;" /></a>
            } 
            @if (MailGondermeYetkisi)
            {
                <a href="javascript:void(0);" title="Öğrencilere Toplu Mail Gönder" onclick="mGonder('', '', '', '', @Model.BasvuruSurecID, 'false', '')"><img src="~/Images/mail_send_O.png" style="width:30px;height:25px;" /></a>
            }
        </h3>
        <ul class="panel-controls">
            <li>
                @if (Model.SinavYerBilgisiBolumMailiGonderildi || Model.SinavNotBilgisiBolumMailiGonderildi)
                {
                    int _cnt = Model.SinavYerBilgisiBolumMailiGonderildi && Model.SinavNotBilgisiBolumMailiGonderildi ? 2 : 1;
                    var mailGcnt = new List<CmbStringDto>();
                    if (Model.SinavYerBilgisiBolumMailiGonderildi)
                    {
                        mailGcnt.Add(new CmbStringDto { Caption = "success", Value = "Sınav yeri ve jüri bilgi girişi için " + Model.SinavYerBilgisiBolumMailiGonderimTarihi.Value.ToFormatDateAndTime() + " tarihinde Anabilim Dallarına mail gönderildi" });
                    }
                    else
                    {
                        mailGcnt.Add(new CmbStringDto { Caption = "primary", Value = "Sınav yeri ve jüri bilgi girişi için mail olarak gönderilmedi!" });

                    }
                    if (Model.SinavNotBilgisiBolumMailiGonderildi)
                    {
                        mailGcnt.Add(new CmbStringDto { Caption = "success", Value = "Sınav notu girişi için " + Model.SinavNotBilgisiBolumMailiGonderimTarihi.Value.ToFormatDateAndTime() + " tarihinde Anabilim Dallarına mail gönderildi" });
                    }
                    else
                    {
                        mailGcnt.Add(new CmbStringDto { Caption = "primary", Value = "Sınav notu girişi için mail gönderilmedi!" });

                    }
                    <span class="badge badge-success" style="cursor:pointer;" onclick="bMailGonderimCnt(@Json.Encode(mailGcnt),'Anabilim Dallarına gönderilen mailler')">@_cnt Adet toplu mail gönderildi</span>
                }
                @if (MulakatBilgiGirisAcik && KayitYetki)
                {
                    var yerJuriBGirilmeyen = Model.MulakatBilgi.MulakatNotGirisDetay.Where(p => p.YerJuriBilgisiGirildi == false && p.MulakatSurecineGirecek).Count();
                    if (IsDelete == false && yerJuriBGirilmeyen > 0)
                    {<span style="cursor:pointer;" onclick="getMJNBolumSendMailBB(@Model.BasvuruSurecID,true)" class="label label-success label-form"><i class="glyphicon glyphicon-time"></i>@(Model.SinavYerBilgisiBolumMailiGonderildi ? (" Sınav bilgi girişi için tekrar mail gönder (" + yerJuriBGirilmeyen + ")") : (" Sınav bilgi girişi için mail gönder (" + yerJuriBGirilmeyen + ")"))</span> }
            }
            else if (MulakatNotGirisAcik && KayitYetki)
            {
                var yerSnotGirilmeyen = Model.MulakatBilgi.MulakatNotGirisDetay.Where(p => p.SinavNotGirisiYapildi == false && p.MulakatSurecineGirecek).Count();
                if (IsDelete == false && yerSnotGirilmeyen > 0)
                { <span style="cursor:pointer;" onclick="getMJNBolumSendMailBB(@Model.BasvuruSurecID,false)" class="label label-success label-form"><i class="fa fa-list-alt"></i>@(Model.SinavNotBilgisiBolumMailiGonderildi ? (" Sınav notu girişi için tekrar mail gönder (" + yerSnotGirilmeyen + ")") : (" Sınav notu girşi için mail gönder (" + yerSnotGirilmeyen + ")"))</span>}
        }
            </li>
        </ul>
    </div>
    <div class="portlet-body">
        <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">
            <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                <div class="panel-body" style="margin: 0px; padding: 0px;">

                    <table class="table" style="margin:0px;">
                        <thead>
                            <tr>
                                <th style="background-color:gainsboro;" width="35"></th>
                                <th style="background-color:gainsboro;">
                                    <table>
                                        <tr>
                                            <td width="120">Öğr.Sev / ABD-Program</td>
                                            <td>
                                                <table style="width:100%; table-layout:fixed;width:100%;">
                                                    <tr>

                                                        <td class="text-center" id="filtreKelimeM_@Model.BasvuruSurecID"></td>
                                                        <td style="width:150px;">
                                                            <input style="color:red;width:150px;" type="text" name="search" id="filterInpM_@Model.BasvuruSurecID" onchange="" placeholder="ara...">
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>

                                </th>
                                <th width="32" style="border-left:1px solid;border-bottom:1px solid;padding:0px;text-align:center;background-color:gainsboro;">Yer<br />Jüri</th>
                                <th width="40" style="border-left:1px solid;border-bottom:1px solid;padding:0px;text-align:center;background-color:gainsboro;">G.Topl</th>
                                <th width="182" style="border-left:1px solid;border-right:1px solid;border-bottom:1px solid;padding:0px;">
                                    <table style="width:100%;table-layout:fixed;text-align:center;font-weight:bold;background-color:gainsboro;">
                                        <tr>
                                            <td style="border-right:1px solid;border-bottom:1px solid;">Alan İçi</td>
                                            <td style="border-bottom:1px solid;">Alan Dışı</td>
                                        </tr>
                                        <tr>
                                            <td style="border-right:1px solid;">
                                                <table style="width:100%;table-layout:fixed;">
                                                    <tr>
                                                        <td style="border-right:1px solid;">
                                                            <span style="color:@_colorAna;">Top</span>
                                                        </td>
                                                        <td>
                                                            <span style="color:@_colorMul;">N.Gr</span>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                            <td style="border-left:1px solid;">
                                                <table style="width:100%;table-layout:fixed;">
                                                    <tr>
                                                        <td style="border-right:1px solid;">
                                                            <span style="color:@_colorAna;">Top</span>
                                                        </td>
                                                        <td>
                                                            <span style="color:@_colorMul;">N.Gr</span>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </th>
                                <th width="19"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="6">
                                    <div style="height:350px;overflow-y:scroll;">
                                        <table class="table-hover" style="width:100%;table-layout:fixed;" id="fltrM_@Model.BasvuruSurecID">
                                            @if (Model.MulakatBilgi.MulakatNotGirisDetay.Count > 0)
                                            {
                                                int RowIndex = 0;
                                                foreach (var item in Model.MulakatBilgi.MulakatNotGirisDetay)
                                                {

                                                    RowIndex++;
                                                    <tr class="mainRow">
                                                        <td width="35" style="border-bottom:1px solid;">@RowIndex</td>
                                                        <td width="130" style="font-size:8pt;border-bottom:1px solid;">
                                                            <span style="color:gray;" class="fltrAdS_@Model.BasvuruSurecID">
                                                                @item.OgrenimTipAdi
                                                            </span>
                                                            <br />
                                                            <span style="color:black;" title="Programa başvurabilecek öğrenci tipi" class="fltrAdS_@Model.BasvuruSurecID">
                                                                @item.KullaniciTipAdi
                                                            </span>
                                                        </td>

                                                        <td style="font-size:8pt;border-bottom:1px solid;">
                                                            @{
                                                                string clickFunct = "onclick=getMsncPrDetay(" + Model.BasvuruSurecID + "," + item.OgrenimTipKod + ",'" + item.ProgramKod + "')";

                                                                <table>
                                                                    <tr>
                                                                        <td style="width:22px;" title="Programa başvuranları gör">
                                                                            <i class="fa fa-eye" style="color:@(item.MulakatSurecineGirecek?(item.YerJuriBilgisiGirildi?_colorMul:"red;"):_colorAna);font-size:16pt;cursor:pointer;" @(IsDelete == false ? clickFunct : "")></i>
                                                                        </td>
                                                                        <td>
                                                                            <span class="fltrAdS_@Model.BasvuruSurecID" style="color:gray;cursor:pointer;" @(IsDelete == false ? clickFunct : "")>@item.AnabilimDaliAdi</span> <br />
                                                                            <span class="fltrAdS_@Model.BasvuruSurecID" style="color:black;cursor:pointer;" @(IsDelete == false ? clickFunct : "")>@item.ProgramAdi (@item.ProgramKod) </span>
                                                                        </td>
                                                                    </tr>
                                                                </table>
                                                            }

                                                        </td>
                                                        <td width="20" style="border-bottom:1px solid;padding:0px;text-align:center;" title="@(item.Ucretli?"Ücretli Program. Ücret: "+item.Ucret.Value.ToString("n2"):"")">
                                                            @if (item.Ucretli)
                                                            {
                                                                <i class="fa fa-try" style="font-weight:bold;color:@(item.MulakatSurecineGirecek ? _colorMul : _colorAna);font-size:14pt;cursor:pointer;" onclick="getMsncPrDetay(@Model.BasvuruSurecID,@item.OgrenimTipKod,'@item.ProgramKod')"></i>
                                                            }
                                                        </td>
                                                        @if (KayitYetki && MailGondermeYetkisi)
                                                        {
                                                            <td width="25" style="font-size:8pt;border-left:1px solid;border-bottom:1px solid;padding:0px;text-align:center;" title="Program yetkilisine mail gönder">
                                                                <a href="javascript:void(0);" onclick="mGonder('', '', '', '', @Model.BasvuruSurecID, 'true', '@item.ProgramKod','@item.OgrenimTipKod')"><img src="~/Images/mail_send_B.png" style="width:23px;height:25px;" /></a>

                                                            </td>
                                                        }
                                                        <td width="25" style="font-size:8pt;border-bottom:1px solid;padding:0px;text-align:center;">
                                                            @if (MailGondermeYetkisi && item.ToplamBasvuru > 0)
                                                            {
                                                                <a title="Programa başvuran Öğrencilere mail gönder" href="javascript:void(0);" onclick="mGonder('', '', '', '', @Model.BasvuruSurecID, 'false', '@item.ProgramKod','@item.OgrenimTipKod')"><img src="~/Images/mail_send_O.png" style="width:23px;height:25px;" /></a>
                                                            }
                                                        </td>

                                                        <td width="32" style="font-size:8pt;border-left:1px solid;border-bottom:1px solid;padding:0px;text-align:center;" title="@(item.MulakatSurecineGirecek ? (item.YerJuriBilgisiGirildi? "Sınav yeri ve jüri bilgisi girildi" : "Sınav yeri ve jüri bilgisi girilmedi") : "Mülakat Yok")">
                                                            @if (item.MulakatSurecineGirecek)
                                                            {
                                                                if (item.YerJuriBilgisiGirildi)
                                                                {
                                                                    <i class="glyphicon glyphicon-check" style="font-size:11pt;font-weight:bold;color:@_colorAna;"></i>

                                                                }
                                                                else
                                                                {
                                                                    <i class="glyphicon glyphicon-unchecked" style="font-size:11pt;font-weight:bold;color:@_colorUyari;"></i>

                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span style="font-size:7pt;">Mlkt<br />Yok</span>
                                                            }
                                                        </td>
                                                        <td width="42" style="border-left:1px solid;border-bottom:1px solid;padding:0px;text-align:center;">
                                                            @if (item.MulakatSurecineGirecek || item.IsAlesYerineDosyaNotuIstensin)
                                                            {
                                                                <span style="font-size:11pt;color:@(item.ToplamBasvuru > 0 ? (item.ToplamBasvuru == item.ToplamMGiris ? _colorMul : _colorUyari) : _colorSG);font-weight:bold;" title="@(item.ToplamBasvuru > 0 ? (item.ToplamBasvuru == item.ToplamMGiris ? "Toplam başvuru" : "Bu programa ait öğrencilerin not girişleri eksik!") : "Bu programa başvuru yapılmadı")">@item.ToplamBasvuru</span>
                                                            }
                                                            else
                                                            {
                                                                <span style="font-size:11pt;color:@(item.ToplamBasvuru > 0 ?  _colorMul : _colorSG);font-weight:bold;" title="@(item.ToplamBasvuru > 0 ? (item.ToplamBasvuru == item.ToplamMGiris ? "Toplam başvuru" : "Bu programa ait öğrencilerin not girişleri eksik!") : "Bu programa başvuru yapılmadı")">@item.ToplamBasvuru</span>
                                                            }
                                                        </td>
                                                        <td width="180" style="border-left:1px solid;border-right:1px solid;border-bottom:1px solid;padding:0px;">
                                                            <table style="font-size:11pt;width:100%;table-layout:fixed;text-align:center;font-weight:bold;background-color:gainsboro;border-top:1px solid;border-bottom:1px solid;">
                                                                <tr>
                                                                    <td style="border-right:1px solid;">
                                                                        <table style="width:100%;table-layout:fixed;">
                                                                            @if (item.MulakatSurecineGirecek || item.IsAlesYerineDosyaNotuIstensin)
                                                                            {
                                                                                <tr>
                                                                                    <td style="border-right:1px solid;padding-top:2px;padding-bottom:2px;" title="@(item.AIToplamBasvuru > 0 ? (item.AIToplamBasvuru == item.AIMToplamBasvuru ? "Alan içi toplam başvuru" : "Alan içi başvuran öğrencilerin not girişi eksik!") : "Bu programa alan içi başvuru yapılmadı")"><span style="color:@(item.AIToplamBasvuru > 0 ? (item.AIToplamBasvuru == item.AIMToplamBasvuru ? _colorAna : _colorUyari) : _colorSG);">@item.AIToplamBasvuru</span></td>
                                                                                    <td style="padding-top:2px;padding-bottom:2px;" title="Alan İçi Notu Girilen Başvuru"><span style="color:@_colorMul;">@item.AIMNotGirildiCount</span></td>
                                                                                </tr>
                                                                            }
                                                                            else
                                                                            {
                                                                                <tr>
                                                                                    <td style="padding-top:2px;padding-bottom:2px;" title="@(item.AIToplamBasvuru > 0 ? (item.AIToplamBasvuru == item.AIMToplamBasvuru ? "Alan içi toplam başvuru" : "Alan içi başvuran öğrencilerin not girişi eksik!") : "Bu programa alan içi başvuru yapılmadı")"><span style="color:@(item.AIToplamBasvuru > 0 ? _colorAna   : _colorSG);">@item.AIToplamBasvuru</span></td>
                                                                                </tr>
                                                                            }
                                                                        </table>
                                                                    </td>
                                                                    <td style="border-left:1px solid;">
                                                                        <table style="width:100%;table-layout:fixed;">
                                                                            @if (item.MulakatSurecineGirecek || item.IsAlesYerineDosyaNotuIstensin)
                                                                            {
                                                                                <tr>
                                                                                    <td style="border-right:1px solid;padding-top:2px;padding-bottom:2px;" title="@(item.ADToplamBasvuru > 0 ? (item.ADToplamBasvuru == item.ADMToplamBasvuru ? "Alan dışı toplam başvuru" : "Alan dışı başvuran öğrencilerin not girişi eksik!") : "Bu programa alan dışı başvuru yapılmadı")"><span style="color:@(item.ADToplamBasvuru > 0 ? (item.ADToplamBasvuru == item.ADMToplamBasvuru ? _colorAna : _colorUyari) : _colorSG);">@item.ADToplamBasvuru</span></td>
                                                                                    <td style="padding-top:2px;padding-bottom:2px;" title="Alan Dışı Notu Girilen Başvuru"><span style="color:@_colorMul;">@item.ADMNotGirildiCount</span></td>
                                                                                </tr>
                                                                            }
                                                                            else
                                                                            {
                                                                                <tr>
                                                                                    <td style="padding-top:2px;padding-bottom:2px;" title="@(item.ADToplamBasvuru > 0 ? (item.ADToplamBasvuru == item.ADMToplamBasvuru ? "Alan dışı toplam başvuru" : "Alan dışı başvuran öğrencilerin not girişi eksik!") : "Bu programa alan dışı başvuru yapılmadı")"><span style="color:@(item.ADToplamBasvuru > 0 ?  _colorAna : _colorSG);">@item.ADToplamBasvuru</span></td>
                                                                                </tr>
                                                                            }
                                                                        </table>
                                                                    </td>
                                                                </tr>
                                                            </table>
                                                        </td>

                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td colspan="8" style="text-align: center;">
                                                        [ Listelenen Kayıt Yok ]
                                                    </td>
                                                </tr>
                                            }

                                        </table>
                                    </div>
                                </td>

                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<script>

    $('#filterInpM_@Model.BasvuruSurecID').bind('keypress', function (e) {
        var code = (e.keyCode ? e.keyCode : e.which);
        if (code == 13) {
            flter(this,@Model.BasvuruSurecID);
        }
    });
    function flter(sndr, mulID) {
        var _val = $(sndr).val();
        var tableName = "fltrM_" + mulID;
        var fltrdCol = "fltrAdS_" + mulID;
        var filtrDurum = "filtreKelimeM_" + mulID;

        if (_val == null || _val.trim() == "")
        {
            $('#' + tableName).find('.mainRow').removeClass("hide");
            $('#' + filtrDurum).html("");
        }
        else {
            _val = _val.trim().replaceAll('İ', 'i').toLowerCase();
            var toplam = $('#' + tableName).find('.mainRow').length;
            $('#' + tableName).find('.mainRow').each(function (inx, filtrx) {
                var show=false;
                $(filtrx).find('.'+fltrdCol).each(function (inx2, filtrx2) {
                    var gVal = $(filtrx2).text().trim().replaceAll('İ', 'i').toLowerCase();
                    var AShow = gVal.indexOf(_val) > -1;
                    if(AShow)show=true;
                });
                if (show) {
                    $(filtrx).removeClass('hide');
                }
                else {
                    $(filtrx).addClass('hide');
                }
            });
            var Gizli = $('#'+tableName).find('.mainRow.hide').length;
            var gosterilen = toplam - Gizli;
            $('#' + filtrDurum).html("[Ara:  %<span style='color:red;'>" + _val + "</span>%] [Bulunan: <span style='color:red;'>" + gosterilen + "</span>]");
        }

    }

</script>