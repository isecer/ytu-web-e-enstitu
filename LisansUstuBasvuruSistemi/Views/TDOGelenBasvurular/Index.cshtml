                                            complete: function (cmp) {
                                                _pRefresh(pnlx, true);
                                            },
                                            error: function (err) {
                                                _pRefresh(pnlx, true);
                                            }

                                        }).submit();
                                        return false;
                                    }
                                },
                                danger: {
                                    label: 'Kapat',
                                    className: "btn-primary",
                                    callback: function () {
                                    }
                            }

                        }
