                    'isCopy': isCopy,
                    'TDODanismanTalepTipID': TDODanismanTalepTipID
                },
                success: function (resultG) {
                    _pRefresh(_panel, true);
                    if (resultG.IsSuccess) {
                        var btbxxFS = bootbox.dialog({
                            message: resultG.Content,
                            //title: "<i class='fa fa-pencil'></i> Anket Sorusu Ekleme İşlemi",
                            buttons: {

                                success: {
                                    label: 'Kaydet',
                                    className: "btn-info",
                                    callback: function (event) {
                                        var pnlx = $(btbxxFS).find('.modal-dialog').first();
                                        _pRefresh(pnlx, false);
                                        $('#FrmTDODanismanFormu').ajaxForm({
                                            success: function (result) {
                                                if (result.IsSuccess) {
                                                    if (result.Messages.length > 0) toastr["success"](result.Messages.join('<br/>'), result.Title, { timeOut: 8000 });
