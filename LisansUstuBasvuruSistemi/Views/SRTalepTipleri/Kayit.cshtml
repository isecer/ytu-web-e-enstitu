@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model LisansUstuBasvuruSistemi.Models.SRTalepTipleri
@{
    var mmMessage = ViewBag.MmMessage as MmMessage;
    Layout = "~/Views/Shared/_Layout.cshtml"; 

}
<div class="row">
    <form method="post" class="form-horizontal" role="form">
        <input type="text" style="display: none;" id="SRTalepTipID" name="SRTalepTipID" value="@Model.SRTalepTipID"/>
        <div class="col-md-12 col-md-12 col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i> @(Model.SRTalepTipID <= 0 ? "Yeni talep tipi tanımlama işlemi" : "Talep tipi bilgisi düzenleme işlemi")</h3>
                    <ul class="panel-controls">
                        <li>
                            <a href="@Url.Action("Kayit", Model.SRTalepTipID)" class="">
                                <span class="fa fa-refresh panel-refresh"></span>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="panel-body">
                    <div class="panel panel-default form-horizontal">
                        <div class="panel-body form-group-separated">
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Talep Tip Adı</label>
                                <div class="col-md-9 col-xs-8">
                                    <input type="text" name="TalepTipAdi" id="TalepTipAdi" value="@Model.TalepTipAdi" class="form-control"/>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-3 col-xs-4 control-label">Tez Sınavı</label>
                                <div class="col-md-9 col-xs-8">
                                    <div class="make-switch" data-on-label="Evet" data-off-label="Hayır" data-on="info" data-off="danger">
                                        <input type="checkbox" value="true" name="IsTezSinavi" onchange="TzChange(this);" class="toggle" @Model.IsTezSinavi.ToChecked()/>
                                    </div>
                                </div>
                            </div> 
                             

                            @if (Model.SRTalepTipID > 0)
                            {
                                <div class="form-group">
                                    <label class="col-md-3 col-xs-4 control-label">Durum</label>
                                    <div class="col-md-9 col-xs-8">
                                        <div class="make-switch" data-on-label="Aktif" data-off-label="Pasif" data-on="info" data-off="danger">
                                            <input type="checkbox" value="true" name="IsAktif" class="toggle" @Model.IsAktif.ToChecked()/>
                                        </div>
                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                </div>
                <div class="panel-footer">
                    <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-reply"></i>Geri Dön</a>
                    <button class="btn btn-primary pull-right"><i class="fa fa-save"></i>Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>
<script>
    function TzChange(sndr) {
        if ($(sndr).prop('checked') == true) {
            $('.isTezSinavi').removeClass('hide');
        }
        else {
            $('.isTezSinavi').addClass('hide');
        } 
    }
    $(function () {
        var model = '@Html.Raw(Json.Encode(mmMessage))';
        validateControl(model);
    });
</script>