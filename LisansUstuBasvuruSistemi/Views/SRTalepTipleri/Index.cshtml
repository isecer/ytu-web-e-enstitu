@using BiskaUtil
@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  LisansUstuBasvuruSistemi.Utilities.Dtos.FmSrTalepTipleri
@{
    var indexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Salon Rezervasyonu Talep Tipleri</h3>
                    <ul class="panel-controls">
                        <li>
                            <span class="label label-success label-form">T:@indexModel.Toplam</span>
                        </li>
                        <li>
                            <span class="label label-info label-form">A:@indexModel.Aktif</span>
                        </li>
                        <li>
                            <span class="label label-danger label-form">P:@indexModel.Pasif</span>
                        </li> 
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="Ad">Talep Tip Adı</th>
                                <th class="sirala" field="IsTezSinavi" width="60">Tez Sınavı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="50">   </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th></th>
                                <th>
                                    @Html.DropDownList("IsTezSinavi", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                var rowIndex = Model.StartRowIndex;
                                foreach (var item in Model.Data)
                                {
                                    rowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@rowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.SRTalepTipID" title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.SRTalepTipID')">
                                                                <a href="javascript:void(0)">
                                                                    <span class="fa fa-angle-down"></span>
                                                                </a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>

                                        <td id="tdMad_@item.SRTalepTipID">
                                            @item.TalepTipAdi
                                        </td>

                                        <td id="tdTz_@item.SRTalepTipID" style="text-align: center;">
                                            <span class="label label-@(item.IsTezSinavi ? "info" : "danger")">@item.IsTezSinavi.ToEvetHayir()</span>
                                        </td>
                                        <td id="tdIa_@item.SRTalepTipID" style="text-align: center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "SrTalepTipleri", new { id = item.SRTalepTipID })">
                                                <i class="fa fa-edit fa-lg" title="Düzelt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.SRTalepTipID" style="display: none">
                                        <td id="cls-@item.SRTalepTipID" colspan="5" style="padding: 1px 1px 2px 75px;">

                                            <div class="panel panel-success">
                                                <div class="panel-heading  padding-0">
                                                    <div class="portlet-title">
                                                        <h3 class="panel-title"><i class="fa fa-file-text"></i> Detay</h3>
                                                    </div>
                                                </div>
                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">
                                                        <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                <div class="panel-body form-group-separated">

                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Talep Tip Adı</label>
                                                                        <div class="col-md-9 col-xs-9">@item.TalepTipAdi</div>
                                                                    </div>

                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Tez Sınavı Mı?</label>
                                                                        <div class="col-md-9 col-xs-9">@item.IsTezSinavi.ToEvetHayir()</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">Durum</label>
                                                                        <div class="col-md-9 col-xs-9" style="max-height: 200px; overflow: auto; text-align: left;">
                                                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 col-xs-3 control-label">İşlem Yapan</label>
                                                                        <div class="col-md-9 col-xs-9">@item.IslemYapan [@item.IslemTarihi.ToFormatDateAndTime()]</div>
                                                                    </div>

                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function ShowDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }

</script>