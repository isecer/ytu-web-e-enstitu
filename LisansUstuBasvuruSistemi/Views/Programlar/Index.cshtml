@using LisansUstuBasvuruSistemi.Models @using LisansUstuBasvuruSistemi.Models.FilterModel
@using BiskaUtil
@model  fmProgramlar
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm("Index", "Programlar", FormMethod.Post, new { id = "frmPrgrmlr" }))
    {

        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-info @(Model.Expand?"":"panel-toggled")" id="pnlFltr">
                <input class="hide" name="Expand" value="@Model.Expand.ToString().ToLower()" id="Expand" />
                <div class="panel-heading padding-0">
                    <h3 class="panel-title">
                        <i class="glyphicon glyphicon-filter"></i> Filtre İşlemi
                    </h3>
                    <ul class="panel-controls">
                        <li><a href="#" class="panel-collapse"><span class="fa fa-angle-down"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover" style="table-layout:fixed;">
                        <tr>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Enstitü</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Ücret Alımı</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("Ucretli", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Ales Tipi</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("AlesTipID", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">DR. Alan Eşleşmesi</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("LYLHerhangiBirindeGecenAlanIci", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Öğrenci Tipi</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("KullaniciTipID", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Ales Not Alım Tipi</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("AlesNotuYuksekOlanAlinsin", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Durum</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("IsAktif", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Ek Açıklama Var Mı</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("ProgramSecimiEkBilgi", null, new { @class = "form-control", style = "padding:0px;" })
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Bölüm Kısıtlaması</label>
                                    <div class="col-md-8 col-xs-7">
                                        @Html.DropDownList("IsAlandisiBolumKisitlamasi", null, new { @class = "form-control", style = "padding:0px;" }) 
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="form-group">
                                    <label class="col-md-4 col-xs-5 control-label">Aranacak Kelime</label>
                                    <div class="col-md-8 col-xs-7">
                                        <table style="table-layout:fixed;width:100%;">
                                            <tr>
                                                <td><input name="ProgramAdi" type="text" value="@Model.ProgramAdi" class="form-control" /></td>
                                                <td width="106">
                                                    <a href="javascript:void(0);" onclick="$('#Expand').val(($('#pnlFltr').hasClass('panel-toggled')?'false':'true')); $('#frmPrgrmlr').submit();" class="btn btn-info"><i class="glyphicon glyphicon-filter"> Filtrele</i></a>
                                                </td>
                                            </tr>
                                        </table>
                                        

                                        
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <table style="width:100%;table-layout:fixed;">
                        <tr>
                            <td><h3 class="panel-title"><i class="fa fa-list-alt"></i>&nbsp; Program Listesi</h3></td>

                            <td style="width:380px;">
                                <ul class="panel-controls">
                                    @*<li><span class="label label-success label-form" onclick="getReportType()" style="cursor:pointer;">Program Listesini İndir</span></li>*@
                                    <li><span class="label label-success label-form">T:@IndexModel.Toplam</span></li>
                                    <li><span class="label label-info label-form">A:@IndexModel.Aktif</span></li>
                                    <li><span class="label label-danger label-form">P:@IndexModel.Pasif</span></li>
                                    <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                                </ul>
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="EnstituAd" width="230">Enstitü / Ales Tip</th> 
                                <th class="sirala" field="ProgramAdi">Anabilim Dalı / P Adı</th>
                                <th class="sirala" field="IsAktif" width="60">Durum</th>
                                <th width="40">
                                    <a href="@Url.Action("Kayit")" class="btn btn-xs btn-success tooltips" style="width:100%;" data-style="blue" data-original-title="Yeni"><i class="fa fa-plus"></i></a>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex;
                                foreach (var item in Model.data)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.ProgramKod"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="showDetail('@item.ProgramKod')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-up"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>
                                            @item.EnstituAd  <br />
                                            @item.AlesTipAdi (@item.KullaniciTipAdi)
                                        </td> 
                                        <td id="tdMad_@item.ProgramKod">
                                            @item.AnabilimDaliAdi <br />@item.ProgramAdi
                                        </td>

                                        <td id="tdIa_@item.ProgramKod" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "Programlar", new { id = item.ProgramKod })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.ProgramKod')"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.ProgramKod" style="display:none">
                                        <td id="cls-@item.ProgramKod" colspan="6" style="padding: 1px 1px 2px 75px;">

                                            <div class="panel panel-success">
                                                <div class="panel-heading  padding-0">
                                                    <div class="portlet-title">
                                                        <h3 class="panel-title"><i class="fa fa-file-text"></i>&nbsp;Detay</h3>
                                                    </div>
                                                </div>
                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-default form-horizontal" style="margin-bottom: 0px;">

                                                        <div class="panel panel-primary" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                                <div class="panel-body form-group-separated">
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Enstitü</label>
                                                                        <div class="col-md-9" style="text-align: left;">@item.EnstituAd</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">P Kod</label>
                                                                        <div class="col-md-9">@item.ProgramKod</div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Ales Tipi</label>
                                                                        <div class="col-md-9" style="text-align: left;">@item.AlesTipAdi</div>
                                                                    </div>


                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Başvurabilecek Öğrenci</label>
                                                                        <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">
                                                                            @item.KullaniciTipAdi
                                                                        </div>
                                                                    </div> 
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Ücret Alımı</label>
                                                                        <div class="col-md-9">
                                                                            <span class="label label-@(item.Ucretli ? "success" : "danger")">@(item.Ucretli ? "Var" : "Yok")</span>
                                                                        </div>
                                                                    </div>
                                                                    @if (item.Ucretli)
                                                                    {
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 control-label">Ücret</label>
                                                                            <div class="col-md-9">
                                                                                @item.Ucret TL
                                                                            </div>
                                                                        </div>
                                                                    }

                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Eğitim Dili Ing</label>
                                                                        <div class="col-md-9">
                                                                            <span class="label label-@(item.Ingilizce ? "success" : "danger")">@(item.Ingilizce ? "Evet" : "Hayır")</span>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Ales Notu Yüksek Olan Alınsın)</label>
                                                                        <div class="col-md-9">
                                                                            <span class="label label-@(item.AlesNotuYuksekOlanAlinsin ? "success" : "danger")">@(item.AlesNotuYuksekOlanAlinsin ? "Evet" : "Hayır")</span>
                                                                            @if (item.AlesNotuYuksekOlanAlinsin)
                                                                            {
                                                                                <span> (@string.Join(", ", item.SecilenAlesTipleri))</span>
                                                                            }
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Doktora'da Alan Eşleşme Durumu</label>
                                                                        <div class="col-md-9">
                                                                            <span class="label label-@(item.LYLHerhangiBirindeGecenAlanIci ? "success" : "danger")">@(item.LYLHerhangiBirindeGecenAlanIci ? "Lisans ya da Yüksek Lisans bilgisinden eşleşen herhangi biri var ise Alan İçi" : "Lisans ve Yüksek Lisans bilgisinden ikiside eşleşiyor ise Alan İçi")</span>
                                                                        </div>
                                                                    </div>
                                                                    @if (item.BasvuruAgnoAlimTipID.HasValue)
                                                                    {
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 control-label">Agno alım tipi</label>
                                                                            <div class="col-md-9">@item.AgnoAlimTipAdi</div>
                                                                        </div>
                                                                        if (item.BasvuruAgnoAlimTipID == BasvuruAgnoAlimTipi.L_YLYuzdeBelirlensin)
                                                                        {
                                                                            <div class="form-group">
                                                                                <label class="col-md-3 control-label">Agno alım tip % oranları</label>
                                                                                <div class="col-md-9">Lisans: %@item.LYuzdeOran, Yüksek Lisans: %@item.YLYuzdeOran</div>
                                                                            </div>
                                                                        }
                                                                    }
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Program için ek açıklama gösterilsin</label>
                                                                        <div class="col-md-9">
                                                                            <span class="label label-@(item.ProgramSecimiEkBilgi ? "success" : "danger")">@(item.ProgramSecimiEkBilgi ? "Evet" : "Hayır")</span>
                                                                        </div>
                                                                    </div> 
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Alan dışı öğrenci bölüm kısıtlaması</label>
                                                                        <div class="col-md-9">
                                                                            <span class="label label-@(item.IsAlandisiBolumKisitlamasi ? "success" : "danger")">@(item.IsAlandisiBolumKisitlamasi ? "Var" : "Yok")</span>
                                                                        </div>
                                                                    </div>
                                                                    @if (item.IsAlandisiBolumKisitlamasi)
                                                                    {
                                                                        <div class="form-group">
                                                                            <label class="col-md-3 control-label"></label>
                                                                            <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">
                                                                                <table class="table" style="width:100%;table-layout:fixed;">
                                                                                    @foreach (var bolumAdi in item.AlandisiBolumKisitListesi)
                                                                                    {
                                                                                        <tr>
                                                                                            <td>@bolumAdi</td>
                                                                                        </tr>
                                                                                    }
                                                                                </table>

                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Durum</label>
                                                                        <div class="col-md-9" style="text-align: left; max-height: 200px; overflow: auto;">
                                                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@(item.IsAktif ? "Aktif" : "Pasif")</span>
                                                                        </div>
                                                                    </div>
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">İşlem Yapan</label>
                                                                        <div class="col-md-9">@item.IslemYapan [@item.IslemTarihi.ToFormatDateAndTime()]</div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">

    function showDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message: "Program Adı: " + gMesaj + " <br/> Seçilen Programı Silmek İstiyor Musunuz?",
            title: "Program Silme İşlemi",
            buttons: {
                success: {
                    label: "Program Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "Programlar")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Program Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
