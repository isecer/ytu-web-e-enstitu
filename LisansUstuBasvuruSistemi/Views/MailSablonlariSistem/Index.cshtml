@using LisansUstuBasvuruSistemi.Models
@using LisansUstuBasvuruSistemi.Utilities.Dtos
@using BiskaUtil
@using LisansUstuBasvuruSistemi.Utilities.Extensions
@model  FmMailSablonlariDto
@{
    var IndexModel = (MIndexBilgi)ViewBag.IndexModel;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    @using (Html.BeginForm())
    {
        <div class="col-md-12">

            <!-- START SIMPLE DATATABLE -->
            <div class="panel panel-danger">
                <div class="panel-heading padding-0">
                    <h3 class="panel-title"><i class="fa fa-list-alt"></i> Şablon Listesi</h3>
                    <ul class="panel-controls">
                        <li><span class="label label-info label-form" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Kayit")'"><i class="fa fa-plus" aria-hidden="true"></i> Yeni Mail Şablonu Ekle</span></li>

                        <li><span class="label label-success label-form">T:@IndexModel.Toplam</span></li>
                        <li><span class="label label-info label-form">A:@IndexModel.Aktif</span></li>
                        <li><span class="label label-danger label-form">P:@IndexModel.Pasif</span></li>
                        <li><a href="javascript:void(0);" onclick="setTimeout(function(){window.location.href='@Url.Action("Index")';},600)" class="panel-refresh"><span class="fa fa-refresh"></span></a></li>
                    </ul>
                </div>
                <div class="panel-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th width="75"></th>
                                <th class="sirala" field="EnstituAdi" width="150">Enstitü Adı</th>
                                <th class="sirala" field="SablonTipAdi">Şablon Tipi</th>
                                <th class="sirala" field="SablonAdi">Mail Konusu</th> 
                                <th class="sirala" field="EkSayisi" width="45">Ek.S.</th>
                                <th class="sirala" field="IsAktif" width="45">Durum</th>
                                <th width="40"> </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="filtrele">
                                <th></th>
                                <th>
                                    @Html.DropDownList("EnstituKod", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    @Html.DropDownList("MailSablonTipID", null, new { @class = "form-control", style = "padding:0px;" })
                                </th>
                                <th>
                                    <input name="SablonAdi" type="text" value="@Model.SablonAdi" class="form-control" />
                                </th>
                                <th></th>
                                <th></th>
                            </tr>
                            @if (Model.RowCount > 0)
                            {
                                int RowIndex = Model.StartRowIndex;
                                foreach (var item in Model.MailSablonlariDtos)
                                {
                                    RowIndex++;
                                    <tr>
                                        <td>
                                            <table>
                                                <tr>
                                                    <td style="width: 30px;">@RowIndex</td>
                                                    <td>
                                                        <ul class="panel-controls">
                                                            <li id="iShow_@item.MailSablonlariID"  title="Detayı açmak veya kapatmak için tıklayınız." onclick="ShowDetail('@item.MailSablonlariID')">
                                                                <a href="javascript:void(0)"><span class="fa fa-angle-down"></span></a>
                                                            </li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                        <td>@item.EnstituAdi</td>
                                        <td>@item.SablonTipAdi</td>

                                        <td>@item.SablonAdi</td> 
                                        <td>
                                            <span class="label label-@(item.EkSayisi>0 ? "success" : "danger")">@item.EkSayisi</span>
                                        </td>

                                        <td id="tdIa_@item.MailSablonlariID" style="text-align:center;">
                                            <span class="label label-@(item.IsAktif ? "success" : "danger")">@item.IsAktif.ToAktifPasif()</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Kayit", "MailSablonlariSistem", new { id = item.MailSablonlariID })"><i class="fa fa-edit  tooltips" data-style="blue" data-original-title="Düzelt"></i></a>
                                            <a href="javascript:void(0)" onclick="silmeOnay(this,'@item.MailSablonlariID')"><i class="fa fa-trash-o tooltips" data-style="blue" data-original-title="Sil"></i></a>
                                        </td>
                                    </tr>
                                    <tr class="cls-@item.MailSablonlariID" style="display:none">
                                        <td id="cls-@item.MailSablonlariID" colspan="7" style="padding: 1px 1px 2px 75px;">
                                            <div id="tdMad_@item.MailSablonlariID" class="panel panel-success">

                                                <div class="panel-body" style="padding: 0px;">
                                                    <div class="panel panel-primary form-horizontal" style="margin-bottom: 0px;">
                                                        <div class="panel-body" style="margin: 0px; padding: 0px;">
                                                            <div class="panel-body form-group-separated">
                                                                @if (item.Parametreler.IsNullOrWhiteSpace() == false)
                                                                {
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Parametreler</label>
                                                                        <div class="col-md-9">@item.Parametreler</div>
                                                                    </div>

                                                                }
                                                                @if (item.GonderilecekEkEpostalar.IsNullOrWhiteSpace() == false)
                                                                {
                                                                    <div class="form-group">
                                                                        <label class="col-md-3 control-label">Gönderilecek Ek Email Adresleri</label>
                                                                        <div class="col-md-9">
                                                                            @Html.Raw(item.GonderilecekEkEpostalar.Replace(",", "<br />"))
                                                                        </div>
                                                                    </div>
                                                                }
                                                                <div class="form-group">
                                                                    <label class="col-md-3 control-label">Mail Konusu</label>
                                                                    <div class="col-md-9">@item.SablonAdi</div>
                                                                </div>

                                                                <div class="form-group">
                                                                    <div class="col-md-12 col-xs-12" style="text-align: left;">
                                                                        <div class="panel panel-primary" style="margin:0px;padding:0px;">
                                                                            <div class="panel-body" style="padding-right:0px;padding-top:2px;padding-bottom:2px;">
                                                                                @Html.Raw(item.SablonHtml)
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label class="col-md-3 col-xs-4 control-label">Ekler <img src="/Images/Attachment.png" style="height: 16px;"></label>
                                                                    <div class="col-md-9 col-xs-8" style="text-align: left; max-height: 250px; overflow: auto;">
                                                                        <div class="panel panel-warning" style="margin:0px;padding:0px;">
                                                                            <div class="panel-body" style="padding-right:0px;padding-top:2px;padding-bottom:2px;">
                                                                                <div class="scrolkikko" style="max-height: 210px; width:100%; overflow:hidden;">
                                                                                    <table style="width: 100%; table-layout: fixed;">
                                                                                        @if (item.EkSayisi > 0)
                                                                                        {
                                                                                            foreach (var item2 in item.MailSablonlariEkleris.Select((s, inx) => new { inx, s }))
                                                                                            {
                                                                                                <tr>
                                                                                                    <td style="width: 25px;">@(item2.inx + 1))</td>
                                                                                                    <td class="name"><a href="@item2.s.EkDosyaYolu" target="_blank"><span class="fa fa-download" style="color: green;"></span>&nbsp;@item2.s.EkAdi</a></td>
                                                                                                </tr>
                                                                                            }
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <tr>
                                                                                                <td colspan="2">Ek Yok</td>
                                                                                            </tr>
                                                                                        }

                                                                                    </table>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div> 
                                                                <div class="form-group">
                                                                    <label class="col-md-3 control-label">İşlem Yapan</label>
                                                                    <div class="col-md-9">@item.IslemYapan [@item.IslemTarihi.ToFormatDateAndTime()]</div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>

                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align: center;">
                                        [ Listelenen Kayıt Yok ]
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="panel-footer">
                    @Model.ToPagerString()
                </div>
            </div>
        </div>
    }
</div>
<script type="text/javascript">
    function ShowDetail(id) {
        var sndr = $('#iShow_' + id);
        var cls = 'cls-' + id;
        var unTogled = ($('.' + cls).css("display") == "none");
        toggleByClass(sndr, cls, unTogled);

    }
    function silmeOnay(sndr, id) {
        var gMesaj = $("#tdMad_" + id).html();
        bootbox.dialog({
            message:   gMesaj + " <br/> Seçilen Sistem Şablonunu Silmek İstiyor Musunuz?",
            title: "Sistem Şablonu Silme İşlemi",
            buttons: {
                success: {
                    label: "Sistem Şablonunu Sil",
                    className: "btn-danger",
                    callback: function () {
                        sil(sndr, id);
                    }
                },
                danger: {
                    label: "Vazgeç",
                    className: "btn-primary",
                    callback: function () {
                    }
                }
            }
        });
    }
    function sil(sndr, id) {
        $.ajax({
            url: '@Url.Action("Sil", "MailSablonlariSistem")',
            data: { id: id },
            success: function (result) {
                toastr[result.success ? "success" : "error"](result.message, "Sistem Şablonu Silme İşlemi")
                if (result.success) {
                    $(sndr).closest("tr").remove();
                    $(".cls-" + id).remove();
                }

            },
            error: function (err) {
                alert(err.responseText);
            }
        });
    }
</script>
